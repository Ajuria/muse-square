---
import { Show } from "@clerk/astro/components";

const items = [
  { href: "/offres", label: "Solutions" },
  { href: "/a-propos", label: "À propos" },
  { href: "/contact", label: "Contact" },
];

// normalize paths and detect "active" for child routes too
const normalize = (p: string) => (p.replace(/\/+$/, "") || "/");
const currentPath = normalize(Astro.url.pathname);
const isActive = (href: string) => {
  const h = normalize(href);
  return currentPath === h || (h !== "/" && currentPath.startsWith(h + "/"));
};

const isApp = Astro.url.pathname.startsWith("/app") || Astro.url.pathname.startsWith("/profile") || Astro.url.pathname === "/notifications";
const piloterCookie = Astro.cookies.get("ms_piloter")?.value ?? "";
const [cookieSavedItemId, cookieDate] = piloterCookie.split("|").map(decodeURIComponent);
const isMonitor = currentPath.startsWith("/app/insightevent/monitor");
const isInsightEvent = currentPath.startsWith("/app/insightevent") && !isMonitor;
const isProfile = currentPath === "/profile" || currentPath === "/notifications";
const isSignIn = currentPath === "/sign-in" || currentPath.startsWith("/sign-in/");
const isSignUp = currentPath === "/sign-up" || currentPath.startsWith("/sign-up/");
const isAppShell = isApp;
---

<header class="sticky top-0 z-50 w-full bg-background border-b border-border">
  <nav class="ms-container py-3 md:py-4 flex items-center justify-between">
    <!-- Logo -->
    <a
      href={isAppShell ? "/app/insightevent/prompt" : "/"}
      class="flex items-center gap-[16px]"
    >
      <img
        src={isAppShell ? "/images/logo_ms_insight.svg" : "/images/muse-square-logo.png?v=2"}
        alt={isAppShell ? "Muse Square Insight" : "Muse Square"}
        class="block h-8 md:h-10 w-auto object-contain"
        loading="lazy"
        decoding="async"
      />
    </a>

      <>
        <!-- Mobile menu button -->
        <button
          id="menuBtn"
          class="md:hidden p-2"
          aria-label="Ouvrir le menu"
          aria-controls="mobileMenu"
          aria-expanded="false"
        >
          <svg width="24" height="24" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 6h18M3 12h18M3 18h18" stroke="#000" />
          </svg>
        </button>
      </>
    
      <div class="hidden md:flex items-center gap-10">
        <!-- Primary nav -->
        <ul class="flex items-center gap-8 font-heading text-[15px] font-medium uppercase tracking-[0.5px] text-primary">
          {!isApp && items.map((i) => (
            <li>
              <a
                href={i.href}
                aria-current={isActive(i.href) ? "page" : undefined}
                class="ms-nav-link"
              >
                {i.label}
              </a>
            </li>
          ))}
          {/* Signed-in on marketing site: show Insight only (no logout) */}
          {!isApp && (
            <Show when="signed-in" client:load>
              <li>
                <a href="/app/insightevent/prompt" class="ms-nav-link">
                  Insight
                </a>
              </li>
            </Show>
          )}

          {/* App-only menu + logout */}
          {isApp && (
            <>
              <li>
                <a
                  href={Astro.url.searchParams.get("saved_item_id") ? `/app/insightevent/days?saved_item_id=${encodeURIComponent(Astro.url.searchParams.get("saved_item_id")!)}&selected_date=__comparison__` : "/app/insightevent/prompt"}
                  aria-current={isInsightEvent ? "page" : undefined}
                  class={`ms-nav-link relative inline-block pb-1 after:content-[''] after:absolute after:left-0 after:right-0 after:-bottom-[2px] after:h-[2px] ${isInsightEvent ? "after:bg-primary" : "after:bg-transparent"}`}
                >
                  Planifier
                </a>
              </li>
              
              <li>
                {(() => {
                 const savedItemId = Astro.url.searchParams.get("saved_item_id") || cookieSavedItemId;
                 const rawDate = Astro.url.searchParams.get("date") ?? Astro.url.searchParams.get("selected_date") ?? "";
                 const focusedDate = (rawDate && rawDate !== "__comparison__" ? rawDate : "") || cookieDate;
                 const monitorHref = savedItemId && focusedDate && focusedDate !== "__comparison__"
                  ? `/app/insightevent/monitor?saved_item_id=${encodeURIComponent(savedItemId)}&date=${encodeURIComponent(focusedDate)}`
                  : null;
    
                  return monitorHref ? (
                    <a href={monitorHref} class={`ms-nav-link relative inline-block pb-1 after:content-[''] after:absolute after:left-0 after:right-0 after:-bottom-[2px] after:h-[2px] ${isMonitor ? "after:bg-primary" : "after:bg-transparent"}`}>Piloter</a>
                  ) : (
                    <span class="ms-nav-link opacity-40 cursor-not-allowed" aria-disabled="true">Piloter</span>
                  );
                })()}
              </li>

              <li class="relative" id="compte-nav-item">
                <button
                  type="button"
                  id="compte-nav-btn"
                  class={`ms-nav-link italic normal-case relative flex items-center gap-1
                    after:content-[''] after:absolute after:left-0 after:right-0 after:-bottom-[2px] after:h-[2px]
                    ${isProfile ? "after:bg-primary" : "after:bg-transparent"}`}
                >
                  Compte
                  <svg id="compte-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" style="transition:transform 0.15s;flex-shrink:0;">
                    <polyline points="2,3 5,7 8,3"/>
                  </svg>
                </button>
                <div id="compte-dropdown" style="display:none;position:absolute;top:calc(100% + 8px);right:0;min-width:160px;background:#fff;border:1px solid #e5e7eb;border-radius:0;padding:4px 0;z-index:100;">
                  <a href="/profile" class={`block px-4 py-2 text-sm font-medium uppercase tracking-wide hover:bg-gray-50 ${isProfile && !Astro.url.pathname.startsWith("/profile/notifications") ? "text-black" : "text-gray-500"}`}>Profil</a>
                  <a href="/notifications" class={`block px-4 py-2 text-sm font-medium uppercase tracking-wide hover:bg-gray-50 ${Astro.url.pathname === "/notifications" ? "text-black" : "text-gray-500"}`}>Notifications</a>
                </div>
              </li>

              <Show when="signed-in" client:load>
                <li>
                  <button type="button" class="logoutBtn ms-nav-link italic normal-case">
                    Log out
                  </button>
                </li>
              </Show>
            </>
          )}
        </ul>

        {/* Auth actions: only when signed out */}
        <Show when="signed-out" client:load>
          <div class="flex items-center gap-8 font-heading text-[15px] font-medium uppercase tracking-[0.5px] text-primary">
            <a href="/sign-in" class="ms-nav-link">
              Se connecter
            </a>

            <a href="/sign-up" class="ms-btn">
              S’inscrire
            </a>
          </div>
        </Show>
      </div>
      
  <!-- Mobile nav -->
  <div id="mobileMenu" class="md:hidden hidden border-t border-border bg-background">
    <ul class="ms-container py-4 grid gap-[24px] font-heading text-[15px] font-medium uppercase tracking-[0.5px] text-primary">
      {isApp ? (
        <>
          <li>
            <a
              href="/app/insightevent/prompt"
              aria-current={isInsightEvent ? "page" : undefined}
              class={`font-heading relative inline-block pb-2 transition-opacity
                hover:opacity-80 focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2
                after:content-[''] after:absolute after:left-0 after:right-0 after:-bottom-[1px] after:h-[2px]
                ${isInsightEvent ? "after:bg-primary" : "after:bg-transparent"}`}
            >
              Planifier
            </a>
          </li>

          <li>
            {(() => {
              const savedItemId = Astro.url.searchParams.get("saved_item_id") || cookieSavedItemId;
              const focusedDate = (Astro.url.searchParams.get("date") ?? Astro.url.searchParams.get("selected_date") ?? "") || cookieDate;
              const monitorHref = savedItemId && focusedDate && focusedDate !== "__comparison__"
                ? `/app/insightevent/monitor?saved_item_id=${encodeURIComponent(savedItemId)}&date=${encodeURIComponent(focusedDate)}`
                : null;

              return monitorHref ? (
                <a href={monitorHref} class="font-heading relative inline-block pb-2 transition-opacity hover:opacity-80">Piloter</a>
              ) : (
                <span class="font-heading inline-block pb-2 text-gray-300 cursor-not-allowed select-none" aria-disabled="true">Piloter</span>
              );
            })()}
          </li>

          <li>
            <a href="/profile" class={`font-heading relative inline-block pb-2 italic normal-case transition-opacity hover:opacity-80 after:content-[''] after:absolute after:left-0 after:right-0 after:-bottom-[1px] after:h-[2px] ${isProfile && !Astro.url.pathname.startsWith("/profile/notifications") ? "after:bg-primary" : "after:bg-transparent"}`}>Compte — Profil</a>
          </li>
          <li>
            <a href="/profile/notifications" class={`font-heading relative inline-block pb-2 italic normal-case transition-opacity hover:opacity-80 after:content-[''] after:absolute after:left-0 after:right-0 after:-bottom-[1px] after:h-[2px] ${Astro.url.pathname.startsWith("/profile/notifications") ? "after:bg-primary" : "after:bg-transparent"}`}>Compte — Notifications</a>
          </li>

          <Show when="signed-in" client:load>
            <li>
              <button
                type="button"
                class="logoutBtn font-heading relative inline-block pb-2 italic normal-case transition-opacity
                      hover:opacity-80 focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
              >
                Log out
              </button>
            </li>
          </Show>
        </>
      ) : (
        items.map((i) => (
          <li>
            <a
              href={i.href}
              aria-current={isActive(i.href) ? "page" : undefined}
              class={`font-heading relative inline-block pb-2 transition-opacity
                hover:opacity-80 focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2
                after:content-[''] after:absolute after:left-0 after:right-0 after:-bottom-[1px] after:h-[2px]
                ${isActive(i.href) ? "after:bg-primary" : "after:bg-transparent"}`}
            >
              {i.label}
            </a>
          </li>
        ))
      )}
    </ul>
  </div>

  <script is:inline>
    const btn = document.getElementById('menuBtn');
    const menu = document.getElementById('mobileMenu');

    if (!(btn instanceof HTMLElement) || !(menu instanceof HTMLElement)) {
      // Nothing to wire up on pages without the mobile nav.
    } else {

    const toggle = () => {
      if (!menu || !btn) return;
      menu.classList.toggle('hidden');
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
    };

    btn.addEventListener('click', toggle);

    // Close menu on link click (mobile)
    menu.addEventListener('click', (e) => {
      const target = e.target;
      const link = target instanceof Element ? target.closest('a') : null;
      if (!link) return;

      menu.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
    }
  </script>

  <script is:inline>
    (function () {
      var btn = document.getElementById('compte-nav-btn');
      var dropdown = document.getElementById('compte-dropdown');
      var chevron = document.getElementById('compte-chevron');
      if (!btn || !dropdown) return;

      var open = false;

      function show() {
        dropdown.style.display = 'block';
        chevron && (chevron.style.transform = 'rotate(180deg)');
        open = true;
      }
      function hide() {
        dropdown.style.display = 'none';
        chevron && (chevron.style.transform = 'rotate(0deg)');
        open = false;
      }

      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        open ? hide() : show();
      });

      document.addEventListener('click', function (e) {
        var item = document.getElementById('compte-nav-item');
        if (item && !item.contains(e.target)) hide();
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') hide();
      });
    })();
  </script>

</header>
