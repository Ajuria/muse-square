---
export const prerender = false;
import BaseLayout from "../../../layouts/BaseLayout.astro";

const ADMIN_USER_ID = "user_38OwkmwUq0Ldj5FwB9AJ8HmziWo";
const userId = Astro.locals.clerk_user_id;

if (userId !== ADMIN_USER_ID) {
  return Astro.redirect("/app/insightevent/pulse", 302);
}
---
<BaseLayout title="Admin — Muse Square" hideSurveyCta={true} hideFooter={true}>
  <div id="admin-wrap" style="max-width:980px;margin:0 auto;padding:24px;font-family:'DM Sans',sans-serif;font-size:13px;color:#111827;">
    <div style="margin-bottom:20px;">
      <h1 style="font-size:20px;font-weight:700;color:#1D3BB3;margin:0;">Admin</h1>
      <p style="font-size:12px;color:#6b7280;margin:0;">Support client & suivi beta</p>
    </div>
    <div id="lv">
      <div id="sm" style="display:flex;gap:10px;margin-bottom:20px;"></div>
      <div style="display:flex;gap:8px;margin-bottom:12px;">
        <input type="text" id="sr" placeholder="Rechercher nom, email, site..." style="flex:1;padding:7px 12px;border-radius:6px;border:1px solid #e5e7eb;font-size:12px;font-family:inherit;outline:none;" />
        <select id="sf" style="padding:7px 12px;border-radius:6px;border:1px solid #e5e7eb;font-size:12px;font-family:inherit;background:#fff;cursor:pointer;">
          <option value="all">Tous</option>
          <option value="active">Active</option>
          <option value="cooling">Cooling</option>
          <option value="declining">Declining</option>
          <option value="inactive">Inactive</option>
        </select>
      </div>
      <div id="tw" style="background:#fff;border-radius:8px;border:1px solid #e5e7eb;overflow:hidden;"></div>
    </div>
    <div id="dv" style="display:none;"></div>
    <div id="lo" style="padding:40px;text-align:center;color:#9ca3af;">Chargement...</div>
  </div>
  <script is:inline>
  var D=[],S=null;
  function fm(d){if(!d)return"\u2014";var t=new Date(d);return t.toLocaleDateString("fr-FR",{day:"2-digit",month:"short"})+" "+t.toLocaleTimeString("fr-FR",{hour:"2-digit",minute:"2-digit"})}
  function fd(d){if(!d)return"\u2014";return new Date(d).toLocaleDateString("fr-FR",{day:"2-digit",month:"short",year:"numeric"})}
  function ag(d){if(d==null)return"\u2014";if(d===0)return"Aujourd'hui";if(d===1)return"Hier";return d+"j"}
  function bh(s){return'<span style="display:inline-flex;align-items:center;gap:5px;padding:2px 9px;border-radius:12px;font-size:11px;font-weight:600;background:'+(s==="active"?"#dcfce7;color:#166534":s==="cooling"?"#fef3c7;color:#92400e":s==="declining"?"#fee2e2;color:#991b1b":"#f3f4f6;color:#6b7280")+'"><span style="width:6px;height:6px;border-radius:50%;background:'+(s==="active"?"#22c55e":s==="cooling"?"#f59e0b":s==="declining"?"#ef4444":"#9ca3af")+'"></span>'+s+"</span>"}
  function es(s){if(!s)return"";var d=document.createElement("div");d.textContent=s;return d.innerHTML}
  fetch("/api/analytics/admin-dashboard").then(function(r){return r.json()}).then(function(j){document.getElementById("lo").style.display="none";if(!j.ok){document.getElementById("lo").textContent="Erreur: "+(j.error||"");document.getElementById("lo").style.display="block";return}D=j.data||[];rS();rT()}).catch(function(e){document.getElementById("lo").textContent="Erreur reseau";console.error(e)});
  function rS(){var us={},si=0,ac=0,pr=0,fb=0;for(var i=0;i<D.length;i++){var u=D[i];us[u.user_id]=1;si++;if(u.activity_status==="active")ac++;pr+=(u.errors_last_7d||0)+(u.failed_crawls||0);fb+=(u.unread_feedback_text_7d||0)}var it=[{l:"Utilisateurs",v:Object.keys(us).length,a:false},{l:"Sites",v:si,a:false},{l:"Actifs",v:ac,a:false},{l:"Problemes 7j",v:pr,a:pr>0},{l:"Feedback non lu",v:fb,a:fb>0}];var h="";for(var i=0;i<it.length;i++){var m=it[i];h+='<div style="flex:1;background:#fff;border-radius:8px;padding:10px 14px;border:1px solid '+(m.a?"#fca5a5":"#e5e7eb")+'"><div style="font-size:10px;color:#9ca3af;text-transform:uppercase;letter-spacing:.04em">'+m.l+'</div><div style="font-size:22px;font-weight:700;color:'+(m.a?"#dc2626":"#111827")+'">'+m.v+"</div></div>"}document.getElementById("sm").innerHTML=h}
  function gF(){var q=(document.getElementById("sr").value||"").toLowerCase();var s=document.getElementById("sf").value;return D.filter(function(u){var mt=!q||(u.first_name+" "+u.last_name+" "+u.company_name+" "+u.email).toLowerCase().indexOf(q)>=0;var st=s==="all"||u.activity_status===s;return mt&&st})}
  function rT(){var rows=gF();var h='<table style="width:100%;border-collapse:collapse"><thead><tr>';var cols=["Utilisateur","Site","Statut","Vu","Probl.","Feedback"];for(var i=0;i<cols.length;i++)h+='<th style="padding:8px 12px;text-align:left;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:#9ca3af;border-bottom:2px solid #e5e7eb">'+cols[i]+"</th>";h+="</tr></thead><tbody>";for(var i=0;i<rows.length;i++){var u=rows[i];var p=(u.errors_last_7d||0)+(u.failed_crawls||0);h+='<tr data-i="'+i+'" style="cursor:pointer;border-bottom:1px solid #f3f4f6" onmouseover="this.style.background=\'#f9fafb\'" onmouseout="this.style.background=\'transparent\'">';h+='<td style="padding:8px 12px"><div style="font-weight:600">'+es(u.first_name)+" "+es(u.last_name)+'</div><div style="font-size:11px;color:#9ca3af">'+es(u.email)+"</div></td>";h+='<td style="padding:8px 12px"><div>'+es(u.company_name)+'</div><div style="font-size:11px;color:#9ca3af">'+es(u.company_activity_type)+"</div></td>";h+='<td style="padding:8px 12px">'+bh(u.activity_status)+"</td>";h+='<td style="padding:8px 12px;color:#6b7280">'+ag(u.days_since_last_action)+"</td>";h+='<td style="padding:8px 12px">'+(p>0?'<span style="color:#dc2626;font-weight:700">'+p+"</span>":'<span style="color:#d1d5db">0</span>')+"</td>";h+='<td style="padding:8px 12px"><div style="display:flex;align-items:center;gap:4px">';if(u.has_unread_feedback_text)h+='<span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:#ef4444"></span>';h+='<span style="color:'+(u.feedback_with_text_count>0?"#111827":"#d1d5db")+'">'+(u.feedback_with_text_count||0)+"</span></div></td></tr>"}h+="</tbody></table>";document.getElementById("tw").innerHTML=h;var trs=document.querySelectorAll("[data-i]");for(var i=0;i<trs.length;i++){trs[i].addEventListener("click",function(){var idx=parseInt(this.getAttribute("data-i"));oD(gF()[idx])})}}
  document.getElementById("sr").addEventListener("input",rT);document.getElementById("sf").addEventListener("change",rT);
  var TC={geocode_low_score:"#b45309",geocode_failed:"#dc2626",crawl_failed:"#dc2626",extraction_failed:"#dc2626",dim_sync_failed:"#7c3aed",dbt_trigger_failed:"#0369a1",besttime_failed:"#b45309",unhandled_exception:"#dc2626"};
  var CC={positive:{bg:"#dcfce7",text:"#166534"},negative:{bg:"#fee2e2",text:"#991b1b"},confirmed:{bg:"#dbeafe",text:"#1e40af"},dismissed:{bg:"#f3f4f6",text:"#6b7280"}};
  function oD(u){S=u;document.getElementById("lv").style.display="none";var dv=document.getElementById("dv");dv.style.display="block";var cn=[["Actions totales",u.total_actions],["Actions 7j",u.actions_last_7d],["Actions 30j",u.actions_last_30d],["Pages vues",u.page_views],["Drafts generes",u.drafts_generated],["Drafts copies",u.drafts_copied],["Drafts sauves",u.drafts_saved],["Drafts publies",u.drafts_published],["Templates",u.templates_created],["Automations",u.automations_enabled],["Envois auto",u.total_auto_sent],["Concurrents suivis",u.competitors_followed],["Dates sauvees",u.dates_saved],["Confirmations",u.total_confirmations],["Positif",u.positive_feedback],["Negatif",u.negative_feedback],["Crawls OK",u.successful_crawls],["Crawls KO",u.failed_crawls]];var h='<button onclick="cD()" style="background:none;border:none;color:#1D3BB3;cursor:pointer;font-size:13px;font-weight:600;margin-bottom:20px;padding:0;font-family:inherit">\u2190 Retour</button>';h+='<div style="display:flex;align-items:center;gap:14px;margin-bottom:20px"><div style="width:42px;height:42px;border-radius:50%;background:#1D3BB3;color:#fff;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700">'+(u.first_name?u.first_name[0].toUpperCase():"?")+'</div><div style="flex:1"><div style="font-size:18px;font-weight:700">'+es(u.first_name)+" "+es(u.last_name)+'</div><div style="font-size:12px;color:#6b7280">'+es(u.email)+(u.position?" \u00B7 "+es(u.position):"")+"</div></div>"+bh(u.activity_status)+"</div>";var LB={live_event:"\u00c9v\u00e9nementiel",culture:"Culture & Patrimoine",commercial:"Commerce & Retail",food_nightlife:"Restauration & Bars",hotel_lodging:"H\u00f4tellerie",sport:"Sports & Loisirs",wellness:"Bien-\u00eatre",outdoor_leisure:"Tourisme & Loisirs",cinema_theatre:"Cin\u00e9ma & Th\u00e9\u00e2tre",institutional:"Collectivit\u00e9s",family:"\u00c9ducation",science_innovation:"Sciences",pro_event:"\u00c9v\u00e9nementiel pro",non_profit:"Associatif",mixed:"Mixte",indoor:"Int\u00e9rieur",outdoor:"Ext\u00e9rieur",geocoded_ok:"OK",geocode_failed:"\u00c9chec",geocode_low_score:"Score faible",throttled:"Limit\u00e9",unchanged:"Inchang\u00e9",address_missing:"Adresse manquante",maximize_attendance:"Maximiser la fr\u00e9quentation",maximize_revenue:"Maximiser le revenu",brand_awareness:"Notori\u00e9t\u00e9",community_building:"Communaut\u00e9",year_round:"Toute l'ann\u00e9e",summer_peak:"Pic \u00e9t\u00e9",winter_peak:"Pic hiver",walking:"\u00c0 pied",driving:"Voiture",transit:"Transports en commun"};function lb(v){return LB[v]||v||"\u2014"}var fi=[["Site",u.site_name||u.company_name],["Adresse",u.company_address],["Industrie",lb(u.company_activity_type)],["Type lieu",lb(u.location_type)],["G\u00e9ocodage",lb(u.company_geocode_status)],["Objectif",lb(u.main_event_objective)],["M\u00e9t\u00e9o","sensibilit\u00e9 "+(u.weather_sensitivity||0)+"/5"],["Saisonnalit\u00e9",lb(u.seasonality)],["Site web",u.website_url||"non renseign\u00e9"],["Compte","cr\u00e9\u00e9 "+fd(u.account_created_at)+" ("+(u.account_age_days||0)+"j)"],["Profil maj",fd(u.profile_updated_at)],["Derni\u00e8re action",ag(u.days_since_last_action)]];h+='<div style="background:#f9fafb;border-radius:8px;padding:12px 16px;margin-bottom:16px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px 20px;font-size:12px">';for(var i=0;i<fi.length;i++){h+='<div style="display:flex;gap:6px"><span style="color:#9ca3af;min-width:85px">'+fi[i][0]+'</span><span style="color:#374151;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+es(String(fi[i][1]||"\u2014"))+"</span></div>"}h+="</div>";h+='<div style="display:grid;grid-template-columns:repeat(9,1fr);gap:6px;margin-bottom:16px">';for(var i=0;i<cn.length;i++){var v=cn[i][1]||0;h+='<div style="background:#fff;border:1px solid #e5e7eb;border-radius:6px;padding:8px 6px;text-align:center"><div style="font-size:18px;font-weight:700;color:'+(v===0?"#d1d5db":"#111827")+'">'+v+'</div><div style="font-size:9px;color:#6b7280;margin-top:2px;line-height:1.2">'+cn[i][0]+"</div></div>"}h+="</div>";h+='<div style="display:flex;border-bottom:2px solid #e5e7eb"><button onclick="sT(\'pr\')" id="tpr" style="background:none;border:none;border-bottom:2px solid #1D3BB3;padding:8px 16px;font-size:12px;font-weight:600;cursor:pointer;color:#1D3BB3;font-family:inherit;margin-bottom:-2px;position:relative">Problemes'+((u.errors_last_7d||0)+(u.failed_crawls||0)>0?' <span style="position:absolute;top:6px;right:4px;width:6px;height:6px;border-radius:50%;background:#ef4444"></span>':"")+'</button><button onclick="sT(\'fb\')" id="tfb" style="background:none;border:none;border-bottom:2px solid transparent;padding:8px 16px;font-size:12px;font-weight:600;cursor:pointer;color:#6b7280;font-family:inherit;margin-bottom:-2px;position:relative">Feedback'+(u.has_unread_feedback_text?' <span style="position:absolute;top:6px;right:4px;width:6px;height:6px;border-radius:50%;background:#ef4444"></span>':"")+"</button></div>";h+='<div id="tp" style="background:#fff;border:1px solid #e5e7eb;border-top:none;border-radius:0 0 8px 8px;padding:4px 16px;max-height:400px;overflow-y:auto"><div style="padding:40px;text-align:center;color:#9ca3af">Chargement...</div></div>';h+='<div id="tf" style="display:none;background:#fff;border:1px solid #e5e7eb;border-top:none;border-radius:0 0 8px 8px;padding:4px 16px;max-height:400px;overflow-y:auto"><div style="padding:40px;text-align:center;color:#9ca3af">Chargement...</div></div>';dv.innerHTML=h;lE(u);lF(u)}
  function sT(t){document.getElementById("tp").style.display=t==="pr"?"block":"none";document.getElementById("tf").style.display=t==="fb"?"block":"none";document.getElementById("tpr").style.borderBottomColor=t==="pr"?"#1D3BB3":"transparent";document.getElementById("tpr").style.color=t==="pr"?"#1D3BB3":"#6b7280";document.getElementById("tfb").style.borderBottomColor=t==="fb"?"#1D3BB3":"transparent";document.getElementById("tfb").style.color=t==="fb"?"#1D3BB3":"#6b7280"}
  function cD(){S=null;document.getElementById("dv").style.display="none";document.getElementById("dv").innerHTML="";document.getElementById("lv").style.display="block"}
  function lE(u){fetch("/api/analytics/admin-errors?user_id="+encodeURIComponent(u.user_id)+"&location_id="+encodeURIComponent(u.location_id)).then(function(r){return r.json()}).then(function(j){var el=document.getElementById("tp");if(!j.ok||!j.data||j.data.length===0){el.innerHTML='<div style="padding:24px;text-align:center;color:#9ca3af;font-size:13px">Aucun probleme enregistre</div>';return}var h="";for(var i=0;i<j.data.length;i++){var e=j.data[i];var c=TC[e.error_type]||"#6b7280";h+='<div style="padding:10px 0;border-bottom:1px solid #f3f4f6;display:grid;grid-template-columns:110px 1fr;gap:8px;align-items:start"><div><div style="font-size:11px;color:#6b7280">'+fm(e.created_at)+'</div><div style="font-size:10px;color:#9ca3af;margin-top:2px">'+es(e.endpoint)+'</div></div><div><span style="display:inline-block;font-size:10px;font-weight:700;padding:1px 7px;border-radius:4px;margin-bottom:4px;background:'+c+'18;color:'+c+'">'+es(e.error_type)+'</span><div style="font-size:12px;color:#374151;line-height:1.4">'+es(e.error_message)+"</div></div></div>"}el.innerHTML=h}).catch(function(){document.getElementById("tp").innerHTML='<div style="padding:24px;text-align:center;color:#9ca3af">Erreur chargement</div>'})}
  function lF(u){fetch("/api/analytics/admin-feedback?user_id="+encodeURIComponent(u.user_id)+"&location_id="+encodeURIComponent(u.location_id)).then(function(r){return r.json()}).then(function(j){var el=document.getElementById("tf");if(!j.ok||!j.data||j.data.length===0){el.innerHTML='<div style="padding:24px;text-align:center;color:#9ca3af;font-size:13px">Aucun feedback texte</div>';return}var h="";for(var i=0;i<j.data.length;i++){var f=j.data[i];var cc=CC[f.confirmation]||CC.dismissed;h+='<div style="padding:10px 0;border-bottom:1px solid #f3f4f6;display:grid;grid-template-columns:110px 1fr;gap:8px;align-items:start"><div><div style="font-size:11px;color:#6b7280">'+fm(f.created_at)+'</div><div style="font-size:10px;color:#9ca3af;margin-top:2px">'+es(f.signal_type)+'</div></div><div><span style="display:inline-block;font-size:10px;font-weight:700;padding:1px 7px;border-radius:4px;margin-bottom:4px;background:'+cc.bg+';color:'+cc.text+'">'+es(f.confirmation)+'</span><div style="font-size:12px;color:#374151;line-height:1.5;background:#f9fafb;border-radius:6px;padding:8px 10px;border-left:3px solid '+cc.text+'">'+es(f.feedback_text)+"</div></div></div>"}el.innerHTML=h}).catch(function(){document.getElementById("tf").innerHTML='<div style="padding:24px;text-align:center;color:#9ca3af">Erreur chargement</div>'})}
  </script>
</BaseLayout>