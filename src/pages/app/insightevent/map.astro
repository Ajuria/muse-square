---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { Show } from "@clerk/astro/components";
import InsightBottomBar from "../../../components/InsightBottomBar.astro";

// --------------------
// Server-side guards
// --------------------

const location_id =
  (Astro.locals && typeof (Astro.locals as any).location_id === "string" && (Astro.locals as any).location_id.trim())
    ? (Astro.locals as any).location_id.trim()
    : null;

if (!location_id) {
  return Astro.redirect("/profile");
}

const date = Astro.url?.searchParams?.get("date") ?? "";
const selected_dates = Astro.url?.searchParams?.get("selected_dates") ?? "";
const is_embed = Astro.url?.searchParams?.get("embed") === "1";
---

<Show when="signed-out" client:load>
<script is:inline>
window.location.href="/sign-in";
</script>
</Show>

<Show when="signed-in" client:load>

<BaseLayout title="Map — Context" hideSurveyCta={true} hideFooter={true} hideNav={is_embed}>

<div class="ms-container">

<nav class="map-breadcrumb" style={is_embed ? "display:none;" : ""}>
  <a href="#" id="breadcrumb-back">Mes dates</a>
  <span>/</span>
  <span>Carte</span>
</nav>

<div style="max-width:720px;margin:12px auto 0 auto;border:0.5px solid #E5E7EB;border-radius:8px;overflow:hidden;">

  <!-- Row 1: mode left | sub-options right -->
  <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 16px;border-bottom:0.5px solid #E5E7EB;">
    <!-- Mode -->
    <div style="display:flex;align-items:center;">
      <span id="mode-concurrence" style="font-size:13px;font-weight:500;color:#111827;cursor:pointer;">Concurrence</span>
      <span style="font-size:13px;color:#E5E7EB;margin:0 10px;">|</span>
      <span id="mode-mobilite" style="font-size:13px;font-weight:400;color:#9CA3AF;cursor:pointer;">Mobilité</span>
    </div>
    <!-- Sub-options right -->
    <div id="sub-concurrence" style="display:flex;align-items:center;">
      <span id="filter-500m" style="font-size:13px;font-weight:400;color:#9CA3AF;cursor:pointer;">500m</span>
      <span style="font-size:13px;color:#E5E7EB;margin:0 10px;">|</span>
      <span id="filter-1km" style="font-size:13px;font-weight:400;color:#9CA3AF;cursor:pointer;">1km</span>
      <span style="font-size:13px;color:#E5E7EB;margin:0 10px;">|</span>
      <span id="filter-5km" style="font-size:13px;font-weight:500;color:#111827;cursor:pointer;">5km</span>
      <span style="font-size:13px;color:#E5E7EB;margin:0 10px;">|</span>
      <span id="filter-10km" style="font-size:13px;font-weight:400;color:#9CA3AF;cursor:pointer;">10km</span>
    </div>
    <div id="sub-mobilite" style="display:none;align-items:center;">
      <span id="filter-route" style="font-size:13px;font-weight:500;color:#111827;cursor:pointer;">Route</span>
      <span style="font-size:13px;color:#E5E7EB;margin:0 10px;">|</span>
      <span id="filter-metro" style="font-size:13px;font-weight:400;color:#9CA3AF;cursor:pointer;">Métro</span>
    </div>
  </div>

  <!-- Row 2: industry filter (concurrence only) -->
  <div id="industry-filter-row" style="display:flex;align-items:center;padding:8px 16px;flex-wrap:wrap;gap:4px 0;"></div>

</div>

<div id="map"></div>

<div id="map-list">
  <div id="map-list-events"></div>
</div>

</div>

<link
rel="stylesheet"
href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
/>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script is:inline src="/map-markers.js"></script>

<style>

:root[data-embed="1"] nav,
:root[data-embed="1"] header,
:root[data-embed="1"] .ms-nav {
  display: none !important;
}

#map{
  height:420px;
  margin-top:16px;
  max-width:720px;
  margin-left:auto;
  margin-right:auto;
  position:relative;
  z-index:0;
}

.map-breadcrumb{
  display:flex;
  align-items:center;
  gap:8px;
  margin-top:16px;
  max-width:720px;
  margin-left:auto;
  margin-right:auto;
  font-size:13px;
  color:#888;
}
.map-breadcrumb a{
  color:#0F1F3D;
  text-decoration:none;
  font-weight:500;
}
.map-breadcrumb a:hover{
text-decoration:underline;
}

.map-filters{ display:none; }

#map-list{
  max-width:720px;
  margin-left:auto;
  margin-right:auto;
  margin-top:24px;
}

.map-event-card{
  display:flex !important;
  flex-direction:column !important;
  gap:8px !important;
  padding:20px 16px 20px 12px !important;
  border-left:3px solid var(--bucket-color, #cbd5e1) !important;
  border-bottom:none !important;
}
.map-event-card + .map-event-card{
  border-top:1px solid rgba(17,24,39,0.07) !important;
  margin-top:4px !important;
}
.map-event-card__header{
  display:flex !important;
  justify-content:space-between !important;
  align-items:baseline !important;
  gap:12px !important;
}
.map-event-card__label{
  font-size:15px !important;
  font-weight:600 !important;
  color:#0F1F3D !important;
  line-height:1.3 !important;
}
.map-event-card__distance{
  font-size:11.5px !important;
  color:#888 !important;
  white-space:nowrap !important;
  flex-shrink:0 !important;
}
.map-event-card__toggle{
  font-size:12px !important;
  color:#4A7FA5 !important;
  font-weight:700 !important;
  background:none !important;
  border:none !important;
  padding:0 !important;
  cursor:pointer !important;
  margin-top:2px !important;
}
.map-event-card__tags{
  display:flex;
  flex-wrap:wrap;
  gap:5px;
  margin-top:2px;
}
body { padding-bottom: 0 !important; margin-bottom: 0 !important; }
html { padding-bottom: 0 !important; margin-bottom: 0 !important; }
.ms-container { padding-bottom: 0 !important; margin-bottom: 0 !important; }
#map-list { padding-bottom: 0 !important; margin-bottom: 0 !important; }

.map-event-card__tag{
  font-size:10.5px;
  font-weight:600;
  background:#eef2f7;
  color:#4A7FA5;
  border-radius:4px;
  padding:1px 6px;
  text-transform:uppercase;
  letter-spacing:0.04em;
}
.map-event-card__venue-name {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #4A7FA5;
  flex: 1 !important;
}
.map-event-card__venue-address {
  font-size: 11.5px;
  color: #888;
}
.map-event-card__venue-row {
  display: flex !important;
  flex-direction: row !important;
  justify-content: space-between !important;
  align-items: baseline !important;
  gap: 12px !important;
}

@keyframes ms-spin { to { transform: rotate(360deg); } }
</style>

<script is:inline define:vars={{ location_id, date }}>

if (new URLSearchParams(window.location.search).get("embed") === "1") {
  document.documentElement.setAttribute("data-embed", "1");
}

let map
let eventsLayer500m, eventsLayer1km, eventsLayer5km, eventsLayer10km, eventsLayer50km
let roadLayer
let subwayLayer

document.getElementById('breadcrumb-back').addEventListener('click', function(e) {
  e.preventDefault();
  history.back();
});

async function init(){

map = L.map('map').setView([48.86, 2.35], 14)

L.tileLayer(
'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',
{
attribution:'© OpenStreetMap contributors'
}
).addTo(map)

eventsLayer500m = L.layerGroup().addTo(map)
eventsLayer1km  = L.layerGroup().addTo(map)
eventsLayer5km  = L.layerGroup().addTo(map)
eventsLayer10km = L.layerGroup().addTo(map)
eventsLayer50km = L.layerGroup().addTo(map)
roadLayer   = L.layerGroup().addTo(map)
subwayLayer = L.layerGroup().addTo(map)

await loadData()

}

async function loadData(){

const url =
`/api/insight/map?location_id=${location_id}&date=${date}`

const res = await fetch(url)

const data = await res.json()

console.log('API response:', JSON.stringify(data, null, 2))

renderVenue(data.meta || {})
renderEvents(data.events || [], data.meta || {})
renderRoad(data.road_disruptions || [])
renderSubway(data.subway_disruptions || [])

if ((data.road_disruptions || []).length || (data.subway_disruptions || []).length) {
  const _bounds = []
  const _vLat = Number(map._lastVenueLat)
  const _vLon = Number(map._lastVenueLon)
  if (Number.isFinite(_vLat) && Number.isFinite(_vLon)) _bounds.push([_vLat, _vLon])
  roadLayer.eachLayer(l => { if (l.getLatLng) _bounds.push([l.getLatLng().lat, l.getLatLng().lng]) })
  subwayLayer.eachLayer(l => { if (l.getLatLng) _bounds.push([l.getLatLng().lat, l.getLatLng().lng]) })
  if (_bounds.length > 1) map.fitBounds(_bounds, { padding: [60, 60], maxZoom: 14 })
}

// Notify parent to resize iframe via postMessage
function sendHeight() {
  try {
    if (window.parent !== window) {
      const h = document.documentElement.scrollHeight;
      window.parent.postMessage({ type: 'map-height', height: Math.ceil(h) }, '*');
    }
  } catch(e) {}
}
setTimeout(sendHeight, 800);
setTimeout(sendHeight, 1800);
setTimeout(sendHeight, 3000);
}

function renderVenue(meta) {
  if (!map || !meta?.venue) return null

  const venueLat = Number(meta.venue.lat)
  const venueLon = Number(meta.venue.lon)

  if (!Number.isFinite(venueLat) || !Number.isFinite(venueLon)) return null

  map._lastVenueLat = venueLat
  map._lastVenueLon = venueLon
  createVenueMarker({
    client_lat: venueLat,
    client_lon: venueLon,
    nearest_transit_stop_name:     meta.venue.nearest_transit_stop_name     ?? null,
    nearest_transit_line_name:     meta.venue.nearest_transit_line_name     ?? null,
    nearest_transit_stop_distance_m: meta.venue.nearest_transit_stop_distance_m ?? null,
  }).addTo(map)
}

function bucketColor(bucket) {
  return { '500m': '#0F1F3D', '5km': '#4A7FA5', '10km': '#93b4cc', '50km': '#cbd5e1' }[bucket] ?? '#cbd5e1'
}

function escapeHtml(v) {
  return String(v ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#039;");
}

function renderEventList(items) {
  const container = document.getElementById('map-list-events');
  if (!container) return;

  const filtered = items.filter(e => (e.event_label || e.title) && e.signal_type !== 'mobility_disruption');

  if (filtered.length === 0) {
    container.innerHTML = '';
    return;
  }

  function renderMapCard(e, idx) {
    const desc = (e.description && e.description !== 'null') ? e.description : '';
    const uid = String(e.event_uid || e.id || idx);
    const panelId = `enrich-panel-map-${uid}`;
    const descId = `enrich-desc-map-${uid}`;
    return `
      <div style="border-left:3px solid var(--color-brand-blue);border-bottom:1px solid rgba(17,24,39,0.07);padding:16px 12px;">
        <div style="display:flex;justify-content:space-between;align-items:baseline;gap:12px;margin-bottom:8px;">
          <span style="font-size:14px;font-weight:500;color:#0F1F3D;">${idx+1}. ${escapeHtml(e.title ?? e.event_label)}</span>
          <span style="font-size:11px;color:#9CA3AF;white-space:nowrap;flex-shrink:0;">${e.distance_m ? Math.round(Number(e.distance_m)) + 'm' : ''}</span>
        </div>
        ${desc ? `<div id="${descId}" style="font-size:13px;color:#374151;line-height:1.55;overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;">${escapeHtml(desc)}</div>` : ''}
        <div style="display:flex;align-items:center;justify-content:flex-end;margin-top:8px;">
          <a href="#"
            style="font-size:13px;color:#1D3BB3;text-decoration:none;"
            data-enrich-trigger
            data-panel-id="${panelId}"
            data-desc-id="${descId}"
            data-event-label="${escapeHtml(e.title ?? e.event_label ?? '')}"
            data-description="${escapeHtml(desc.slice(0, 500))}"
            data-city-name="${escapeHtml(e.city_name || '')}"
            data-venue-name="${escapeHtml(e.event_venue_name || '')}"
            data-event-uid="${escapeHtml(e.event_uid || '')}"
            data-city-id="${escapeHtml(e.city_id || '')}"
            data-distance-m="${Math.round(Number(e.distance_m)) || ''}"
            data-radius-bucket="${escapeHtml(e.radius_bucket || '')}"
            data-industry-code="${escapeHtml(e.industry_code || '')}"
            data-signal-type="${escapeHtml(e.signal_type || '')}">
            En savoir plus →
          </a>
        </div>
        <div id="${panelId}" style="display:none;margin-top:10px;"></div>
      </div>`;
  }

  const visible = filtered.slice(0, 10);
  const remaining = filtered.length - 10;

  container.innerHTML = visible.map((e, idx) => renderMapCard(e, idx)).join('')
    + (remaining > 0 ? `
      <div id="map-more-btn-wrap" style="border-top:0.5px solid #E5E7EB;padding:12px 16px;display:flex;justify-content:center;">
        <button style="font-size:12px;color:var(--color-brand-blue);background:none;border:none;padding:0;cursor:pointer;font-weight:500;">+ ${remaining} autres résultats</button>
      </div>` : '');

  wireEnrichLinks(container);

  const moreWrap = container.querySelector('#map-more-btn-wrap');
  if (moreWrap) {
    moreWrap.querySelector('button').addEventListener('click', () => {
      const extra = filtered.slice(10).map((e, idx) => renderMapCard(e, idx + 10)).join('');
      moreWrap.insertAdjacentHTML('beforebegin', extra);
      moreWrap.remove();
      wireEnrichLinks(container);
    });
  }
}

function wireEnrichLinks(root) {
  root.querySelectorAll("[data-enrich-trigger]").forEach(link => {
    if (link._enrichWired) return;
    link._enrichWired = true;
    link.addEventListener("click", async (ev) => {
      ev.preventDefault();
      const signalType = link.getAttribute("data-signal-type");
      if (signalType && signalType !== "event_competition") return;
      const panelId = link.getAttribute("data-panel-id");
      const descId = link.getAttribute("data-desc-id");
      const panel = document.getElementById(panelId);
      const descEl = document.getElementById(descId);
      if (!panel) return;

      if (panel.style.display !== "none" && panel.innerHTML.trim()) {
        panel.style.display = "none";
        if (descEl) descEl.style.cssText = "font-size:13px;color:#374151;line-height:1.55;overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;";
        link.textContent = "En savoir plus →";
        return;
      }

      if (descEl) descEl.style.cssText = "font-size:13px;color:#374151;line-height:1.55;";
      panel.style.display = "block";
      panel.innerHTML = `<div style="font-size:12px;color:#9CA3AF;padding:8px 0;display:flex;align-items:center;gap:8px;"><span style="width:10px;height:10px;border:1.5px solid #E5E7EB;border-top-color:#1D3BB3;border-radius:50%;display:inline-block;animation:ms-spin 0.7s linear infinite;flex-shrink:0;"></span>Recherche en cours…</div>`;
      link.textContent = "Réduire ↑";

      try {
        const res = await fetch("/api/insight/enrich-event", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            event_label: link.getAttribute("data-event-label"),
            description: link.getAttribute("data-description"),
            city_name: link.getAttribute("data-city-name"),
            event_venue_name: link.getAttribute("data-venue-name"),
            event_uid: link.getAttribute("data-event-uid") || null,
            city_id: link.getAttribute("data-city-id") || null,
            distance_m: Number(link.getAttribute("data-distance-m")) || null,
            radius_bucket: link.getAttribute("data-radius-bucket") || null,
            industry_code: link.getAttribute("data-industry-code") || null,
          }),
        });
        const json = await res.json().catch(() => null);
        if (!json?.ok || !json?.data) throw new Error("Réponse invalide");
        const d = json.data;
        const rows = [
          d.confirmed_dates      ? ["Dates",        d.confirmed_dates]      : null,
          d.venue_name           ? ["Lieu",          d.venue_name]           : null,
          d.venue_capacity       ? ["Capacité",      d.venue_capacity]       : null,
          d.organizer            ? ["Organisateur",  d.organizer]            : null,
          d.estimated_attendance ? ["Fréquentation", d.estimated_attendance] : null,
        ].filter(Boolean);

        const tags = d.audience_profile
          ? d.audience_profile.split(/[,;]/).map(t => t.trim()).filter(Boolean)
          : [];

        panel.innerHTML = `
          <div style="background:#F9FAFB;border:0.5px solid #E5E7EB;border-radius:10px;overflow:hidden;margin-top:4px;">
            ${rows.length ? `
              <div style="display:grid;grid-template-columns:1fr 1fr;">
                ${rows.map(([label, val], i) => `
                  <div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;${i % 2 === 0 && i < rows.length - 1 ? 'border-right:0.5px solid #F3F4F6;' : ''}">
                    <div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:3px;">${label}</div>
                    <div style="font-size:13px;color:#111827;line-height:1.4;">${String(val)}</div>
                  </div>`).join('')}
              </div>` : ''}
            ${tags.length ? `
              <div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">
                <div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:6px;">Audience</div>
                <div style="display:flex;flex-wrap:wrap;gap:5px;">
                  ${tags.map(t => `<span style="font-size:11px;font-weight:500;padding:2px 9px;border-radius:20px;background:#EFF6FF;color:#1D4ED8;">${escapeHtml(t)}</span>`).join('')}
                </div>
              </div>` : ''}
            ${d.business_takeaway ? `
              <div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">
                <div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:5px;">Impact pour votre activité</div>
                <div style="font-size:12px;color:#111827;line-height:1.55;">${d.business_takeaway}</div>
              </div>` : ''}
            <div style="padding:9px 14px;display:flex;justify-content:space-between;align-items:center;">
              <div style="font-size:10px;letter-spacing:0.07em;text-transform:uppercase;color:#9CA3AF;display:flex;align-items:center;gap:5px;">
                <span style="width:6px;height:6px;border-radius:50%;background:#059669;display:inline-block;flex-shrink:0;"></span>
                Agent IA · web
              </div>
              ${d.source_url ? `<a href="${d.source_url}" target="_blank" rel="noopener" style="font-size:12px;color:#1D3BB3;text-decoration:none;">Source officielle →</a>` : ''}
            </div>
          </div>`;
        link.textContent = "Réduire ↑";
      } catch {
        panel.innerHTML = `<div style="font-size:12px;color:#B91C1C;padding:4px 0;">Données non disponibles.</div>`;
        link.textContent = "En savoir plus →";
        if (descEl) descEl.style.cssText = "font-size:13px;color:#374151;line-height:1.55;overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;";
      }
    });
  });
}

function renderEvents(items, meta) {
  eventsLayer500m.clearLayers()
  eventsLayer1km.clearLayers()
  eventsLayer5km.clearLayers()
  eventsLayer10km.clearLayers()
  eventsLayer50km.clearLayers()

const buckets = { '500m': [], '1km': [], '5km': [], '10km': [], '50km': [] }
  items.forEach(e => {
    const b = e.radius_bucket || '50km'
    if (buckets[b]) buckets[b].push(e)
  })

  console.log('BUCKETS', {
    '500m': buckets['500m'].length,
    '1km':  buckets['1km'].length,
    '5km':  buckets['5km'].length,
    '10km': buckets['10km'].length,
    '50km': buckets['50km'].length,
    'sample radius_bucket': items.slice(0,3).map(e => e.radius_bucket),
    'sample distance_m': items.slice(0,3).map(e => e.distance_m),
  })

  // Global numbering across all buckets for list
  const allVisible = [
    ...buckets['500m'],
    ...buckets['1km'],
    ...buckets['5km'],
    ...buckets['10km'],
    ...buckets['50km'],
  ]
  renderEventList(allVisible)

  const venueLat = Number(meta?.venue?.lat)
  const venueLon = Number(meta?.venue?.lon)

  const layerMap = {
    '500m': eventsLayer500m,
    '1km':  eventsLayer1km,
    '5km':  eventsLayer5km,
    '10km': eventsLayer10km,
    '50km': eventsLayer50km,
  }

  let globalNum = 1
  ;['500m','1km','5km','10km','50km'].forEach(bucket => {
    buckets[bucket].forEach(e => {
      const lat = Number(e.latitude)
      const lng = Number(e.longitude)
      if (!Number.isFinite(lat) || !Number.isFinite(lng)) return
      createEventMarker(e, globalNum).addTo(layerMap[bucket])
      globalNum++
    })
  })

  if (Number.isFinite(venueLat) && Number.isFinite(venueLon)) {
    map.setView([venueLat, venueLon], 14)
  }

  if (window._onEventsLoaded) window._onEventsLoaded(allVisible)
}

function renderRoad(items) {
  roadLayer.clearLayers()

  items.forEach(r => {
    createRoadMarker(r).addTo(roadLayer)
  })
}

function renderSubway(items) {
  subwayLayer.clearLayers()

  items.forEach(s => {
    createSubwayMarker(s).addTo(subwayLayer)
  })
}

window.addEventListener("load", () => {
  init()

  const modeConcurrence = document.getElementById('mode-concurrence')
  const modeMobilite    = document.getElementById('mode-mobilite')
  const subConcurrence  = document.getElementById('sub-concurrence')
  const subMobilite     = document.getElementById('sub-mobilite')
  const industryRow     = document.getElementById('industry-filter-row')

  // Text-link style helpers (no borders — typographic style)
  function setActive(el) {
    if (!el) return
    el.style.color = '#111827'
    el.style.fontWeight = '500'
  }
  function setInactive(el) {
    if (!el) return
    el.style.color = '#9CA3AF'
    el.style.fontWeight = '400'
  }
  function getEl(id) { return document.getElementById(id) }

  // ---- Radius state (radio, cumulative) ----
  let activeRadius = 'filter-5km'

  const radiusIncludes = {
    'filter-500m': ['500m'],
    'filter-1km':  ['500m', '1km'],
    'filter-5km':  ['500m', '1km', '5km'],
    'filter-10km': ['500m', '1km', '5km', '10km'],
  }

  function applyRadius(id) {
    activeRadius = id
    setInactive(getEl('filter-500m'))
    setInactive(getEl('filter-1km'))
    setInactive(getEl('filter-5km'))
    setInactive(getEl('filter-10km'))
    setActive(getEl(id))
    applyIndustryFilter()
  }

  getEl('filter-500m').addEventListener('click', () => applyRadius('filter-500m'))
  getEl('filter-1km').addEventListener('click',  () => applyRadius('filter-1km'))
  getEl('filter-5km').addEventListener('click',  () => applyRadius('filter-5km'))
  getEl('filter-10km').addEventListener('click', () => applyRadius('filter-10km'))

  // ---- Industry bucket mapping (French labels from seed) ----
  const INDUSTRY_BUCKETS = {
    'culture_event':          ['Culture & Patrimoine', 'Cinéma & Théâtre', 'Événementiel', 'Vie nocturne'],
    'leisure_activity':       ['Tourisme & Loisirs', 'Sports & Loisirs actifs', 'Bien-être & Fitness'],
    'commercial_activity':    ['Restauration & Bars', 'Commerce & Retail', 'Hôtellerie & Hébergement', 'Salons & Événements professionnels'],
    'institutional_activity': ['Collectivités & Secteur public', 'Éducation & Enseignement', 'Associatif & Non lucratif', 'Transport & Mobilité locale', 'Sciences & Innovation'],
  }

  function getClientBucket(clientIndustry) {
    for (const [bucket, industries] of Object.entries(INDUSTRY_BUCKETS)) {
      if (industries.includes(clientIndustry)) return bucket
    }
    return null
  }

  function getIndustryOrder(industries, events) {
    // Find client's own industry = most frequent in events
    const freq = {}
    events.forEach(e => { freq[e.industry_code] = (freq[e.industry_code] || 0) + 1 })
    const ownIndustry = Object.entries(freq).sort((a, b) => b[1] - a[1])[0]?.[0]
    const clientBucket = ownIndustry ? getClientBucket(ownIndustry) : null
    const bucketOrder = clientBucket ? INDUSTRY_BUCKETS[clientBucket] : []

    // Sort: own bucket industries first (in bucket order), then others
    return [...industries].sort((a, b) => {
      const ai = bucketOrder.indexOf(a)
      const bi = bucketOrder.indexOf(b)
      if (ai !== -1 && bi !== -1) return ai - bi
      if (ai !== -1) return -1
      if (bi !== -1) return 1
      return (freq[b] || 0) - (freq[a] || 0)
    })
  }

  // ---- Industry filter ----
  let allEvents = []
  let industryState = {}

  function truncateIndustry(label, max = 22) {
    return label.length > max ? label.slice(0, max - 1) + '…' : label
  }

  function buildIndustryRow(events) {
    if (!industryRow) return
    const industries = [...new Set(events.map(e => e.industry_code).filter(Boolean))]
    if (industries.length <= 1) { industryRow.innerHTML = ''; return }

    const ordered = getIndustryOrder(industries, events)

    // Default: only own industry active (first in ordered = highest frequency = client's own)
    // If own industry has no events, activate all
    const ownIndustry = ordered[0]
    const ownHasEvents = allEvents.some(e => e.industry_code === ownIndustry)
    ordered.forEach(i => {
      if (industryState[i] === undefined) {
        industryState[i] = ownHasEvents ? (i === ownIndustry) : true
      }
    })

    industryRow.innerHTML = ordered.map((ind, idx) => {
      const active = industryState[ind] !== false
      const sep = idx < ordered.length - 1
        ? `<span style="font-size:12px;color:#E5E7EB;margin:0 10px;">|</span>` : ''
      return `<span data-industry="${ind}"
        style="font-size:12px;font-weight:${active ? '500' : '400'};color:${active ? '#111827' : '#9CA3AF'};cursor:pointer;white-space:nowrap;"
      >${truncateIndustry(ind)}</span>${sep}`
    }).join('')

    industryRow.querySelectorAll('[data-industry]').forEach(el => {
      el.addEventListener('click', () => {
        const ind = el.getAttribute('data-industry')
        industryState[ind] = !industryState[ind]
        el.style.fontWeight = industryState[ind] ? '500' : '400'
        el.style.color = industryState[ind] ? '#111827' : '#9CA3AF'
        applyIndustryFilter()
      })
    })
  }

  function applyIndustryFilter() {
    // Clear all event layers
    eventsLayer500m.clearLayers()
    eventsLayer1km.clearLayers()
    eventsLayer5km.clearLayers()
    eventsLayer10km.clearLayers()
    eventsLayer50km.clearLayers()

    const layerMap = {
      '500m': eventsLayer500m,
      '1km':  eventsLayer1km,
      '5km':  eventsLayer5km,
      '10km': eventsLayer10km,
      '50km': eventsLayer50km,
    }

    // Filter by active industries
    const filtered = allEvents.filter(e => industryState[e.industry_code] !== false)

    // Re-render list with filtered events
    renderEventList(filtered)

    // Re-render markers
    let num = 1
    ;['500m','1km','5km','10km','50km'].forEach(bucket => {
      filtered.filter(e => e.radius_bucket === bucket).forEach(e => {
        const lat = Number(e.latitude)
        const lng = Number(e.longitude)
        if (!Number.isFinite(lat) || !Number.isFinite(lng)) return
        createEventMarker(e, num).addTo(layerMap[bucket])
        num++
      })
    })

    // Show/hide layers based on active radius (cumulative)
    const included = radiusIncludes[activeRadius] || []
    ;['500m','1km','5km','10km','50km'].forEach(bucket => {
      const layer = { '500m': eventsLayer500m, '1km': eventsLayer1km, '5km': eventsLayer5km, '10km': eventsLayer10km, '50km': eventsLayer50km }[bucket]
      if (included.includes(bucket)) map.addLayer(layer)
      else map.removeLayer(layer)
    })

    // Zoom to fit only events in active radius + venue
    const venueLat = Number(map._lastVenueLat)
    const venueLon = Number(map._lastVenueLon)
    const bounds = []
    if (Number.isFinite(venueLat) && Number.isFinite(venueLon)) bounds.push([venueLat, venueLon])
    filtered.filter(e => included.includes(e.radius_bucket)).forEach(e => {
      const lat = Number(e.latitude), lng = Number(e.longitude)
      if (Number.isFinite(lat) && Number.isFinite(lng)) bounds.push([lat, lng])
    })
    const radiusZoom = { 'filter-500m': 17, 'filter-1km': 16, 'filter-5km': 14, 'filter-10km': 13 };
    const zoomLevel = radiusZoom[activeRadius] || 14;
    const vLat = Number(map._lastVenueLat);
    const vLon = Number(map._lastVenueLon);
    if (bounds.length > 1) map.fitBounds(bounds, { padding: [40, 40], maxZoom: 15 })
    else if (Number.isFinite(vLat) && Number.isFinite(vLon)) map.setView([vLat, vLon], zoomLevel)
  }

  // Override renderEvents to store allEvents and build industry row
  const _origRenderEvents = renderEvents
  window._onEventsLoaded = function(events) {
    allEvents = events
    buildIndustryRow(events)
  }

  // ---- Mobilité ----
  const filterRoute = getEl('filter-route')
  const filterMetro = getEl('filter-metro')
  if (filterRoute) filterRoute.addEventListener('click', () => {
    setActive(filterRoute); setInactive(filterMetro)
    subwayLayer.remove(); roadLayer.addTo(map)
  })
  if (filterMetro) filterMetro.addEventListener('click', () => {
    setActive(filterMetro); setInactive(filterRoute)
    roadLayer.remove(); subwayLayer.addTo(map)
  })

  // ---- Mode toggle ----
  modeConcurrence.addEventListener('click', () => {
    setActive(modeConcurrence); setInactive(modeMobilite)
    subConcurrence.style.display = 'flex'
    subMobilite.style.display = 'none'
    industryRow.style.display = 'flex'
    roadLayer.remove()
    applyIndustryFilter()
  })

  modeMobilite.addEventListener('click', () => {
    setActive(modeMobilite); setInactive(modeConcurrence)
    subMobilite.style.display = 'flex'
    subConcurrence.style.display = 'none'
    industryRow.style.display = 'none'
    map.removeLayer(eventsLayer500m); map.removeLayer(eventsLayer1km); map.removeLayer(eventsLayer5km)
    map.removeLayer(eventsLayer10km); map.removeLayer(eventsLayer50km)
    roadLayer.addTo(map)
    subwayLayer.addTo(map)
    setActive(getEl('filter-route'))
    setInactive(getEl('filter-metro'))
    const _bounds = []
    const _vLat = Number(map._lastVenueLat)
    const _vLon = Number(map._lastVenueLon)
    if (Number.isFinite(_vLat) && Number.isFinite(_vLon)) _bounds.push([_vLat, _vLon])
    roadLayer.eachLayer(l => { if (l.getLatLng) _bounds.push([l.getLatLng().lat, l.getLatLng().lng]) })
    subwayLayer.eachLayer(l => { if (l.getLatLng) _bounds.push([l.getLatLng().lat, l.getLatLng().lng]) })
    if (_bounds.length > 1) map.fitBounds(_bounds, { padding: [60, 60], maxZoom: 14 })
    else if (_bounds.length === 1) map.setView(_bounds[0], 14)
  })

  // ---- Initial state: concurrence, 5km active ----
  eventsLayer50km.remove()
  roadLayer.remove()
  setActive(modeConcurrence)
  setInactive(modeMobilite)
  applyRadius('filter-5km')
})

</script>

{!is_embed && <InsightBottomBar active="days" showActions={false} />}

</BaseLayout>

</Show>