            </div>
          </div>

          <div id="ie-30d-month-header" data-role="ie-30d-month-header" data-window-start=""></div>
          <div id="ie-30d-filter-empty"></div>
            <div id="ie-30d-calendar" data-role="ie-30d-calendar" style="position:relative;">
              <div id="ie-30d-weekdays" data-role="ie-30d-weekdays">
                <div class="ie-30d-weekday">Lun</div>
                <div class="ie-30d-weekday">Mar</div>
                <div class="ie-30d-weekday">Mer</div>
                <div class="ie-30d-weekday">Jeu</div>
                <div class="ie-30d-weekday">Ven</div>
                <div class="ie-30d-weekday">Sam</div>
                <div class="ie-30d-weekday">Dim</div>
              </div>

              <div id="ie-30d-grid" data-role="ie-30d-grid" style="position:relative;">
                <!-- GRID_ANCHOR -->
              </div>
              <div id="ie-30d-grid-overlay" style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:3;"></div>
            </div>
          <div id="ie-30d-weather-disclaimer">
            Au-delà de 10 jours, météo basée sur moyenne saisonnière.
          </div>
        </section>

        <!-- Month intro overlay (client-only, v1: localStorage) -->
        <div
          id="ms-month-intro"
          class="ms-month-intro hidden"
          role="dialog"
          aria-modal="true"
          aria-labelledby="ms-month-intro-title"
        >
          <div class="ms-month-intro__card">
            <div class="ms-month-intro__icon" aria-hidden="true">🗓️</div>

            <h2 id="ms-month-intro-title" class="ms-month-intro__title">
              Comment utiliser le calendrier
            </h2>

            <ul class="ms-month-intro__list">
              <li><strong>A, B et C</strong> indiquent si un jour est plus ou moins favorable pour votre évènement.</li>
              <li>Les signes <strong>"+"</strong> et <strong>"−"</strong> précisent si le jour est meilleur ou légèrement en dessous de la moyenne.</li>
              <li><strong>Cliquez sur 1 à 7 jours</strong> pour voir le détail de chaque journée.</li>
            </ul>

            <button type="button" class="ms-month-intro__cta" id="ms-month-intro-dismiss">
              NE PLUS AFFICHER
            </button>
          </div>
        </div>

        <script is:inline>
          (function () {
            const KEY = "ms_month_intro_dismissed_v1";

            const root = document.getElementById("ms-month-intro");
            if (!root) return;

            const dismissBtn = document.getElementById("ms-month-intro-dismiss");
            const backdrop = root.querySelector(".ms-month-intro__backdrop");

            const hide = () => {
              root.classList.add("hidden");
              root.setAttribute("aria-hidden", "true");
              document.documentElement.style.overflow = "";
              document.body.style.overflow = "";
            };

            const show = () => {
              root.classList.remove("hidden");
              root.removeAttribute("aria-hidden");
              document.documentElement.style.overflow = "hidden";
              document.body.style.overflow = "hidden";
            };

            // Show only if user did not dismiss
            try {
              const dismissed = window.localStorage.getItem(KEY) === "1";
              if (!dismissed) show();
              else hide();
            } catch (_) {
              // If storage blocked, default to showing once per page load
              show();
            }

            const dismissForever = () => {
              try { window.localStorage.setItem(KEY, "1"); } catch (_) {}
              hide();
            };

            if (dismissBtn) dismissBtn.addEventListener("click", dismissForever);

            // Optional niceties (safe + standard UX):
            // click outside closes (WITHOUT saving preference)
            if (backdrop) backdrop.addEventListener("click", hide);

            // Escape closes (WITHOUT saving preference)
            document.addEventListener("keydown", (e) => {
              if (e.key === "Escape" && !root.classList.contains("hidden")) hide();
            });
          })();

          // =====================
          // LOCATION PICKER
          // =====================
          (function initLocationPicker() {
            const LOC_ID = String(window.__ie_location_id || "");
            let __locMap = null;
            let __locMarker = null;
            let __locCompLayer = null;
            let __selectedSavedId = null;
            let __pendingAddress = null;
            let __pendingLat = null;
            let __pendingLon = null;
            let __locSearchTimeout = null;
            let __locationsCache = null;

            const panel       = document.getElementById("ms-loc-panel");
            const barName     = document.getElementById("ms-loc-name");
            const barAddr     = document.getElementById("ms-loc-addr");
            const barBadge    = document.getElementById("ms-loc-badge");
            const btnChange   = document.getElementById("ms-loc-change");
            const btnClose    = document.getElementById("ms-loc-close");
            const btnCancel   = document.getElementById("ms-loc-cancel");
            const btnSaved    = document.getElementById("ms-loc-confirm-saved");
            const btnNew      = document.getElementById("ms-loc-confirm-new");
            const savedWrap   = document.getElementById("ms-loc-saved");
            const searchEl    = document.getElementById("ms-loc-search");
            const suggestEl   = document.getElementById("ms-loc-suggestions");
            const mapWrap     = document.getElementById("ms-loc-map-wrap");
            const mapLabel    = document.getElementById("ms-loc-map-label");
            const nameWrap    = document.getElementById("ms-loc-name-wrap");
            const nameInput   = document.getElementById("ms-loc-name-input");

            function escLoc(v) {
              return String(v || "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
            }

            function showSavedMode() {
              if (btnSaved) btnSaved.style.display = "inline-block";
              if (btnNew)   btnNew.style.display   = "none";
              if (mapWrap)  mapWrap.style.display  = "none";
            }

            function showNewMode() {
              if (btnSaved) btnSaved.style.display = "none";
              if (btnNew)   btnNew.style.display   = "inline-block";
            }

            async function loadLocations() {
              if (__locationsCache) return __locationsCache;
              try {
                const res = await fetch("/api/profile/locations");
                if (!res.ok) return [];
                const data = await res.json();
                __locationsCache = Array.isArray(data.locations) ? data.locations : [];
              } catch (_) {
                __locationsCache = [];
              }
              return __locationsCache;
            }

            async function populateBar() {
              const locs = await loadLocations();
              const urlLocId = new URL(window.location.href).searchParams.get("location_id") || LOC_ID;
              const current = locs.find(l => l.location_id === urlLocId) || locs[0];
              if (!current) return;
              if (barName) barName.textContent = current.company_name || current.company_address || "Mon site";
              if (barAddr) barAddr.textContent = current.company_address || "";
              if (barBadge) barBadge.style.display = current.is_primary ? "inline-flex" : "none";
            }

            async function renderSavedList() {
              if (!savedWrap) return;
              const locs = await loadLocations();
              if (!locs.length) { savedWrap.style.display = "none"; return; }
              const label = savedWrap.querySelector("div");
              savedWrap.innerHTML = "";
              if (label) savedWrap.appendChild(label);
              locs.forEach(loc => {
                const item = document.createElement("div");
                item.className = "ms-loc-saved-item";
                const isActive = loc.location_id === __selectedSavedId;
                item.innerHTML = `
                  <div class="ms-loc-check ${isActive ? "active" : ""}" data-id="${loc.location_id}"></div>
                  <div>
                    <div class="ms-loc-item-name">${escLoc(loc.is_primary ? (loc.company_name || loc.company_address) : (loc.company_name || loc.company_address || "Site"))}</div>
                    <div class="ms-loc-item-addr">${escLoc(loc.company_address || "")}${loc.is_primary ? ' · <span style="color:#0b37e5">Principal</span>' : ""}</div>
                  </div>
                `;
                item.addEventListener("click", () => {
                  __selectedSavedId = loc.location_id;
                  __pendingAddress = null;
                  __pendingLat = null;
                  __pendingLon = null;
                  if (searchEl) searchEl.value = "";
                  if (suggestEl) suggestEl.innerHTML = "";
                  renderSavedList();
                  showSavedMode();
                  if (nameWrap && nameInput) {
                    if (!loc.is_primary) {
                      nameWrap.style.display = "block";
                      nameInput.value = loc.company_name || loc.company_address || "";
                    } else {
                      nameWrap.style.display = "none";
                    }
                  }
                });
                savedWrap.appendChild(item);
              });
            }

            const DEPT_FILTER = ["75","77","78","91","92","93","94","95","13","06","83","84","04","05","31","34","30","66","65","11","81","09","12","46","48","32","82"];

            async function searchBAN(q) {
              const url = new URL("https://api-adresse.data.gouv.fr/search/");
              url.searchParams.set("q", q);
              url.searchParams.set("limit", "6");
              url.searchParams.set("type", "housenumber");
              const res = await fetch(url.toString());
              if (!res.ok) return [];
              const data = await res.json();
              return (data.features || []).filter(f => {
                const dept = String(f.properties?.postcode || "").slice(0, 2);
                return DEPT_FILTER.includes(dept);
              });
            }

            if (searchEl) {
              searchEl.addEventListener("input", () => {
                clearTimeout(__locSearchTimeout);
                const q = searchEl.value.trim();
                if (q.length < 4) { if (suggestEl) suggestEl.innerHTML = ""; return; }
                __locSearchTimeout = setTimeout(async () => {
                  const feats = await searchBAN(q).catch(() => []);
                  if (!feats.length) { if (suggestEl) suggestEl.innerHTML = ""; return; }
                  suggestEl.innerHTML = '<div style="border:1px solid #e5e7eb;border-top:none;">' +
                    feats.map(f => `
                      <div class="ms-loc-suggestion"
                        data-lat="${f.geometry.coordinates[1]}"
                        data-lon="${f.geometry.coordinates[0]}"
                        data-label="${escLoc(f.properties.label)}">
                        <div>${escLoc(f.properties.label)}</div>
                        <div class="ms-loc-suggestion-sub">${escLoc(f.properties.city || "")} · ${escLoc(f.properties.context || "")}</div>
                      </div>`).join("") + "</div>";
                  suggestEl.querySelectorAll(".ms-loc-suggestion").forEach(el => {
                    el.addEventListener("click", () => {
                      const lat = parseFloat(el.getAttribute("data-lat"));
                      const lon = parseFloat(el.getAttribute("data-lon"));
                      const label = el.getAttribute("data-label");
                      searchEl.value = label;
                      suggestEl.innerHTML = "";
                      __selectedSavedId = null;
                      __pendingAddress = label;
                      __pendingLat = lat;
                      __pendingLon = lon;
                      if (nameWrap) nameWrap.style.display = "none";
                      renderSavedList();
                      showNewMode();
                      showMapPreview(lat, lon, label);
                    });
                  });
                }, 250);
              });
            }

            function showMapPreview(lat, lon, label) {
              if (!mapWrap) return;
              mapWrap.style.display = "block";
              const today = new Date();
              const ymd = `${today.getUTCFullYear()}-${String(today.getUTCMonth()+1).padStart(2,"0")}-${String(today.getUTCDate()).padStart(2,"0")}`;
              if (!__locMap) {
                if (typeof L === "undefined") {
                  const css = document.createElement("link");
                  css.rel = "stylesheet";
                  css.href = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css";
                  document.head.appendChild(css);
                  const js = document.createElement("script");
                  js.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
                  js.onload = () => initMap(lat, lon, label, ymd);
                  document.head.appendChild(js);
                  return;
                }
                initMap(lat, lon, label, ymd);
              } else {
                updateMap(lat, lon, label, ymd);
              }
            }

            function initMap(lat, lon, label, date) {
              __locMap = L.map("ms-loc-map", { zoomControl: false }).setView([lat, lon], 14);
              L.tileLayer("https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png", {
                attribution: "© OpenStreetMap contributors"
              }).addTo(__locMap);
              __locMarker = L.circleMarker([lat, lon], {
                radius: 8, fillColor: "#0b37e5", color: "#fff", weight: 2, fillOpacity: 1
              }).addTo(__locMap);
              __locCompLayer = L.layerGroup().addTo(__locMap);
              if (mapLabel) mapLabel.textContent = label || "";
              loadCompetitionDots(date);
            }

            function updateMap(lat, lon, label, date) {
              __locMap.setView([lat, lon], 14);
              if (__locMarker) __locMarker.setLatLng([lat, lon]);
              if (__locCompLayer) __locCompLayer.clearLayers();
              if (mapLabel) mapLabel.textContent = label || "";
              loadCompetitionDots(date);
            }

            async function loadCompetitionDots(date) {
              if (!__locCompLayer) return;
              const locs = await loadLocations();
              const match = locs.find(l => l.company_address === __pendingAddress);
              const lid = match?.location_id || null;
              if (!lid) { if (mapLabel) mapLabel.textContent = __pendingAddress || ""; return; }
              try {
                const res = await fetch(`/api/insight/map?location_id=${encodeURIComponent(lid)}&date=${encodeURIComponent(date)}`);
                if (!res.ok) return;
                const data = await res.json();
                const events = Array.isArray(data.events) ? data.events : [];
                __locCompLayer.clearLayers();
                let count = 0;
                events.slice(0, 30).forEach(e => {
                  const elat = Number(e.latitude), elon = Number(e.longitude);
                  if (!Number.isFinite(elat) || !Number.isFinite(elon)) return;
                  L.circleMarker([elat, elon], {
                    radius: 5, fillColor: "#e24b4a", color: "#fff", weight: 1.5, fillOpacity: 0.85
                  }).bindTooltip(e.title || "Événement", { direction: "top" }).addTo(__locCompLayer);
                  count++;
                });
                if (mapLabel) mapLabel.textContent = `${count} événements concurrents · 5km`;
              } catch (_) {}
            }

            function openPanel() {
              if (panel) panel.style.display = "block";
              const urlLocId = new URL(window.location.href).searchParams.get("location_id") || LOC_ID;
              __selectedSavedId = urlLocId;
              __pendingAddress = null;
              __pendingLat = null;
              __pendingLon = null;
              if (nameWrap) nameWrap.style.display = "none";
              if (mapWrap) mapWrap.style.display = "none";
              if (searchEl) searchEl.value = "";
              if (suggestEl) suggestEl.innerHTML = "";
              showSavedMode();
              renderSavedList();
            }

            function closePanel() {
              if (panel) panel.style.display = "none";
              if (mapWrap) mapWrap.style.display = "none";
              if (nameWrap) nameWrap.style.display = "none";
              if (searchEl) searchEl.value = "";
              if (suggestEl) suggestEl.innerHTML = "";
              __pendingAddress = null;
              __pendingLat = null;
              __pendingLon = null;
            }

            if (btnChange) btnChange.addEventListener("click", openPanel);
            if (btnClose)  btnClose.addEventListener("click", closePanel);
            if (btnCancel) btnCancel.addEventListener("click", closePanel);

            // ---- Choisir ce site (saved location) ----
            if (btnSaved) {
              btnSaved.addEventListener("click", async () => {
                if (!__selectedSavedId) return;
                btnSaved.disabled = true;
                btnSaved.textContent = "…";

                // Save renamed name if applicable
                if (nameWrap && nameWrap.style.display !== "none" && nameInput instanceof HTMLInputElement) {
                  const newName = nameInput.value.trim();
                  if (newName) {
                    await fetch("/api/profile/location-rename", {
                      method: "POST",
                      headers: { "content-type": "application/json" },
                      body: JSON.stringify({ location_id: __selectedSavedId, company_name: newName }),
                    }).catch(() => {});
                    __locationsCache = null; // bust cache so bar refreshes
                  }
                }

                const u = new URL(window.location.href);
                u.searchParams.set("location_id", __selectedSavedId);
                u.searchParams.delete("new_location");
                window.location.href = u.toString();
              });
            }

            // ---- Ajouter ce site (new address) ----
            if (btnNew) {
              btnNew.addEventListener("click", async () => {
                if (!__pendingAddress) return;
                btnNew.disabled = true;
                btnNew.textContent = "…";

                try {
                  const res = await fetch("/api/profile/location-add", {
                    method: "POST",
                    headers: { "content-type": "application/json" },
                    body: JSON.stringify({
                      company_address: __pendingAddress,
                      company_name: __pendingAddress,
                    }),
                  });
                  const out = await res.json().catch(() => null);
                  if (out?.ok && out?.location_id) {
                    const u = new URL(window.location.href);
                    u.searchParams.set("location_id", out.location_id);
                    u.searchParams.set("new_location", "1");
                    window.location.href = u.toString();
                  }
                } catch (_) {}

                btnNew.disabled = false;
                btnNew.textContent = "Ajouter ce site";
              });
            }

            populateBar();
          })();
        </script>
      </main>

