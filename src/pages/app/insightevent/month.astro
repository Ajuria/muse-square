              <button type="button" class="ms-seg__btn" data-ms-filter="vacances" role="tab" aria-selected="false">Vacances</button>
              <div class="ms-seg__sep"></div>
              <button type="button" class="ms-seg__btn" data-ms-filter="ferie" role="tab" aria-selected="false">Férié</button>
