---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";

const clerk_user_id_raw = (Astro.locals as any)?.clerk_user_id;
if (typeof clerk_user_id_raw !== "string" || clerk_user_id_raw.trim() === "") {
  return Astro.redirect("/sign-in");
}
---

<BaseLayout title="Mes suivis - Muse Square" hideSurveyCta={true}>
  <div class="min-h-screen bg-white pt-26 pb-20 px-4">
    <div class="max-w-2xl mx-auto mt-10">

      <div class="mb-8">
        <h1 class="text-3xl font-semibold">Mes suivis</h1>
        <p class="text-sm text-gray-500 mt-2">Événements et marques suivis par site.</p>
      </div>

      <div class="flex gap-2 mb-8">
        <button id="tab-events" onclick="showTab('events')"
          class="px-4 py-1.5 text-xs font-medium border border-black bg-black text-white tracking-wide uppercase">
          Événements
        </button>
        <button id="tab-brands" onclick="showTab('brands')"
          class="px-4 py-1.5 text-xs font-medium border border-gray-300 text-gray-500 tracking-wide uppercase">
          Entit\u00e9s suivies
        </button>
      </div>

      <div id="entity-type-filter" style="display:none;margin-bottom:12px;">
        <div style="display:flex;gap:6px;flex-wrap:wrap;" id="entity-filter-pills"></div>
      </div>

      <div id="panel-loading" class="text-sm text-gray-400">Chargement…</div>
      <div id="panel-events" style="display:none;"></div>
      <div id="panel-brands" style="display:none;"></div>

    </div>
  </div>
</BaseLayout>

<script is:inline>
(function () {

  var currentTab = 'brands';
  var expandedId = null;
  var data = null;
  var eventsCache = {};
  var editingUrlId = null;

  var INDUSTRY_LABELS = {
    non_profit:'Associatif & Non lucratif', wellness:'Bien-être & Fitness',
    cinema_theatre:'Cinéma & Théâtre', commercial:'Commerce & Retail',
    institutional:'Collectivités & Secteur public', culture:'Culture & Patrimoine',
    family:'Éducation & Enseignement', live_event:'Événementiel',
    hotel_lodging:'Hôtellerie & Hébergement', food_nightlife:'Restauration & Bars',
    science_innovation:'Sciences & Innovation', pro_event:'Salons & Événements professionnels',
    sport:'Sports & Loisirs actifs', transport_mobility:'Transport & Mobilité locale',
    outdoor_leisure:'Tourisme & Loisirs', nightlife:'Vie nocturne',
    unknown:'Autre activité accueillant du public',
  };

  var ENTITY_TYPE_LABELS = {
    competitor: 'Concurrent',
    institution: 'Institution locale',
    media: 'M\u00e9dia local',
    aggregator: 'Plateforme'
  };

  var ENTITY_TYPE_COLORS = {
    competitor: { bg: '#EEF2FF', color: '#3730A3' },
    institution: { bg: '#FEF3C7', color: '#92400E' },
    media: { bg: '#E0E7FF', color: '#3730A3' },
    aggregator: { bg: '#F3E8FF', color: '#6B21A8' }
  };

  function escH(s) {
    return String(s || '')
      .replace(/&/g,'&amp;').replace(/</g,'&lt;')
      .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function fmtDate(iso) {
    if (!iso) return '';
    var months = ['jan.','fév.','mars','avr.','mai','juin','juil.','août','sept.','oct.','nov.','déc.'];
    var parts = iso.slice(0,10).split('-');
    return parseInt(parts[2]) + ' ' + months[parseInt(parts[1])-1] + ' ' + parts[0];
  }

  function fmtDay(iso) {
    if (!iso) return { day:'—', month:'' };
    var months = ['jan','fév','mar','avr','mai','juin','juil','août','sep','oct','nov','déc'];
    var parts = iso.slice(0,10).split('-');
    return { day: parseInt(parts[2]), month: months[parseInt(parts[1])-1] };
  }

  function showTab(t) {
    currentTab = t;
    var evtBtn  = document.getElementById('tab-events');
    var brdBtn  = document.getElementById('tab-brands');
    var evtPanel = document.getElementById('panel-events');
    var brdPanel = document.getElementById('panel-brands');
    if (t === 'events') {
      evtBtn.className  = 'px-4 py-1.5 text-xs font-medium border border-black bg-black text-white tracking-wide uppercase';
      brdBtn.className  = 'px-4 py-1.5 text-xs font-medium border border-gray-300 text-gray-500 tracking-wide uppercase';
      evtPanel.style.display = 'block';
      brdPanel.style.display = 'none';
    } else {
      brdBtn.className  = 'px-4 py-1.5 text-xs font-medium border border-black bg-black text-white tracking-wide uppercase';
      evtBtn.className  = 'px-4 py-1.5 text-xs font-medium border border-gray-300 text-gray-500 tracking-wide uppercase';
      brdPanel.style.display = 'block';
      evtPanel.style.display = 'none';
    }
  }

  // ── Events tab ────────────────────────────────────────────────────
  function renderEventsPanel(competitors) {
    if (!competitors || competitors.length === 0) {
      return '<p style="font-size:13px;color:#6B7280;font-style:italic;">Aucun concurrent suivi pour le moment.</p>';
    }
    var groups = groupByLocation(competitors);
    var html = '';
    var hasAny = false;
    Object.keys(groups).forEach(function(locKey) {
      var locHtml = '';
      groups[locKey].forEach(function(comp) {
        if (!comp.competitor_id) return;
        var evts = eventsCache[comp.competitor_id] || [];
        if (!evts.length) return;
        var industryLabel = INDUSTRY_LABELS[comp.industry_code] || comp.industry_code || '';
        if (compExpanded[comp.competitor_id] === undefined) compExpanded[comp.competitor_id] = true;
        var isCompOpen = compExpanded[comp.competitor_id];
        locHtml += '<div style="border:0.5px solid #E5E7EB;border-radius:10px;overflow:hidden;margin-bottom:8px;">';
        locHtml += '<div style="padding:10px 14px;background:#F9FAFB;' + (isCompOpen ? 'border-bottom:0.5px solid #E5E7EB;' : '') + 'cursor:pointer;display:flex;align-items:center;justify-content:space-between;" onclick="toggleCompExpand(\'' + escH(comp.competitor_id) + '\')">';
        locHtml += '<div>';
        locHtml += '<div style="font-size:13px;font-weight:500;color:#111827;">' + escH(comp.name) + '</div>';
        if (industryLabel) locHtml += '<div style="font-size:11px;color:#6B7280;margin-top:1px;">' + escH(industryLabel) + '</div>';
        locHtml += '</div>';
        if (isCompOpen) {
          locHtml += '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round"><path d="M19 9l-7 7-7-7"/></svg>';
        } else {
          locHtml += '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>';
        }
        locHtml += '</div>';
        if (!isCompOpen) { locHtml += '</div>'; hasAny = true; return; }
        evts.forEach(function(ev, idx) {
          var isLast = idx === evts.length - 1;
          var d = fmtDay(ev.event_date);
          locHtml += '<div style="display:flex;align-items:flex-start;gap:10px;padding:10px 14px;' + (isLast ? '' : 'border-bottom:0.5px solid #F3F4F6;') + '">';
          locHtml += '<div style="flex-shrink:0;text-align:center;min-width:28px;">';
          locHtml += '<div style="font-size:15px;font-weight:500;color:#111827;">' + escH(String(d.day)) + '</div>';
          locHtml += '<div style="font-size:10px;color:#9CA3AF;text-transform:uppercase;">' + escH(d.month) + '</div>';
          locHtml += '</div>';
          locHtml += '<div style="flex:1;min-width:0;">';
          locHtml += '<div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">';
          locHtml += '<span style="font-size:13px;font-weight:500;color:#111827;">' + escH(ev.event_name || '—') + '</span>';
          if (ev.signal_type || ev.event_type) {
            locHtml += '<span style="font-size:10px;font-weight:500;padding:1px 7px;border-radius:20px;background:#FCEBEB;color:#791F1F;">' + escH(ev.signal_type || ev.event_type) + '</span>';
          }
          locHtml += '</div>';
          var sub = [];
          if (ev.venue_name) sub.push(ev.venue_name);
          if (ev.venue_exposure && ev.venue_exposure !== 'unknown') sub.push(ev.venue_exposure === 'indoor' ? 'Intérieur' : 'Extérieur');
          if (sub.length) locHtml += '<div style="font-size:11px;color:#6B7280;margin-top:2px;">' + escH(sub.join(' · ')) + '</div>';
          locHtml += '</div>';
          locHtml += '</div>';
        });
        locHtml += '</div>';
        hasAny = true;
      });
      if (locHtml) {
        var locIdx = Object.keys(groups).indexOf(locKey);
        if (locExpanded[locIdx] === undefined) locExpanded[locIdx] = true;
        var isOpen = locExpanded[locIdx];
        html += '<div style="display:flex;align-items:center;justify-content:space-between;cursor:pointer;margin-bottom:8px;margin-top:1.5rem;" onclick="toggleLocExpand(' + locIdx + ')">';
        html += '<div style="font-size:11px;font-weight:500;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.10em;">' + escH(locKey) + '</div>';
        html += '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round" style="transition:transform 0.15s;transform:rotate(' + (isOpen ? '90' : '0') + 'deg)"><path d="M9 18l6-6-6-6"/></svg>';
        html += '</div>';
        if (isOpen) html += locHtml;
      }
    });
    if (!hasAny) return '<p style="font-size:13px;color:#6B7280;font-style:italic;">Aucun événement détecté pour le moment.</p>';
    return html;
  }

  // ── Brands tab ────────────────────────────────────────────────────

  function renderBrandsPanel(items) {
    if (!items || items.length === 0) {
      return '<p class="text-sm text-gray-400">Aucune marque suivie pour le moment.</p>';
    }
    var groups = groupByLocation(items);
    var html = '';
    Object.keys(groups).forEach(function(key) {
      html += '<div style="font-size:11px;font-weight:500;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.10em;margin-bottom:8px;">' + escH(key) + '</div>';
      html += '<div style="margin-bottom:20px;display:flex;flex-direction:column;gap:6px;">';
      groups[key].forEach(function(item) {
        html += renderCompetitorRow(item);
      });
      html += '</div>';
    });
    return html;
  }

  function renderCompetitorRow(item) {
    var isExpanded = expandedId === item.id;
    var industryLabel = INDUSTRY_LABELS[item.industry_code] || item.industry_code || '';
    
    var html = '<div style="border:0.5px solid #E5E7EB;border-radius:10px;overflow:hidden;" id="comp-row-' + escH(item.id) + '">';

    // ── Header (always visible) ──
    html += '<div style="display:flex;align-items:center;justify-content:space-between;padding:12px 14px;cursor:pointer;' + (isExpanded ? 'background:#F9FAFB;border-bottom:0.5px solid #E5E7EB;' : '') + '" onclick="toggleExpand(\'' + escH(item.id) + '\')">';
    html += '<div style="flex:1;min-width:0;">';
    html += '<div style="font-size:14px;font-weight:500;color:#111827;">' + escH(item.name) + '</div>';
    var statusBadge = (item.extraction_status === 'fetch_error' || item.extraction_status === 'failed' || (item.fetch_http_status && item.fetch_http_status >= 400))
      ? '<span style="font-size:10px;font-weight:500;padding:2px 8px;border-radius:20px;background:#FCEBEB;color:#791F1F;white-space:nowrap;">Suivi interrompu</span>'
      : item.source_url
      ? '<span style="font-size:10px;font-weight:500;padding:2px 8px;border-radius:20px;background:#EAF3DE;color:#27500A;white-space:nowrap;">Suivi actif</span>'
      : '<span style="font-size:10px;font-weight:500;padding:2px 8px;border-radius:20px;background:#F1EFE8;color:#444441;white-space:nowrap;">Sans URL</span>';
    var etLabel = ENTITY_TYPE_LABELS[item.entity_type] || ENTITY_TYPE_LABELS['competitor'];
    var etColor = ENTITY_TYPE_COLORS[item.entity_type] || ENTITY_TYPE_COLORS['competitor'];
    var entityPill = item.entity_type && item.entity_type !== 'competitor'
      ? '<span style="font-size:10px;font-weight:500;padding:2px 8px;border-radius:20px;background:' + etColor.bg + ';color:' + etColor.color + ';white-space:nowrap;">' + escH(etLabel) + '</span>'
      : '';
    html += '<div style="font-size:12px;color:#6B7280;margin-top:4px;display:flex;align-items:center;gap:6px;flex-wrap:wrap;">' + escH(industryLabel) + entityPill + statusBadge + '</div>';
    html += '</div>';
    html += '<div style="display:flex;align-items:center;gap:10px;flex-shrink:0;">';
    // chevron
    if (isExpanded) {
      html += '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round"><path d="M19 9l-7 7-7-7"/></svg>';
    } else {
      html += '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>';
    }
    html += '</div>';
    html += '</div>';

    if (isExpanded) {
      html += renderExpandedBody(item);
    }

    html += '</div>';
    return html;
  }

  function renderExpandedBody(item) {
    var isEditingUrl = editingUrlId === item.id;
    var confidencePct = item.confidence_score ? Math.round(item.confidence_score * 100) : 0;
    var isFailed = item.extraction_status === 'fetch_error' || item.extraction_status === 'failed' ||
      (item.fetch_http_status && item.fetch_http_status >= 400);

    var html = '<div style="border-top:0.5px solid #E5E7EB;padding:14px;display:flex;flex-direction:column;gap:14px;">';

    // ── URL section ──
    html += '<div>';
    html += '<div style="font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:0.08em;color:#9CA3AF;margin-bottom:5px;">URL surveillée</div>';
    if (isEditingUrl) {
      html += '<div style="display:flex;flex-direction:column;gap:6px;">';
      html += '<div style="display:flex;gap:6px;align-items:center;">';
      html += '<input id="url-input-' + escH(item.id) + '" type="url" value="' + escH(item.source_url || '') + '" placeholder="https://exemple.fr/agenda" style="flex:1;border:0;border-bottom:1.5px solid #d1d5db;padding:6px 0;font-size:12px;background:transparent;outline:none;font-family:inherit;color:#111827;" />';
      html += '<button onclick="saveUrl(\'' + escH(item.id) + '\')" style="padding:5px 10px;background:#111827;color:#fff;border:none;font-size:11px;font-weight:500;cursor:pointer;border-radius:6px;white-space:nowrap;">Enregistrer</button>';
      html += '<button onclick="cancelEditUrl(\'' + escH(item.id) + '\')" style="padding:5px 8px;background:none;border:0.5px solid #E5E7EB;font-size:11px;color:#6B7280;cursor:pointer;border-radius:6px;">Annuler</button>';
      html += '</div>';
      html += '<div id="url-error-' + escH(item.id) + '" style="display:none;font-size:11px;color:#b91c1c;"></div>';
      html += '</div>';
    } else if (item.source_url) {
      html += '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">';
      html += '<a href="' + escH(item.source_url) + '" target="_blank" rel="noopener" style="font-size:13px;color:#185FA5;text-decoration:none;word-break:break-all;">' + escH(item.source_url.replace(/^https?:\/\//, '')) + '</a>';
      html += '<span style="font-size:10px;font-weight:500;padding:1px 6px;border-radius:20px;background:' + (isFailed ? '#FCEBEB' : '#EAF3DE') + ';color:' + (isFailed ? '#791F1F' : '#3B6D11') + ';">' + confidencePct + '%</span>';
      html += '</div>';
      if (isFailed) {
        var urlPath = '';
        try { urlPath = new URL(item.source_url).pathname.toLowerCase(); } catch {}
        var isHomepage = !urlPath || urlPath === '/' || /^\/(fr|en|de|es)\/?$/.test(urlPath);
        var failMsg = isHomepage
          ? 'Page d\'accueil protégée — essayez l\'URL de la page agenda ou programme.'
          : 'Page inaccessible — essayez une URL pointant directement vers les événements.';
        html += '<div style="font-size:12px;color:#B91C1C;margin-top:6px;line-height:1.5;">' + failMsg + '</div>';
      }
      html += '<div style="display:flex;align-items:center;gap:12px;margin-top:6px;">';
      html += '<button onclick="startEditUrl(\'' + escH(item.id) + '\')" style="font-size:12px;color:#6B7280;background:none;border:none;cursor:pointer;padding:0;text-decoration:underline;text-underline-offset:2px;">Modifier l\'URL</button>';
      html += '<span style="font-size:10px;color:#D1D5DB;">·</span>';
      html += '<button onclick="unfollowCompetitor(\'' + escH(item.id) + '\')" style="font-size:12px;color:#6B7280;background:none;border:none;cursor:pointer;padding:0;text-decoration:underline;text-underline-offset:2px;" onmouseover="this.style.color=\'#b91c1c\'" onmouseout="this.style.color=\'#6B7280\'">Ne plus suivre</button>';
      html += '</div>';
    } else {
      html += '<div style="font-size:13px;color:#6B7280;margin-bottom:6px;">Aucune URL configurée — la surveillance est inactive.</div>';
      html += '<div style="display:flex;align-items:center;gap:12px;">';
      html += '<button onclick="startEditUrl(\'' + escH(item.id) + '\')" style="font-size:12px;color:#185FA5;background:none;border:none;cursor:pointer;padding:0;text-decoration:underline;text-underline-offset:2px;">+ Ajouter une URL</button>';
      html += '<span style="font-size:10px;color:#D1D5DB;">·</span>';
      html += '<button onclick="unfollowCompetitor(\'' + escH(item.id) + '\')" style="font-size:12px;color:#6B7280;background:none;border:none;cursor:pointer;padding:0;text-decoration:underline;text-underline-offset:2px;" onmouseover="this.style.color=\'#b91c1c\'" onmouseout="this.style.color=\'#6B7280\'">Ne plus suivre</button>';
      html += '</div>';
    }
    html += '</div>';

    // ── Extraction stats ──
    if (item.total_runs > 0) {
      var firstDate = item.first_crawled_at ? fmtDate(String(item.first_crawled_at).slice(0,10)) : '—';
      var lastDate  = item.last_crawled_at  ? fmtDate(String(item.last_crawled_at).slice(0,10))  : '—';
      html += '<div>';
      html += '<div style="font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:0.08em;color:#9CA3AF;margin-bottom:8px;">Statistiques d\'extraction</div>';
      html += '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:8px;">';
      html += '<div><div style="font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:0.07em;color:#9CA3AF;">Total</div><div style="font-size:13px;color:#111827;">' + item.total_runs + ' extraction' + (item.total_runs > 1 ? 's' : '') + '</div></div>';
      html += '<div><div style="font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:0.07em;color:#9CA3AF;">Première</div><div style="font-size:13px;color:#111827;">' + firstDate + '</div></div>';
      html += '<div><div style="font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:0.07em;color:#9CA3AF;">Dernière</div><div style="font-size:13px;color:#111827;">' + lastDate + '</div></div>';
      html += '</div>';
      html += '<button id="hist-toggle-' + escH(item.id) + '" onclick="toggleCrawlHistory(\'' + escH(item.id) + '\',\'' + escH(item.competitor_id) + '\')" style="font-size:11px;color:#6B7280;background:none;border:none;cursor:pointer;padding:0;text-decoration:underline;text-underline-offset:2px;">Voir l\'historique complet ↓</button>';
      html += '<div id="hist-body-' + escH(item.id) + '" style="display:none;margin-top:8px;"></div>';
      html += '</div>';
    }

    html += '<div style="font-size:11px;color:#9CA3AF;font-style:italic;">Prochaine analyse : cette nuit à 03h00</div>';
    html += '</div>';
    return html;
  }

  function renderDetectedEvents(events) {
    if (!Array.isArray(events) || events.length === 0) {
      return '<div style="font-size:13px;color:#9CA3AF;font-style:italic;">Aucun événement détecté pour le moment.<br><span style="font-size:12px;">Prochaine analyse : cette nuit à 03h00</span></div>';
    }
    var html = '<div style="display:flex;flex-direction:column;gap:6px;">';
    events.forEach(function(ev) {
      var d = fmtDay(ev.event_date);
      html += '<div style="display:flex;align-items:flex-start;gap:10px;padding:10px 12px;border:0.5px solid #E5E7EB;border-radius:8px;">';
      html += '<div style="flex-shrink:0;text-align:center;min-width:32px;">';
      html += '<div style="font-size:15px;font-weight:500;color:#111827;">' + escH(String(d.day)) + '</div>';
      html += '<div style="font-size:10px;color:#9CA3AF;text-transform:uppercase;">' + escH(d.month) + '</div>';
      html += '</div>';
      html += '<div style="flex:1;min-width:0;">';
      html += '<div style="font-size:13px;font-weight:500;color:#111827;">' + escH(ev.event_name || '—') + '</div>';
      var sub = [];
      if (ev.venue_name) sub.push(ev.venue_name);
      if (ev.event_city) sub.push(ev.event_city);
      if (ev.venue_exposure && ev.venue_exposure !== 'unknown') {
        sub.push(ev.venue_exposure === 'indoor' ? 'Intérieur' : 'Extérieur');
      }
      if (sub.length) {
        html += '<div style="font-size:12px;color:#6B7280;margin-top:2px;">' + escH(sub.join(' · ')) + '</div>';
      }
      html += '</div>';
      html += '</div>';
    });
    html += '</div>';
    html += '<div style="font-size:11px;color:#9CA3AF;margin-top:6px;font-style:italic;">Prochaine analyse : cette nuit à 03h00</div>';
    return html;
  }

  // ── Interactions ──────────────────────────────────────────────────

  function toggleExpand(id) {
    if (expandedId === id) {
      expandedId = null;
      editingUrlId = null;
    } else {
      expandedId = id;
      editingUrlId = null;
    }
    rerenderBrands();
    if (expandedId === id) {
      loadCompetitorEvents(id);
    }
  }

  function startEditUrl(id) {
    editingUrlId = id;
    rerenderBrands();
    // Focus the input after render
    setTimeout(function() {
      var input = document.getElementById('url-input-' + id);
      if (input) input.focus();
    }, 0);
  }

  function cancelEditUrl(id) {
    editingUrlId = null;
    rerenderBrands();
  }

  async function saveUrl(id) {
    var input = document.getElementById('url-input-' + id);
    var errorEl = document.getElementById('url-error-' + id);
    if (!input) return;
    var url = (input.value || '').trim();

    if (errorEl) { errorEl.style.display = 'none'; errorEl.textContent = ''; }

    if (!url) {
      if (errorEl) { errorEl.textContent = 'URL requise.'; errorEl.style.display = 'block'; }
      return;
    }
    try { new URL(url); } catch {
      if (errorEl) { errorEl.textContent = 'URL invalide — ex: https://exemple.fr/agenda'; errorEl.style.display = 'block'; }
      return;
    }

    try {
      var res = await fetch('/api/competitive/update-competitor-url', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ watched_competitor_id: id, source_url: url }),
      });
      var json = await res.json().catch(() => null);
      if (!json || !json.ok) throw new Error(json?.error || 'Erreur API');

      // Update local data
      var comp = data.competitors.find(function(c) { return c.id === id; });
      if (comp) {
        comp.source_url = url;
        comp.confidence_score = json.confidence_score;
        comp.is_user_vetted = json.is_user_vetted;
        comp.extraction_status = json.extraction_status ?? null;
        comp.fetch_http_status = null;
        if (comp.competitor_id) delete eventsCache[comp.competitor_id];
      }

      editingUrlId = null;
      rerenderBrands();

    } catch(e) {
      if (errorEl) { errorEl.textContent = e?.message || 'Erreur.'; errorEl.style.display = 'block'; }
    }
  }

  async function loadCompetitorEvents(watchedCompetitorId) {
    var comp = data && data.competitors
      ? data.competitors.find(function(c) { return c.id === watchedCompetitorId; })
      : null;

    if (!comp || !comp.competitor_id) return;

    if (!eventsCache[comp.competitor_id]) {
      try {
        var res = await fetch('/api/competitive/competitor-events?competitor_id=' + encodeURIComponent(comp.competitor_id));
        var json = await res.json().catch(function() { return null; });
        eventsCache[comp.competitor_id] = (json && json.ok && Array.isArray(json.events)) ? json.events : [];
      } catch(e) {
        eventsCache[comp.competitor_id] = [];
      }
    }

    var el = document.getElementById('comp-events-' + watchedCompetitorId);
    if (el) el.innerHTML = renderDetectedEvents(eventsCache[comp.competitor_id]);
  }

  var locExpanded = {};
  var compExpanded = {};

  function toggleCompExpand(competitorId) {
    compExpanded[competitorId] = !compExpanded[competitorId];
    var evtPanel = document.getElementById('panel-events');
    if (evtPanel && data) evtPanel.innerHTML = renderEventsPanel(data.competitors);
  }

  function toggleLocExpand(idx) {
    locExpanded[idx] = !locExpanded[idx];
    var evtPanel = document.getElementById('panel-events');
    if (evtPanel && data) evtPanel.innerHTML = renderEventsPanel(data.competitors);
  }

  var crawlHistoryCache = {};

  async function toggleCrawlHistory(watchedId, competitorId) {
    console.log('toggleCrawlHistory called', watchedId, competitorId);
    var bodyEl   = document.getElementById('hist-body-' + watchedId);
    var toggleEl = document.getElementById('hist-toggle-' + watchedId);
    if (!bodyEl || !toggleEl) return;
    var isOpen = bodyEl.style.display !== 'none' && bodyEl.innerHTML !== '';
    if (isOpen) {
      bodyEl.style.display = 'none';
      toggleEl.textContent = 'Voir l\'historique complet ↓';
      return;
    }
    bodyEl.style.display = 'block';
    toggleEl.textContent = 'Masquer l\'historique ↑';
    if (crawlHistoryCache[competitorId]) {
      bodyEl.innerHTML = renderCrawlHistory(crawlHistoryCache[competitorId]);
      return;
    }
    bodyEl.innerHTML = '<div style="font-size:12px;color:#9CA3AF;">Chargement…</div>';
    try {
      var res  = await fetch('/api/competitive/competitor-crawl-history?competitor_id=' + encodeURIComponent(competitorId));
      var json = await res.json().catch(function() { return null; });
      var history = (json && json.ok && Array.isArray(json.history)) ? json.history : [];
      crawlHistoryCache[competitorId] = history;
      bodyEl.innerHTML = renderCrawlHistory(history);
    } catch(e) {
      bodyEl.innerHTML = '<div style="font-size:12px;color:#B91C1C;">Erreur de chargement.</div>';
    }
  }

  function renderCrawlHistory(history) {
    if (!history.length) return '<div style="font-size:12px;color:#9CA3AF;">Aucun historique disponible.</div>';
    var STATUS_LABEL = { success: 'Succès', partial: 'Partiel', failed: 'Échec', fetch_error: 'Inaccessible' };
    var STATUS_COLOR = { success: '#27500A', partial: '#633806', failed: '#791F1F', fetch_error: '#791F1F' };
    var html = '<table style="width:100%;border-collapse:collapse;font-size:12px;">';
    html += '<thead><tr>';
    html += '<th style="text-align:left;font-weight:500;font-size:10px;text-transform:uppercase;letter-spacing:0.07em;color:#9CA3AF;padding:4px 0;border-bottom:0.5px solid #E5E7EB;">Date</th>';
    html += '<th style="text-align:left;font-weight:500;font-size:10px;text-transform:uppercase;letter-spacing:0.07em;color:#9CA3AF;padding:4px 0;border-bottom:0.5px solid #E5E7EB;">Statut</th>';
    html += '<th style="text-align:left;font-weight:500;font-size:10px;text-transform:uppercase;letter-spacing:0.07em;color:#9CA3AF;padding:4px 0;border-bottom:0.5px solid #E5E7EB;">Événements</th>';
    html += '<th style="text-align:left;font-weight:500;font-size:10px;text-transform:uppercase;letter-spacing:0.07em;color:#9CA3AF;padding:4px 0;border-bottom:0.5px solid #E5E7EB;">Champs</th>';
    html += '</tr></thead><tbody>';
    history.forEach(function(r, idx) {
      var isLast = idx === history.length - 1;
      var border = isLast ? '' : 'border-bottom:0.5px solid #F3F4F6;';
      var statusLabel = STATUS_LABEL[r.extraction_status] || r.extraction_status || '—';
      var statusColor = STATUS_COLOR[r.extraction_status] || '#6B7280';
      var dateStr = r.crawled_at ? r.crawled_at.slice(0,10).split('-').reverse().join('/') + ' · ' + r.crawled_at.slice(11,16) : '—';
      html += '<tr>';
      html += '<td style="padding:6px 0;' + border + 'color:#374151;">' + escH(dateStr) + '</td>';
      html += '<td style="padding:6px 0;' + border + 'color:' + statusColor + ';">' + escH(statusLabel) + '</td>';
      html += '<td style="padding:6px 0;' + border + 'color:#374151;">' + r.event_count + '</td>';
      html += '<td style="padding:6px 0;' + border + 'color:#374151;">' + r.max_field_count + '</td>';
      html += '</tr>';
    });
    html += '</tbody></table>';
    return html;
  }

  async function unfollowEvent(id) {
    try {
      await fetch('/api/competitive/unfollow-event', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ id }),
      });
      await loadData();
    } catch(e) {}
  }

  async function unfollowCompetitor(id) {
    var ok = window.confirm('Ne plus suivre ce concurrent ?');
    if (!ok) return;
    try {
      await fetch('/api/competitive/unfollow-competitor', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ id }),
      });
      expandedId = null;
      editingUrlId = null;
      await loadData();
    } catch(e) {}
  }

  // ── Helpers ───────────────────────────────────────────────────────

  function groupByLocation(items) {
    var groups = {};
    items.forEach(function(item) {
      var key = item.location_label || item.location_id;
      if (!groups[key]) groups[key] = [];
      groups[key].push(item);
    });
    return groups;
  }

  function rerenderBrands() {
    var brdPanel = document.getElementById('panel-brands');
    if (!brdPanel || !data) return;
    brdPanel.innerHTML = renderBrandsPanel(data.competitors);
  }

  // ── Data loading ──────────────────────────────────────────────────

  async function loadData() {
    try {
      var res = await fetch('/api/competitive/suivis');
      var out = await res.json().catch(() => null);
      if (!out || !out.ok) return;
      data = out;

      var loading  = document.getElementById('panel-loading');
      var evtPanel = document.getElementById('panel-events');
      var brdPanel = document.getElementById('panel-brands');

      if (loading) loading.style.display = 'none';
      await Promise.all(
        (out.competitors || [])
          .filter(function(c) { return c.competitor_id; })
          .map(function(c) { return loadCompetitorEvents(c.id); })
      );
      evtPanel.innerHTML = renderEventsPanel(out.competitors);
      brdPanel.innerHTML = renderBrandsPanel(out.competitors);
      renderEntityFilterPills();

      showTab('events');
    } catch(e) { console.error('loadData error', e); }
  }

  // Expose to inline onclick handlers
  window.showTab            = showTab;
  window.toggleLocExpand    = toggleLocExpand;
  window.toggleCompExpand   = toggleCompExpand;
  window.toggleCrawlHistory = toggleCrawlHistory;
  window.toggleExpand       = toggleExpand;
  window.startEditUrl       = startEditUrl;
  window.cancelEditUrl      = cancelEditUrl;
  window.saveUrl            = saveUrl;
  window.unfollowEvent      = unfollowEvent;
  window.unfollowCompetitor = unfollowCompetitor;

  var activeEntityFilter = null;

  function renderEntityFilterPills() {
    if (!data || !data.competitors) return;
    var types = {};
    data.competitors.forEach(function(c) {
      var t = c.entity_type || 'competitor';
      types[t] = (types[t] || 0) + 1;
    });
    var keys = Object.keys(types);
    var container = document.getElementById('entity-filter-pills');
    var wrapper = document.getElementById('entity-type-filter');
    if (!container || !wrapper) return;
    if (keys.length <= 1) { wrapper.style.display = 'none'; return; }
    wrapper.style.display = 'block';
    var html = '<button onclick="filterByEntityType(null)" style="font-size:11px;padding:4px 10px;border-radius:20px;border:0.5px solid ' + (!activeEntityFilter ? '#111827' : '#E5E7EB') + ';background:' + (!activeEntityFilter ? '#111827' : '#fff') + ';color:' + (!activeEntityFilter ? '#fff' : '#6B7280') + ';cursor:pointer;font-family:inherit;">Tous (' + data.competitors.length + ')</button>';
    keys.forEach(function(k) {
      var label = ENTITY_TYPE_LABELS[k] || k;
      var isActive = activeEntityFilter === k;
      html += '<button onclick="filterByEntityType(\'' + escH(k) + '\')" style="font-size:11px;padding:4px 10px;border-radius:20px;border:0.5px solid ' + (isActive ? '#111827' : '#E5E7EB') + ';background:' + (isActive ? '#111827' : '#fff') + ';color:' + (isActive ? '#fff' : '#6B7280') + ';cursor:pointer;font-family:inherit;">' + escH(label) + ' (' + types[k] + ')</button>';
    });
    container.innerHTML = html;
  }

  function filterByEntityType(type) {
    activeEntityFilter = type;
    renderEntityFilterPills();
    rerenderBrands();
  }

  window.filterByEntityType = filterByEntityType;

  // Patch rerenderBrands to apply filter
  var _origRenderBrandsPanel = renderBrandsPanel;
  renderBrandsPanel = function(items) {
    if (activeEntityFilter && items) {
      items = items.filter(function(c) { return (c.entity_type || 'competitor') === activeEntityFilter; });
    }
    return _origRenderBrandsPanel(items);
  };

  loadData();

})();
</script>