            var INDUSTRY_PILL = { direct: { bg: "var(--color-pill-risk-bg)", fg: "var(--color-pill-risk-text)", t: "M\u00eame secteur" }, partial: { bg: "var(--color-pill-risk-bg)", fg: "var(--color-pill-risk-text)", t: "Secteur proche" }, contextual: { bg: "var(--color-pill-source-low-bg)", fg: "var(--color-pill-source-low-text)", t: "Secteur diff\u00e9rent" } };
