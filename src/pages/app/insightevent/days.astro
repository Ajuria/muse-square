                  locationLabelEl.textContent = groupEl ? groupEl.getAttribute("data-location-label") : "";
                }

                // Initialize flatpickr first, then set dates via API
                if (window.__msFlatpickrDecision) window.__msFlatpickrDecision.destroy();
                if (window.__msFlatpickrEnd) window.__msFlatpickrEnd.destroy();

                window.__msFlatpickrDecision = flatpickr(modalDecisionDate, {
                  locale: flatpickr.l10ns.fr,
                  firstDayOfWeek: 1,
                  dateFormat: "d/m/Y",
                  disableMobile: true,
                });
                window.__msFlatpickrEnd = flatpickr(modalEventDate, {
                  locale: flatpickr.l10ns.fr,
