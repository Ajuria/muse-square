        function escapeHtml(v) {
          return String(v ?? "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
        }

        function computeStatusPill(r) {
          if (r?.is_major_realization_risk_flag === true || r?.is_forced_regime_c_flag === true) {
            return { cls: 'mon-statut-risk', label: 'À RISQUE' };
          }
          const alertMax = Number(r?.alert_level_max ?? 0);
          const deltaAtt = Number(r?.delta_att_mobility_pct ?? 0);
          const deltaEvents = Number(r?.delta_att_events_pct ?? 0);
          const risks = [];
          if (alertMax >= 2) risks.push({ label: 'ALERTE MÉTÉO', high: alertMax >= 3 });
          if (deltaAtt < -4) risks.push({ label: 'ALERTE MOBILITÉ', high: deltaAtt < -8 });
          if (deltaEvents > 5) risks.push({ label: 'ALERTE CONCURRENCE', high: false });
          if (!risks.length) return { cls: 'mon-statut-safe', label: 'SANS RISQUE' };
          if (risks.length === 1) {
            return { cls: risks[0].high ? 'mon-statut-risk' : 'mon-statut-warn', label: risks[0].label };
          }
          const hasHigh = risks.some(r => r.high);
          return { cls: hasHigh ? 'mon-statut-risk' : 'mon-statut-warn', label: `${risks.length} RISQUES` };
        }

