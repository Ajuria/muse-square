---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { Show } from "@clerk/astro/components";
import InsightBottomBar from "../../../components/InsightBottomBar.astro";
import { MS_ASTER_CONTRACT, MS_ASTER_CONTRACT_VERSION } from "../../../lib/ai/msAsterContract";

// --------------------
// Server-side guards
// --------------------

const location_id =
  (Astro.locals && typeof (Astro.locals as any).location_id === "string" && (Astro.locals as any).location_id.trim())
    ? (Astro.locals as any).location_id.trim()
    : null;

if (!location_id) {
  return Astro.redirect("/profile");
}

// --------------------
// Page mode truth (URL-driven)
// --------------------
const selected_dates_raw = Astro.url?.searchParams?.get("selected_dates") ?? "";
const saved_item_id_raw = Astro.url?.searchParams?.get("saved_item_id") ?? "";

const has_selected_dates =
  selected_dates_raw
    .split(",")
    .map((s) => s.trim())
    .filter(Boolean).length > 0;

const has_saved_item_id =
  typeof saved_item_id_raw === "string" && saved_item_id_raw.trim().length > 0;

const show_actions = has_selected_dates;

---

<Show when="signed-out" client:load>
  <script is:inline>
    window.location.href = "/sign-in";
  </script>
</Show>

<Show when="signed-in" client:load>
  <BaseLayout title="Insight Event — Days" hideSurveyCta={true} hideFooter={true}>
    <div class="ms-container pt-6 w-full max-w-none"></div>
  
  <style is:inline id="ms-selected-days-style">  
  /* =========================
   HERO SCORE BLOCK
   ========================= */

  .ms-hero-score{
    display:flex;
    align-items:flex-end;
    gap:6px;
  }

  .ms-hero {
    padding: var(--space-3xl) 0;
  }

  .ms-hero-date {
    font-size: 18px;
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xl);
    text-transform: capitalize;
  }

  .ms-choose-day-btn{
    width:100%;
    margin-top:14px;

    background:#FFFFFF !important;
    color:#1D3BB3 !important;

    border:1px solid #1D3BB3 !important;
    border-radius:6px;

    padding:8px 10px;

    font-size:12px;
    font-weight:600;
    text-align:center;

    cursor:pointer;
  }

  .ms-choose-day-btn:hover{
    background:color-mix(in srgb, var(--color-brand-blue) 10%, transparent);
  }

  /* =========================
    COMPARISON CARD LAYOUT
    ========================= */

  .ms-comp-cards{
    display:grid;
    grid-template-columns:1fr;
    gap:8px;
    margin-top:16px;
    margin-left:12px;
    margin-right:12px;
  }

  /* tablet */
  @media (min-width:640px){
    .ms-comp-cards{
      grid-template-columns:repeat(2,1fr);
      gap:8px;
    }
  }

  @media (min-width:1024px){
  .ms-comp-cards{
    grid-template-columns:repeat(3,minmax(0,1fr));
    gap:8px;
  }
}

  .ms-comp-card{
    background:#fff;
    border:1px solid #E5E7EB;
    border-radius:12px;
    padding:18px 16px;
    box-shadow:0 1px 4px rgba(17,24,39,0.04);
    display:flex;
    flex-direction:column;
    gap:10px;
  }

  .ms-comp-card-date{
    font-size:13px;
    font-weight:700;
    text-align:center;
  }

  .ms-comp-card-score{
    font-size:32px;
    font-weight:700;
    color:#1D3BB3;
    text-align:center;
  }

  .ms-comp-metric{
    display:flex;
    justify-content:space-between;
    font-size:13px;
    color:#374151;
  }  

  .ms-hero-grid {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .ms-hero-score-block {
    display: flex;
    flex-direction: column;
  }

  .ms-hero-label {
    font-size: var(--font-size-label);
    letter-spacing: var(--letter-spacing-wider);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-secondary);
    margin-bottom: 6px;
  }

  .ms-hero-score {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .ms-score-main {
    font-size: var(--font-size-display);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
  }

  .ms-score-max {
    font-size: 20px;
    color: var(--color-text-secondary);
  }

  .ms-key-signals{
    padding:28px 0 12px 0;
    text-align:center;
  }

  .ms-section-title{
    font-size:12px;
    letter-spacing:0.18em;
    text-transform:uppercase;
    color:rgba(17,24,39,0.55);
    font-weight:600;
    margin-bottom:14px;
  }

  .ms-delta-pill {
    background: rgba(16, 185, 129, 0.1);
    color: #059669;
    padding: 6px 14px;
    border-radius: var(--radius-md);
    font-weight: var(--font-weight-semibold);
  }

  .ms-delta-pill.is-positive {
    background: rgba(16, 185, 129, 0.1);
    color: #059669;
  }

  .ms-delta-pill.is-neutral {
    background: rgba(107, 114, 128, 0.12);
    color: #6b7280;
  }

  .ms-delta-pill.is-negative {
    background: rgba(220, 38, 38, 0.1);
    color: #b91c1c;
  }

  .ms-delta-sub {
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
    margin-top: 6px;
  }

  .ms-hero-divider {
    border: none;
    height: 1px;
    background: var(--color-border);
    margin: var(--space-2xl) 0;
  }

  /* =========================
   Score breakdown bars (concept)
   ========================= */

  .ms-breakdown {
    padding: 32px 20px 20px 20px;
  }

  .ms-breakdown-item {
    margin-bottom: 34px;
  }

  .ms-breakdown-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .ms-breakdown-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ms-breakdown-ico img {
    width: 20px;
    height: 20px;
    transform: translateY(-1px);
  }

  .ms-breakdown-label {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }

  .ms-breakdown-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .ms-breakdown-value .muted {
    opacity: 0.55;
    font-weight: 500;
  }

  .ms-breakdown-bar {
    height: 8px;
    background: #E2E8F0;
    border-radius: 6px;
    margin-left: 32px; /* 20 icon + 12 gap */
    width: calc(100% - 32px);
  }

  .ms-breakdown-fill {
    height: 8px;
    border-radius: 6px;
    background: var(--color-brand-blue);
  }

  .ms-breakdown-value{
    font-size:14px;
    font-weight:600;
    width:60px;
    text-align:right;
    color:var(--color-text-secondary);
  }
  
  .ms-breakdown-value .muted{
    opacity:0.55;
    font-weight:500;
  }

  .ms-breakdown-item.is-active .ms-breakdown-value {
    color: var(--color-brand-blue);
  }

  .ms-breakdown-item.is-active .ms-breakdown-fill {
    background: var(--color-brand-blue);
  }

  .ms-breakdown-item:not(.is-active) .ms-breakdown-fill {
    opacity: 0.75;
  }
   
  /* add near your inline styles */
  .ms-grid--split { grid-template-columns: minmax(0,1fr) 360px; }
  .ms-grid--single { grid-template-columns: minmax(0,1fr); }

  /* ---------- List mode layout fix (Saved list must NOT live in 360px aside) ---------- */
  .ms-days-grid.ms-list-mode { grid-template-columns: 1fr !important; }
  .ms-days-grid.ms-list-mode > aside { width: 100%; }
  .ms-days-grid.ms-list-mode #main-col { display: none; }

  .ms-days-nav{
    background:#FFFFFF;
    border-top:1px solid #E5E7EB;
    border-bottom:1px solid #E5E7EB;
    padding:16px 24px 0 24px;
  }

  .ms-tabs{
    display:flex;
    justify-content:flex-start;
    align-items:flex-end;
    gap:22px;

    padding:0 0 16px 0;
    margin:0;

    border-bottom:1px solid #E5E7EB;
  }

  #ms-day-tabs .ms-tabs{
    border-bottom:none;
    padding:0 0 0 0;
  }
  
  /* =========================
   Days grid (split vs single)
   ========================= */
  .ms-days-grid{
    display:grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items:start;
  }

  @media (min-width: 1024px){
    .ms-score-main {
      font-size: 56px;
    }
    .ms-days-grid.ms-grid--split{
      grid-template-columns: minmax(0,1fr) 360px;
    }
    .ms-days-grid.ms-grid--single{
      grid-template-columns: minmax(0,1fr);
    }
  }

  /* =========================
   Selected Days (core view)
   ========================= */
  .ms-grey-zone{
    width:100%;
    background:#f8f6f7;
    padding-bottom:10px;
  }

  .ms-days-wrap{
    width:100%;
    max-width:720px;
    margin:0 auto;
    padding:0 24px;
  }

  .ms-days-top{
    background:#FFFFFF;
    padding:40px 0 18px 0; /* keep your rhythm */
  }

  .ms-days-bottom{
    padding:22px 0 0 0;
  }
  
  .ms-top-wrap{ text-align:center; }
  .ms-top-month{ font-size:28px; line-height:1.08; font-weight:500; letter-spacing:-0.01em; margin:10px 0 6px 0; color:#111827; }
  .ms-top-week{ font-size:12px; letter-spacing:0.22em; text-transform:uppercase; color:rgba(17,24,39,0.55); margin:0 0 28px 0; font-weight:500; }

  .ms-chip-date{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:6px 10px;
    border-radius:0;
    font-size:12px;
    border:1px solid #1D3BB3;
    background:#E6EBF8;
    color:#1D3BB3;
  }

  .ms-chip-date.removable {
    position: relative;
    padding-right: 22px;
    cursor: pointer;
  }

  .ms-chip-date.removable::after {
    content: "×";
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 12px;
    opacity: 0.6;
  }

  /* ---------- French calendar styling ---------- */

  .flatpickr-calendar {
    font-family: inherit;
  }

  .flatpickr-weekday {
    color: #111827;
    font-weight: 600;
  }

  .flatpickr-day.today {
    background: var(--color-brand-blue);
    border-color: var(--color-brand-blue);
    color: #fff;
  }

  .flatpickr-day.selected {
    background: var(--color-brand-blue);
    border-color: var(--color-brand-blue);
  }
  .flatpickr-day.selected,
  .flatpickr-day.selected:hover,
  .flatpickr-day.startRange,
  .flatpickr-day.startRange:hover,
  .flatpickr-day.endRange,
  .flatpickr-day.endRange:hover {
    background: #0b37e5 !important;
    border-color: #0b37e5 !important;
    color: #ffffff !important;
  }

  .flatpickr-day.weekend {
    color: var(--color-brand-blue);
    background: rgba(29,59,179,0.08);
  }

  .flatpickr-day.prevMonthDay {
    color: #cbd5e1;
  }

  .flatpickr-day.is-past-day {
    color: #cbd5e1;
  }

  .flatpickr-calendar {
    left: 50% !important;
    transform: translateX(-50%);
  }

  /* =========================
   Top viz + tabs (replaces carousel)
   ========================= */

  .ms-viz-wrap{
    width:100%;
    max-width:760px;
    margin: 6px auto 10px auto;
    padding: 0 6px;
  }

  .ms-viz-card{
    background:var(--color-bg-card);
    border:1px solid var(--color-border);
    border-radius:var(--radius-lg);
    padding:var(--space-lg);
    box-shadow:var(--shadow-md);
  }

  .ms-viz-title{
    font-size:12px;
    letter-spacing:0.10em;
    text-transform:uppercase;
    color:rgba(17,24,39,0.55);
    font-weight:600;
    margin-bottom:12px;
  }

  .ms-viz-rows{
    display:flex;
    flex-direction:column;
    gap:10px;
  }

  .ms-viz-row{
    display:grid;
    grid-template-columns: 84px 1fr 56px;
    align-items:center;
    gap:12px;
  }

  .ms-viz-label{
    font-size:12px;
    color:rgba(17,24,39,0.65);
    letter-spacing:0.12em;
    text-transform:uppercase;
  }

  .ms-viz-bar{
    position:relative;
    height:10px;
    border-radius:var(--radius-full);
    background:rgba(29,59,179,0.08);
    border:1px solid var(--color-border);
    overflow:hidden;
  }  

  .ms-viz-fill{
    position:absolute;
    left:0; top:0; bottom:0;
    width:0%;
    border-radius:var(--radius-full);
    background:var(--color-brand-blue);
    opacity:0.85;
  }
  
  .ms-viz-row.is-active .ms-viz-fill{
    opacity:1.0;
  }

  .ms-viz-score{
    text-align:right;
    font-size:13px;
    color:#111827;
    font-weight:600;
  }

  .ms-viz-score .muted{
    opacity:0.55;
    font-weight:500;
  }

  .ms-tab{
    appearance:none;
    -webkit-appearance:none;
    border:none;
    background:transparent;
    box-shadow:none;

    font-size:14px;
    font-weight:500;
    color:#94A3B8;

    padding:0 0 16px 0;
    position:relative;
    cursor:pointer;
  }
  
  .ms-tab.is-active{
    color:var(--color-brand-blue);
  }

  .ms-tab.is-active::after{
    content:"";
    position:absolute;
    left:0;
    bottom:-17px;
    height:3px;
    width:100%;
    background:#1D3BB3;
    border-radius:3px;
  }

  #ms-day-tabs .ms-tab.is-active::after{
    bottom:-1px;
  }

  .ms-tab:disabled{
    opacity:0.35;
    cursor:not-allowed;
  }

  .ms-tab:focus{ outline:none; }
  .ms-tab:focus-visible{
    outline:2px solid rgba(29,59,179,0.18);
    outline-offset:4px;
    border-radius:8px;
  }
    
  /* REMOVE decorative lines */
  .ms-analyse-line:before,
  .ms-analyse-line:after{
    content:none;
    display:none;
  }
  
  /* --- Context tags --- */
  .ms-context-tags{ margin-top:14px; display:flex; flex-wrap:wrap; gap:12px; justify-content:center; }
  .ms-ctx-tag{
    display:inline-flex; align-items:center; gap:10px;
    padding:10px 14px;
    border-radius:14px;
    border:1px solid #e5e7eb;
    background:#f3f4f6;
    color:rgba(17,24,39,0.55);
    font-size:14px;
    font-weight:500;
    line-height:1;
    white-space:nowrap;
  }
  .ms-ctx-ico{ width:22px; height:22px; display:inline-flex; align-items:center; justify-content:center; flex:0 0 auto; }
  
  /* --- Panels (Points clés / Alertes / Concurrence / Météo) --- */
  
  .ms-panels{
    padding-top:12px;
    padding-bottom:160px;
    display:flex;
    flex-direction:column;
    gap:16px;
  }
  
  .ms-section{ width:100%; margin-top:0; }

  .ms-kicker{
    display:block;
    font-size:13px;
    font-weight:700;
    letter-spacing:0.10em;
    text-transform:uppercase;
    color:#1D3BB3;
    line-height:1.1;
    margin:0 0 20px 0;
  }

  .ms-card{
    background:#FFFFFF;
    border:1px solid #E8EDF5;
    border-radius:14px;
    padding:32px 24px;
    font-size:15px;
    line-height:1.8;
    color:#1a1a2e;
    margin:0 12px;
    box-shadow:0 2px 12px rgba(17,24,39,0.06);
  }

  .ms-card-decision{
    background:rgba(29,59,179,0.06);
    border-left:6px solid #0b37e5;
    border-radius:0;
  }

  .ms-card + .ms-card{
    margin-top:32px;
  }

  .ms-section + .ms-section{
    margin-top:40px;
  }

  .ms-head{
    display:flex;
    align-items:flex-start;
    gap:12px;
  }
  
  /* Points clés: icon aligns to top of multi-line content */
  .ms-section--sparkle .ms-head { align-items: flex-start; }
  .ms-section--sparkle .ms-ico { margin-top: 2px; }

  .ms-ico{
    width:20px;
    height:20px;
    display:flex;
    align-items:center;
    justify-content:center;
    background:transparent;
    margin-right:14px;
    flex-shrink:0;
    margin-top:-8px;
  }
  
  .ms-head-content{ flex:1; min-width:0; }
  /* Deterministic renderer output (new): preserve \n line breaks */
  .ms-takeaway.preline{ white-space: pre-line; }
  .ms-below{ margin-left:0; margin-top:14px; }

  .ms-ul{
    padding-left:0;
    margin:16px 0 0 0;
    list-style:none;
  }

  .ms-ul li{
    padding-left:0;
    margin:0 0 12px 0;
    font-size:15px;
    line-height:1.7;
    color:#374151;
  }

  .ms-ul li::before{
    content:none;
  }

  .ms-ul li strong, .ms-ul li b{
    color:#111827;
    font-weight:600;
  }

  .ms-muted{ color:#6b7280; font-size:14px; }
  .ms-caveat{ margin-top:12px; color:#6b7280; font-size:12.5px; line-height:1.4; font-style:italic; }

  /* -------------------------
   SECTION HEADER ALIGNMENT
   ------------------------- */

  /* Keep header row top-aligned */
  .ms-head{
    align-items: flex-start;
  }

  /* Remove double spacing: gap already exists on .ms-head */
  .ms-ico{
    margin-right: 0;              /* IMPORTANT: you currently add +14px on top of gap */
    flex: 0 0 auto;
    align-self: auto;
    margin-top: 0px;              /* small optical alignment */
  }

  /* Make SVG not participate in baseline quirks */
  .ms-ico svg{
    display: block;
    margin-top: -8px;
  }

  /* Title + subtitle stack cleanly */
  .ms-head-content{
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    min-width: 0;
  }

  /* Make title tighter so subtitle reads as subtitle */
  .ms-kicker{
    margin: 0 0 6px 0;            /* was 0 0 20px 0 */
  }

  /* Subtitle styling: same left edge as title, quick scan */
  .ms-takeaway{
    margin: 0;
    color: #111827;
    font-size: 15px;
    line-height: 1.55;
  }

  /* Details block spacing */
  .ms-below{
    margin-top: 16px;
  }


  /* -------------------------
    LIST READABILITY + CLAMP
    ------------------------- */

  .ms-ul{
    margin-top: 12px;
  }

  .ms-ul li{
    margin: 0 0 14px 0;
    line-height: 1.6;
  }

  /* Make event titles scanable (prevents “dump” feel) */
  .ms-ul li strong,
  .ms-ul li b{
    display: block;
    margin-bottom: 4px;
  }

  /* Clamp long muted descriptions (your event desc uses <div class="ms-muted">...) */
  .ms-ul li .ms-muted{
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;        /* tweak: 2..4 */
    overflow: hidden;
  }

  /* --- Selected dates pills bar --- */
  .ms-pills-row{ display:flex; flex-wrap:wrap; gap:8px; align-items:center; }
  .ms-pill{
    border:1px solid rgba(17,24,39,0.12);
    background:rgba(17,24,39,0.06);
    border-radius:12px;
    padding:8px 10px;
    font:inherit;
    color:#111827;
    cursor:pointer;
  }
  .ms-pill.is-active{ outline:2px solid var(--color-brand-blue); }

  .ms-pill:disabled{ opacity:0.45; cursor:not-allowed; }
  
  /* ---------- Saved panel + pills (already used by your markup) ---------- */
  .ms-pills-row{ display:flex; flex-wrap:wrap; gap:8px; align-items:center; }
  .ms-pill{
    border:1px solid rgba(17,24,39,0.12);
    background:rgba(17,24,39,0.06);
    border-radius:12px;
    padding:8px 10px;
    font:inherit;
    color:#111827;
    cursor:pointer;
  }
  .ms-pill.is-active{ outline:2px solid var(--color-brand-blue); }
  .ms-pill:disabled{ opacity:0.45; cursor:not-allowed; }

  /* ---------- Saved list (template-like rows) ---------- */
  .ms-saved-wrap{ width:100%; max-width:720px; margin:0 auto; padding-top:40px; }

  .ms-saved-hero{
    font-size:28px;
    line-height:1.1;
    font-weight:300;
    letter-spacing:-0.02em;
    margin:10px 0 20px 0;
    color:#111827;
  }

  .ms-saved-list{
    border-top:1px solid #eef2f7;
  }

  .ms-saved-row{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:18px;
    padding:18px 0;
    border-bottom:1px solid #eef2f7;
  }

  .ms-saved-left{ min-width:0; flex:1 1 auto; display:flex; flex-direction:column; gap:6px; }
  .ms-saved-title2{
    font-size:20px;
    font-weight:400;
    color:#111827;
    line-height:1.15;
    white-space:nowrap;
    overflow:hidden;
    text-overflow:ellipsis;
    cursor:pointer;
    transition: color 150ms ease;
  }

  .ms-saved-title2:hover{
    color: var(--color-brand-blue);
  }
  
  .ms-saved-subline{
    display:flex;
    align-items:center;
    gap:10px;
    min-width:0;
    color:#6b7280;
    font-size:14px;
    line-height:1.3;
  }

  .ms-saved-datesline{
    color:#111827;
    font-weight:400;
    white-space:nowrap;
  }

  .ms-saved-sep{ opacity:0.4; }

  .ms-saved-desc{
