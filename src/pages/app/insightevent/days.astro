              </svg>`,
            };
            return icons[kind] || icons.info;
          }
        
        function sectionHex(title, icon, takeawayHtml, bodyHtml, score, hideVoirPlus) {
          const scoreHtml = (score !== null && score !== undefined)
            ? `<div style="display:flex;align-items:baseline;gap:3px;flex-shrink:0;">
