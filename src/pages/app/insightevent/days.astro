                const decisionRaw = rowEl.getAttribute("data-decision-date") || "";
                const eventEndRaw = rowEl.getAttribute("data-event-end-date") || "";
                if (decisionRaw) window.__msFlatpickrDecision.setDate(decisionRaw, true, "Y-m-d");
                if (eventEndRaw) window.__msFlatpickrEnd.setDate(eventEndRaw, true, "Y-m-d");
