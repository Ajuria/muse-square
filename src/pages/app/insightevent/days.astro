                      const medalBg = String(medal || "").toUpperCase().startsWith("A") ? "#E1F5EE" : String(medal || "").toUpperCase().startsWith("B") ? "#FAEEDA" : "#FCEBEB";
                      const medalColor = String(medal || "").toUpperCase().startsWith("A") ? "#0F6E56" : String(medal || "").toUpperCase().startsWith("B") ? "#854F0B" : "#A32D2D";
