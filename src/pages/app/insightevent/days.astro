          var compEntries = Array.from(byComp.entries()).sort(function(a, b) {
            var aOverlaps = a[1].filter(function(s) { return s.industry_overlap || s.audience_overlap || s.distance_flag; }).length;
            var bOverlaps = b[1].filter(function(s) { return s.industry_overlap || s.audience_overlap || s.distance_flag; }).length;
            if (bOverlaps !== aOverlaps) return bOverlaps - aOverlaps;
            var aMax = Math.max.apply(null, a[1].map(function(s) { return Number(s.conflict_score || 0); }));
            var bMax = Math.max.apply(null, b[1].map(function(s) { return Number(s.conflict_score || 0); }));
            return bMax - aMax;
