    <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {

      if (!window.flatpickr) {
        console.error("Flatpickr not loaded");
        return;
      }

      window.flatpickr.l10ns.fr = {
        ...window.flatpickr.l10ns.default,
        firstDayOfWeek: 1,
        weekdays: {
          shorthand: ["dim","lun","mar","mer","jeu","ven","sam"],
          longhand: ["dimanche","lundi","mardi","mercredi","jeudi","vendredi","samedi"]
        },
        months: {
          shorthand: ["janv","févr","mars","avr","mai","juin","juil","août","sept","oct","nov","déc"],
          longhand: ["janvier","février","mars","avril","mai","juin","juillet","août","septembre","octobre","novembre","décembre"]
        }
      };

    });
    </script>
    
    <script is:inline define:vars={{ location_id }}>
      (function () {
        // ---- SERVER TRUTH (injected by Astro via define:vars) ----
        const LOCATION_ID = (typeof location_id === "string" ? location_id : "").trim();

        const params = new URLSearchParams(window.location.search);

        const selectedDatesRaw = params.get("selected_dates") || "";
        let selectedDateRaw = (params.get("selected_date") || "").trim();
        let selectedDate = selectedDateRaw === "__comparison__" ? "__comparison__" : normalizeYmd(selectedDateRaw);

        function normalizeYmd(v) {
          const s = String(v ?? "").trim();
          const m = s.match(/^(\d{4}-\d{2}-\d{2})/);
          return m ? m[1] : "";
        }

        const selectedDates = [...new Set(
          selectedDatesRaw
            .split(",")
            .map(s => normalizeYmd(s))
            .filter(Boolean)
        )].slice(0, 7);
        
        let savedItemId = (params.get("saved_item_id") || "").trim();

        // Canonicalize selected_date if missing but we do have selected_dates
        if (!selectedDate && selectedDates.length > 0) {
          selectedDate = "__comparison__";
          params.set("selected_date", selectedDate);
          window.history.replaceState({}, "", "?" + params.toString());
        }

        function getPillsContainer() {
          return container ? container.querySelector("#ms-day-tabs") : null;
        }

        function getSavedPanel() {
          return document.getElementById("saved-panel");
        }

        function setLayoutMode(mode) {
          const grid = document.getElementById("days-grid");
          const panel = getSavedPanel();
          const aside = panel ? panel.closest("aside") : null;
          const mainCol = document.getElementById("main-col");
          if (!grid || !aside || !mainCol) return;

          if (mode === "list") {
            // LIST MODE: saved list uses full width; main hidden
            aside.style.display = "";
            mainCol.style.display = "none";

            grid.classList.remove("ms-grid--split");
            grid.classList.add("ms-grid--single");
            grid.classList.add("ms-list-mode");
          } else {
            // DETAIL MODE: selected day view; saved panel hidden
            mainCol.style.display = "";
            aside.style.display = "none";

            grid.classList.remove("ms-list-mode");
            grid.classList.remove("ms-grid--split");
            grid.classList.add("ms-grid--single");
          }
        }

        const container = document.getElementById("day-content");

        function ensureSelectedDaysStyles() {
          // Styles are now server-rendered via <style is:inline id="ms-selected-days-style">.
          // Keep this function only because other code calls it.
          return;
        }

        const modalBackdrop = document.getElementById("ms-save-modal");
        const modalClose = document.getElementById("ms-save-close");
        const modalCancel = document.getElementById("ms-save-cancel");
        const modalSubmit = document.getElementById("ms-save-submit");
        const modalTitle = document.getElementById("ms-save-title-input");
        const modalDecisionDate = document.getElementById("ms-save-decision-date");
        const modalEventDate = document.getElementById("ms-save-event-date");
        const modalDesc = document.getElementById("ms-save-desc");
        const modalDates = document.getElementById("ms-save-dates");
        const modalError = document.getElementById("ms-save-error");
        const modalEventType = document.getElementById("ms-save-event-type");
        const modalLaunchHour = document.getElementById("ms-save-launch-hour");

        // ---- Single global namespace (minimum “production-grade” state) ----
        const MS = (window.__MS_DAYS__ ||= {});
        MS.editingId ||= "";
        MS.editingDates ||= [];
        MS.pointsCles ||= null;
        MS.draftDates ||= [];

        // Allow BottomBar to open modal without tight coupling
        window.addEventListener("ms:open-save-modal", () => {
          if (Array.isArray(selectedDates) && selectedDates.length > 0) openSaveModal();
        });

        // EXTRA SAFETY: also bind the BottomBar button directly (no reliance on CustomEvent)
        const saveActionBtn = document.getElementById("cta-save");
        if (saveActionBtn) {
          saveActionBtn.addEventListener("click", () => {
            if (Array.isArray(selectedDates) && selectedDates.length > 0) openSaveModal();
          });
        }

        function openSaveModal() {
          ensureSelectedDaysStyles();
          if (!modalBackdrop) return;

          // If a savedItemId is already in scope, open in edit mode
          if (savedItemId) {
            const allSavedItems = window.__MS_DAYS__?._allSavedItems || [];
            const matchedItem = allSavedItems.find(i => String(i.saved_item_id) === savedItemId);
            if (matchedItem) {
              MS.editingId = savedItemId;
              MS.editingDates = extractDatesFromSavedItem(matchedItem).map(normalizeYmd).filter(Boolean);

              if (modalTitle) modalTitle.value = matchedItem.title || "";
              if (modalDesc) modalDesc.value = matchedItem.description || "";
              if (modalEventType) modalEventType.value = matchedItem.event_type || "";
              if (modalLaunchHour) modalLaunchHour.value = matchedItem.launch_hour ?? "";

              const locationLabelEl = document.getElementById("ms-save-location-label");
              if (locationLabelEl) locationLabelEl.textContent = matchedItem.location_label || "";

              if (window.__msFlatpickrDecision) window.__msFlatpickrDecision.destroy();
              if (window.__msFlatpickrEnd) window.__msFlatpickrEnd.destroy();
              window.__msFlatpickrDecision = flatpickr(modalDecisionDate, { locale: flatpickr.l10ns.fr, firstDayOfWeek: 1, dateFormat: "d/m/Y", disableMobile: true });
              window.__msFlatpickrEnd = flatpickr(modalEventDate, { locale: flatpickr.l10ns.fr, firstDayOfWeek: 1, dateFormat: "d/m/Y", disableMobile: true });
              if (matchedItem.decision_date) window.__msFlatpickrDecision.setDate(matchedItem.decision_date, true, "Y-m-d");
              if (matchedItem.event_end_date) window.__msFlatpickrEnd.setDate(matchedItem.event_end_date, true, "Y-m-d");

              renderModalDateChipsEdit();

              const modalHeading = document.getElementById("ms-save-title");
              if (modalHeading) modalHeading.textContent = "Modifier cette liste";
              if (modalSubmit) modalSubmit.textContent = "Mettre à jour";

              if (modalError) { modalError.style.display = "none"; modalError.textContent = ""; }
              modalBackdrop.hidden = false;
              modalBackdrop.setAttribute("aria-hidden", "false");
              return;
            }
          }

          // Ensure create mode wording + clear edit state ---
          MS.editingId = "";
          MS.editingDates = [];
          
          const modalHeading = document.getElementById("ms-save-title");
          if (modalHeading) modalHeading.textContent = "Enregistrer ces jours";
          if (modalSubmit) modalSubmit.textContent = "Enregistrer";

          // HARD RESET (avoid stale edit values leaking into create)
          if (modalDecisionDate) modalDecisionDate.value = "";
          if (modalDesc) modalDesc.value = "";
          if (modalTitle) modalTitle.value = "";
          if (modalEventDate) modalEventDate.value = "";
          if (modalEventType) modalEventType.value = "";
          if (modalLaunchHour) modalLaunchHour.value = "";

          // default title suggestion (create mode only)
          if (modalTitle && !String(modalTitle.value || "").trim()) {
            modalTitle.value = selectedDates.length ? `Sélection ${selectedDates[0]}…` : "";
          }

          // render date chips (create mode = read-only)
          MS.draftDates = (Array.isArray(selectedDates) ? selectedDates : [])
            .map(normalizeYmd)
            .filter(Boolean)
            .slice(0, 7);

          renderModalDateChipsCreate(MS.draftDates);

          // DATE FIN calendar constraint
          if (modalEventDate && Array.isArray(MS.draftDates) && MS.draftDates.length > 0) {

            const minLaunchDate = MS.draftDates
              .map(d => flatpickr.parseDate(d, "Y-m-d"))
              .filter(Boolean)
              .sort((a,b) => a - b)[0];
            
            if (window.__msFlatpickrEnd) {
              window.__msFlatpickrEnd.destroy();
            }

            window.__msFlatpickrEnd = flatpickr(modalEventDate, {
              locale: flatpickr.l10ns.fr,
              firstDayOfWeek: 1,
              dateFormat: "d/m/Y",
              minDate: minLaunchDate,
              disableMobile: true,
              onDayCreate: function(dObj, dStr, fp, dayElem) {
                const dayDate = dayElem.dateObj;
                if (!(dayDate instanceof Date)) return;
                const min = flatpickr.parseDate(minLaunchDate, "Y-m-d");
                if (!(min instanceof Date)) return;
                dayDate.setHours(0, 0, 0, 0);
                min.setHours(0, 0, 0, 0);
                if (dayDate.getTime() < min.getTime()) {
                  dayElem.classList.add("is-past-day");
                }
              }
            });

            if (window.__msFlatpickrDecision) {
              window.__msFlatpickrDecision.destroy();
            }

            window.__msFlatpickrDecision = flatpickr(modalDecisionDate, {
              locale: flatpickr.l10ns.fr,
              firstDayOfWeek: 1,
              dateFormat: "d/m/Y",
              disableMobile: true
            });
          }

          if (modalError) { modalError.style.display = "none"; modalError.textContent = ""; }
          
          modalBackdrop.hidden = false;
          modalBackdrop.setAttribute("aria-hidden", "false");

          // focus
          setTimeout(() => { try { modalTitle && modalTitle.focus(); } catch(_) {} }, 0);
        }

        function closeSaveModal() {
          if (!modalBackdrop) return;
          modalBackdrop.hidden = true;
          modalBackdrop.setAttribute("aria-hidden", "true");

          // avoid stale removable chips/state
          MS.editingId = "";
          MS.editingDates = [];
        }

        function showSaveError(msg) {
          if (!modalError) return;
          modalError.textContent = msg || "Erreur.";
          modalError.style.display = "block";
        }

        async function saveCurrentSelection() {
          if (MS.isSaving) return;
          MS.isSaving = true;
          
          const editingId = String(MS.editingId || "").trim();
          const isEdit = Boolean(editingId);

          const loc = String(LOCATION_ID || "").trim();
          if (!loc) return showSaveError("location_id manquant.");

          const title = String(modalTitle?.value || "").trim();
          if (!title) return showSaveError("Le titre est requis.");

          if (!isEdit && !selectedDates.length) {
            return showSaveError("Aucune date sélectionnée.");
          }

          const url = isEdit ? "/api/saved-items/update" : "/api/saved-items/create";

          function displayDateToYmd(v) {
            // converts DD/MM/YYYY → YYYY-MM-DD; passes through YYYY-MM-DD unchanged
            const s = String(v || "").trim();
            if (!s) return null;
            const dmy = s.match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
            if (dmy) return `${dmy[3]}-${dmy[2]}-${dmy[1]}`;
            const ymd = s.match(/^\d{4}-\d{2}-\d{2}$/);
            if (ymd) return s;
            return null;
          }

          const eventTypeVal = String(modalEventType?.value || "").trim() || null;
          const launchHourVal = modalLaunchHour?.value !== "" && modalLaunchHour?.value != null
            ? parseInt(modalLaunchHour.value, 10)
            : null;

          const payload = isEdit
            ? {
                saved_item_id: editingId,
                title,
                description: String(modalDesc?.value || "").trim() || null,
                decision_date: displayDateToYmd(modalDecisionDate?.value),
                event_end_date: displayDateToYmd(modalEventDate?.value),
                event_type: eventTypeVal,
                launch_hour: launchHourVal,
                dates: (Array.isArray(MS.editingDates) ? MS.editingDates : []).map(normalizeYmd).filter(Boolean).slice(0, 7),
              }
            : {
                location_id: loc,
                title,
                description: String(modalDesc?.value || "").trim() || null,
                decision_date: displayDateToYmd(modalDecisionDate?.value),
                event_end_date: displayDateToYmd(modalEventDate?.value),
                event_type: eventTypeVal,
                launch_hour: launchHourVal,
                dates: (Array.isArray(MS.draftDates) ? MS.draftDates : []).map(normalizeYmd).filter(Boolean).slice(0, 7),
              };
          
          if (modalSubmit) modalSubmit.disabled = true;

          try {
            const res = await fetch(url, {
              method: "POST",
              headers: { "content-type": "application/json", accept: "application/json" },
              body: JSON.stringify(payload),
              cache: "no-store",
            });

            const ct = (res.headers.get("content-type") || "").toLowerCase();
            const json = ct.includes("application/json") ? await res.json().catch(() => null) : null;

            if (!res.ok || !json?.ok) {
              throw new Error(json?.error || `Erreur API (${res.status})`);
            }

            // reset edit state
            MS.editingId = "";
            MS.editingDates = [];

            closeSaveModal();

            const newId = (!isEdit && json?.saved_item_id) ? String(json.saved_item_id).trim() : "";
            if (newId) {
              MS._pendingMonitorDate = "";
              const next = new URL(window.location.origin + "/app/insightevent/days");
              next.searchParams.set("saved_item_id", newId);
              next.searchParams.set("selected_dates", selectedDates.join(","));
              next.searchParams.set("selected_date", "__comparison__");
              window.location.assign(next.toString());
              return;
            }
            // Fallback: refresh list
            await loadSavedItems();

          } catch (e) {
            showSaveError(e?.message || "Erreur.");
          } finally {
            MS.isSaving = false;
            if (modalSubmit) modalSubmit.disabled = false;
          }
        }

        function fmtDDMMYYYY(ymd) {
          const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(String(ymd || "").trim());
          if (!m) return ymd;
          return `${m[3]}/${m[2]}/${m[1]}`;
        }

        function daysUntil(ymd) {
          if (!ymd) return null;
          const today = new Date();
          today.setHours(0, 0, 0, 0);
          const target = parseYmdToDate(ymd);
          if (!target) return null;
          return Math.round((target - today) / 86400000);
        }

        function countdownLabel(ymd, label) {
          const d = daysUntil(ymd);
          if (d === null) return null;
          if (d < 0)  return `${label} passée il y a ${Math.abs(d)}j`;
          if (d === 0) return `${label} aujourd'hui`;
          return `J-${d}`;
        }

        function stageLabel(s) {
          const v = String(s || "").toLowerCase();
          if (v === "option") return "Option";
          if (v === "exploration") return "Exploration";
          if (v === "prevalidation") return "Pré-validation";
          if (v === "retenue") return "Retenue";
          return null;
        }

        function normalizeYmd(v) {
          const s = String(v ?? "").trim();
          const m = s.match(/^(\d{4}-\d{2}-\d{2})/);
          return m ? m[1] : "";
        }

        function extractDatesFromSavedItem(it) {
          // 1) array
          if (Array.isArray(it?.dates)) {
            return it.dates.map(normalizeYmd).filter(Boolean);
          }

          // 2) JSON string (common: '["2026-01-01","2026-01-02"]')
          const s1 = typeof it?.dates === "string" ? it.dates.trim() : "";
          if (s1.startsWith("[") && s1.endsWith("]")) {
            try {
              const arr = JSON.parse(s1);
              if (Array.isArray(arr)) return arr.map(normalizeYmd).filter(Boolean);
            } catch (_) {}
          }

          // 3) csv string (common: '2026-01-01,2026-01-02')
          if (s1.includes("-")) {
            const csv = s1.split(",").map(normalizeYmd).filter(Boolean);
            if (csv.length) return csv;
          }

          // 4) alternate fields
          const s2 = typeof it?.dates_csv === "string" ? it.dates_csv.trim() : "";
          if (s2) {
            const csv = s2.split(",").map(normalizeYmd).filter(Boolean);
            if (csv.length) return csv;
          }

          const s3 = typeof it?.dates_json === "string" ? it.dates_json.trim() : "";
          if (s3.startsWith("[") && s3.endsWith("]")) {
            try {
              const arr = JSON.parse(s3);
              if (Array.isArray(arr)) return arr.map(normalizeYmd).filter(Boolean);
            } catch (_) {}
          }

          return [];
        }

        function parseYmdToDate(ymd) {
          const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(String(ymd || "").trim());
          if (!m) return null;
          const y = Number(m[1]);
          const mo = Number(m[2]);
          const da = Number(m[3]);
          const dt = new Date(Date.UTC(y, mo - 1, da));
          if (Number.isNaN(dt.getTime())) return null;
          return dt;
        }

        function isoWeekNumber(dateUtc) {
          // dateUtc is a Date built in UTC; compute ISO week in UTC to avoid TZ drift.
          const d = new Date(Date.UTC(dateUtc.getUTCFullYear(), dateUtc.getUTCMonth(), dateUtc.getUTCDate()));
          // Thursday in current week decides the year.
          const day = d.getUTCDay() || 7;
          d.setUTCDate(d.getUTCDate() + 4 - day);
          const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
          const weekNo = Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
          return weekNo;
        }

        function buildMetaForDate(ymd) {
          const d = parseYmdToDate(ymd);
          if (!d) {
            return { monthYear: "", weekLabel: "", dow3: "", dayNum2: "", isWeekend: null };
          }

          const dow3 = ["LUN", "MAR", "MER", "JEU", "VEN", "SAM", "DIM"][((d.getUTCDay() + 6) % 7)];
          const dayNum2 = String(d.getUTCDate()).padStart(2, "0");

          const monthYearRaw = new Intl.DateTimeFormat("fr-FR", { month: "long", year: "numeric" }).format(d);
          const monthYear = monthYearRaw ? monthYearRaw.charAt(0).toUpperCase() + monthYearRaw.slice(1) : "";

          const week = isoWeekNumber(d);
          const weekLabel = `SEMAINE ${week}`;

          const isWeekend = (d.getUTCDay() === 0) || (d.getUTCDay() === 6);

          return { monthYear, weekLabel, dow3, dayNum2, isWeekend };
        }

        function renderSavedPanel(items) {
          const savedPanel = getSavedPanel();
          if (!savedPanel) return;

          const rows = Array.isArray(items) ? items : [];

          // Title block (template-like)
          const head = `
            <div class="ms-saved-wrap">
              <div style="display:flex;justify-content:space-between;align-items:center;">
                <div class="ms-saved-hero">Mes dates</div>
                <button onclick="window.location.href='/app/insightevent/month'" onmouseover="this.style.color='#1D3BB3';this.style.borderColor='#1D3BB3';" onmouseout="this.style.color='#111827';this.style.borderColor='rgba(17,24,39,0.12)';" style="display:inline-flex;align-items:center;gap:6px;padding:8px 14px;background:rgba(17,24,39,0.06);border:0.5px solid rgba(17,24,39,0.12);border-radius:6px;font-size:13px;font-weight:500;color:#111827;cursor:pointer;font-family:inherit;letter-spacing:0.01em;">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 2v3M17 2v3"/><path d="M4 7h16v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7z"/><path d="M4 11h16"/></svg>
                  Calendrier
                </button>
              </div>
            </div>
          `;

          if (rows.length === 0) {
            savedPanel.innerHTML =
              head +
              `<div class="ms-saved-wrap"><div class="ms-saved-empty">Sélectionnez vos dates dans le Calendrier, ou dans Explorer laissez l'IA « Trouver une date pour un événement ».</div></div>`;
            return;
          }

          // Helpers (local to saved list)
          function fmtShortFr(ymd) {
            // ymd is "YYYY-MM-DD"
            const d = parseYmdToDate(ymd);
            if (!d) return ymd;
            const day = String(d.getUTCDate()).padStart(2, "0");
            const month = new Intl.DateTimeFormat("fr-FR", { month: "short" }).format(d);
            const m = month ? (month.charAt(0).toUpperCase() + month.slice(1)) : "";
            return `${m} ${day}`; // ex: "Jan 21"
          }

          function datesSummary(datesArr) {
            const dates = Array.isArray(datesArr) ? datesArr : [];
            const shown = dates.slice(0, 3).map(fmtShortFr);
            const rest = Math.max(0, dates.length - shown.length);
            return {
              text: shown.join(" · ") + (rest > 0 ? ` · +${rest}` : ""),
              first: dates[0] ? fmtShortFr(dates[0]) : "",
            };
          }

          // Group by location
          const locationGroups = [];
          const locationOrder = [];
          const locationMap = new Map();
          rows.forEach(it => {
            const key = it.location_id || "unknown";
            if (!locationMap.has(key)) {
              locationMap.set(key, []);
              locationOrder.push({ key, label: it.location_label || it.location_id, is_primary: it.is_primary });
            }
            locationMap.get(key).push(it);
          });

          const groupsHtml = locationOrder.map(({ key, label, is_primary }) => {
            const groupItems = locationMap.get(key);
            return `
              <div style="background:#fff;border:1px solid #E8EDF5;border-radius:14px;overflow:hidden;box-shadow:0 2px 12px rgba(17,24,39,0.06);margin-bottom:16px;" data-location-label="${escapeHtml(label)}">
                <div style="padding:14px 20px;border-bottom:0.5px solid #E5E7EB;display:flex;align-items:center;gap:8px;">
                  <span style="font-size:11px;font-weight:600;letter-spacing:0.10em;text-transform:uppercase;color:#6B7280;">${escapeHtml(label)}</span>
                  ${is_primary ? `<span style="font-size:10px;padding:2px 8px;border-radius:20px;background:#F3F4F6;color:#6B7280;border:0.5px solid #E5E7EB;">Principal</span>` : ""}
                  <span style="flex:1;"></span>
                  <span style="font-size:11px;font-weight:600;letter-spacing:0.10em;text-transform:uppercase;color:#9CA3AF;min-width:64px;text-align:right;">Date décision</span>
                  <span style="font-size:11px;font-weight:600;letter-spacing:0.10em;text-transform:uppercase;color:#9CA3AF;min-width:64px;text-align:right;">Début</span>
                  <span style="min-width:64px;text-align:right;"></span>
                </div>
                <div>
                  ${groupItems.map((it) => {
                    const id = it?.saved_item_id ? String(it.saved_item_id) : "";
                    const title = it?.title ? String(it.title) : "Sans titre";
                    const desc = it?.description ? String(it.description) : "";

                    function short10Words(s) {
                      const words = String(s || "").trim().split(/\s+/).filter(Boolean);
                      if (words.length <= 10) return words.join(" ");
                      return words.slice(0, 10).join(" ") + "…";
                    }

                    function extractDates(it) {
                      return extractDatesFromSavedItem(it);
                    }

                    const dates = extractDates(it);
                    const datesCsv = dates.join(",");
                    const ds = datesSummary(dates);
                    const hint = desc ? short10Words(desc) : "";
                    const hintSafe = hint ? escapeHtml(hint) : "";

                    function smartLabel(ymd) {
                      if (!ymd) return "—";
                      const raw = normalizeYmd(String(ymd?.value ?? ymd ?? ""));
                      if (!raw) return "—";
                      const d = parseYmdToDate(raw);
                      if (!d) return "—";
                      const diff = Math.round((d - new Date().setHours(0,0,0,0)) / 86400000);
                      if (diff === 0) return "Aujourd'hui";
                      if (diff < 0)  return fmtShortFr(raw);
                      if (diff <= 7) return `J-${diff}`;
                      return fmtShortFr(raw);
                    }
                    function smartColor(ymd) {
                      if (!ymd) return "#6b7280";
                      const raw = normalizeYmd(String(ymd?.value ?? ymd ?? ""));
                      if (!raw) return "#6b7280";
                      const d = parseYmdToDate(raw);
                      if (!d) return "#6b7280";
                      const diff = Math.round((d - new Date().setHours(0,0,0,0)) / 86400000);
                      if (diff === 0) return "#059669";
                      if (diff < 0)  return "#9CA3AF";
                      if (diff <= 7) return "#d97706";
                      return "#6b7280";
                    }
                    const decVal = smartLabel(it?.decision_date);
                    const decColor = smartColor(it?.decision_date);
                    const evtVal = smartLabel(it?.event_end_date);
                    const evtColor = smartColor(it?.event_end_date);

                    return `
                      <div class="ms-saved-tr"
                        style="padding:14px 20px;display:flex;align-items:center;gap:8px;border-bottom:0.5px solid #F3F4F6;cursor:pointer;transition:background 120ms;"
                        onmouseover="this.style.background='#F9FAFB';this.querySelector('.ms-saved-title2').style.color='#1D3BB3';"
                        onmouseout="this.style.background='';this.querySelector('.ms-saved-title2').style.color='#111827';"
                        data-id="${escapeHtml(id)}"
                        data-dates="${escapeHtml(datesCsv)}"
                        data-title="${escapeHtml(title)}"
                        data-decision-date="${escapeHtml(String(it?.decision_date || ""))}"
                        data-event-end-date="${escapeHtml(String(it?.event_end_date || ""))}"
                        data-desc="${escapeHtml(desc)}"
                        data-selected-date="${escapeHtml(String(it?.selected_date || ""))}"
                        data-event-type="${escapeHtml(String(it?.event_type || ""))}"
                        data-launch-hour="${escapeHtml(String(it?.launch_hour ?? ""))}">
                        <div class="ms-saved-left" style="flex:1;min-width:0;">
                          <div class="ms-saved-title2" style="cursor:pointer;font-size:15px;font-weight:400;color:#111827;margin-bottom:3px;" data-action="consult">${escapeHtml(title)}</div>
                          <div class="ms-saved-subline">
                            ${(() => {
                              const selDate = normalizeYmd(String(it?.selected_date?.value ?? it?.selected_date ?? ""));
                              if (selDate) {
