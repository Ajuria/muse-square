          function renderMeteoHexLike(r) {

            const locationType = r?.points_cles?.location_context?.location_type ?? null;
            const isOutdoor = locationType === "outdoor";
            const isMixed = locationType === "mixed";
            const isIndoor = locationType === "indoor";
            const hasInstallationRisk = isOutdoor || isMixed;

            const summary = r?.interpretation?.weather || "";

            const tmin = r?.temperature_2m_min;
            const tmax = r?.temperature_2m_max;
            const tappMin = r?.apparent_temperature_min;
            const tappMax = r?.apparent_temperature_max;
            const rainProb = r?.precipitation_probability_max_pct;
            const rainSum = r?.precipitation_sum_mm;
            const snowfall = r?.snowfall_sum;
            const windSpeed = r?.wind_speed_10m_max;
            const windGusts = r?.wind_gusts_10m_max;
            const weatherLabel = r?.weather_label_fr || "";
            const alertMax = Number(r?.alert_level_max ?? 0);

            const lvlWind = Number(r?.lvl_wind ?? 0);
            const lvlRain = Number(r?.lvl_rain ?? 0);
            const lvlSnow = Number(r?.lvl_snow ?? 0);
            const lvlHeat = Number(r?.lvl_heat ?? 0);
            const lvlCold = Number(r?.lvl_cold ?? 0);

            const impactRain = Number(r?.impact_rain_pct ?? 0);
            const impactSnow = Number(r?.impact_snow_pct ?? 0);
            const impactHeat = Number(r?.impact_heat_pct ?? 0);
            const impactCold = Number(r?.impact_cold_pct ?? 0);
            const impactWind = Number(r?.impact_wind_pct ?? 0);
            const impactTotal = Number(r?.impact_weather_pct ?? 0);

            const headlineParts = [];
            if (weatherLabel) headlineParts.push(weatherLabel);
            if (alertMax > 0) headlineParts.push(`Alerte niveau ${alertMax}`);
            const headlineBase = headlineParts.join(" — ") || "Conditions météo";
            const headline = (() => {
              const hasHazard = lvlRain > 0 || lvlSnow > 0 || lvlHeat > 0 || lvlCold > 0 || lvlWind > 0;
              if (!hasHazard && alertMax === 0) {
                return isIndoor
                  ? `${headlineBase} — Conditions favorables en intérieur`
                  : isMixed
                  ? `${headlineBase} — Conditions favorables`
                  : `${headlineBase} — Conditions favorables en extérieur`;
              }
              if (isIndoor) return `${headlineBase} — Impact limité en intérieur`;
              if (isMixed) return `${headlineBase} — Surveiller les espaces extérieurs`;
              return `${headlineBase} — Conditions défavorables en extérieur`;
            })();

            const freqImpact = (() => {
              const hasAttendanceHazard = lvlRain > 0 || lvlSnow > 0 || lvlHeat > 0 || lvlCold > 0;
              if (!hasAttendanceHazard && alertMax === 0) {
                return { label: "Aucun", pill: "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);" };
              }
              if (alertMax >= 3 || impactTotal < -10) {
                return { label: "Défavorable", pill: "background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);" };
              }
              if (alertMax >= 1 || impactTotal < 0) {
                if (isIndoor) return { label: "Légère friction", pill: "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);" };
                return { label: "Modérément défavorable", pill: "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);" };
              }
              return { label: "Neutre", pill: "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);" };
            })();

            const installRisk = (() => {
              if (!hasInstallationRisk) return { label: "Aucun", pill: "background:var(--color-pill-green-bg);color:var(--color-pill-green-text);" };
              if (lvlWind >= 3 || (windGusts != null && windGusts > 60)) {
                return { label: "Élevé", pill: "background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);" };
              }
              if (lvlWind >= 2 || (windGusts != null && windGusts > 40)) {
                return { label: "Modéré", pill: "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);" };
              }
              if (lvlWind >= 1) {
                return { label: "Faible", pill: "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);" };
              }
              return { label: "Aucun", pill: "background:var(--color-pill-green-bg);color:var(--color-pill-green-text);" };
            })();

            const hazardRows = [];

            if (lvlRain > 0) {
              if (isIndoor) {
                hazardRows.push({ dot: "#D97706", text: `Pluie${rainSum ? ` (${rainSum.toFixed(1)} mm)` : ""} : légère friction à l'entrée, sans impact sur la venue globale` });
              } else {
                hazardRows.push({ dot: "#B91C1C", text: `Pluie${rainSum ? ` (${rainSum.toFixed(1)} mm)` : ""} : risque de baisse de fréquentation en extérieur` });
              }
            }

            if (lvlSnow > 0) {
              hazardRows.push({ dot: "#B91C1C", text: `Neige${snowfall ? ` (${snowfall.toFixed(1)} cm)` : ""} : impact sur l'accès et la fréquentation` });
            }

            if (lvlHeat > 0) {
              if (isIndoor) {
                hazardRows.push({ dot: "#D97706", text: `Chaleur forte : confort en intérieur dépendant de la climatisation` });
              } else {
                hazardRows.push({ dot: "#D97706", text: `Chaleur forte : impact sur le confort et le temps de présence` });
              }
            }

            if (lvlCold > 0) {
              if (isIndoor) {
                hazardRows.push({ dot: "#D97706", text: `Froid intense : légère friction à l'entrée` });
              } else {
                hazardRows.push({ dot: "#B91C1C", text: `Froid intense : impact sur la fréquentation et le temps de présence` });
              }
            }

            if (hasInstallationRisk && lvlWind >= 1) {
              const gustText = windGusts ? ` — rafales à ${Math.round(windGusts)} km/h` : "";
              if (lvlWind >= 2) {
                hazardRows.push({ dot: "#D97706", text: `Vent fort${gustText} : risque pour les structures légères, signalétique et installations extérieures` });
              } else {
                hazardRows.push({ dot: "#6B7280", text: `Vent modéré${gustText} : surveiller les installations légères` });
              }
            }

            const tempDisplay = (() => {
              const appMin = tappMin != null ? Math.round(tappMin) : null;
              const appMax = tappMax != null ? Math.round(tappMax) : null;
              const rawMin = tmin != null ? Math.round(tmin) : null;
              const rawMax = tmax != null ? Math.round(tmax) : null;
              if (appMin !== null && appMax !== null) return `${appMin}° – ${appMax}° ressentis`;
              if (rawMin !== null && rawMax !== null) return `${rawMin}° – ${rawMax}°`;
              return null;
            })();

            const rawLineParts = [];
            if (tempDisplay) rawLineParts.push(tempDisplay);
            if (rainProb != null) rawLineParts.push(`Précipitations ${Math.round(rainProb)}%`);
            if (rainSum != null && rainSum > 0) rawLineParts.push(`Cumul ${rainSum.toFixed(1)} mm`);
            if (windSpeed != null) rawLineParts.push(`Vent ${Math.round(windSpeed)} km/h`);
            const rawLine = rawLineParts.join(" · ");

            const body = `
              <div style="margin-top:6px;">
                <p style="font-size:15px;font-weight:500;color:var(--color-text-primary);margin:0 0 8px;line-height:1.4;">
                  ${escapeHtml(headline)}
                </p>
                ${summary ? `
                  <p style="font-size:13px;color:#374151;line-height:1.65;margin:0 0 4px;">
                    ${escapeHtml(summary)}
                  </p>
                ` : ""}
                <hr style="border:none;border-top:1px solid #E5E7EB;margin:14px 0;">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                  <div style="display:flex;flex-direction:column;gap:2px;">
                    <span style="font-size:11px;color:#9CA3AF;text-transform:uppercase;letter-spacing:.06em;">Impact fréquentation</span>
                    <span style="font-size:13px;color:#111827;">
                      ${escapeHtml(freqImpact.label)}
                      <span style="display:inline-block;font-size:11px;font-weight:500;padding:2px 8px;border-radius:20px;margin-left:6px;${freqImpact.pill}">
                        ${alertMax > 0 ? `Alerte niv. ${alertMax}` : (lvlRain > 0 ? "Pluie" : lvlSnow > 0 ? "Neige" : lvlHeat > 0 ? "Chaleur" : lvlCold > 0 ? "Froid" : "Aucune alerte")}
                      </span>
                    </span>
                  </div>
                  <div style="display:flex;flex-direction:column;gap:2px;">
                    <span style="font-size:11px;color:#9CA3AF;text-transform:uppercase;letter-spacing:.06em;">Risque installations</span>
                    <span style="font-size:13px;color:#111827;">
                      ${escapeHtml(installRisk.label)}
                      <span style="display:inline-block;font-size:11px;font-weight:500;padding:2px 8px;border-radius:20px;margin-left:6px;${installRisk.pill}">
                        ${hasInstallationRisk && windGusts ? `Rafales ${Math.round(windGusts)} km/h` : (isIndoor ? "Indoor" : "Vent faible")}
                      </span>
                    </span>
                  </div>
                </div>
                ${hazardRows.length > 0 ? `
                  <div style="margin-top:14px;display:flex;flex-direction:column;gap:8px;">
                    ${hazardRows.map(h => `
                      <div style="display:flex;align-items:flex-start;gap:8px;font-size:13px;color:#374151;line-height:1.5;">
                        <span style="width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-top:5px;background:${h.dot};display:inline-block;"></span>
                        <span>${escapeHtml(h.text)}</span>
                      </div>
                    `).join("")}
                  </div>
                ` : ""}
                ${rawLine ? `
                  <p style="font-size:12px;color:#9CA3AF;margin-top:12px;line-height:1.6;">
                    ${escapeHtml(rawLine)}
                  </p>
                ` : ""}
              </div>
            `;

            return sectionHex("Conditions d'exploitation", "sun", "", body, r?.weather_score ?? null);
          }
          }


          function weatherIconSrc(code){
            const c = Number(code);
            if (!Number.isFinite(c)) return "";

            // WMO weather interpretation groups (Open-Meteo style)
            if (c === 0) return "/icons/weather/weather_sunny.svg";
            if (c === 1 || c === 2 || c === 3) return "/icons/weather/weather_cloudy.svg";
            if (c === 45 || c === 48) return "/icons/weather/weather_cloudy.svg";

            // drizzle / rain
            if ((c >= 51 && c <= 57) || (c >= 61 && c <= 67))
              return "/icons/weather/weather_rain.svg";

            // snow
            if (c >= 71 && c <= 77)
              return "/icons/weather/weather_snow.svg";

            // rain showers
            if (c >= 80 && c <= 82)
              return "/icons/weather/weather_rain-showers.svg";

            // thunderstorm
            if (c >= 95 && c <= 99)
              return "/icons/weather/weather_rain-showers.svg";

            return "/icons/weather/weather_cloudy.svg";
          }   
        
          MS.renderComparisonSection = function renderComparisonSection(dayRowsByDate){

            const rows = selectedDates.map((d, i) => {

              const r = dayRowsByDate.get(d);

              // ---------------------------
              // CENTRALIZED COMPARISON DATA
              // ---------------------------

              const comparison = {

                score_global: r?.opportunity_score_final_local ?? null,

                audience: (() => {
                  const label = String(r?.audience_availability_label || "").trim();
                  if (!label) {
                    const dt = parseYmdToDate(d);
                    const isWeekend = dt && (dt.getUTCDay() === 0 || dt.getUTCDay() === 6);
                    const hasVacation = Boolean(r?.vacation_name);
                    const hasHoliday = Boolean(r?.holiday_name);
                    return (isWeekend || hasVacation || hasHoliday) ? "Disponible" : "Peu disponible";
                  }
                  const delta = Number(r?.delta_att_calendar_pct ?? null);
                  if (Number.isFinite(delta)) {
                    if (delta >= 1.5) return "Disponible";
                    if (delta >= 0.0) return "Partielle";
                    return "Peu disponible";
                  }
                  return label;
                })(),

                concurrence: (() => {
                  const delta = Number(r?.delta_att_events_pct ?? 0);
                  if (delta > 3)  return "Élevée";
                  if (delta < -3) return "Basse";
                  return "Normale";
                })(),

                accessibilite: (() => {
                  const delta = Number(r?.delta_att_mobility_pct ?? 0);
                  if (delta >= 0) return "Fluide";
                  if (delta >= -4) return "Perturbé";
                  return "Fortement perturbé";
                })(),

                exploitation: (() => {
                  const alert = Number(r?.alert_level_max ?? 0);
                  return alert > 0 ? `Alerte niv. ${alert}` : "Aucune alerte";
                })(),

                weather_code: r?.weather_code ?? null,

              };

              return {
                date: d,
                comparison
              };

            });
 
            if (!rows.length) {
              container.innerHTML = "<div class='ms-days-wrap'>Aucune date sélectionnée.</div>";
              return;
            }

            function headerDate(ymd){
              const d = parseYmdToDate(ymd);
              if (!d) return ymd;

              const dow = ["LUN","MAR","MER","JEU","VEN","SAM","DIM"][((d.getUTCDay() + 6) % 7)];
              const day = String(d.getUTCDate()).padStart(2, "0");

              const month = new Intl.DateTimeFormat("fr-FR", { month: "long" }).format(d);
              const m = month.charAt(0).toUpperCase() + month.slice(1);

              return `
                <div style="display:flex;flex-direction:column;align-items:center;gap:6px;">

                  <div style="font-size:11px;letter-spacing:0.08em;color:#6B7280;">
                    ${dow}
                  </div>

                  <div style="font-size:14px;font-weight:600;">
                    ${day} ${m}
                  </div>

                </div>
              `;
            }

            function scoreCell(v){
              const n = Number(v);
              if (!Number.isFinite(n)) return "—";
              return n.toFixed(1);
            }

            container.innerHTML = `

            <div class="ms-days-wrap">

              ${renderChoiceRecapCard(dayRowsByDate)}

              <div class="ms-comp-cards">

                ${rows.map(r => {

                  const score = Number(r.comparison.score_global);
                  const scoreVal = Number.isFinite(score) ? score.toFixed(1) : "—";

                  const weatherIcon = weatherIconSrc(r.comparison.weather_code);

                  return `
                    <div class="ms-comp-card">

                      <div class="ms-comp-card-date">
                        ${headerDate(r.date)}
                      </div>

                      <div class="ms-comp-card-score">
                        ${scoreVal}
                      </div>

                      ${(() => {
                        const pillHtml = (label, style) =>
                          `<span style="font-size:11px;font-weight:600;padding:2px 8px;border-radius:20px;${style}">${escapeHtml(label)}</span>`;

                        const audienceStyle = r.comparison.audience === "Disponible"
                          ? "background:var(--color-pill-green-bg);color:var(--color-pill-green-text);"
                          : r.comparison.audience === "Partielle"
                          ? "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);"
                          : "background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);";

                        const concurrenceStyle = r.comparison.concurrence === "Élevée"
                          ? "background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);"
                          : "background:var(--color-pill-green-bg);color:var(--color-pill-green-text);";

                        const accessibiliteStyle = r.comparison.accessibilite === "Fluide"
                          ? "background:var(--color-pill-green-bg);color:var(--color-pill-green-text);"
                          : r.comparison.accessibilite === "Fortement perturbé"
                          ? "background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);"
                          : "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);";

                        const exploitationStyle = r.comparison.exploitation === "Aucune alerte"
                          ? "background:var(--color-pill-green-bg);color:var(--color-pill-green-text);"
                          : r.comparison.exploitation.includes("3") || r.comparison.exploitation.includes("4")
                          ? "background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);"
                          : "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);";

                        return `
                          <div class="ms-comp-metric">
                            <span>Audience</span>
                            ${pillHtml(r.comparison.audience, audienceStyle)}
                          </div>
                          <div class="ms-comp-metric">
                            <span>Concurrence</span>
                            ${pillHtml(r.comparison.concurrence, concurrenceStyle)}
                          </div>
                          <div class="ms-comp-metric">
                            <span>Accessibilité</span>
                            ${pillHtml(r.comparison.accessibilite, accessibiliteStyle)}
                          </div>
                          <div class="ms-comp-metric">
                            <span>Exploitation</span>
                            ${pillHtml(r.comparison.exploitation, exploitationStyle)}
                          </div>
                          <div class="ms-comp-metric">
                            <span>Météo</span>
                            <span>
                              ${weatherIcon
                                ? `<img src="${escapeHtml(weatherIcon)}" style="width:22px;height:22px;">`
                                : "—"}
                            </span>
                          </div>
                        `;
                      })()}

                      <button
                        class="ms-choose-day-btn"
                        data-date="${r.date}"
                      >
                        Choisir cette date
                      </button>

                    </div>
                  `;

                }).join("")}

              </div>

            </div>
            `;

          const chosenDate = savedItemId
            ? (MS._chosenDate || (params.get("selected_date") && params.get("selected_date") !== "__comparison__"
              ? normalizeYmd(params.get("selected_date"))
              : null))
            : null;

          container.querySelectorAll(".ms-choose-day-btn, .ms-change-day-btn").forEach(btn => {
            const d = btn.getAttribute("data-date");
            if (!d) return;

            const isChosen = chosenDate && normalizeYmd(d) === chosenDate;

            if (isChosen) {
              btn.textContent = "Changer de date";
              btn.classList.add("ms-change-day-btn");
            }

            // Grey out other cards
            if (chosenDate && !isChosen) {
              const card = btn.closest(".ms-comp-card");
              if (card) card.style.opacity = "0.35";
            }

            btn.addEventListener("click", async () => {
              if (!d) return;

              if (btn.classList.contains("ms-change-day-btn")) {
                // Unselect: clear selected_date, update API
                btn.disabled = true;
                btn.textContent = "…";
                try {
                  await fetch("/api/saved-items/update", {
                    method: "POST",
                    headers: { "content-type": "application/json", accept: "application/json" },
                    body: JSON.stringify({ saved_item_id: savedItemId, selected_date: null }),
                    cache: "no-store",
                                  });
                                  document.cookie = `ms_piloter=; path=/; max-age=0`;
                                } catch(_) {}
                params.set("selected_date", "__comparison__");
                params.delete("date");
                window.location.replace("/app/insightevent/days?" + params.toString());
                return;
              }

              // Choose: normal flow
              if (savedItemId) {
                btn.disabled = true;
                btn.textContent = "…";
                try {
                await fetch("/api/saved-items/update", {
                method: "POST",
                headers: { "content-type": "application/json", accept: "application/json" },
                body: JSON.stringify({ saved_item_id: savedItemId, selected_date: d }),
                cache: "no-store",
                                  });
                                  // cookie removed — nav uses API
                                } catch(_) {}
                params.set("selected_date", d);
                window.history.replaceState({}, "", "?" + params.toString());
                params.set("selected_date", d);
                window.history.replaceState({}, "", "?" + params.toString());
                MS.renderComparisonSection(dayRowsByDate);
                window.location.assign(
                  `/app/insightevent/monitor?saved_item_id=${encodeURIComponent(savedItemId)}&date=${encodeURIComponent(d)}`
                );
                return;
              }

              MS._pendingMonitorDate = d;
              openSaveModal();
            });
          });
          }  
        
        async function fetchCompetitorSignals(date) {
          if (!date || date === "__comparison__") return { signals: [], followed_count: 0 };
          try {
            const res = await fetch(
              `/api/competitive/competitor-signals?selected_date=${encodeURIComponent(date)}`
            );
            const json = await res.json().catch(() => null);
            return {
              signals: (json?.ok && Array.isArray(json.signals)) ? json.signals : [],
              followed_count: json?.followed_count ?? 0,
              top_threats: (json?.ok && Array.isArray(json.top_threats)) ? json.top_threats : [],
            };
          } catch(e) {
            return { signals: [], followed_count: 0 };
          }
        }

        async function fetchDays() {
          if (!container) return null;

          const loc = String(LOCATION_ID || "").trim();
          if (!loc) {
            container.innerHTML = '<div class="text-sm text-red-600">Erreur: location_id manquant.</div>';
            return null;
          }

          if (!Array.isArray(selectedDates) || selectedDates.length === 0) {
            return { days: [], points_cles: null };
          }

          const qs = new URLSearchParams();
          qs.set("location_id", loc);
          qs.set("selected_dates", selectedDates.join(","));

          const apiUrl = "/api/insight/days?" + qs.toString();

          const controller = new AbortController();
          const timeout = setTimeout(() => controller.abort(), 30000);

          try {
            const res = await fetch(apiUrl, {
              method: "GET",
              headers: { Accept: "application/json" },
              signal: controller.signal,
              cache: "no-store",
            });

            if (!res.ok) {
              const text = await res.text().catch(() => "");
              throw new Error("API error " + res.status + (text ? " :: " + text.slice(0, 200) : ""));
            }

            const ct = (res.headers.get("content-type") || "").toLowerCase();
            if (!ct.includes("application/json")) {
              const text = await res.text().catch(() => "");
              throw new Error("API returned non-JSON" + (text ? " :: " + text.slice(0, 200) : ""));
            }

            return await res.json();
          } finally {
            clearTimeout(timeout);
          }
        }

        async function fetchSavedItems() {
          // IMPORTANT: use your existing real endpoint.
          // Your screenshot shows you already have: src/pages/api/saved-items/list (POST).
          const res = await fetch("/api/saved-items/list", {
            method: "POST",
            headers: { "content-type": "application/json", "accept": "application/json" },
            body: JSON.stringify({ limit: 50, offset: 0, stage: null }),
            cache: "no-store",
          });

          const ct = (res.headers.get("content-type") || "").toLowerCase();
          const json = ct.includes("application/json") ? await res.json().catch(() => null) : null;

          if (!res.ok || !json?.ok) return [];
          return Array.isArray(json.items) ? json.items : [];
        }

        async function loadSavedItems() {
          const savedPanel = getSavedPanel();
          if (!savedPanel) return;
          savedPanel.innerHTML = `<div style="display:flex;align-items:center;justify-content:center;padding:24px 0;"><img src="/icons/load/ms_load_icon.gif" alt="Chargement" style="height:140px;width:auto;" /></div>`;
          const items = await fetchSavedItems().catch(() => []);
          renderSavedPanel(items);
        }

        async function fetchSavedItemById(saved_item_id) {
          const res = await fetch("/api/saved-items/get", {
            method: "POST",
            headers: { "content-type": "application/json", accept: "application/json" },
            body: JSON.stringify({ saved_item_id }),
            cache: "no-store",
          });

          const ct = (res.headers.get("content-type") || "").toLowerCase();
          const json = ct.includes("application/json") ? await res.json().catch(() => null) : null;

          if (!res.ok || !json?.ok || !json?.item) {
            const msg = json?.error || `Erreur get (${res.status})`;
            throw new Error(msg);
          }

          return json.item;
        }

        function maybeResolveSavedItemId() {
          // Only run if we have a saved_item_id in the URL
          if (!savedItemId) return false;

          // If you already have selected_dates, no need to resolve/redirect.
          if (Array.isArray(selectedDates) && selectedDates.length > 0) return false;

          // Kick off async resolver; return true to stop the rest of the page from running.
          (async () => {
            try {
              // Render a minimal loading state (no new UI, just reuse existing)
              setLayoutMode("detail");
              if (container) {
                container.style.display = "";
                container.innerHTML = `<div style="display:flex;align-items:center;justify-content:center;padding:24px 0;"><img src="/icons/load/ms_load_icon.gif" alt="Chargement" style="height:140px;width:auto;" /></div>`
              }

              const item = await fetchSavedItemById(savedItemId);

              const dates = extractDatesFromSavedItem(item)
                .map(normalizeYmd)
                .filter(Boolean)
                .slice(0, 7);

              if (!dates.length) {
                throw new Error("Cet enregistrement ne contient aucune date.");
              }

              // Canonical redirect to selection mode (keeps UX stable + uses your existing flow)
              const next = new URLSearchParams(params);
            // Keep saved_item_id — needed for Choisir ce jour → monitor redirect
            next.set("selected_dates", dates.join(","));
            next.set("selected_date", "__comparison__");
            window.location.replace("/app/insightevent/days?" + next.toString());
              
            } catch (e) {
              // If get fails, fall back to list mode + show list (and optionally error)
              console.error(e);

              setLayoutMode("list");
              await loadSavedItems().catch(() => {});

              if (container) {
                container.style.display = "";
                container.innerHTML =
                  `<div class="text-sm text-red-600">Impossible d’ouvrir cet enregistrement.</div>` +
                  `<div class="mt-2 text-xs text-gray-500 break-words">${escapeHtml(e?.message || "Erreur.")}</div>`;
              }
            }
          })();

          return true;
        }

        // --------------------
        // saved_item_id resolver → canonical redirect
        // --------------------
        if (maybeResolveSavedItemId()) return;

        // --------------------
        // LIST MODE (no selection)
        // --------------------
        if (!Array.isArray(selectedDates) || selectedDates.length === 0) {
          setLayoutMode("list");

          // Do NOT render empty state yet. Decide after we know if saved items exist.
          (async () => {
            const savedPanel = getSavedPanel();
            if (savedPanel) savedPanel.innerHTML = `<div style="display:flex;align-items:center;justify-content:center;padding:24px 0;"><img src="/icons/load/ms_load_icon.gif" alt="Chargement" style="height:140px;width:auto;" /></div>`;

            const items = await fetchSavedItems().catch(() => []);
            renderSavedPanel(items);

            // Main column behavior depends on whether items exist
            if (Array.isArray(items) && items.length > 0) {
              const pills = getPillsContainer();
              if (pills) pills.innerHTML = "";

              if (container) {
                container.innerHTML = "";
                container.style.display = "none";
              }
            } else {
              if (container) container.style.display = ""; // restore if previously hidden
              renderEmptyState();
            }
          })();

          return;
        }

        // If we do have selected days: hide saved panel (no overlap with selected-days UX).
        setLayoutMode("detail");

        if (container) container.style.display = "";

        (async function init() {
          try {
            const [data, allSavedItems] = await Promise.all([
              fetchDays(),
              fetchSavedItems().catch(() => []),
            ]);
            window.__MS_DAYS__._allSavedItems = allSavedItems;
            if (!savedItemId && Array.isArray(allSavedItems) && allSavedItems.length > 0) {
              const match = allSavedItems.find(item => {
                const itemDates = extractDatesFromSavedItem(item).map(normalizeYmd).filter(Boolean);
                return selectedDates.every(d => itemDates.includes(d));
              });
              if (match?.saved_item_id) {
                savedItemId = String(match.saved_item_id).trim();
                params.set("saved_item_id", savedItemId);
                window.history.replaceState({}, "", "?" + params.toString());
              }
            }

            const matchedItem = allSavedItems.find(i => String(i.saved_item_id) === savedItemId);
            const storedSelectedDate = matchedItem?.selected_date
              ? normalizeYmd(String(matchedItem.selected_date?.value ?? matchedItem.selected_date ?? ""))
              : null;
            if (storedSelectedDate) {
              MS._chosenDate = storedSelectedDate;
              params.set("selected_date", "__comparison__");
              params.set("date", storedSelectedDate);
              window.history.replaceState({}, "", "?" + params.toString());
            }
      
            const rawMeta = allSavedItems
              .find(i => i.location_id === LOCATION_ID && (i.decision_date || i.event_end_date))
              ?? null;

            const savedItemMeta = rawMeta ? {
                          ...rawMeta,
                          decision_date: rawMeta.decision_date?.value ?? rawMeta.decision_date ?? null,
                          event_end_date: rawMeta.event_end_date?.value ?? rawMeta.event_end_date ?? null,
                        } : null;
            
            if (!data) {
              // fetchDays already rendered the error state.
              return;
            }

            const daysArr = Array.isArray(data.days) ? data.days : [];
            const byDate = new Map();

            for (const r of daysArr) {
              const raw = (r && r.date != null ? String(r.date) : "").trim();
              const d = normalizeYmd(raw);
              if (d) {
                r.opportunity_score = r.opportunity_score_final_local;
                byDate.set(d, r);
              }
            }

            MS.pointsCles = data.points_cles ?? null;
            MS.alerts = Array.isArray(data.alerts) ? data.alerts : [];
            MS.savedItemMeta = savedItemMeta ?? null;
            const _cs = await fetchCompetitorSignals(
              selectedDate !== "__comparison__" ? selectedDate : (selectedDates[0] || "")
            );
            MS.competitorSignals = _cs.signals;
            MS.competitorFollowedCount = _cs.followed_count;
            MS.topThreats = _cs.top_threats;

            if ((!selectedDate || (selectedDate !== "__comparison__" && !byDate.has(selectedDate))) && selectedDates.length > 0) {
              const firstFound = selectedDates.find((d) => byDate.has(d));
              if (firstFound) {
                selectedDate = firstFound;
                params.set("selected_date", selectedDate);
                window.history.replaceState({}, "", "?" + params.toString());
              }
            }

            if (selectedDate === "__comparison__") {
              renderComparisonTable(byDate);
            } else {
              renderDayDetail(byDate);
            }

            renderPills(byDate);
          
          // Capture hero card height so CHOIX card matches
            requestAnimationFrame(() => {
              const heroCard = container.querySelector(".ms-card-decision");
              if (heroCard) {
                document.documentElement.style.setProperty(
                  "--ms-hero-card-height",
                  heroCard.offsetHeight + "px"
                );
              }
            });

          } catch (e) {
            console.error('INIT CRASH:', e?.message, e?.stack);
            if (container) {
              const msg =
                e && typeof e.message === "string" && e.message.trim()
                  ? e.message
                  : "Erreur de chargement.";
              container.innerHTML =
                '<div class="text-sm text-red-600">Erreur de chargement.</div>' +
                '<div class="mt-2 text-xs text-gray-500 break-words">' +
                escapeHtml(msg) +
                "</div>";
            }
            console.error(e);
          }
        })();
      })();
    </script>

  </BaseLayout>
</Show>
