            var active = compSignals.filter(function(s) { return s.is_active && !s.is_launch; });
            var upcoming = compSignals.filter(function(s) { return s.is_upcoming && !s.is_active && !s.is_launch; });

            var locAuds = [first.location_primary_audience_1, first.location_primary_audience_2].filter(Boolean);
            var compAuds = [first.competitor_primary_audience, first.competitor_secondary_audience].filter(Boolean);
            var sharedCompAuds = compAuds.filter(function(a) { return locAuds.includes(a); }).map(function(a) { return AUDIENCE_FR[a] || a; });
            var eventAuds = [];
