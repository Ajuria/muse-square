            var activeHtml = active.length ? section("\u00c9v\u00e9nements en cours", renderEventRows(active, 3, "#1D3BB3")) : "";
            var upcomingHtml = upcoming.length ? section("\u00c0 venir", renderEventRows(upcoming, 3, "#EF9F27")) : "";

            return '<div class="ms-comp-card" style="background:#fff;border:0.5px solid #E8EDF5;border-radius:12px;overflow:hidden;">' +
              '<div style="display:flex;align-items:center;gap:12px;padding:16px 20px;">' +
                photoHtml +
                '<div style="flex:1;min-width:0;">' +
                  '<div style="font-size:15px;font-weight:500;color:#111827;margin:0 0 2px;">' + escapeHtml(name) + '</div>' +
                  '<div style="font-size:12px;color:#6B7280;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">' +
                    ratingHtml +
                    (distKm ? '<span>' + distKm + ' km</span>' : '') +
                  '</div>' +
                '</div>' +
              '</div>' +
              '<div style="padding:0 20px 16px;">' +
                flagsHtml +
                (takeaway ? '<div style="font-size:12px;color:#111827;background:#F9FAFB;border-radius:8px;padding:10px 14px;margin-top:' + (hasAnyOverlap ? '10' : '0') + 'px;line-height:1.45;border-left:3px solid ' + takeawayAccent + ';">' + escapeHtml(takeaway) + '</div>' : '') +
                launchesHtml +
                activeHtml +
                upcomingHtml +
              '</div>' +
            '</div>';
          }).join("");

          return '<div style="padding:0;">' +
            '<div style="display:flex;flex-direction:column;gap:10px;">' + cardsHtml + '</div>' +
            '<div style="padding:12px 0 0;display:flex;justify-content:flex-end;">' +
              '<a href="/app/insightevent/suivis" style="font-size:12px;color:var(--color-brand-blue);text-decoration:none;">G\u00e9rer mes suivis \u2192</a>' +
            '</div>' +
          '</div>';
        }

        // ----------------------------------------------------------------
        // renderScoreDetail — score hero for day detail (from pulse.astro V4)
        // ----------------------------------------------------------------
        function renderScoreDetail(day, days) {
          var score = day.opportunity_score;
          var regime = String(day.opportunity_regime || "B").toUpperCase();
          var regimeMap = { A: { t: "Contexte favorable", bg: "#dcfce7", fg: "#166534" }, C: { t: "Contexte d\u00e9favorable", bg: "#fee2e2", fg: "#991b1b" } };
          var rd = regimeMap[regime] || { t: "Conditions normales", bg: "#f3f4f6", fg: "#374151" };

          // weekRank: position of this day among all days sorted by score DESC
          var sorted = days.filter(function(d) { return d.opportunity_score != null; }).slice().sort(function(a, b) { return (b.opportunity_score || 0) - (a.opportunity_score || 0); });
          var rankIdx = sorted.findIndex(function(d) { return normalizeYmd(d.date) === normalizeYmd(day.date); });
          var rank = rankIdx >= 0 ? rankIdx + 1 : null;
          var total = sorted.length;
          var weekRankLabel = "";
          if (rank === 1) weekRankLabel = "Meilleur jour";
          else if (rank === total) weekRankLabel = "Jour le moins favorable";
          else if (rank != null) weekRankLabel = rank + "e sur " + total + " jours";

          var scoreColor = score >= 7.5 ? "#059669" : score >= 5.5 ? "#d97706" : "#dc2626";

          // Context tags
          var rawTags = Array.isArray(day.daily_signal_summary_fr) ? day.daily_signal_summary_fr : [];
          var TAG_BLOCKLIST = [
            "concurrence", "concurrence pr\u00e9sente", "preuves compl\u00e8tes", "preuves incompl\u00e8tes",
            "evidence_complete", "evidence_incomplete", "competition_present",
            "weather_alert_present", "weather_impact_present",
            "fen\u00eatre stable", "fen\u00eatre mixte", "fen\u00eatre volatile",
            "stable_window", "mixed_window", "volatile_window",
            "weather_risk_present", "competition_spike_present",
          ];
          var tags = rawTags.filter(function(t) {
            if (!t) return false;
            var lower = String(t).toLowerCase();
            return !TAG_BLOCKLIST.some(function(blocked) { return lower === blocked || lower.includes(blocked); });
          });
          var holidayTag = day.holiday_name || null;
          var vacationTag = day.vacation_name || null;

          var tagItems = [];
          if (holidayTag) tagItems.push('<span style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:11.5px;font-weight:600;background:#fef2f2;color:#991b1b;">' + escapeHtml(holidayTag) + '</span>');
          if (vacationTag) tagItems.push('<span style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:11.5px;font-weight:600;background:#faf5ff;color:#6b21a8;">' + escapeHtml(vacationTag) + '</span>');
          for (var i = 0; i < tags.length; i++) {
            if (tags[i]) tagItems.push('<span style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:11.5px;font-weight:600;background:#f3f4f6;color:#374151;">' + escapeHtml(tags[i]) + '</span>');
          }
          var tagsHtml = tagItems.length ? '<div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;">' + tagItems.join("") + '</div>' : "";

          // Weather (only if alert_level_max > 0)
          var weatherHtml = "";
          var alertMax = Number(day.alert_level_max || 0);
          if (alertMax > 0) {
            var wLabel = day.weather_label_fr || "Alerte m\u00e9t\u00e9o";
            var tMin = day.temperature_2m_min != null ? Math.round(Number(day.temperature_2m_min)) : null;
            var tMax = day.temperature_2m_max != null ? Math.round(Number(day.temperature_2m_max)) : null;
            var tempStr = (tMin != null && tMax != null) ? tMin + "\u00b0 \u2013 " + tMax + "\u00b0" : "";
            weatherHtml = '<div style="display:flex;align-items:center;gap:10px;margin-top:10px;padding:10px 12px;background:#fffbeb;border-radius:8px;">' +
              '<span style="font-size:18px;">\u26a0\ufe0f</span>' +
              '<div style="flex:1;">' +
                '<span style="font-size:13px;font-weight:600;color:#1f2937;">' + escapeHtml(wLabel) + '</span>' +
                (tempStr ? '<span style="font-size:12px;color:#6b7280;"> \u00b7 ' + escapeHtml(tempStr) + '</span>' : "") +
              '</div>' +
              '<span style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:10px;font-weight:600;background:#fef3c7;color:#92400e;">Niv. ' + alertMax + '</span>' +
            '</div>';
          }

          return '<div style="padding-top:12px;">' +
            '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">' +
              '<div>' +
                (score != null ? '<div style="display:flex;align-items:baseline;gap:6px;">' +
                  '<span style="font-size:36px;font-weight:800;color:' + scoreColor + ';">' + escapeHtml(String(score)) + '</span>' +
                  '<span style="font-size:14px;color:#9ca3af;">/10</span>' +
                '</div>' : "") +
                (weekRankLabel ? '<div style="font-size:12px;color:#6b7280;margin-top:2px;">' + escapeHtml(weekRankLabel) + '</div>' : "") +
              '</div>' +
              '<div style="text-align:right;">' +
                '<span style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:11.5px;font-weight:600;background:' + rd.bg + ';color:' + rd.fg + ';">' + escapeHtml(rd.t) + '</span>' +
              '</div>' +
            '</div>' +
            tagsHtml +
            weatherHtml +
          '</div>';
        }

        // ----------------------------------------------------------------
        // renderChangeDetail — competition context card (from pulse.astro V4)
        // ----------------------------------------------------------------
        function renderChangeDetail(day, topThreats) {
          var count500 = Number(day.events_within_500m_count || 0);
          var count5km = Number(day.events_within_5km_count || 0);
          var pressureRatio = Number(day.competition_pressure_ratio || 0);
          var hasBaseline = Boolean(day.has_valid_baseline_flag);

          var pressureLabel = "";
          var pressureBg = "#f3f4f6";
          var pressureFg = "#374151";
          if (hasBaseline && pressureRatio > 1.2) {
            pressureLabel = "Sup\u00e9rieur \u00e0 la moyenne";
            pressureBg = "#fee2e2"; pressureFg = "#991b1b";
          } else if (hasBaseline && pressureRatio < 0.8) {
            pressureLabel = "Inf\u00e9rieur \u00e0 la moyenne";
            pressureBg = "#dcfce7"; pressureFg = "#166534";
          } else if (hasBaseline) {
            pressureLabel = "Dans la moyenne";
          }

          var AUDIENCE_FR = {
            local: "r\u00e9sidents locaux", professionals: "professionnels",
            tourists: "touristes", students: "\u00e9tudiants",
            families: "familles", seniors: "seniors",
            general_public: "grand public", art_lovers: "amateurs d\u2019art",
            mixed: "public mixte"
          };

          var INDUSTRY_TIER_FR = {
            direct: "M\u00eame secteur",
            partial: "Secteur proche",
            contextual: "Secteur diff\u00e9rent"
          };

          var THREAT_BADGE = {
            high:     { bg: "#fee2e2", fg: "#991b1b", t: "Menace \u00e9lev\u00e9e" },
            moderate: { bg: "#fef3c7", fg: "#92400e", t: "Menace mod\u00e9r\u00e9e" },
            low:      { bg: "#f3f4f6", fg: "#6b7280", t: "Menace faible" },
          };

          function renderThreatCard(tc) {
            var name = tc.competitor_name || "Concurrent";
            var distKm = tc.distance_km != null ? Number(tc.distance_km).toFixed(1) : null;
            var badge = THREAT_BADGE[tc.threat_level] || THREAT_BADGE.low;
            var indLabel = INDUSTRY_TIER_FR[tc.industry_match_tier] || "";

            var locAuds = [tc.location_primary_audience_1, tc.location_primary_audience_2].filter(Boolean);
            var compAuds = [tc.competitor_primary_audience, tc.competitor_secondary_audience].filter(Boolean);
            var sharedAuds = compAuds.filter(function(a) { return locAuds.indexOf(a) >= 0; }).map(function(a) { return AUDIENCE_FR[a] || a; });

            var audLine = "";
            if (sharedAuds.length > 0) {
              audLine = "Cible les m\u00eames audiences : " + sharedAuds.join(", ");
            } else if (compAuds.length > 0) {
              audLine = "Cible : " + compAuds.map(function(a) { return AUDIENCE_FR[a] || a; }).join(", ");
            }

            var initials = name.split(" ").map(function(w) { return (w[0] || ""); }).join("").slice(0, 2).toUpperCase();

            var detailParts = [];
            if (tc.competitor_industry_code) detailParts.push("Secteur : " + escapeHtml(tc.competitor_industry_code));
            if (tc.competitor_google_rating) detailParts.push("\u2605 " + tc.competitor_google_rating + (tc.competitor_google_rating_count ? " \u00b7 " + Number(tc.competitor_google_rating_count).toLocaleString("fr-FR") + " avis" : ""));

            return '<div class="ms-threat-card" style="background:#fff;border:0.5px solid #E8EDF5;border-radius:10px;overflow:hidden;margin-bottom:6px;">'
              + '<div style="display:flex;align-items:center;gap:10px;padding:12px 14px;">'
                + '<div style="width:36px;height:36px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-weight:500;font-size:13px;color:#0C447C;background:#E6F1FB;flex-shrink:0;">' + escapeHtml(initials) + '</div>'
                + '<div style="flex:1;min-width:0;">'
                  + '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">'
                    + '<span style="font-size:13px;font-weight:500;color:#111827;">' + escapeHtml(name) + '</span>'
                    + (distKm ? '<span style="font-size:11px;color:#6b7280;">' + escapeHtml(distKm + ' km') + '</span>' : '')
                  + '</div>'
                  + '<div style="display:flex;align-items:center;gap:6px;margin-top:3px;flex-wrap:wrap;">'
                    + '<span style="display:inline-block;padding:1px 8px;border-radius:4px;font-size:10px;font-weight:600;background:' + badge.bg + ';color:' + badge.fg + ';">' + escapeHtml(badge.t) + '</span>'
                    + (indLabel ? '<span style="font-size:11px;color:#6b7280;">' + escapeHtml(indLabel) + '</span>' : '')
                  + '</div>'
                  + (audLine ? '<div style="font-size:11px;color:#374151;margin-top:3px;">' + escapeHtml(audLine) + '</div>' : '')
                + '</div>'
                + '<div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;">'
                  + '<button type="button" data-follow-threat="' + escapeHtml(tc.competitor_id) + '" data-follow-name="' + escapeHtml(name) + '" style="padding:4px 10px;border-radius:6px;border:1px solid #dbeafe;background:#eff6ff;font-size:11px;font-weight:600;color:#1e40af;cursor:pointer;white-space:nowrap;font-family:inherit;">Suivre \u2192</button>'
                + '</div>'
              + '</div>'
            + '</div>';
          }

          var threatsHtml = '';

          var deltaEvents = Number(day.delta_att_events_pct || 0);
          var trendLabel = "";
          var trendColor = "#6b7280";
          if (deltaEvents > 3) { trendLabel = "+" + Math.round(deltaEvents) + "% vs moyenne"; trendColor = "#dc2626"; }
          else if (deltaEvents < -3) { trendLabel = Math.round(deltaEvents) + "% vs moyenne"; trendColor = "#059669"; }
          else { trendLabel = "Dans la moyenne"; }

          return '<div style="padding-top:12px;">'
            + (pressureLabel
              ? '<div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;">'
                  + '<span style="font-size:12px;color:#6b7280;">Pression concurrentielle :</span>'
                  + '<span style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:11px;font-weight:600;background:' + pressureBg + ';color:' + pressureFg + ';">' + escapeHtml(pressureLabel) + '</span>'
                + '</div>'
              : '')
            + '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;">'
              + '<div style="background:#f8fafc;border-radius:8px;padding:10px 12px;">'
                + '<div style="font-size:10px;color:#6b7280;margin-bottom:3px;">< 500 m</div>'
                + '<div style="font-size:22px;font-weight:700;color:#1f2937;">' + count500 + '</div>'
              + '</div>'
              + '<div style="background:#f8fafc;border-radius:8px;padding:10px 12px;">'
                + '<div style="font-size:10px;color:#6b7280;margin-bottom:3px;">< 5 km</div>'
                + '<div style="font-size:22px;font-weight:700;color:#1f2937;">' + count5km + '</div>'
              + '</div>'
            + '</div>'
            + '<div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;">'
              + '<span style="font-size:12px;color:#6b7280;">Tendance :</span>'
              + '<span style="font-size:12px;font-weight:600;color:' + trendColor + ';">' + escapeHtml(trendLabel) + '</span>'
            + '</div>'
            + '<div style="display:flex;gap:8px;margin-bottom:4px;">'
              + '<button type="button" data-daydetail-carte style="flex:1;display:flex;align-items:center;justify-content:center;gap:5px;padding:8px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;font-size:12px;font-weight:600;color:#1e40af;cursor:pointer;font-family:inherit;">Carte</button>'
              + '<button type="button" data-daydetail-concurrents style="flex:1;display:flex;align-items:center;justify-content:center;gap:5px;padding:8px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;font-size:12px;font-weight:600;color:#1e40af;cursor:pointer;font-family:inherit;">Concurrents potentiels</button>'
            + '</div>'
            + threatsHtml
          + '</div>';
        }

        // ================================================================
        // V4 — renderDayDetail (day detail tab, ANALYSIS mode)
        // Everything expanded, no radar strips, no collapsing.
        // ================================================================
        // ----------------------------------------------------------------
        // renderCriteriaBlock — "Pourquoi ces dates" collapsible card with pill badges
        // ----------------------------------------------------------------
        function renderCriteriaBlock(dayRowsByDate) {
          var rows = selectedDates.map(function(d) { return dayRowsByDate.get(d); }).filter(Boolean);
          var hasWeekend = false;
          var hasWeekday = false;
          var hasVacation = false;
          var hasHoliday = false;
          var hasTourismPeak = false;

          rows.forEach(function(r) {
            var meta = buildMetaForDate(r.date);
            if (meta?.isWeekend) hasWeekend = true;
            else hasWeekday = true;
            if (r.vacation_name) hasVacation = true;
            if (r.holiday_name) hasHoliday = true;
            if (r.tourism_peak_flag_region === true) hasTourismPeak = true;
          });

          var pills = [];
          if (hasWeekend && hasWeekday) pills.push("Semaine + week-end");
          else if (hasWeekend) pills.push("Week-end");
          else if (hasWeekday) pills.push("Semaine");

          if (hasVacation && hasHoliday) pills.push("Vacances scolaires + jours f\u00e9ri\u00e9s");
          else if (hasVacation) pills.push("Vacances scolaires");
          else if (hasHoliday) pills.push("Jour f\u00e9ri\u00e9");
          else pills.push("Hors vacances scolaires");

          if (hasTourismPeak) pills.push("P\u00e9riode touristique");
          else pills.push("Hors p\u00e9riode touristique");

          var collapsedSummary = pills.join(" \u00b7 ");
          var pillsHtml = pills.map(function(p) {
            return '<span style="display:inline-block;padding:4px 12px;border-radius:6px;font-size:12px;font-weight:500;background:#eff6ff;color:#1e40af;">' + escapeHtml(p) + '</span>';
          }).join("");

          var blockId = "ms-criteria-block";
          var bodyId = "ms-criteria-body";
          var summaryId = "ms-criteria-summary";
          var chevronId = "ms-criteria-chevron";

          return '<div style="background:#fff;border-radius:12px;border:1px solid #e5e7eb;border-left:4px solid #2563eb;margin-bottom:16px;overflow:hidden;">' +
            '<div id="' + blockId + '" style="padding:16px 20px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;">' +
              '<div>' +
                '<div style="font-size:11px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#1e40af;margin-bottom:4px;">Pourquoi ces dates ?</div>' +
                '<div id="' + summaryId + '" style="font-size:12px;color:#6b7280;display:none;">' + escapeHtml(collapsedSummary) + '</div>' +
              '</div>' +
              '<span id="' + chevronId + '" style="color:#9ca3af;font-size:14px;transition:transform 0.2s;transform:rotate(180deg);">\u25be</span>' +
            '</div>' +
            '<div id="' + bodyId + '" style="padding:0 20px 16px;">' +
              '<div style="font-size:13px;color:#374151;margin-bottom:8px;">Vous avez choisi vos dates selon les crit\u00e8res suivants :</div>' +
              '<div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;">' + pillsHtml + '</div>' +
              '<div style="font-size:12px;color:#6b7280;line-height:1.5;">Une fois la date choisie, vous recevrez \u00e0 partir de J-10 un suivi m\u00e9t\u00e9o et mobilit\u00e9 quotidien avec des pr\u00e9visions de plus en plus pr\u00e9cises.</div>' +
            '</div>' +
          '</div>';
        }

        function wireCriteriaToggle() {
          var block = document.getElementById("ms-criteria-block");
          if (!block || block._wired) return;
          block._wired = true;
          var body = document.getElementById("ms-criteria-body");
          var summary = document.getElementById("ms-criteria-summary");
          var chevron = document.getElementById("ms-criteria-chevron");
          var open = true;
          block.addEventListener("click", function() {
            open = !open;
            if (body) body.style.display = open ? "block" : "none";
            if (summary) summary.style.display = open ? "none" : "block";
            if (chevron) chevron.style.transform = open ? "rotate(180deg)" : "rotate(0deg)";
          });
        }

        // ================================================================
        // V4 — renderComparisonTable (CHOIX tab)
        // Winner badge + comparison grid with section rows
        // ================================================================
        function renderComparisonTable(dayRowsByDate) {
          if (!container) return;

          // --- Gather data per date ---
          var dateRows = selectedDates.map(function(d) {
            var r = dayRowsByDate.get(d);
            if (!r) return null;
            var meta = buildMetaForDate(d);
            var score = r.opportunity_score;
            var regime = String(r.opportunity_regime || "B").toUpperCase();
            var delta = Number(r.delta_att_events_pct || 0);
            var count500 = Number(r.events_within_500m_count || 0);
            var count5km = Number(r.events_within_5km_count || 0);
            var alertMax = Number(r.alert_level_max || 0);
            var deltaMob = Number(r.delta_att_mobility_pct || 0);

            var trend = delta > 3 ? "up" : delta < -3 ? "down" : "stable";
            var pression = delta > 3 ? "\u00c9lev\u00e9e" : delta < -3 ? "Faible" : "Normale";

            var isWE = meta.isWeekend === true;
            var hasVac = Boolean(r.vacation_name);
            var hasHol = Boolean(r.holiday_name);
            var residents = (isWE || hasVac || hasHol) ? "Disponible" : "Peu disponible";
            var pros = (!isWE) ? "Disponible" : "Peu disponible";
            var access = deltaMob >= 0 ? "Fluide" : deltaMob >= -4 ? "Perturb\u00e9" : "Fortement perturb\u00e9";
            var weatherLabel = r.weather_label_fr || "\u2014";

            return {
              date: d, meta: meta, score: score, regime: regime, trend: trend,
              count500: count500, count5km: count5km, pression: pression,
              residents: residents, pros: pros, access: access,
              weatherLabel: weatherLabel, weatherCode: r.weather_code,
              alertMax: alertMax, raw: r
            };
          }).filter(Boolean);

          if (!dateRows.length) {
            container.innerHTML = '<div class="ms-days-wrap"><div style="padding:24px;color:#9CA3AF;">Aucune donn\u00e9e disponible.</div></div>';
            return;
          }

          // --- Winner logic ---
          var winner = dateRows.slice().sort(function(a, b) {
            var scoreDiff = (b.score || 0) - (a.score || 0);
            if (scoreDiff !== 0) return scoreDiff;
            return (a.count5km || 0) - (b.count5km || 0);
          })[0];

          var winnerDate = parseYmdToDate(winner.date);
          var winnerLabel = winnerDate
            ? new Intl.DateTimeFormat("fr-FR", { weekday: "long", day: "numeric", month: "long" }).format(winnerDate)
            : winner.date;
          winnerLabel = winnerLabel.charAt(0).toUpperCase() + winnerLabel.slice(1);

          var winnerReason = "";
          if (dateRows.length === 1) {
            winnerReason = "Seule date s\u00e9lectionn\u00e9e";
          } else {
            var allSameScore = dateRows.every(function(r) { return r.score === winner.score; });
            if (allSameScore) {
              winnerReason = "score identique \u2014 moins de concurrence \u00e0 5 km";
            } else {
              winnerReason = "score le plus \u00e9lev\u00e9";
            }
          }

          // --- Helpers ---
          var anyWeatherAlert = dateRows.some(function(r) { return r.alertMax > 0; });

          function statusPill(label) {
            var positives = ["Disponible", "Fluide", "Faible", "Normale"];
            var negatives = ["\u00c9lev\u00e9e", "Fortement perturb\u00e9", "Peu disponible"];
            var neutrals = ["Perturb\u00e9", "Semaine"];
            if (positives.indexOf(label) >= 0) return pill(label, GREEN);
            if (negatives.indexOf(label) >= 0) return pill(label, RED);
            if (neutrals.indexOf(label) >= 0) return pill(label, YELLOW);
            return pill(label, "background:#f3f4f6;color:#374151;");
          }

          function regimeBadge(regime) {
            if (regime === "A") return pill("Favorable", "background:#dcfce7;color:#166534;");
            if (regime === "C") return pill("D\u00e9favorable", "background:#fee2e2;color:#991b1b;");
            return pill("Normale", "background:#f3f4f6;color:#374151;");
          }

          function trendHtml(trend) {
            if (trend === "up") return '<span style="color:#dc2626;font-weight:600;">\u2197</span>';
            if (trend === "down") return '<span style="color:#059669;font-weight:600;">\u2198</span>';
            return '<span style="color:#6b7280;font-weight:600;">\u2192</span>';
          }

          function scoreColor(s) {
            if (s == null) return "#6b7280";
            if (s >= 7.5) return "#059669";
            if (s >= 5.5) return "#d97706";
            return "#dc2626";
          }

          // --- Best value detection ---
          var maxScore = Math.max.apply(null, dateRows.map(function(r) { return r.score || 0; }));
          var minCount500 = Math.min.apply(null, dateRows.map(function(r) { return r.count500; }));
          var minCount5km = Math.min.apply(null, dateRows.map(function(r) { return r.count5km; }));

          // --- Build comparison rows ---
          var sections = [
            { label: "OPPORTUNIT\u00c9", accent: true, rows: [
              { label: "Score", cells: dateRows.map(function(r) {
                return { html: '<span style="font-size:18px;font-weight:800;color:' + scoreColor(r.score) + ';">' + (r.score != null ? String(r.score) : "\u2014") + '</span>', best: r.score === maxScore };
              })},
              { label: "R\u00e9gime", cells: dateRows.map(function(r) {
                return { html: regimeBadge(r.regime), best: r.regime === "A" };
              })},
              { label: "Tendance", cells: dateRows.map(function(r) {
                return { html: trendHtml(r.trend), best: false };
              })},
            ]},
            { label: "CONCURRENCE", accent: false, rows: [
              { label: "< 500 m", cells: dateRows.map(function(r) {
                return { html: '<span style="font-size:14px;font-weight:600;">' + r.count500 + '</span>', best: r.count500 === minCount500 };
              })},
              { label: "< 5 km", cells: dateRows.map(function(r) {
                return { html: '<span style="font-size:14px;font-weight:600;">' + r.count5km + '</span>', best: r.count5km === minCount5km };
              })},
              { label: "Pression", cells: dateRows.map(function(r) {
                return { html: statusPill(r.pression), best: false };
              })},
            ]},
            { label: "CONTEXTE", accent: false, rows: [
              { label: "Jour", cells: dateRows.map(function(r) {
                return { html: pill(r.meta.isWeekend ? "Week-end" : "Semaine", "background:#eff6ff;color:#1e40af;"), best: false };
              })},
              { label: "R\u00e9sidents", cells: dateRows.map(function(r) {
                return { html: statusPill(r.residents), best: r.residents === "Disponible" };
              })},
              { label: "Professionnels", cells: dateRows.map(function(r) {
                return { html: statusPill(r.pros), best: r.pros === "Disponible" };
              })},
            ]},
            { label: "CONDITIONS", accent: false, rows: [
              { label: "M\u00e9t\u00e9o", cells: dateRows.map(function(r) {
                var icon = weatherIconSrc(r.weatherCode);
                var iconHtml = icon ? '<img src="' + escapeHtml(icon) + '" style="width:20px;height:20px;vertical-align:middle;margin-right:4px;">' : '';
                return { html: '<span style="font-size:13px;">' + iconHtml + escapeHtml(r.weatherLabel) + '</span>', best: r.alertMax === 0 };
              })},
            ]}
          ];

          if (anyWeatherAlert) {
            sections[sections.length - 1].rows.push({
              label: "Impact", cells: dateRows.map(function(r) {
                if (r.alertMax === 0) return { html: statusPill("Aucune alerte"), best: true };
                return { html: pill("Alerte niv. " + r.alertMax, r.alertMax >= 2 ? RED : YELLOW), best: false };
              })
            });
          }

          sections[sections.length - 1].rows.push({
            label: "Acc\u00e8s", cells: dateRows.map(function(r) {
              return { html: statusPill(r.access), best: r.access === "Fluide" };
            })
          });

          // --- Column width ---
          var colCount = dateRows.length + 1;
          var colW = (100 / colCount).toFixed(2) + "%";

          // --- Column headers with ★ MEILLEUR on winner ---
          var headerCells = dateRows.map(function(r) {
            var isWinner = r.date === winner.date && dateRows.length > 1;
            var d = parseYmdToDate(r.date);
            var monthLabel = d ? new Intl.DateTimeFormat("fr-FR", { month: "long" }).format(d) : "";
            monthLabel = monthLabel.charAt(0).toUpperCase() + monthLabel.slice(1);
            return '<div style="width:' + colW + ';padding:12px 10px;text-align:center;border-left:1px solid #f3f4f6;">' +
              (isWinner ? '<div style="font-size:9px;font-weight:700;color:#059669;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:2px;">\u2605 MEILLEUR</div>' : '') +
              '<div style="font-size:10px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.06em;">' + escapeHtml(r.meta.dow3 || "") + '</div>' +
              '<div style="font-size:15px;font-weight:700;color:#111827;">' + escapeHtml(r.meta.dayNum2 || "") + ' ' + escapeHtml(monthLabel) + '</div>' +
            '</div>';
          }).join("");

          // --- Build table HTML ---
          var sectionsHtml = sections.map(function(section, si) {
            var sectionHeaderCols = dateRows.map(function() {
              return '<div style="width:' + colW + ';border-left:1px solid #f3f4f6;"></div>';
            }).join("");

            var rowsHtml = section.rows.map(function(row) {
              var cellsHtml = row.cells.map(function(cell) {
                var bg = cell.best ? "#f0fdf4" : "transparent";
                return '<div style="width:' + colW + ';padding:6px 10px;text-align:center;border-left:1px solid #f3f4f6;background:' + bg + ';">' + cell.html + '</div>';
              }).join("");
              return '<div style="display:flex;align-items:center;min-height:40px;">' +
                '<div style="width:' + colW + ';padding:6px 14px;font-size:12px;color:#6b7280;">' + escapeHtml(row.label) + '</div>' +
                cellsHtml +
              '</div>';
            }).join("");

            return '<div>' +
              '<div style="display:flex;' + (si > 0 ? 'border-top:1px solid #e5e7eb;' : '') + '">' +
                '<div style="width:' + colW + ';padding:8px 14px 4px;font-size:10px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:' + (section.accent ? '#1e40af' : '#6b7280') + ';">' + escapeHtml(section.label) + '</div>' +
                sectionHeaderCols +
              '</div>' +
              rowsHtml +
            '</div>';
          }).join("");

          var tableHtml = '<div style="background:#fff;border-radius:12px;border:1px solid #e5e7eb;overflow:hidden;">' +
            '<div style="display:flex;border-bottom:2px solid #e5e7eb;">' +
              '<div style="width:' + colW + ';padding:12px 14px;"></div>' +
              headerCells +
            '</div>' +
            sectionsHtml +
          '</div>';

          // --- Recommendation BELOW table ---
          var recommendationHtml = dateRows.length > 1
            ? '<div style="margin-top:16px;padding:14px 16px;background:#f0fdf4;border-radius:10px;border:1px solid #bbf7d0;">' +
                '<div style="font-size:11px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#166534;margin-bottom:6px;">Recommandation</div>' +
                '<div style="font-size:13.5px;color:#1f2937;line-height:1.5;">' +
                  '<strong>' + escapeHtml(winnerLabel) + '</strong> \u2014 ' + escapeHtml(winnerReason) + '.' +
                '</div>' +
              '</div>'
            : '';

          // --- Page header ---
          var dateCount = selectedDates.length;
          var pageHeaderHtml = '<div style="background:#fff;border-bottom:1px solid #e5e7eb;padding:14px 24px;margin:-20px -20px 16px -20px;">' +
            '<div style="max-width:720px;margin:0 auto;padding:0 24px;display:flex;justify-content:space-between;align-items:center;">' +
              '<div>' +
                '<div style="font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#6b7280;">Planifier</div>' +
                '<div style="font-size:18px;font-weight:700;color:#111827;">Dates s\u00e9lectionn\u00e9es</div>' +
              '</div>' +
              '<div style="font-size:12px;color:#6b7280;">' + dateCount + ' dates</div>' +
            '</div>' +
          '</div>';

          // --- Criteria block ---
          var criteriaHtml = renderCriteriaBlock(dayRowsByDate);

          // --- Assemble: header → criteria → tabs → table → recommendation → buttons ---
          container.innerHTML = pageHeaderHtml +
            '<div class="ms-days-wrap" style="padding-top:0;">' +
              criteriaHtml +
              '<div id="ms-day-tabs" style="margin-bottom:16px;"></div>' +
              tableHtml +
              recommendationHtml +
            '</div>';

          // Wire criteria toggle
          wireCriteriaToggle();

          // --- Wire "Choisir cette date" via column header click ---
          // Clicking a column header navigates to that date tab
          // (handled by renderPills tab buttons, not inline buttons)

          // --- Also keep explicit buttons for mobile ---
          // No explicit buttons in prototype — navigation via tabs only
        }

        // ================================================================
        // V4 — renderDayDetail (day detail tab, ANALYSIS mode)
        // Everything expanded, no radar strips, no collapsing.
        // Wrapped in mon-card / mon-head / mon-kicker structure.
        // NO feed section — feed is PILOTER only.
        // ================================================================
        function renderDayDetail(dayRowsByDate) {
        if (!container) return;

        var row = dayRowsByDate.get(selectedDate);
        if (!row) {
            container.innerHTML = '<div class="ms-days-wrap"><div style="padding:24px;color:#9CA3AF;">Aucune donn\u00e9e pour ' + escapeHtml(selectedDate) + '.</div></div>';
            return;
        }

        // Build the "days" array for weekRank (selected dates only)
        var daysForRank = selectedDates.map(function(d) {
            return dayRowsByDate.get(d);
        }).filter(Boolean);

        // Date heading
        var dateObj = parseYmdToDate(selectedDate);
        var dateLabel = dateObj
            ? new Intl.DateTimeFormat("fr-FR", { weekday: "long", day: "numeric", month: "long", year: "numeric" }).format(dateObj)
            : selectedDate;
        dateLabel = dateLabel.charAt(0).toUpperCase() + dateLabel.slice(1);

        // Status pill
        var statutPill = computeStatusPill(row);

        // Section A: Score hero
        var scoreHtml = renderScoreDetail(row, daysForRank);

        // Section B: Competition card
        var competitionHtml = renderChangeDetail(row, MS.topThreats || []);

        // Section C: Competitor cards (compact for PLANIFIER)
        var competitorSignals = MS.competitorSignals || [];
        var followedCount = MS.competitorFollowedCount || 0;
        var suivisCompactHtml = renderSuivisCompactSection(competitorSignals, selectedDate, followedCount);

        // Map CTA URL
        var mapUrl = "/app/insightevent/map?date=" + encodeURIComponent(selectedDate) +
            "&selected_dates=" + encodeURIComponent(selectedDates.join(",")) + "&embed=1";

        // Page header
        var dateCount = selectedDates.length;
        var pageHeaderHtml = '<div style="background:#fff;border-bottom:1px solid #e5e7eb;padding:14px 24px;margin:-20px -20px 16px -20px;">'
            + '<div style="max-width:720px;margin:0 auto;padding:0 24px;display:flex;justify-content:space-between;align-items:center;">'
            + '<div>'
                + '<div style="font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#6b7280;">Planifier</div>'
                + '<div style="font-size:18px;font-weight:700;color:#111827;">Dates s\u00e9lectionn\u00e9es</div>'
            + '</div>'
            + '<div style="font-size:12px;color:#6b7280;">Muse Square \u00b7 ' + dateCount + ' dates</div>'
            + '</div>'
        + '</div>';

        // Criteria block
        var criteriaHtml = renderCriteriaBlock(dayRowsByDate);

        // ---- Section B: Competition — wrapped in mon-card ----
        var competitionCardHtml = '<div class="mon-card" style="margin-bottom:16px;">'
            + '<div class="mon-head">'
            + '<div class="mon-ico">'
                + '<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M8 21v-7M12 21V3M16 21v-11" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"/></svg>'
            + '</div>'
            + '<div>'
                + '<div class="mon-kicker" style="margin:0;">Autour de vous</div>'
            + '</div>'
            + '</div>'
            + competitionHtml
        + '</div>';

        // ---- Section C: Suivis (compact for PLANIFIER) ----
        var suivisCardHtml = suivisCompactHtml || '';

        // ---- Section D: Contexte de r\u00e9f\u00e9rence table ----
        var contexteCardHtml = renderContexteReferenceCard(row);

        var scoreCardHtml = '<div class="mon-card" style="margin-bottom:16px;">'
          + scoreHtml
        + '</div>';

        // Assemble
        container.innerHTML = pageHeaderHtml
            + '<div class="ms-days-wrap" style="padding-top:0;">'
            + criteriaHtml
            + '<div id="ms-day-tabs" style="margin-bottom:16px;"></div>'

            // Panels
            + '<div class="mon-panels">'
                + scoreCardHtml
                + contexteCardHtml
                + competitionCardHtml
                + suivisCardHtml
            + '</div>'

            // Bottom padding for fixed action bar
            + '<div style="height:80px;"></div>'

            + '</div>';

        // Wire criteria toggle
        wireCriteriaToggle();

        // --- Wire drill-through buttons ---
        var carteBtn = container.querySelector("[data-daydetail-carte]");
        if (carteBtn) {
            carteBtn.addEventListener("click", function() {
            container.innerHTML = '<div class="ms-days-wrap">'
                + '<button type="button" id="daydetail-back" style="display:flex;align-items:center;gap:6px;margin-bottom:12px;padding:6px 0;background:none;border:none;font-size:13px;font-weight:600;color:#1D3BB3;cursor:pointer;font-family:inherit;">\u2190 Retour</button>'
                + '<iframe src="' + escapeHtml(mapUrl) + '" style="width:100%;height:600px;border:none;border-radius:14px;display:block;"></iframe>'
            + '</div>';
            var backBtn = container.querySelector("#daydetail-back");
            if (backBtn) {
                backBtn.addEventListener("click", function() {
                renderDayDetail(dayRowsByDate);
                renderPills(dayRowsByDate);
                });
            }
            });
        }

        var concurrentsBtn = container.querySelector("[data-daydetail-concurrents]");
        if (concurrentsBtn) {
            concurrentsBtn.addEventListener("click", function() {
            var topThreats = MS.topThreats || [];
            if (!topThreats.length) {
                alert("Aucun concurrent potentiel d\u00e9tect\u00e9.");
                return;
            }

            var AUDIENCE_FR = {
                local: "r\u00e9sidents locaux", professionals: "professionnels",
                tourists: "touristes", students: "\u00e9tudiants",
                families: "familles", seniors: "seniors",
                general_public: "grand public", art_lovers: "amateurs d\u2019art",
                mixed: "public mixte"
            };
            var INDUSTRY_TIER_FR = { direct: "M\u00eame secteur", partial: "Secteur proche", contextual: "Secteur diff\u00e9rent" };
            var THREAT_BADGE = {
                high:     { bg: "#fee2e2", fg: "#991b1b", t: "Menace \u00e9lev\u00e9e" },
                moderate: { bg: "#fef3c7", fg: "#92400e", t: "Menace mod\u00e9r\u00e9e" },
                low:      { bg: "#f3f4f6", fg: "#6b7280", t: "Menace faible" },
            };

            var threatCardsArr = [];
            for (var ti = 0; ti < topThreats.length; ti++) {
                var tc = topThreats[ti];
                var tcName = tc.competitor_name || "Concurrent";
                var tcDistKm = tc.distance_km != null ? Number(tc.distance_km).toFixed(1) : null;
                var tcBadge = THREAT_BADGE[tc.threat_level] || THREAT_BADGE.low;
                var tcIndLabel = INDUSTRY_TIER_FR[tc.industry_match_tier] || "";
                var tcLocAuds = [tc.location_primary_audience_1, tc.location_primary_audience_2].filter(Boolean);
                var tcCompAuds = [tc.competitor_primary_audience, tc.competitor_secondary_audience].filter(Boolean);
                var tcSharedAuds = [];
                for (var ai = 0; ai < tcCompAuds.length; ai++) {
                if (tcLocAuds.indexOf(tcCompAuds[ai]) >= 0) tcSharedAuds.push(AUDIENCE_FR[tcCompAuds[ai]] || tcCompAuds[ai]);
                }
                var tcAudLine = "";
                if (tcSharedAuds.length > 0) tcAudLine = "Cible les m\u00eames audiences : " + tcSharedAuds.join(", ");
                else if (tcCompAuds.length > 0) {
                var tcCompAudLabels = [];
                for (var ci = 0; ci < tcCompAuds.length; ci++) tcCompAudLabels.push(AUDIENCE_FR[tcCompAuds[ci]] || tcCompAuds[ci]);
                tcAudLine = "Cible : " + tcCompAudLabels.join(", ");
                }
                var tcInitials = tcName.split(" ").map(function(w) { return (w[0] || ""); }).join("").slice(0, 2).toUpperCase();

                var tcCard = '<div style="background:#fff;border:0.5px solid #E8EDF5;border-radius:10px;overflow:hidden;margin-bottom:6px;">'
                + '<div style="display:flex;align-items:center;gap:10px;padding:12px 14px;">'
                    + '<div style="width:36px;height:36px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-weight:500;font-size:13px;color:#0C447C;background:#E6F1FB;flex-shrink:0;">' + escapeHtml(tcInitials) + '</div>'
                    + '<div style="flex:1;min-width:0;">'
                    + '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">'
                        + '<span style="font-size:13px;font-weight:500;color:#111827;">' + escapeHtml(tcName) + '</span>'
                        + (tcDistKm ? '<span style="font-size:11px;color:#6b7280;">' + escapeHtml(tcDistKm + ' km') + '</span>' : '')
                    + '</div>'
                    + '<div style="display:flex;align-items:center;gap:6px;margin-top:3px;flex-wrap:wrap;">'
                        + '<span style="display:inline-block;padding:1px 8px;border-radius:4px;font-size:10px;font-weight:600;background:' + tcBadge.bg + ';color:' + tcBadge.fg + ';">' + escapeHtml(tcBadge.t) + '</span>'
                        + (tcIndLabel ? '<span style="font-size:11px;color:#6b7280;">' + escapeHtml(tcIndLabel) + '</span>' : '')
                    + '</div>'
                    + (tcAudLine ? '<div style="font-size:11px;color:#374151;margin-top:3px;">' + escapeHtml(tcAudLine) + '</div>' : '')
                    + '</div>'
                    + '<div style="flex-shrink:0;">'
                    + '<button type="button" data-follow-threat="' + escapeHtml(tc.competitor_id) + '" data-follow-name="' + escapeHtml(tcName) + '" style="padding:4px 10px;border-radius:6px;border:1px solid #dbeafe;background:#eff6ff;font-size:11px;font-weight:600;color:#1e40af;cursor:pointer;white-space:nowrap;font-family:inherit;">Suivre \u2192</button>'
                    + '</div>'
                + '</div>'
                + '</div>';
                threatCardsArr.push(tcCard);
            }

            container.innerHTML = '<div class="ms-days-wrap">'
                + '<button type="button" id="daydetail-back" style="display:flex;align-items:center;gap:6px;margin-bottom:12px;padding:6px 0;background:none;border:none;font-size:13px;font-weight:600;color:#1D3BB3;cursor:pointer;font-family:inherit;">\u2190 Retour</button>'
                + '<div style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#374151;margin-bottom:12px;">Concurrents potentiels \u00b7 ' + topThreats.length + '</div>'
                + threatCardsArr.join("")
            + '</div>';

            var backBtn2 = container.querySelector("#daydetail-back");
            if (backBtn2) {
                backBtn2.addEventListener("click", function() {
                renderDayDetail(dayRowsByDate);
                renderPills(dayRowsByDate);
                });
            }

            container.querySelectorAll("[data-follow-threat]").forEach(function(btn) {
                btn.addEventListener("click", function() {
                var compId = btn.getAttribute("data-follow-threat");
                var compName = btn.getAttribute("data-follow-name") || "";
                if (!compId) return;
                btn.disabled = true;
                btn.textContent = "...";
                fetch("/api/competitive/add-competitor", {
                    method: "POST",
                    headers: { "content-type": "application/json" },
                    body: JSON.stringify({ competitor_id: compId, competitor_name: compName }),
                }).then(function(res) { return res.json(); }).then(function(json) {
                    if (json && json.ok) {
                    btn.textContent = "Suivi";
                    btn.style.background = "#dcfce7";
                    btn.style.borderColor = "#bbf7d0";
                    btn.style.color = "#166534";
                    } else {
                    btn.textContent = "Erreur";
                    btn.disabled = false;
                    }
                }).catch(function() {
                    btn.textContent = "Erreur";
                    btn.disabled = false;
                });
                });
            });
            });
        }
        }

        // ----------------------------------------------------------------
        // renderContexteReferenceCard — CONTEXTE DE R\u00c9F\u00c9RENCE table
        // Analysis-mode only (days.astro / PLANIFIER).
        // Sections: OPPORTUNIT\u00c9, CONTEXTE, ACCESSIBILIT\u00c9, CONDITIONS
        // ----------------------------------------------------------------
        function renderContexteReferenceCard(row) {
        if (!row) return '';

        var count500 = Number(row.events_within_500m_count || 0);
        var count5km = Number(row.events_within_5km_count || 0);
        var deltaEvents = Number(row.delta_att_events_pct || 0);
        var deltaMob = Number(row.delta_att_mobility_pct || 0);
        var deltaOps = Number(row.delta_ops_mobility_car_pct || 0);
        var alertMax = Number(row.alert_level_max || 0);
        var lvlWind = Number(row.lvl_wind || 0);
        var windGusts = row.wind_gusts_10m_max != null ? Math.round(Number(row.wind_gusts_10m_max)) : null;

        var dateObj = parseYmdToDate(selectedDate);
        var isWeekend = dateObj ? (dateObj.getUTCDay() === 0 || dateObj.getUTCDay() === 6) : false;
        var hasVacation = Boolean(row.vacation_name);
        var hasHoliday = Boolean(row.holiday_name);

        // --- Helpers ---
        function statusPill(label, style) {
            return '<span style="display:inline-block;font-size:11px;font-weight:600;padding:2px 10px;border-radius:20px;' + style + '">' + escapeHtml(label) + '</span>';
        }
        var GREEN_S  = "background:var(--color-pill-green-bg);color:var(--color-pill-green-text);";
        var YELLOW_S = "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);border:1px solid var(--color-pill-warn-border);";
        var RED_S    = "background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);border:1px solid var(--color-pill-risk-border);";

        // --- OPPORTUNIT\u00c9 ---
        var compPressureLabel = deltaEvents > 3 ? "\u00c9lev\u00e9e" : deltaEvents < -3 ? "Faible" : "Normale";
        var compPressureStyle = deltaEvents > 3 ? RED_S : deltaEvents < -3 ? GREEN_S : YELLOW_S;

        var opportuniteRows = '<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:0.5px solid #F3F4F6;">'
            + '<span style="font-size:13px;color:#374151;">' + count500 + ' \u00e9v\u00e9n. &lt; 500m</span>'
            + '<span style="font-size:13px;font-weight:600;color:#111827;"></span>'
        + '</div>'
        + '<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:0.5px solid #F3F4F6;">'
            + '<span style="font-size:13px;color:#374151;">' + count5km + ' \u00e9v\u00e9n. &lt; 5km</span>'
            + statusPill(compPressureLabel, compPressureStyle)
        + '</div>';

        // --- CONTEXTE ---
        var residentsAvail = (isWeekend || hasVacation || hasHoliday) ? "Disponible" : "Peu disponible";
        var residentsStyle = residentsAvail === "Disponible" ? GREEN_S : RED_S;
        var prosAvail = (!isWeekend) ? "Disponible" : "Peu disponible";
        var prosStyle = prosAvail === "Disponible" ? GREEN_S : RED_S;

        var contexteRows = '<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:0.5px solid #F3F4F6;">'
            + '<span style="font-size:13px;color:#374151;">R\u00e9sidents locaux</span>'
            + statusPill(residentsAvail, residentsStyle)
        + '</div>'
        + '<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:0.5px solid #F3F4F6;">'
            + '<span style="font-size:13px;color:#374151;">Professionnels</span>'
            + statusPill(prosAvail, prosStyle)
        + '</div>';

        // --- ACCESSIBILIT\u00c9 ---
        var visiteurLabel = deltaMob >= 0 ? "Fluide" : deltaMob >= -4 ? "Perturb\u00e9" : "Fortement perturb\u00e9";
        var visiteurStyle = deltaMob >= 0 ? GREEN_S : deltaMob >= -4 ? YELLOW_S : RED_S;
        var prestaLabel = deltaOps >= 0 ? "Fluide" : deltaOps >= -4 ? "Perturb\u00e9" : "Fortement perturb\u00e9";
        var prestaStyle = deltaOps >= 0 ? GREEN_S : deltaOps >= -4 ? YELLOW_S : RED_S;

        var accessRows = '<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:0.5px solid #F3F4F6;">'
            + '<span style="font-size:13px;color:#374151;">Visiteurs (&lt; 5 km)</span>'
            + statusPill(visiteurLabel, visiteurStyle)
        + '</div>'
        + '<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:0.5px solid #F3F4F6;">'
            + '<span style="font-size:13px;color:#374151;">Prestataires (&lt; 10 km)</span>'
            + statusPill(prestaLabel, prestaStyle)
        + '</div>';

        // --- CONDITIONS ---
        var freqImpactLabel = alertMax === 0 ? "Aucune alerte" : "Alerte niv. " + alertMax;
        var freqImpactStyle = alertMax === 0 ? GREEN_S : alertMax >= 2 ? RED_S : YELLOW_S;

        var installLabel = "Aucun";
        var installStyle = GREEN_S;
        if (lvlWind >= 3 || (windGusts != null && windGusts > 60)) {
            installLabel = "\u00c9lev\u00e9";
            installStyle = RED_S;
        } else if (lvlWind >= 2 || (windGusts != null && windGusts > 40)) {
            installLabel = "Mod\u00e9r\u00e9";
            installStyle = YELLOW_S;
        } else if (lvlWind >= 1) {
            installLabel = "Faible";
            installStyle = YELLOW_S;
        }

        var conditionsRows = '<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:0.5px solid #F3F4F6;">'
            + '<span style="font-size:13px;color:#374151;">Impact fr\u00e9quentation</span>'
            + statusPill(freqImpactLabel, freqImpactStyle)
        + '</div>'
        + '<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:0.5px solid #F3F4F6;">'
            + '<span style="font-size:13px;color:#374151;">Risque installations</span>'
            + statusPill(installLabel, installStyle)
        + '</div>';

        // --- Assemble sections ---
        function sectionBlock(label, isAccent, rowsHtml) {
            var color = isAccent ? '#1e40af' : '#6b7280';
            return '<div style="margin-bottom:16px;">'
            + '<div style="font-size:10px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:' + color + ';padding:8px 0 4px 0;border-bottom:1px solid #e5e7eb;">' + escapeHtml(label) + '</div>'
            + rowsHtml
            + '</div>';
        }

        var tableBody = sectionBlock("OPPORTUNIT\u00c9", false, opportuniteRows)
            + sectionBlock("CONTEXTE", false, contexteRows)
            + sectionBlock("ACCESSIBILIT\u00c9", false, accessRows)
            + sectionBlock("CONDITIONS", false, conditionsRows);

        return '<div class="mon-card" style="margin-bottom:16px;">'
            + '<div class="mon-head">'
            + '<div class="mon-ico">'
                + '<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 2v3M17 2v3" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"/><path d="M3.5 9h17" stroke="#1D3BB3" stroke-width="1.6"/><path d="M6 5h12a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z" stroke="#1D3BB3" stroke-width="1.6"/></svg>'
            + '</div>'
            + '<div>'
                + '<div class="mon-kicker" style="margin:0;">Contexte de r\u00e9f\u00e9rence</div>'
            + '</div>'
            + '</div>'
            + tableBody
        + '</div>';
        }

        // ----------------------------------------------------------------
        // renderSuivisCompactSection — compact competitor rows for PLANIFIER
        // Shows: photo + name + rating + distance + event count on this date
        // + overlap pills. NO expanded event list. NO takeaway paragraph.
        // ----------------------------------------------------------------
        function renderSuivisCompactSection(signals, eventDate, followedCount) {
          if (!followedCount && (!Array.isArray(signals) || signals.length === 0)) return '';

          var AUDIENCE_FR = {
            local: "r\u00e9sidents locaux", professionals: "professionnels",
            tourists: "touristes", students: "\u00e9tudiants",
            families: "familles", seniors: "seniors",
            general_public: "grand public", art_lovers: "amateurs d\u2019art",
            mixed: "public mixte"
          };

          if (!Array.isArray(signals) || signals.length === 0) {
            return '<div class="mon-card" style="margin-bottom:16px;">'
              + '<div class="mon-head">'
                + '<div class="mon-ico">'
                  + '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>'
                + '</div>'
                + '<div>'
                  + '<div class="mon-kicker" style="margin:0;">Concurrents suivis</div>'
                  + '<div style="font-size:13px;color:#6B7280;margin-top:4px;">Aucun signal d\u00e9tect\u00e9. <a href="/app/insightevent/suivis" style="color:#1D3BB3;text-decoration:none;">G\u00e9rer mes suivis \u2192</a></div>'
                + '</div>'
              + '</div>'
            + '</div>';
          }

          var byComp = new Map();
          for (var si = 0; si < signals.length; si++) {
            var s = signals[si];
            var cid = s.competitor_id || "unknown";
            if (!byComp.has(cid)) byComp.set(cid, []);
            byComp.get(cid).push(s);
          }

          var compEntries = Array.from(byComp.entries()).sort(function(a, b) {
            var aOv = a[1].filter(function(s) { return s.industry_overlap || s.audience_overlap || s.distance_flag; }).length;
            var bOv = b[1].filter(function(s) { return s.industry_overlap || s.audience_overlap || s.distance_flag; }).length;
            if (bOv !== aOv) return bOv - aOv;
            var aMax = Math.max.apply(null, a[1].map(function(s) { return Number(s.conflict_score || 0); }));
            var bMax = Math.max.apply(null, b[1].map(function(s) { return Number(s.conflict_score || 0); }));
            return bMax - aMax;
          });

          var totalSignals = signals.length;
          var totalComps = compEntries.length;

          var rowsHtml = compEntries.map(function(entry, idx) {
            var cid = entry[0];
            var compSignals = entry[1];
            var first = compSignals[0];
            var name = first.competitor_name || "Concurrent";
            var rating = first.google_rating;
            var ratingCount = first.google_rating_count;
            var photo = first.google_photos;
            var distM = first.distance_from_location_m;
            var distKm = distM ? (Number(distM) / 1000).toFixed(1) : null;
            var evCount = compSignals.length;

            var hasAudienceOverlap = compSignals.some(function(s) { return s.audience_overlap; });
            var hasIndustryOverlap = compSignals.some(function(s) { return s.industry_overlap; });
            var hasDistanceFlag = compSignals.some(function(s) { return s.distance_flag; });
            var threatSeasonality = first.entity_threat_seasonality_flag === true;
            var threatIndustryTier = first.entity_threat_industry_tier || null;

            var locAuds = [first.location_primary_audience_1, first.location_primary_audience_2].filter(Boolean);
            var compAuds = [first.competitor_primary_audience, first.competitor_secondary_audience].filter(Boolean);
            var eventAuds = [];
            var seenEA = {};
            compSignals.forEach(function(s) { if (s.event_primary_audience && !seenEA[s.event_primary_audience]) { seenEA[s.event_primary_audience] = true; eventAuds.push(s.event_primary_audience); } });
            var sharedEventAuds = eventAuds.filter(function(a) { return locAuds.indexOf(a) >= 0; });
            var sharedCompAuds = compAuds.filter(function(a) { return locAuds.indexOf(a) >= 0; });
            var hasSharedAudience = sharedEventAuds.length > 0 || sharedCompAuds.length > 0;

            var initials = name.split(" ").map(function(w) { return (w[0] || ""); }).join("").slice(0, 2).toUpperCase();
            var photoHtml = photo
              ? '<img style="width:44px;height:44px;border-radius:8px;object-fit:cover;flex-shrink:0;" src="' + escapeHtml(photo) + '" alt="">'
              : '<div style="width:44px;height:44px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:500;font-size:14px;color:#0C447C;background:#E6F1FB;flex-shrink:0;">' + escapeHtml(initials) + '</div>';

            var pillParts = [];
            if (hasSharedAudience) pillParts.push('<span style="font-size:10px;font-weight:500;padding:2px 8px;border-radius:4px;background:#FCEBEB;color:#791F1F;">M\u00eame audience</span>');
            if (hasIndustryOverlap) pillParts.push('<span style="font-size:10px;font-weight:500;padding:2px 8px;border-radius:4px;background:#FCEBEB;color:#791F1F;">M\u00eame secteur</span>');
            else if (threatIndustryTier === "partial") pillParts.push('<span style="font-size:10px;font-weight:500;padding:2px 8px;border-radius:4px;background:#FAEEDA;color:#633806;">Secteur proche</span>');
            if (threatSeasonality) pillParts.push('<span style="font-size:10px;font-weight:500;padding:2px 8px;border-radius:4px;background:#E6F1FB;color:#0C447C;">M\u00eame saisonnalit\u00e9</span>');
            var pillsHtml = pillParts.length ? '<div style="display:flex;gap:5px;flex-wrap:wrap;">' + pillParts.join("") + '</div>' : '';

            var metaParts = [];
            if (rating) metaParts.push('\u2605 ' + rating);
            if (distKm) metaParts.push(distKm + ' km');
            metaParts.push(evCount + ' \u00e9v\u00e9n.');
            var metaLine = metaParts.join(' \u00b7 ');

            var isLast = idx === compEntries.length - 1;

            return '<div style="display:flex;align-items:center;gap:12px;padding:14px 0;' + (isLast ? '' : 'border-bottom:0.5px solid #F3F4F6;') + '">'
              + photoHtml
              + '<div style="flex:1;min-width:0;">'
                + '<div style="display:flex;align-items:center;gap:8px;margin-bottom:2px;">'
                  + '<span style="font-size:14px;font-weight:500;color:#111827;">' + escapeHtml(name) + '</span>'
                  + '<span style="font-size:11px;color:#6B7280;">' + escapeHtml(metaLine) + '</span>'
                + '</div>'
                + pillsHtml
              + '</div>'
              + '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round" style="flex-shrink:0;"><polyline points="9 18 15 12 9 6"/></svg>'
            + '</div>';
          }).join("");

          return '<div class="mon-card" style="margin-bottom:16px;">'
            + '<div class="mon-head">'
              + '<div class="mon-ico">'
                + '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>'
              + '</div>'
              + '<div style="flex:1;display:flex;justify-content:space-between;align-items:center;">'
                + '<div class="mon-kicker" style="margin:0;">Concurrents suivis</div>'
                + '<a href="/app/insightevent/suivis" style="font-size:12px;color:#1D3BB3;text-decoration:none;font-weight:500;">Voir tout \u2192</a>'
              + '</div>'
            + '</div>'
            + rowsHtml
            + '<div style="padding:12px 0 0;border-top:0.5px solid #F3F4F6;font-size:12px;color:#6B7280;">'
              + totalComps + ' concurrent' + (totalComps > 1 ? 's' : '') + ' suivi' + (totalComps > 1 ? 's' : '') + ' \u00b7 ' + totalSignals + ' \u00e9v\u00e9nement' + (totalSignals > 1 ? 's' : '') + ' actif' + (totalSignals > 1 ? 's' : '') + ' sur cette date'
            + '</div>'
          + '</div>';
        }

        function renderPills(dayRowsByDate) {
          const pillsContainer = getPillsContainer();
          if (!pillsContainer) return;

          ensureSelectedDaysStyles();

          if (!selectedDates.length) {
            pillsContainer.innerHTML = "";
            return;
          }

          pillsContainer.innerHTML = `
            <div class="ms-tabs" role="tablist" aria-label="Jours sélectionnés">
              ${["__comparison__", ...selectedDates].map((d0) => {
                  const d = d0 === "__comparison__" ? "__comparison__" : normalizeYmd(d0);
                  const isActive = d === selectedDate;
                  const hasData = d === "__comparison__" || (dayRowsByDate && dayRowsByDate.has(d));
                  const meta = buildMetaForDate(d);
                  const label = d === "__comparison__"
                    ? "CHOIX"
                    : (meta?.dow3 && meta?.dayNum2 ? `${meta.dow3} ${meta.dayNum2}` : d);

                  return `
                    <button type="button"
                      class="ms-tab ${isActive ? "is-active" : ""}"
                      data-date="${escapeHtml(d)}"
                      ${hasData ? "" : "disabled"}
                      role="tab"
                      aria-selected="${isActive ? "true" : "false"}">
                      ${escapeHtml(label)}
                    </button>
                  `;
                })
                .join("")}
            </div>
          `;
          pillsContainer.querySelectorAll("button[data-date]").forEach((btn) => {
            btn.addEventListener("click", () => {
              const d = btn.getAttribute("data-date");
              if (!d || d === selectedDate) return;

              selectedDate = d;
              params.set("selected_date", d);
              window.history.replaceState({}, "", "?" + params.toString());

              if (selectedDate === "__comparison__") {
                renderComparisonTable(dayRowsByDate);
                renderPills(dayRowsByDate);
              } else {
                const _clickedDate = selectedDate;
                MS._pendingTabDate = _clickedDate;
                fetchCompetitorSignals(_clickedDate).then(res => {
                  if (MS._pendingTabDate !== _clickedDate) return;
                  MS.competitorSignals = res.signals;
                  MS.competitorFollowedCount = res.followed_count;
                  MS.topThreats = res.top_threats;
                  renderDayDetail(dayRowsByDate);
                  renderPills(dayRowsByDate);
                });
              }
            });
          });
        }

        function ctxIconSVG(kind) {
            if (kind === "daytype") {
              return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M4 7h16M4 12h16M4 17h16" stroke="#6b7280" stroke-width="1.8" stroke-linecap="round"/>
                <path d="M7 4v16M12 4v16M17 4v16" stroke="#6b7280" stroke-width="1.2" stroke-linecap="round" opacity="0.55"/>
              </svg>`;
            }
            if (kind === "break") {
              return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M12 3c-4.8 0-8.7 3.5-9.5 8.1h19C20.7 6.5 16.8 3 12 3z" stroke="#6b7280" stroke-width="1.6" stroke-linejoin="round"/>
                <path d="M12 11v7a2 2 0 0 1-4 0" stroke="#6b7280" stroke-width="1.6" stroke-linecap="round"/>
                <path d="M6.2 11c.7 1.2 2 2 3.5 2s2.8-.8 3.5-2c.7 1.2 2 2 3.5 2s2.8-.8 3.5-2" stroke="#6b7280" stroke-width="1.2" stroke-linecap="round" opacity="0.65"/>
              </svg>`;
            }
            return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M20 12v6a2 2 0 0 1-2 2H8l-4-4V6a2 2 0 0 1 2-2h6" stroke="#6b7280" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M16 3h5v5" stroke="#6b7280" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M21 3l-8 8" stroke="#6b7280" stroke-width="1.6" stroke-linecap="round"/>
            </svg>`;
          }
        
        function renderKeySignals(ctxTags) {

          if (!Array.isArray(ctxTags) || ctxTags.length === 0) {
            return `
              <div class="ms-key-signals">
                <div class="ms-section-title">SIGNALS</div>
                <div class="ms-muted">Aucun signal contextuel.</div>
              </div>
            `;
          }

          return `
            <div class="ms-key-signals">

              <div class="ms-section-title">
                SIGNALS
              </div>

              <div class="ms-context-tags">
                ${ctxTags.map(t => `
                  <span class="ms-ctx-tag">
                    <span class="ms-ctx-ico">${ctxIconSVG(t.kind)}</span>
                    ${escapeHtml(t.label)}
                  </span>
                `).join("")}
              </div>

            </div>
          `;
        }

        function renderChoiceRecapCard(dayRowsByDate) {

          const rows = Array.from(dayRowsByDate.values());

          let hasWeekend = false;
          let hasWeekday = false;
          let hasVacation = false;
          let hasHoliday = false;
          let hasTourismPeak = false;

          rows.forEach((r) => {
            const meta = buildMetaForDate(r.date);

            if (meta?.isWeekend) hasWeekend = true;
            else hasWeekday = true;

            if (r.vacation_name) hasVacation = true;
            if (r.holiday_name) hasHoliday = true;
            if (r.tourism_peak_flag_region === true) hasTourismPeak = true;
          });

          const criteria = [];

          if (hasWeekend && hasWeekday) criteria.push("en semaine et le week-end");
          else if (hasWeekend) criteria.push("le week-end");
          else if (hasWeekday) criteria.push("en semaine");

          if (hasVacation && hasHoliday) criteria.push("pendant les vacances scolaires ou jours fériés");
          else if (hasVacation) criteria.push("pendant les vacances scolaires");
          else if (hasHoliday) criteria.push("pendant un jour férié");
          else criteria.push("hors vacances scolaires");

          if (hasTourismPeak) criteria.push("pendant une période touristique");
          else criteria.push("hors période touristique");

          const bodyLines = [
            "Vous avez choisi vos dates selon les critères suivants :",
            "",
            ...criteria.map((c) => `• ${c}`),
            "",
            "Une fois la date choisie, vous recevrez à partir de J-10 un suivi météo et mobilité quotidien avec des prévisions de plus en plus précises"
          ];

          return `
            <div class="ms-choice-recap-wrap">
              <div class="ms-card ms-card-decision" style="padding-bottom:0;min-height:var(--ms-hero-card-height,340px);display:flex;flex-direction:column;justify-content:space-between;">
                <div>
                  <div class="ms-kicker">POURQUOI CES DATES ?</div>
                  <div class="ms-choice-recap-body">${escapeHtml(bodyLines.join("\n"))}</div>
                </div>
                <div id="ms-day-tabs" style="margin-top:16px;margin-bottom:0;"></div>
              </div>
            </div>
          `;
        }

        function renderKeyFacts(keyFacts) {
          const arr = Array.isArray(keyFacts) ? keyFacts : [];
          if (arr.length === 0) return "";
          const items = arr
            .map(x => `<li class="text-sm text-gray-700">${escapeHtml(x)}</li>`)
            .join("");
          return `<ul class="list-disc pl-5 space-y-1">${items}</ul>`;
        }

        function renderPointsCles(pointsCles) {
          const txt = (typeof pointsCles?.text === "string" ? pointsCles.text.trim() : "");

          if (!txt) {
            return `
              <div class="border rounded-lg p-4">
                <div class="text-sm text-gray-500">Signaux clés indisponibles.</div>
              </div>
            `;
          }

          return `
            <div class="border rounded-lg p-4">
              <div class="text-sm text-gray-400 mb-2">Signaux clés</div>
              <p class="ms-takeaway preline">${escapeHtml(txt)}</p>
            </div>
          `;
        }

        function renderPanel(title, bodyHtml) {
          return `
            <div class="border rounded-lg p-4">
              <div class="text-sm font-medium mb-2">${escapeHtml(title)}</div>
              ${bodyHtml}
            </div>
          `;
        }


        // ------------------------------
        // Local helpers (pure UI; no semantic changes)
        // ------------------------------
        // ✅ Remove all carousel/ms-c-* markup when we switched to viz+tabs
        function stripCarouselMarkup(rootEl) {
          if (!rootEl) return;
          const nuke = rootEl.querySelectorAll(
            ".ms-carousel-viewport, .ms-carousel-strip, .ms-slot, .ms-c-card, [id^='ms-slot-'], #ms-carousel-strip"
          );
            nuke.forEach((el) => el.remove());
        }

        function norm100(v) {
          const n = Number(v);
          return Number.isFinite(n) ? Math.max(0, Math.min(100, Math.round(n))) : null;
        }

        function renderScoreBreakdownBars(r) {
          if (!r) return "";

          const clamp = (x) => Math.max(0, Math.min(100, x));
          const norm = (v) => {
            const n = Number(v);
            return Number.isFinite(n) ? clamp(Math.round(n)) : null;
          };

          const cells = [
            { label: "AUDIENCE",   val: r?.events_score != null ? String(r.events_score).trim() : null },
            { label: "CONDITIONS",        val: r?.weather_score != null ? String(r.weather_score).trim() : null },
            { label: "ACCESSIBILITÉ",     val: r?.mobility_score != null ? String(r.mobility_score).trim() : null },
            { label: "CONCURRENCE",  val: r?.calendar_score != null ? String(r.calendar_score).trim() : null },
          ];  
          
          return `
            <div class="ms-section-title" style="text-align:center;margin-top:26px;">
              COMPOSANTS DE L'INDICE
            </div>

            <div class="ms-breakdown-grid">
              ${cells.map(x => {
                const v = x.val;
                const w = v === null ? 0 : parseFloat(v) * 10;
                return `
                  <div class="ms-breakdown-cell">
                    <div class="ms-breakdown-cell-top">
                      <div class="ms-breakdown-cell-label">${escapeHtml(x.label)}</div>
                      <div class="ms-breakdown-cell-value">
                        ${v === null ? "—" : v}
                      </div>
                    </div>
                    <div class="ms-breakdown-cell-bar">
                      <div class="ms-breakdown-cell-fill" style="width:${w}%;"></div>
                    </div>
                  </div>
                `;
              }).join("")}
            </div>
          `;
        }

        function renderAudienceContext(row) {

          const audience =
            row?.audience_primary ||
            row?.customer_mix_primary ||
            row?.target_audience ||
            null;

          if (!audience) return "";

          return `
            <div style="
              margin-top:18px;
              padding:12px 14px;
              border:1px solid #E5E7EB;
              border-radius:10px;
              background:#F9FAFB;
              text-align:center;
            ">
              <div style="
                font-size:11px;
                letter-spacing:0.12em;
                text-transform:uppercase;
                color:#9CA3AF;
                font-weight:600;
                margin-bottom:4px;
              ">
                PUBLIC LE PLUS PROBABLE
              </div>

              <div style="
                font-size:14px;
                font-weight:600;
                color:#111827;
              ">
                ${escapeHtml(audience)}
              </div>
            </div>
          `;
        }

        function renderFocusedDay(dayRowsByDate, pointsCles, savedItemMeta) {
          if (!container) return;

          ensureSelectedDaysStyles();

          const row = dayRowsByDate.get(selectedDate);

          if (!row) {
            container.innerHTML = `
              <div class="text-sm text-gray-600">
                Aucune donnée trouvée pour ${escapeHtml(selectedDate)}.
              </div>
            `;
            return;
          }

          // ------------------------------
          // Carousel DOM refs (AFTER innerHTML; scoped to container)
          // ------------------------------
          const stripEl = container.querySelector("#ms-carousel-strip");
          const slotLeftEl = container.querySelector("#ms-slot-left");
          const slotMidEl = container.querySelector("#ms-slot-mid");
          const slotRightEl = container.querySelector("#ms-slot-right");

          const getSlotDate = (slotEl) => {
            const card = slotEl ? slotEl.querySelector(".ms-c-card.preview[data-date]") : null;
            return card ? String(card.getAttribute("data-date") || "").trim() : "";
          };

          // ------------------------------
          // Meta (Month / Week / DOW / Day number)
          // ------------------------------
          const meta = buildMetaForDate(selectedDate);

          // ------------------------------
          // Meaning line: compare score among selected days
          // ------------------------------
          const meaningText = (() => {
            const scores = (Array.isArray(selectedDates) ? selectedDates : [])
              .map((d) => {
                const r = dayRowsByDate.get(d);
                const s = r && typeof r.opportunity_score_final_local === "number" ? r.opportunity_score_final_local : null;
                return s;
              })
              .filter((v) => v !== null);

            const currentScore = typeof row.opportunity_score_final_local === "number" ? row.opportunity_score_final_local : null;
            if (currentScore === null || scores.length <= 1) return "";

            const max = Math.max(...scores);
            const min = Math.min(...scores);

            if (currentScore === max && currentScore !== min) return "Score le plus élevé parmi les jours sélectionnés";
            if (currentScore === min && currentScore !== max) return "Score inférieur aux autres jours sélectionnés";
            return "Score intermédiaire parmi les jours sélectionnés";
          })();

          // ------------------------------
          // Context tags (MAX 3): daytype, vacation/holiday, commercial (first)
          // ------------------------------
          const ctxTags = (() => {
            const tags = [];

            // Convert unknown payloads (string | number | object | array) into safe human text
            const tagText = (v) => {
              if (v == null) return "";
              if (typeof v === "string") return v.trim();
              if (typeof v === "number" || typeof v === "boolean") return String(v);

              if (Array.isArray(v)) {
                // take first meaningful string from array
                for (const it of v) {
                  const t = tagText(it);
                  if (t) return t;
                }
                return "";
              }

              if (typeof v === "object") {
                // common “label/name/title” fields; extend if your structs differ
                const o = v;
                return (
                  tagText(o.label) ||
                  tagText(o.name) ||
                  tagText(o.title) ||
                  tagText(o.event_label) ||
                  tagText(o.event_name) ||
                  tagText(o.holiday_name) ||
                  tagText(o.vacation_name) ||
                  ""
                );
              }

              return "";
            };

            // 1) daytype
            if (meta.isWeekend === true) tags.push({ kind: "daytype", label: "Week-end" });
            if (meta.isWeekend === false) tags.push({ kind: "daytype", label: "Semaine" });

            // 2) vacation OR holiday (never both)
            const vac = tagText(row.vacation_name);
            const hol = tagText(row.holiday_name);
            if (vac) tags.push({ kind: "break", label: vac });
            else if (hol) tags.push({ kind: "break", label: hol });

            // 3) commercial event (first non-empty only)
            const ceRaw = row.commercial_events;
            const ceArr = Array.isArray(ceRaw) ? ceRaw : (ceRaw ? [ceRaw] : []);
            const firstCe = ceArr.map(tagText).find(Boolean);
            if (firstCe) tags.push({ kind: "commercial", label: firstCe });

            return tags.slice(0, 3);
          })();

          // ------------------------------
          // Sections (single column; fixed order)
          // ------------------------------
          const calendrierHtml = renderCalendrierHexLike(row);
          const concurrenceHtml = renderConcurrenceHexLike(row);
          const mobiliteHtml = renderMobiliteHexLike(row);
          const meteoHtml = renderMeteoHexLike(row);
          const suivisSignals = MS.competitorSignals || [];
          const suivisHtml = renderSuivisHexLike(suivisSignals, selectedDate, MS.competitorFollowedCount || 0);

          container.innerHTML = `

            <!-- ZONE A (WHITE - constrained width) -->
            <div class="ms-days-wrap">
                ${renderHeroScore(row, meta, ctxTags, dayRowsByDate, savedItemMeta)}

                ${renderAudienceContext(row)}
            </div>
                                      
          <!-- ZONE B (GREY - constrained to match breakdown width) -->
                
          <!-- ZONE C — PANELS -->
          <div class="ms-days-wrap">
            <div id="ms-zone-c">
              <div class="ms-panels">
                ${suivisHtml}
                ${calendrierHtml}
                ${concurrenceHtml}
                ${mobiliteHtml}
                ${meteoHtml}
              </div>
            </div>
          </div>
          </div>
          `;
          
          function renderFeedForDate(date, allAlerts) {
            const items = (Array.isArray(allAlerts) ? allAlerts : [])
              .filter(a => normalizeYmd(a?.affected_date) === date);

            if (!items.length) {
              return `<div class="ms-feed-wrap"><div class="ms-feed-empty">Aucun signal détecté pour cette date.</div></div>`;
            }

            function formatFeedDateLong(ymd) {
              const d = parseYmdToDate(normalizeYmd(ymd));
              if (!d) return String(ymd || "");
              const raw = new Intl.DateTimeFormat("fr-FR", { weekday:"long", day:"numeric", month:"long", year:"numeric" }).format(d);
              return raw.charAt(0).toUpperCase() + raw.slice(1);
            }

            function formatFeedDateShort(ymd) {
              const d = parseYmdToDate(normalizeYmd(ymd));
              if (!d) return String(ymd || "");
              return new Intl.DateTimeFormat("fr-FR", { day:"numeric", month:"long" }).format(d);
            }

            function feedLine1(a) {
              const sub = String(a?.change_subtype || "").toLowerCase();
              const dir = String(a?.direction || "").toLowerCase();
              const cat = String(a?.change_category || "").toLowerCase();
              const nv  = String(a?.new_value ?? "").toLowerCase();
              const d = formatFeedDateShort(a?.affected_date);
              const map = {
                context_change:           cat === "competition" ? (nv === "true" ? `Concurrent détecté · ${d}` : `Concurrent retiré · ${d}`)
                                          : cat === "context" ? (dir === "worsened" || dir === "down" ? `Alerte météo renforcée · ${d}` : `Alerte météo réduite · ${d}`)
                                          : cat === "mobility" ? `Mobilité perturbée · ${d}`
                                          : `Signal de contexte · ${d}`,
                score_change:             dir === "up" ? `Indice de faisabilité en hausse · ${d}` : `Score d'opportunité en baisse · ${d}`,
                future_score_change:      `Prévision d'opportunité revue · ${d}`,
                regime_change:            `Régime d'opportunité changé · ${d}`,
                medal_change:             `Classement des dates modifié · ${d}`,
                event_new:                `Concurrent détecté · ${d}`,
                event_removed:            `Concurrent retiré · ${d}`,
                weather_change:           (dir === "down" || dir === "worsened") ? `Alerte météo renforcée · ${d}` : `Alerte météo réduite · ${d}`,
                mobility_change:          `Mobilité perturbée · ${d}`,
                mega_event_activation:    `Méga-événement annoncé · ${d}`,
                mega_event_end:           `Méga-événement terminé · ${d}`,
                ranking_change:           `Classement des dates modifié · ${d}`,
                baseline_validity_change: `Référence recalculée · ${d}`,
              };
              return map[sub] || `Signal détecté · ${d}`;
            }

            function feedLine2(a) {
              const sub  = String(a?.change_subtype || "").toLowerCase();
              const loc  = String(a?.location_type || "").toLowerCase();
              const locClient = String(a?.location_type_client || "").toLowerCase();
              const lvlRain = Number(a?.lvl_rain || 0);
              const lvlWind = Number(a?.lvl_wind || 0);
              const lvlSnow = Number(a?.lvl_snow || 0);
              const lvlHeat = Number(a?.lvl_heat || 0);
              const lvlCold = Number(a?.lvl_cold || 0);
              const venue = a?.event_venue_name || "";
              const city  = a?.city_name || "";
              const km    = a?.distance_m != null ? `${(Number(a.distance_m)/1000).toFixed(1)} km` : null;
              const distM = Number(a?.distance_m || 0);
              const aud1  = String(a?.primary_audience_1 || "").toLowerCase();
              const aud2  = String(a?.primary_audience_2 || "").toLowerCase();
              const activ = String(a?.company_activity_type || "").toLowerCase();
              const hasActiveEvent = Boolean(a?.has_active_event);
              const activeTitle = a?.active_event_title || null;
              const weatherSens = Number(a?.weather_sensitivity || 0);
              const capSens = String(a?.capacity_sensitivity || "").toLowerCase();
              const isOutdoorClient = locClient === "outdoor" || locClient === "mixed";

              function parseHours(s) {
                if (!s) return null;
                const m = String(s).match(/(\d{1,2})[h:]?(\d{0,2})\s*[-–]\s*(\d{1,2})[h:]?(\d{0,2})/i);
                if (!m) return null;
                const start = parseInt(m[1]) * 60 + (parseInt(m[2]) || 0);
                const end   = parseInt(m[3]) * 60 + (parseInt(m[4]) || 0);
                return { start, end };
              }

              function audienceLabel(code) {
                const map = { local: "résidents locaux", professionals: "professionnels", tourists: "touristes", students: "étudiants", families: "familles", seniors: "seniors" };
                return map[code] || code;
              }

              if (sub === "score_up") {
                if (lvlRain > 0) return "Amélioration des conditions de pluie.";
                if (lvlSnow > 0) return "Réduction du risque neige.";
                if (lvlWind > 0) return "Vent en baisse.";
                if (lvlHeat > 0) return "Chaleur moins intense.";
                if (lvlCold > 0) return "Froid moins intense.";
                return "Attractivité de la date en progression.";
              }

              if (sub === "score_down") {
                if (lvlRain > 0) {
                  if (isOutdoorClient) return "Fortes pluies prévues — impact direct sur vos installations et la fréquentation.";
                  return "Fortes pluies prévues — possible friction à l'entrée du site.";
                }
                if (lvlSnow > 0) return "Neige prévue — impact sur l'accès et la fréquentation.";
                if (lvlWind > 0) {
                  if (isOutdoorClient) return "Vent fort prévu — vérifier la solidité des structures et signalétiques.";
                  return "Vent fort prévu — impact sur les conditions d'exploitation.";
                }
                if (lvlHeat > 0) return "Chaleur forte prévue — impact sur le confort et la durée de présence.";
                if (lvlCold > 0) return "Grand froid prévu — impact sur la fréquentation.";
                return "Dégradation de l'attractivité de la date.";
              }

              if (sub === "event_new") {
                const parts = [];
                if (distM > 0 && distM <= 500) {
                  parts.push(`Concurrent à ${Math.round(distM)} m`);
                } else if (distM > 0) {
                  parts.push(`À ${km} de votre site`);
                } else if (venue) {
                  parts.push(venue);
                } else if (city) {
                  parts.push(city);
                }
                const audParts = [aud1, aud2].filter(Boolean);
                if (audParts.length) {
                  parts.push(`cible potentielle : ${audParts.map(audienceLabel).join(", ")}`);
                }
                if (hasActiveEvent && activeTitle) {
                  parts.push(`pendant votre événement "${activeTitle}"`);
                }
                const oh = parseHours(a?.operating_hours);
                if (oh) {
                  parts.push(`vos horaires d'ouverture : ${Math.floor(oh.start/60)}h–${Math.floor(oh.end/60)}h`);
                }
                return parts.length ? parts.join(" — ") + "." : km ? `À ${km} de votre site.` : "Concurrent détecté dans votre zone.";
              }

              if (sub === "event_removed") return "";

              if (sub === "weather_worsened") {
                if (weatherSens >= 3) {
                  if (isOutdoorClient) return "Impact direct sur vos installations et la fréquentation — sensibilité météo élevée.";
                  return "Impact probable sur la fréquentation — votre activité est sensible aux conditions météo.";
                }
                if (isOutdoorClient) return "Impact direct sur les installations et la fréquentation.";
                if (locClient === "mixed") return "Impact probable sur les espaces extérieurs et la venue des visiteurs.";
                return "Légère friction possible à l'entrée du site.";
              }

              if (sub === "weather_improved") return "Risque météo réduit sur cette date.";

              if (sub === "mobility_disruption") {
                if (hasActiveEvent && activeTitle) return `Accès au site potentiellement impacté pendant votre événement "${activeTitle}".`;
                if (capSens === "high" || capSens === "élevée") return "Accès perturbé — votre activité dépend d'une fréquentation élevée.";
                return "Accès au site potentiellement impacté.";
              }

              if (sub === "ranking_up")   return "Cette date gagne en attractivité relative dans votre région.";
              if (sub === "ranking_down") return "Cette date perd en attractivité relative dans votre région.";
              if (sub === "context_change") return "";
              return "";
            }

            function feedLine3(a) {
              const sub = String(a?.change_subtype || "").toLowerCase();
              const cat = String(a?.change_category || "").toLowerCase();
              const parts = [];

              if (sub === "score_change" || cat === "opportunity") {
                const from = a?.old_value != null ? Math.round(Number(a.old_value)) : null;
                const to   = a?.new_value != null ? Math.round(Number(a.new_value)) : null;
                const delta = a?.score_delta != null ? Math.round(Number(a.score_delta)) : (from != null && to != null ? to - from : null);
                if (from != null && to != null && Number.isFinite(from) && Number.isFinite(to)) {
                  const sign = delta >= 0 ? "+" : "";
                  parts.push(`Score : ${from} → ${to} (${sign}${delta})`);
                }
              }

              else if (cat === "competition" || sub === "event_new" || sub === "event_removed" || sub === "context_change") {
                const name = a?.event_label || a?.event_name || "";
                const km = a?.distance_m != null ? `${(Number(a.distance_m)/1000).toFixed(1)} km` : "";
                const ov = a?.old_value != null ? String(a.old_value) : null;
                const nv = a?.new_value != null ? String(a.new_value) : null;
                if (name && km) parts.push(`${name} · ${km}`);
                else if (name) parts.push(name);
                else if (km) parts.push(`À ${km}`);
                else if (ov != null && nv != null && ov !== nv) {
                  const ovLabel = ov === "true" ? "présent" : ov === "false" ? "absent" : ov;
                  const nvLabel = nv === "true" ? "présent" : nv === "false" ? "absent" : nv;
                  parts.push(`Présence concurrentielle : ${ovLabel} → ${nvLabel}`);
                }
              }

              else if (cat === "context" || sub === "weather_change") {
                const from = a?.old_value != null ? String(a.old_value) : null;
                const to   = a?.new_value != null ? String(a.new_value) : null;
                if (from && to && from !== to) parts.push(`${from} → ${to}`);
                else if (to) parts.push(to);
              }

              else if (cat === "mobility" || sub === "mobility_change") {
                const from = a?.old_value != null ? String(a.old_value) : null;
                const to   = a?.new_value != null ? String(a.new_value) : null;
                if (from && to && from !== to) parts.push(`Trafic : ${from} → ${to}`);
              }

              else if (sub === "mega_event_activation" || sub === "mega_event_end") {
                const name = a?.event_label || a?.event_name || "";
                if (name) parts.push(name);
              }

              else if (sub === "baseline_validity_change") {
                const from = a?.old_value != null ? String(a.old_value) : null;
                const to   = a?.new_value != null ? String(a.new_value) : null;
                if (from && to && from !== to) parts.push(`${from} → ${to}`);
              }

              return parts.join(" · ");
            }

            // Group items by date
            const byDate = new Map();
            for (const a of items) {
              const d = normalizeYmd(a?.affected_date);
              if (!byDate.has(d)) byDate.set(d, []);
              byDate.get(d).push(a);
            }

            function feedCatConfig(cat) {
              const c = String(cat || "").toLowerCase();
              if (c === "competition") return { ico: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M8 21v-7M12 21V3M16 21v-11"/></svg>` };
              if (c === "opportunity") return { ico: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>` };
              if (c === "context")     return { ico: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.3 4.3l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.7-2.7l-8-14a2 2 0 0 0-3.4 0z"/></svg>` };
              if (c === "planning")    return { ico: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M7 2v3M17 2v3"/><path d="M4 7h16v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7z"/><path d="M4 11h16"/></svg>` };
              if (c === "mobility")    return { ico: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M7 16h10l1-6H6l1 6z"/><path d="M7 16l-1 4M17 16l1 4"/><path d="M9 10V7a3 3 0 0 1 6 0v3"/></svg>` };
              return { ico: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/></svg>` };
            }

            function severityDots(level) {
              const l = Math.min(4, Math.max(1, Number(level) || 1));
              return [1,2,3,4].map(i =>
                `<span style="width:10px;height:10px;border-radius:50%;display:inline-block;background:${i <= l ? "#1D3BB3" : "#E2E8F0"};"></span>`
              ).join("&nbsp;");
            }

            const groupsHtml = [...byDate.entries()].map(([d, dayItems]) => {
              const itemsHtml = dayItems.map((a, idx) => {
                const line1 = feedLine1(a);
                const line2 = feedLine2(a);
                const line3 = feedLine3(a);
                const cat = String(a?.change_category || "").toLowerCase();
                const lvl = Number(a?.alert_level) || 1;
                const cfg = feedCatConfig(cat);
                const isLast = idx === dayItems.length - 1;

                return `
                  <div style="padding:14px 0;display:flex;align-items:flex-start;gap:12px;border-left:3px solid ${lvl>=3?"#EF4444":lvl>=2?"#F59E0B":"#93C5FD"};padding-left:10px;${isLast ? "" : "border-bottom:1px solid #F3F4F6;"}">
                  
                  <!-- Icon: black SVG, no background -->
                    <div style="flex:0 0 auto;width:24px;display:flex;align-items:center;justify-content:center;margin-top:2px;">
                      ${cfg.ico}
                    </div>

                    <!-- Body -->
                    <div style="flex:1;min-width:0;">

                      <!-- Line 1: signal name, bold, dark -->
                      <div style="font-size:14px;font-weight:700;color:#111827;line-height:1.3;margin-bottom:4px;">
                        ${escapeHtml(line1)}
                      </div>

                      <!-- Line 2: factual, dots inline at end of same line -->
                      ${line2 ? `
                      <div style="font-size:14px;color:#374151;line-height:1.4;margin-bottom:2px;display:flex;align-items:center;gap:12px;">
                        <span>${escapeHtml(line2)}</span>
                        <span style="display:inline-flex;align-items:center;gap:5px;flex:0 0 auto;">${severityDots(lvl)}</span>
                      </div>` : ""}

                      <!-- Line 3: score impact -->
                      ${line3 ? `<div style="font-size:12px;color:#6B7280;font-variant-numeric:tabular-nums;">${escapeHtml(line3)}</div>` : ""}

                    </div>
                  </div>
                `;
              }).join("");

              return `
                <div style="margin-bottom:16px;">
                  <div style="background:#fff;border:1px solid #E8EDF5;border-radius:12px;padding:0 16px;box-shadow:0 1px 4px rgba(17,24,39,0.04);">

                    <!-- Date: first row inside card -->
                    <div style="font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(17,24,39,0.38);padding:14px 0 10px 0;border-bottom:1px solid #F3F4F6;">
                      ${escapeHtml(formatFeedDateLong(d))}
                    </div>

                    ${itemsHtml}
                  </div>
                </div>
              `;
            }).join("");

            return `<div class="ms-feed-wrap">${groupsHtml}</div>`;
          }

          function breakdownIconSVG(kind) {
            // minimal inline SVGs, no deps
            if (kind === "competition") {
              return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M8 21v-7M12 21V3M16 21v-11" stroke="#111827" stroke-width="1.8" stroke-linecap="round"/>
              </svg>`;
            }
            if (kind === "weather") {
              return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M12 18a6 6 0 1 0 0-12 6 6 0 0 0 0 12z" stroke="#111827" stroke-width="1.6"/>
                <path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke="#111827" stroke-width="1.6" stroke-linecap="round"/>
              </svg>`;
            }
            if (kind === "mobility") {
              return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M7 16h10l1-6H6l1 6z" stroke="#111827" stroke-width="1.6" stroke-linejoin="round"/>
                <path d="M7 16l-1 4M17 16l1 4" stroke="#111827" stroke-width="1.6" stroke-linecap="round"/>
                <path d="M9 10V7a3 3 0 0 1 6 0v3" stroke="#111827" stroke-width="1.6" stroke-linecap="round"/>
              </svg>`;
            }
            // calendar
            return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M7 2v3M17 2v3" stroke="#111827" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M4 7h16v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7z" stroke="#111827" stroke-width="1.6"/>
              <path d="M4 11h16" stroke="#111827" stroke-width="1.6"/>
            </svg>`;
          }

          function renderHeroScore(r, meta, ctxTags, dayRowsByDate, savedItemMeta) {
            const score = r?.opportunity_score_final_local;
            const safeScore = score !== null && score !== undefined ? String(score).trim() : null;

            const deltaRaw = r?.opportunity_score_vs_last_week;
            const safeDelta = deltaRaw != null ? parseFloat(String(deltaRaw).trim()) / 10 : null;
            
            let deltaClass = '';
            let formattedDelta;
            if (safeDelta === null || !Number.isFinite(safeDelta)) {
              deltaClass = 'is-neutral';
              formattedDelta = '—';
            } else if (safeDelta > 0) {
              deltaClass = 'is-positive';
              formattedDelta = `+${safeDelta.toFixed(1)} pts`;
            } else if (safeDelta < 0) {
              deltaClass = 'is-negative';
              formattedDelta = `${safeDelta.toFixed(1)} pts`;
            } else {
              deltaClass = 'is-neutral';
              formattedDelta = `0.0 pts`;
            }
            
            // STATUT: authoritative signals from scoring model
            const hasRisk = r?.is_major_realization_risk_flag === true;
            const statutPill = computeStatusPill(r);

            // Points clés: up to 3 bullets
            const pointsBullets = (() => {
              const bullets = [];

              // Bullet 1: day ranking among selected dates
              const scores = selectedDates
                .map(d => {
                  const row2 = dayRowsByDate ? dayRowsByDate.get(d) : null;
                  return { d, s: row2 && row2.opportunity_score_final_local != null ? parseFloat(String(row2.opportunity_score_final_local)) : null };
                })
                .filter(x => x.s !== null)
                .sort((a, b) => b.s - a.s);

              if (scores.length > 0 && safeScore !== null) {
                const rank = scores.findIndex(x => x.d === selectedDate) + 1;
                if (rank === 1 && scores.length > 1) bullets.push({ ico: "★", text: "Meilleur jour de la sélection" });
                else if (rank > 1) bullets.push({ ico: "★", text: `${rank}e jour de la sélection` });
                else bullets.push({ ico: "★", text: "Seul jour de la sélection" });
              }

              // Bullet 2: alert level only
              const alertLevel = Number(r?.alert_level_max ?? 0);
              const alertText = (Number.isFinite(alertLevel) && alertLevel > 0) ? `Alerte niveau ${alertLevel}` : "Pas d'alertes";
              bullets.push({ ico: "●", text: alertText });

              // Bullet 3: context tags (ferié / vacation / commercial / weekend fallback)
              const tagLabels = (Array.isArray(ctxTags) ? ctxTags : []).map(t => t.label).filter(Boolean);
              if (tagLabels.length > 0) bullets.push({ ico: "◈", text: tagLabels.join(" · ") });
              
              return bullets.slice(0, 3);
            })();

            const fullDate = new Intl.DateTimeFormat("fr-FR", {
              weekday: "long",
              day: "numeric",
              month: "long",
              year: "numeric"
            }).format(parseYmdToDate(selectedDate));
            const capitalizedDate = fullDate.charAt(0).toUpperCase() + fullDate.slice(1);
            
            const decisionCountdown = (() => {
              const dd = savedItemMeta?.decision_date || null;
              if (!dd) return null;
              return countdownLabel(dd, "");
            })();

            return `
              <div style="background:rgba(29,59,179,0.04);border-left:6px solid #0b37e5;padding:24px;margin:0 12px;min-height:var(--ms-hero-card-height,auto);">
              
                <!-- Date + countdown row -->
                <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:14px;">
                  <span style="font-size:13px;font-weight:700;color:#1D3BB3;text-transform:uppercase;letter-spacing:0.10em;">${escapeHtml(capitalizedDate)}</span>
                  <div style="display:flex;flex-direction:column;align-items:flex-end;gap:2px;">
                    ${decisionCountdown ? `<span style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#9CA3AF;">Choix limite de date : ${escapeHtml(decisionCountdown)}</span>` : ""}
                    ${safeDelta !== null && !decisionCountdown ? `<span style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#9CA3AF;">${formattedDelta} VS SEMAINE DERNIÈRE</span>` : ""}
                  </div>
                </div>

                <!-- Score + statut row -->
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
                  <div>
                    <div style="font-size:11px;font-weight:600;letter-spacing:0.10em;text-transform:uppercase;color:#9CA3AF;margin-bottom:4px;">Indice de faisabilité</div>
                    <div style="display:flex;align-items:baseline;gap:8px;">
                      <span style="font-size:48px;font-weight:500;color:#111827;line-height:1;">${safeScore === null ? "—" : String(safeScore)}</span>
                      <span style="font-size:18px;color:#9CA3AF;">/10</span>
                      <span class="ms-delta-pill ${deltaClass}" style="font-size:12px;padding:4px 10px;">${formattedDelta}</span>
                    </div>
                  </div>
                  <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;">
                    <span style="font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#9CA3AF;">Statut</span>
                    <span class="${statutPill.cls}" style="padding:6px 14px;border-radius:999px;font-size:11px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;">${escapeHtml(statutPill.label)}</span>
                  </div>
                </div>

                <!-- Points clés -->
                <div class="ms-points-cles-block">
                  <div class="ms-points-cles-label">Signaux clés</div>
                  <ul class="ms-points-cles-list">
                    ${pointsBullets.map(b => `
                      <li>
                        <span class="ms-pc-ico">${escapeHtml(b.ico)}</span>
                        <span>${escapeHtml(b.text)}</span>
                      </li>
                    `).join("")}
                  </ul>
                </div>

                <!-- Tabs inside blue card -->
                <div id="ms-day-tabs" style="margin-top:16px;margin-bottom:-24px;"></div>
              </div>
            `;
          }

          function isSeasonalAverageDate(ymd) {
            const target = parseYmdToDate(ymd);
            if (!target) return false;

            const today = new Date();
            const todayUtc = new Date(Date.UTC(
              today.getFullYear(),
              today.getMonth(),
              today.getDate()
            ));

            const diffDays = Math.floor((target.getTime() - todayUtc.getTime()) / 86400000);
            return diffDays > 10;
          }

          function getWeatherIconSrcFrom30DayGrid(weatherCode) {
            const code = Number(weatherCode);

            // IMPORTANT:
            // Paste here the EXACT weather_code -> /icons/weather/... mapping body
            // already used in your 30-day grid.
            // Do not invent a new mapping here.
            //
            // Example shape only:
            //
            // if (code === 0) return "/icons/weather/clear.svg";
            // if ([1,2,3].includes(code)) return "/icons/weather/partly-cloudy.svg";
            // ...
            //
            // Replace this fallback once pasted:
            return "";
          }

          function renderComparisonWeatherCell(row) {
            const iconSrc = getWeatherIconSrcFrom30DayGrid(row?.comparison?.weather_code);
            const label = String(row?.comparison?.weather_label_fr || "").trim();
            const seasonal = isSeasonalAverageDate(row?.date);

            if (!iconSrc) {
              return `
                <div class="ms-weather-compare">
                  <div class="ms-weather-compare-fallback">—</div>
                  ${seasonal ? `<div class="ms-weather-compare-note">moyenne saisonnière</div>` : ""}
                </div>
              `;
            }

            return `
              <div class="ms-weather-compare">
                <img
                  src="${escapeHtml(iconSrc)}"
                  alt="${escapeHtml(label || "Météo")}"
                  title="${escapeHtml(label || "Météo")}"
                  class="ms-weather-compare-icon"
                />
                ${seasonal ? `<div class="ms-weather-compare-note">moyenne saisonnière</div>` : ""}
              </div>
            `;
          }
              
          function renderTopViz(r) {
            const score = r?.opportunity_score_final_local;
            const safeScore = score !== null && score !== undefined ? String(score).trim() : null;

            const norm = (v) => {
              const n = Number(v);
              return Number.isFinite(n) ? Math.max(0, Math.min(100, Math.round(n))) : 0;
            };

            const rows = [
              { label: "Concurrence", val: norm(r?.events_score) },
              { label: "Météo",       val: norm(r?.weather_score) },
              { label: "Calendrier",  val: norm(r?.calendar_score) },
              { label: "Mobilité",    val: norm(r?.mobility_score) },
            ];
            
            return `
              <div class="ms-viz-wrap">
                <div class="ms-viz-card">
                  <div class="ms-viz-title">
                    ${safeScore !== null ? `Score global : ${safeScore}/100` : "Score global indisponible"}
                  </div>
                  <div class="ms-viz-rows">
                    ${rows.map(x => `
                      <div class="ms-viz-row">
                        <div class="ms-viz-label">${escapeHtml(x.label)}</div>
                        <div class="ms-viz-bar">
                          <div class="ms-viz-fill" style="width:${x.val}%"></div>
                        </div>
                        <div class="ms-viz-score">
                          ${x.val}<span class="muted">/100</span>
                        </div>
                      </div>
                    `).join("")}
                  </div>
                </div>
              </div>
            `;
          }

          function renderPointsClesHexLike(pc) {
            const txt = pc?.text ? String(pc.text) : "";

            if (!txt.trim()) {
              return sectionHex(
                "SYNTHÈSE DÉCISIONNELLE",
                "sparkle",
                `<div class="ms-muted">Synthèse décisionnelle indisponible.</div>`,
                ""
              );
            }

            const body = `
              <div class="ms-takeaway" style="white-space:pre-line;">
                ${escapeHtml(txt)}
              </div>
            `;

            return `
              <div class="ms-card ms-card-decision">
                <div class="ms-kicker" style="display:flex;align-items:center;gap:8px;">
                  ${sectionIconSVG("sparkle")}
                  SYNTHÈSE DÉCISIONNELLE
                </div>
                ${body}
              </div>
            `;
          }

          function renderSuivisHexLike(signals, date, followedCount) {
            if (!Array.isArray(signals) || signals.length === 0) {
              if (!followedCount) return "";
              return `
                <div class="ms-section">
                  <div class="ms-card">
                    <div class="ms-head">
                      <div class="ms-ico">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                      </div>
                      <div class="ms-head-content">
                        <span style="font-size:13px;font-weight:700;letter-spacing:0.10em;text-transform:uppercase;color:#1D3BB3;">Concurrents suivis</span>
                      </div>
                    </div>
                    <div class="ms-below">
                      <div style="font-size:13px;color:#6B7280;margin-bottom:8px;">Aucun signal détecté.</div>
                      <div><a href="/app/insightevent/suivis" style="font-size:13px;color:#1D3BB3;text-decoration:none;">Gérer mes suivis →</a></div>
                    </div>
                  </div>
                </div>
              `;
            }

            const fmtDate = (iso) => {
              if (!iso) return "—";
              const months = ["jan.","fév.","mars","avr.","mai","juin","juil.","août","sept.","oct.","nov.","déc."];
              const s = iso?.value ?? iso;
              const str = typeof s === "string" ? s : String(s ?? "");
              const parts = str.slice(0,10).split("-");
              if (parts.length < 3) return str;
              return parseInt(parts[2]) + " " + months[parseInt(parts[1])-1] + " " + parts[0];
            };

            const fmtDateRange = (start, end) => {
              const s = fmtDate(start);
              if (!end) return s;
              const e = fmtDate(end);
              return `${s} → ${e}`;
            };

            const byComp = new Map();
            for (const s of signals) {
              const cid = s.competitor_id || "unknown";
              if (!byComp.has(cid)) byComp.set(cid, []);
              byComp.get(cid).push(s);
            }

            const compEntries = [...byComp.entries()].sort((a, b) => {
              const aOv = a[1].filter(s => s.industry_overlap || s.audience_overlap || s.distance_flag).length;
              const bOv = b[1].filter(s => s.industry_overlap || s.audience_overlap || s.distance_flag).length;
              if (bOv !== aOv) return bOv - aOv;
              const aMax = Math.max(...a[1].map(s => Number(s.conflict_score || 0)));
              const bMax = Math.max(...b[1].map(s => Number(s.conflict_score || 0)));
              return bMax - aMax;
            });

            const totalSignals = signals.length;
            const totalComps = compEntries.length;

            const cardsHtml = compEntries.map(([cid, compSignals]) => {
              const first = compSignals[0];
              const name = first.competitor_name || "Concurrent";
              const rating = first.google_rating;
              const ratingCount = first.google_rating_count;
              const photo = first.google_photos;
              const distM = first.distance_from_location_m;
              const distKm = distM ? (Number(distM) / 1000).toFixed(1) : null;

              const hasAudienceOverlap = compSignals.some(s => s.audience_overlap);
              const hasIndustryOverlap = compSignals.some(s => s.industry_overlap);
              const hasDistanceFlag = compSignals.some(s => s.distance_flag);
              const hasAnyOverlap = hasAudienceOverlap || hasIndustryOverlap || hasDistanceFlag;

              const launches = compSignals.filter(s => s.is_launch);
              const active = compSignals.filter(s => s.is_active && !s.is_launch);
              const upcoming = compSignals.filter(s => s.is_upcoming && !s.is_active && !s.is_launch);

              // --- Dynamic takeaway ---
              const AUDIENCE_FR = {
                local: "résidents locaux", professionals: "professionnels",
                tourists: "touristes", students: "étudiants",
                families: "familles", seniors: "seniors",
                general_public: "grand public", art_lovers: "amateurs d'art",
                mixed: "public mixte"
              };
              const locAuds = [first.location_primary_audience_1, first.location_primary_audience_2].filter(Boolean);
              
              // Find shared audiences at COMPETITOR level
              const compAuds = [first.competitor_primary_audience, first.competitor_secondary_audience].filter(Boolean);
              const sharedCompAuds = compAuds.filter(a => locAuds.includes(a)).map(a => AUDIENCE_FR[a] || a);
              
              // Find shared audiences at EVENT level (more precise)
              const eventAuds = [...new Set(compSignals.map(s => s.event_primary_audience).filter(Boolean))];
              const sharedEventAuds = eventAuds.filter(a => locAuds.includes(a)).map(a => AUDIENCE_FR[a] || a);
              
              // Are events short-lived (< 14 days) or long-running?
              const shortEvents = compSignals.filter(s => {
                if (!s.event_date_end) return true;
                const start = new Date(normalizeYmd(s.event_date?.value ?? s.event_date));
                const end = new Date(normalizeYmd(s.event_date_end?.value ?? s.event_date_end));
                return (end - start) / 86400000 < 14;
              });
              const longEvents = compSignals.filter(s => {
                if (!s.event_date_end) return false;
                const start = new Date(normalizeYmd(s.event_date?.value ?? s.event_date));
                const end = new Date(normalizeYmd(s.event_date_end?.value ?? s.event_date_end));
                return (end - start) / 86400000 >= 14;
              });

              let takeaway = "";
              let takeawayAccent = "#1D3BB3";

              if (sharedEventAuds.length > 0 && launches.length > 0) {
                // Highest threat: event-level audience match + launch timing
                takeaway = `Lancement ciblant ${sharedEventAuds.join(" et ")}${distKm ? ` à ${distKm} km` : ""} — captation directe de votre audience.`;
                takeawayAccent = "#E24B4A";
              } else if (sharedEventAuds.length > 0 && shortEvents.length > 0) {
                // Event audience match + short event = real competition
                takeaway = `${shortEvents.length} événement${shortEvents.length > 1 ? "s" : ""} ciblant ${sharedEventAuds.join(" et ")}${distKm ? ` à ${distKm} km` : ""} — concurrence directe sur votre public.`;
                takeawayAccent = "#E24B4A";
              } else if (sharedCompAuds.length > 0 && sharedEventAuds.length === 0) {
                // Competitor targets your audience, but current events don't
                const eventAudLabels = eventAuds.map(a => AUDIENCE_FR[a] || a).join(", ");
                takeaway = eventAudLabels
                  ? `Concurrent ciblant ${sharedCompAuds.join(" et ")}, mais programmation actuelle orientée ${eventAudLabels} — impact limité.`
                  : `Concurrent ciblant ${sharedCompAuds.join(" et ")}${distKm ? ` à ${distKm} km` : ""} — surveiller la programmation.`;
                takeawayAccent = "#EF9F27";
              } else if (sharedEventAuds.length > 0 && longEvents.length > 0 && shortEvents.length === 0) {
                // Only long-running events with audience match = background noise
                takeaway = `Programmation longue ciblant ${sharedEventAuds.join(" et ")} — présence continue, impact diffus.`;
                takeawayAccent = "#EF9F27";
              } else if (hasIndustryOverlap && !hasAudienceOverlap) {
                takeaway = `Même secteur, public différent${distKm ? ` (${distKm} km)` : ""} — concurrence indirecte.`;
                takeawayAccent = "#1D3BB3";
              } else if (hasDistanceFlag && !hasAudienceOverlap && !hasIndustryOverlap) {
                const compAudLabel = compAuds.map(a => AUDIENCE_FR[a] || a).join(", ");
                takeaway = compAudLabel
                  ? `Cible ${compAudLabel}${distKm ? ` à ${distKm} km` : ""} — public différent du vôtre.`
                  : `À proximité${distKm ? ` (${distKm} km)` : ""} — faible risque.`;
                takeawayAccent = "#1D3BB3";
              } else if (!hasAnyOverlap) {
                takeaway = "";
                takeawayAccent = "#9CA3AF";
              } else {
                takeaway = `${compSignals.length} événement${compSignals.length > 1 ? "s" : ""} détecté${compSignals.length > 1 ? "s" : ""}${distKm ? ` à ${distKm} km` : ""}.`;
                takeawayAccent = "#1D3BB3";
              }

              const initials = name.split(" ").map(w => w[0]).join("").slice(0, 2).toUpperCase();
              const photoHtml = photo
                ? `<img style="width:52px;height:52px;border-radius:8px;object-fit:cover;flex-shrink:0;" src="${escapeHtml(photo)}" alt="">`
                : `<div style="width:52px;height:52px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:500;font-size:16px;color:#0C447C;background:#E6F1FB;flex-shrink:0;">${escapeHtml(initials)}</div>`;

              const ratingHtml = rating
                ? `<span style="color:#854F0B;font-weight:500;">★ ${rating}${ratingCount ? ` · ${Number(ratingCount).toLocaleString('fr-FR')} avis` : ''}</span>`
                : '';

              const sharedAudLabel = sharedEventAuds.length ? sharedEventAuds.join(", ") : (sharedCompAuds.length ? sharedCompAuds.join(", ") : null);
              const flagsHtml = (hasAnyOverlap || sharedAudLabel) ? `<div style="display:flex;gap:6px;flex-wrap:wrap;">
                ${sharedAudLabel ? `<span style="font-size:11px;padding:3px 10px;border-radius:20px;background:#FCEBEB;color:#791F1F;">Cible : ${escapeHtml(sharedAudLabel)}</span>` : (hasAudienceOverlap ? '<span style="font-size:11px;padding:3px 10px;border-radius:20px;background:#FCEBEB;color:#791F1F;">Même audience</span>' : '')}
                ${hasIndustryOverlap ? '<span style="font-size:11px;padding:3px 10px;border-radius:20px;background:#FCEBEB;color:#791F1F;">Même secteur</span>' : ''}
                ${hasDistanceFlag ? `<span style="font-size:11px;padding:3px 10px;border-radius:20px;background:#FCEBEB;color:#791F1F;">Proximité${distKm ? ` (${distKm} km)` : ''}</span>` : ''}
              </div>` : '';

              function renderEventRows(events, maxVisible, dotColor) {
                if (!events.length) return "";
                const visible = events.slice(0, maxVisible);
                const hidden = events.slice(maxVisible);
                let html = visible.map(s => {
                  const evName = s.event_name || "—";
                  const venue = s.venue_name || "";
                  const dateStr = s.event_date_end
                    ? fmtDateRange(normalizeYmd(s.event_date?.value ?? s.event_date), normalizeYmd(s.event_date_end?.value ?? s.event_date_end))
                    : fmtDate(normalizeYmd(s.event_date?.value ?? s.event_date));
                  const detailParts = [dateStr, venue].filter(Boolean);
                  return `<div style="display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:0.5px solid #F3F4F6;">
                    <span style="width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:5px;background:${dotColor};"></span>
                    <div style="flex:1;min-width:0;">
                      <div style="font-size:13px;color:#111827;line-height:1.35;">${escapeHtml(evName)}</div>
                      ${detailParts.length ? `<div style="font-size:11px;color:#6B7280;margin-top:2px;">${escapeHtml(detailParts.join(' · '))}</div>` : ''}
                    </div>
                  </div>`;
                }).join("");
                if (hidden.length) {
                  const hiddenHtml = hidden.map(s => {
                    const evName = s.event_name || "—";
                    const venue = s.venue_name || "";
                    const dateStr = s.event_date_end
                      ? fmtDateRange(normalizeYmd(s.event_date?.value ?? s.event_date), normalizeYmd(s.event_date_end?.value ?? s.event_date_end))
                      : fmtDate(normalizeYmd(s.event_date?.value ?? s.event_date));
                    const detailParts = [dateStr, venue].filter(Boolean);
                    return `<div class="ms-comp-extra" style="display:none;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:0.5px solid #F3F4F6;">
                      <span style="width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:5px;background:${dotColor};"></span>
                      <div style="flex:1;min-width:0;">
                        <div style="font-size:13px;color:#111827;line-height:1.35;">${escapeHtml(evName)}</div>
                        ${detailParts.length ? `<div style="font-size:11px;color:#6B7280;margin-top:2px;">${escapeHtml(detailParts.join(' · '))}</div>` : ''}
                      </div>
                    </div>`;
                  }).join("");
                  html += hiddenHtml;
                  html += `<div style="padding:8px 0 0;"><button type="button" onclick="this.parentElement.style.display='none';this.closest('.ms-comp-card').querySelectorAll('.ms-comp-extra').forEach(e=>e.style.display='flex');" style="font-size:11px;font-weight:500;color:#1D3BB3;background:none;border:none;padding:0;cursor:pointer;">+${hidden.length} événement${hidden.length > 1 ? 's' : ''} →</button></div>`;
                }
                return html;
              }

              function section(label, content) {
                if (!content) return "";
                return `<div style="font-size:10px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:#9CA3AF;padding:14px 0 6px;border-top:0.5px solid #F3F4F6;margin-top:12px;">${escapeHtml(label)}</div>${content}`;
              }

              const launchesHtml = launches.length ? section("Lancements événements concurrents", renderEventRows(launches, 3, "#E24B4A")) : "";
              const activeHtml = active.length ? section("Événements en cours", renderEventRows(active, 3, "#1D3BB3")) : "";
              const upcomingHtml = upcoming.length ? section("À venir", renderEventRows(upcoming, 3, "#EF9F27")) : "";

              return `<div class="ms-comp-card" style="background:#fff;border:0.5px solid #E8EDF5;border-radius:12px;overflow:hidden;">
                <div style="display:flex;align-items:center;gap:12px;padding:16px 20px;">
                  ${photoHtml}
                  <div style="flex:1;min-width:0;">
                    <div style="font-size:15px;font-weight:500;color:#111827;margin:0 0 2px;">${escapeHtml(name)}</div>
                    <div style="font-size:12px;color:#6B7280;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
