            { key: "competition", label: "Concurrence", match: function(a) { var s = String(a?.change_subtype||""); return s === "event_new" || s === "competitor_event_launch" || s === "competitor_event_ending" || s === "competitor_audience_conflict" || s === "competition_pressure_spike" || s === "mega_event_activation" || s === "mega_event_end"; } },
            { key: "weather", label: "M\u00e9t\u00e9o", match: function(a) { var s = String(a?.change_subtype||""); return s === "weather_worsened" || s === "weather_improved" || s === "weather_hazard_onset"; } },
            { key: "context", label: "Contexte", match: function() { return true; } },
          ];

          var categoryBuckets = new Map();
          CATEGORY_ORDER.forEach(function(cat) { categoryBuckets.set(cat.key, []); });
          allFeed.forEach(function(a) {
