              partnership: "Partenariat",
              unknown:     "Signal",
            };

            function dayDiff(eventDate, refDate) {
              const e = parseYmdToDate(eventDate);
              const r = parseYmdToDate(refDate);
              if (!e || !r) return null;
              return Math.round((e.getTime() - r.getTime()) / 86400000);
            }

            function impactLabel(diff) {
              if (diff === null) return null;
              if (diff === 0) return { text: "Même jour que votre lancement", color: "#791F1F" };
              if (diff > 0)  return { text: `${diff} jour${diff > 1 ? "s" : ""} après votre lancement`, color: "#6B7280" };
              return { text: `${Math.abs(diff)} jour${Math.abs(diff) > 1 ? "s" : ""} avant votre lancement`, color: "#854F0B" };
            }

            function rowAccentColor(diff) {
              if (diff === null) return "#9CA3AF";
              if (diff === 0)   return "#E24B4A";
              if (Math.abs(diff) <= 3) return "#EF9F27";
              return "#9CA3AF";
            }

            function signalPillStyle(type) {
