                  <div style="padding:10px 20px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;user-select:none;border-top:0.5px solid #E5E7EB;" onclick="(function(e){var el=document.getElementById('${pastId}');var chev=document.getElementById('chev-${pastId}');if(!el)return;var open=el.style.display!=='none';el.style.display=open?'none':'block';if(chev)chev.style.transform=open?'rotate(0deg)':'rotate(180deg)';})(event)">
                    <div style="display:flex;align-items:center;">
