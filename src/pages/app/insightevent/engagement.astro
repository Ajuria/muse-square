---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { Show } from "@clerk/astro/components";
import { EVOL_COPY } from "../../../lib/commitmentCopy";

const id = Astro.url.searchParams.get("id") || "";
---

<Show when="signed-out" client:load>
  <meta http-equiv="refresh" content="0; url=/sign-in" />
</Show>

<Show when="signed-in" client:load>
  <BaseLayout title="Évolution de l'engagement — Muse Square" hideSurveyCta={true} hideFooter={true}>
    <div id="eng-root" data-id={id}>
      <div id="eng-toolbar">
        <a href="/app/insightevent/pulse" id="eng-back">← {EVOL_COPY.back}</a>
      </div>
      <div id="eng-status">Chargement de l'évolution…</div>
      <div id="eng-doc" style="display:none;"></div>
    </div>

    <style is:global>
      #eng-root { max-width: 820px; margin: 0 auto; padding: 16px; font-family: system-ui, -apple-system, sans-serif; color: #111827; }
      #eng-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
      #eng-back { font-size: 14px; color: #6b7280; text-decoration: none; }
      #eng-status { padding: 60px 0; text-align: center; color: #9ca3af; font-size: 14px; }
      #eng-doc { background: #fff; border: 1px solid rgba(0,0,0,0.10); border-radius: 10px; padding: 26px 28px; }
      .eg-uc { font-size: 13px; letter-spacing: .06em; text-transform: uppercase; color: #9ca3af; font-weight: 600; margin-bottom: 10px; }
      .eg-sec { margin-bottom: 26px; }
    </style>

    <script is:inline src="/commit-form.js?v=1"></script>
    <script is:inline src="/card-kit.js?v=26"></script>
    <script is:inline define:vars={{ COPY: EVOL_COPY }}>
      (function () {
        var root = document.getElementById("eng-root");
        var statusEl = document.getElementById("eng-status");
        var docEl = document.getElementById("eng-doc");

        function esc(s) { return String(s == null ? "" : s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }
        function t(key, vars) { var s = COPY[key] || ""; if (vars) for (var k in vars) if (vars.hasOwnProperty(k)) s = s.split("{"+k+"}").join(vars[k]); return s; }
        function showError(msg) { statusEl.textContent = msg; statusEl.style.display = "block"; docEl.style.display = "none"; }
        function doneBtnStyle(sel) { return "font-size:12px;padding:6px 14px;border-radius:6px;cursor:pointer;font-family:inherit;font-weight:600;" + (sel ? "background:#1D3BB3;color:#fff;border:1px solid #1D3BB3;" : "background:#f3f4f6;color:#6b7280;border:1px solid #e5e7eb;"); }

        // ── PURE render moved to the SHARED public/card-kit.js (MSCardKit.renderEvolution),
        //    the SINGLE source verified by public/card-harness.html — same as the system
        //    cards. This page keeps ONLY the interactive wiring (capture POSTs + advice
        //    M'engager sub-form via window.MSCommitForm), attached after the kit renders. ──
        function render(data) {
          if (!data || !data.ok) { showError((data && data.error) || "Engagement introuvable."); return; }
          if (!window.MSCardKit || !MSCardKit.renderEvolution) { showError("Erreur lors du chargement de l'évolution."); return; }
          docEl.innerHTML = MSCardKit.renderEvolution(data, COPY);
          docEl.style.display = "block";
          statusEl.style.display = "none";
          var cm = data.commitment, open = cm.status === "open", advice = data.advice || [];
          wireAdvice(cm, advice);
          wireCapture(cm, open);
          wireDiag(cm);
        }

        // Diagnostic panel — execution self-check (ephemeral highlight) + "Ajuster / Renforcer" which
        // re-commits the action on a fresh window via the shared M'engager form (capture loop).
        function wireDiag(cm) {
          // Exécution self-check — persist (execution_quality) then reload so the recommended move reflects it.
          docEl.querySelectorAll("[data-exec]").forEach(function (b) {
            b.addEventListener("click", function () {
              docEl.querySelectorAll("[data-exec]").forEach(function (x) { x.setAttribute("style", doneBtnStyle(x === b)); });
              fetch("/api/commitments/disposition", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ commitment_id: cm.commitment_id, location_id: cm.location_id, execution_quality: b.getAttribute("data-exec") }) })
                .then(function (r) { return r.json(); }).then(function (j) { if (j && j.ok) setTimeout(load, 350); }).catch(function () {});
            });
          });
          // Guided move: select a move, then Engager → re-commit a child on a fresh window (poursuivre/
          // doubler/pivoter) or Arrêter (soft-cancel → system card reappears via Phase-1 suppression).
          var move = { v: null };
          function moveStyle(sel) { return "display:block;width:100%;text-align:left;box-sizing:border-box;padding:12px 14px;margin-bottom:8px;cursor:pointer;font-family:inherit;" + (sel ? "background:#F5F8FF;border:1px solid #1D3BB3;" : "background:#fff;border:1px solid #e5e7eb;"); }
          var moveBtns = docEl.querySelectorAll("[data-move]");
          moveBtns.forEach(function (b) {
            b.addEventListener("click", function () {
              move.v = b.getAttribute("data-move");
              moveBtns.forEach(function (x) { x.setAttribute("style", moveStyle(x === b)); });
              var q = docEl.querySelector("[data-adjust-noteq]");
              if (q) q.textContent = (move.v === "stop") ? t("diag_move_note_stop_q") : t("diag_move_note_q");
            });
          });
          var submit = docEl.querySelector("[data-adjust-submit]");
          var msg = docEl.querySelector("[data-adjust-msg]");
          if (!submit) return;
          submit.addEventListener("click", function () {
            if (!move.v) { if (msg) { msg.style.color = "#b91c1c"; msg.textContent = "Choisissez un move."; } return; }
            var note = (docEl.querySelector("[data-adjust-note]") || {}).value || "";
            submit.disabled = true; submit.textContent = "…"; if (msg) msg.textContent = "";
            var toPulse = function () { window.location.href = "/app/insightevent/pulse"; };
            var fail = function (j) { submit.disabled = false; submit.textContent = t("diag_move_cta"); if (msg) { msg.style.color = "#b91c1c"; msg.textContent = "Erreur : " + ((j && j.error) || "réessayez"); } };
            if (move.v === "stop") {
              fetch("/api/commitments", { method: "DELETE", headers: { "content-type": "application/json" }, body: JSON.stringify({ commitment_id: cm.commitment_id, location_id: cm.location_id, adjustment_move: "stop", adjustment_note: note }) })
                .then(function (r) { return r.json(); }).then(function (j) { if (j && j.ok) { toPulse(); } else { fail(j); } }).catch(function () { fail(); });
              return;
            }
            // re-commit: child on a fresh window, then supersede (soft-cancel) the parent.
            fetch("/api/commitments", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({
              location_id: cm.location_id, origin_action_type: cm.origin_action_type, window_kind: cm.window_kind || "7d",
              threshold_level: cm.threshold_level || "net", committed_action_text: cm.committed_action_text, owner_person_name: cm.owner_person_name,
              origin_suppression_key: cm.origin_suppression_key || null, adjustment_move: move.v, adjustment_note: note, parent_commitment_id: cm.commitment_id
            }) }).then(function (r) { return r.json(); }).then(function (j) {
              if (!j || !j.ok) { fail(j); return; }
              fetch("/api/commitments", { method: "DELETE", headers: { "content-type": "application/json" }, body: JSON.stringify({ commitment_id: cm.commitment_id, location_id: cm.location_id }) })
                .then(function () { toPulse(); }).catch(function () { toPulse(); });
            }).catch(function () { fail(); });
          });
        }

        function wireCapture(cm, open) {
          var doneState = { v: cm.action_done_status || null };
          docEl.querySelectorAll("[data-done]").forEach(function (b) {
            b.addEventListener("click", function () {
              doneState.v = b.getAttribute("data-done");
              docEl.querySelectorAll("[data-done]").forEach(function (x) { x.setAttribute("style", doneBtnStyle(x === b)); });
            });
          });
          // Documenter (Spec 2) — "À reproduire ?" oui/non toggle (resolved state).
          var repeatState = { v: cm.retro_repeat === true ? "oui" : cm.retro_repeat === false ? "non" : null };
          docEl.querySelectorAll("[data-retro-repeat]").forEach(function (b) {
            b.addEventListener("click", function () {
              repeatState.v = b.getAttribute("data-retro-repeat");
              docEl.querySelectorAll("[data-retro-repeat]").forEach(function (x) { x.setAttribute("style", doneBtnStyle(x.getAttribute("data-retro-repeat") === repeatState.v)); });
            });
          });
          // Read/edit mode (remark #2): Éditer flips to the form; Annuler flips back. Editing rights TBD.
          var readEl = docEl.querySelector("[data-cap-read]"), editEl = docEl.querySelector("[data-cap-edit]");
          function showEdit(on) { if (readEl) readEl.style.display = on ? "none" : "block"; if (editEl) editEl.style.display = on ? "block" : "none"; }
          var editBtn = docEl.querySelector("[data-cap-edit-btn]"); if (editBtn) editBtn.addEventListener("click", function () { showEdit(true); });
          var cancelBtn = docEl.querySelector("[data-cap-cancel]"); if (cancelBtn) cancelBtn.addEventListener("click", function () { showEdit(false); });
          var save = docEl.querySelector("[data-cap-save]"); if (!save) return;
          save.addEventListener("click", function () {
            var msg = docEl.querySelector("[data-cap-msg]"); save.disabled = true; save.textContent = "…";
            // On success, reload → the page re-renders in read mode with the saved values.
            var done = function (ok) { save.disabled = false; save.textContent = t("save"); if (msg) { msg.textContent = ok ? t("saved") : "Erreur"; msg.style.color = ok ? "#166534" : "#b91c1c"; } if (ok) setTimeout(load, 400); };
            if (open) {
              var disp = (docEl.querySelector("[data-dispositif]") || {}).value || "";
              if (!doneState.v) { done(false); return; }
              fetch("/api/commitments/disposition", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ commitment_id: cm.commitment_id, location_id: cm.location_id, action_done_status: doneState.v, dispositif_note: disp }) })
                .then(function (r) { return r.json(); }).then(function (j) { done(j && j.ok); }).catch(function () { done(false); });
            } else {
              var worked = (docEl.querySelector("[data-retro-worked]") || {}).value || "";
              var change = (docEl.querySelector("[data-retro-change]") || {}).value || "";
              var payload = { commitment_id: cm.commitment_id, location_id: cm.location_id, retro_worked: worked, retro_change: change };
              if (repeatState.v) payload.retro_repeat = (repeatState.v === "oui");
              fetch("/api/commitments/retro", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(payload) })
                .then(function (r) { return r.json(); }).then(function (j) { done(j && j.ok); }).catch(function () { done(false); });
            }
          });
        }

        function wireAdvice(cm, advice) {
          docEl.querySelectorAll("[data-adv-cta]").forEach(function (btn) {
            btn.addEventListener("click", function () {
              var i = btn.getAttribute("data-adv-cta");
              var slot = docEl.querySelector('[data-adv-form="'+i+'"]'); if (!slot || !window.MSCommitForm) return;
              if (slot.style.display === "block") { slot.style.display = "none"; slot.innerHTML = ""; return; }
              var a = advice[i], pre = (a && a.prefill) || {};
              slot.style.display = "block";
              slot.innerHTML = window.MSCommitForm.buildHtml({ prefill: { committed_action_text: pre.committed_action_text, window_kind: pre.window_kind || "7d" } });
              window.MSCommitForm.wire(slot, {
                location_id: cm.location_id,
                prefill: { committed_action_text: pre.committed_action_text, window_kind: pre.window_kind || "7d" },
                origin: { origin_action_type: pre.origin_action_type || null },
                onCancel: function () { slot.style.display = "none"; slot.innerHTML = ""; },
                onDone: function (j) { slot.innerHTML = '<div style="padding:12px 14px;font-size:12px;color:'+(j&&j.ok?"#166534":"#b91c1c")+';">'+(j&&j.ok?"Engagement créé. Il sera évalué à l'échéance.":("Erreur : "+esc((j&&j.error)||"réessayez")))+'</div>'; }
              });
            });
          });
        }

        var id = root.dataset.id;
        if (!id) { showError("Engagement manquant dans l'adresse."); return; }
        function load() {
          fetch("/api/commitments/evolution?commitment_id=" + encodeURIComponent(id), { headers: { "accept": "application/json" } })
            .then(function (r) { return r.json(); })
            .then(render)
            .catch(function () { showError("Erreur lors du chargement de l'évolution."); });
        }
        load();
      })();
    </script>
  </BaseLayout>
</Show>
