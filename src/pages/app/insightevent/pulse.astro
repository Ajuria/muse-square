        const isOpen = body.style.display !== "none";
        _voletIds.forEach(other => { if (other !== id) _setVoletOpen(other, false); });
        _setVoletOpen(id, !isOpen);
        try { localStorage.setItem(_radarOpenKey, isOpen ? "" : id); } catch (e) {}
      });
    });
    // Restaure le volet ouvert lors de la dernière visite.
    try {
      const _savedOpen = localStorage.getItem(_radarOpenKey);
