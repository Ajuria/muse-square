            + '</div>'
          + '</div></div></div>'
          + '<div style="display:flex;align-items:center;gap:8px;margin-top:4px;padding:0 4px;">'
            + '<div style="flex:1;height:3px;background:#E5E7EB;border-radius:2px;overflow:hidden;"><div style="height:100%;background:#059669;width:0%;border-radius:2px;"></div></div>'
            + '<span style="font-size:10px;color:#6B7280;">0/1</span>'
