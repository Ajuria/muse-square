        perfChip = { label: (_ssPct >= 0 ? "+" : "−") + Math.abs(Math.round(_ssPct)) + " % vs moy. 30 j", bg: _ssSv.bg, fg: _ssSv.fg };
        if (_ssOut) perfAccent = _ssSv.ac;
