  // Channel constants — used for future agent routing + clipboard context
  var CH_GBP = "gbp";           // Google Business Profile
  var CH_INSTAGRAM = "instagram";
  var CH_EMAIL = "email";
  var CH_SMS = "sms";
  var CH_INTERNAL = "internal";  // On-site / team operations (no external channel)
  var CH_PHONE = "phone";        // Phone/WhatsApp to suppliers, partners

  // ---- Clipboard text generator ----
  // Produces a ready-to-paste message from the card context + action text
  function briefClipboardText(cardWhat, cardSowhat, actionText) {
    // Strip HTML tags from what
    var cleanWhat = String(cardWhat||"").replace(/<[^>]+>/g,"");
    return cleanWhat + "\n" + actionText;
  }

  // ---- AI sowhat generator ----
  var _sowhatCache = {};
  async function fetchSowhat(signals, profile, day) {
    var cacheKey = signals.map(function(s) { return s.signal_id; }).sort().join("|") + "|" + normalizeYmd(day.date);
    if (_sowhatCache[cacheKey]) return _sowhatCache[cacheKey];
    try {
      var res = await fetch("/api/insight/generate-sowhat", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ signals: signals, profile: profile, day: day }),
      });
      var json = await res.json().catch(function() { return null; });
      if (json?.ok && Array.isArray(json.results)) {
        var map = {};
        for (var i = 0; i < json.results.length; i++) {
          if (json.results[i].signal_id && json.results[i].sowhat) {
            map[json.results[i].signal_id] = json.results[i].sowhat;
          }
        }
        _sowhatCache[cacheKey] = map;
        return map;
      }
    } catch {}
    return {};
  }

  var _teamMembersCache = null;
  async function fetchTeamMembers(locationId) {
    if (_teamMembersCache !== null) return _teamMembersCache;
    try {
      var res = await fetch("/api/channels/team?location_id=" + encodeURIComponent(locationId));
      var json = await res.json().catch(function() { return null; });
      if (json && json.ok && Array.isArray(json.items)) {
        _teamMembersCache = json.items;
        return _teamMembersCache;
      }
    } catch(e) {}
    _teamMembersCache = [];
    return [];
  }

  var _channelConfigsCache = null;
  async function fetchChannelConfigs(locationId) {
    if (_channelConfigsCache !== null) return _channelConfigsCache;
    try {
      var res = await fetch("/api/channels/config?location_id=" + encodeURIComponent(locationId));
      var json = await res.json().catch(function() { return null; });
      if (json && json.ok && Array.isArray(json.items)) {
        _channelConfigsCache = {};
        json.items.forEach(function(item) { if (item.enabled) _channelConfigsCache[item.channel] = item.config; });
        return _channelConfigsCache;
      }
    } catch(e) {}
    _channelConfigsCache = {};
    return {};
  }

  var _pendingFeedbackCache = [];
  async function fetchPendingFeedback(locationId) {
    try {
      var lsKey = "ms_feedback_dismissed_" + locationId;
