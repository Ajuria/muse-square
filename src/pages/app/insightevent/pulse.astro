    }
    // ---- audience_mismatch (client-side only — needs profile join) ----
    var audLabel = String(currentDay.audience_availability_label || "").toLowerCase();
    var myAudComp = String(prof.primary_audience_1 || "").toLowerCase();
    var AUD_FR_COMP = {local:"r\u00e9sidents locaux",professionals:"professionnels",tourists:"touristes",students:"\u00e9tudiants",families:"familles",seniors:"seniors"};
    var myAudLabelComp = AUD_FR_COMP[myAudComp] || "";
    var audMismatch = false;
    if (myAudComp === "professionals" && (audLabel.indexOf("vacances") >= 0 || audLabel.indexOf("f\u00e9ri\u00e9") >= 0 || audLabel.indexOf("famille") >= 0)) audMismatch = true;
    if (myAudComp === "tourists" && audLabel.indexOf("touris") < 0 && audLabel.indexOf("f\u00e9ri\u00e9") < 0 && audLabel.indexOf("vacances") < 0) audMismatch = true;
    if ((myAudComp === "local" || myAudComp === "families") && audLabel.indexOf("professionnel") >= 0 && audLabel.indexOf("vacances") < 0) audMismatch = true;
    if (audMismatch && myAudLabelComp) {
      var audAvailable = audLabel.indexOf("touris") >= 0 ? "touristes" : audLabel.indexOf("famille") >= 0 ? "familles" : audLabel.indexOf("f\u00e9ri\u00e9") >= 0 ? "public jour f\u00e9ri\u00e9" : audLabel.indexOf("vacances") >= 0 ? "vacanciers" : audLabel.indexOf("soldes") >= 0 || audLabel.indexOf("commercia") >= 0 ? "acheteurs" : "public diff\u00e9rent";
      candidates.push({ item: { change_subtype:"_audience_mismatch", affected_date:currentDay.date, alert_level:2, location_label: currentDay.location_label || "" }, tmpl: {
        type:"threat", barClass:"ab-warning",
        urgencyPill:{label:"Aujourd\u2019hui",style:"background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);"},
        typePill:{label:"Audience",style:"background:#EFF6FF;color:#1e40af;"},
        what: "Public du jour : " + audAvailable + " \u2014 votre cible (" + myAudLabelComp + ") est moins disponible",
        sowhat: (function() {
          var peak = currentDay ? Number(currentDay.ft_peak_hour || 0) : 0;
          var peakStr = peak > 0 ? peak + "h" : "";
          return "Public du jour : " + audAvailable + ". Votre cible (" + myAudLabelComp + ") est moins disponible." + (peakStr ? " Pic \u00e0 " + peakStr + " \u2014 adaptez vos effectifs en cons\u00e9quence." : " R\u00e9duisez vos effectifs ou adaptez votre offre.");
        })(),
        actions: [
          {text:"R\u00e9duisez votre \u00e9quipe si la fr\u00e9quentation cible sera faible",meta:"Exploitation \u00b7 \u00c9quipe",key:"staff_adjust",channel:CH_INTERNAL},
          {text:"Publiez un post adapt\u00e9 au public disponible (" + audAvailable + ")",meta:"Communication \u00b7 Adaptation",key:"visitor_comm",channel:CH_GBP},
        ],
      }, score: 65 });
    }

    candidates.sort(function(a,b) { return b.score - a.score; });
    var seen = {};
    var top = [];
    var _catCounts = {};
    var MAX_PER_CAT = 2;

    // Goal pass: up to 3 cards serving the active weekly goal, surfaced first.
    var _goalTypes = (activeGoalKey && window.GOAL_SERVING_TYPES) ? (window.GOAL_SERVING_TYPES[activeGoalKey] || []) : [];
    var _goalSet = {};
    for (var _gi = 0; _gi < _goalTypes.length; _gi++) _goalSet[String(_goalTypes[_gi]).toLowerCase()] = true;
    if (_goalTypes.length) {
      var _goalCount = 0;
      for (var _gj = 0; _gj < candidates.length && _goalCount < 3; _gj++) {
        var _gc = candidates[_gj];
        var _gsub = String(_gc.item.change_subtype||"").toLowerCase();
        if (!_goalSet[_gsub]) continue;
        var _gDedupSub = (_gsub === "weather_hazard_onset" || _gsub === "weather_worsened") ? "weather_alert" : (_gsub === "high_competition_density" || _gsub === "competition_proximity") ? "competition_density" : _gsub;
        var _gDedup = _gDedupSub + "|" + normalizeYmd(_gc.item.affected_date);
        if (seen[_gDedup]) continue;
        seen[_gDedup] = true;
        _gc.tmpl._goal_card = true;
        top.push(_gc);
        _goalCount++;
      }
    }

    // Context pass: fill up to 8 total (≈5 context after up to 3 goal cards).
    for (var j = 0; j < candidates.length && top.length < 8; j++) {
      var c = candidates[j];
      var sub2 = String(c.item.change_subtype||"").toLowerCase();
      var dedupSub = (sub2 === "weather_hazard_onset" || sub2 === "weather_worsened") ? "weather_alert" : (sub2 === "high_competition_density" || sub2 === "competition_proximity") ? "competition_density" : sub2;
      var dedup = dedupSub + "|" + normalizeYmd(c.item.affected_date);
      if (seen[dedup]) {
        var existingIdx = top.findIndex(function(t) { return (String(t.item.change_subtype||"").toLowerCase() === dedupSub || ((dedupSub === "weather_alert") && (String(t.item.change_subtype||"").toLowerCase() === "weather_hazard_onset" || String(t.item.change_subtype||"").toLowerCase() === "weather_worsened"))) && normalizeYmd(t.item.affected_date) === normalizeYmd(c.item.affected_date); });
        if (existingIdx >= 0 && c.item.location_label && top[existingIdx].item.location_label && top[existingIdx].item.location_label.indexOf(c.item.location_label) < 0) {
          top[existingIdx].item.location_label += " \u00b7 " + c.item.location_label;
        }
        continue;
      }
      seen[dedup] = true;
      var catKey = dedupSub.startsWith("weather") || dedupSub === "_extended_bad_weather" || dedupSub === "_saturated_bad_weather" || dedupSub === "_ft_peak_bad_weather" || dedupSub === "_weather_window" || dedupSub === "_weather_mobility_double" ? "_weather" : dedupSub.startsWith("calendar_") || dedupSub === "_audience_mismatch" ? "_audience" : null;
      if (catKey) {
        var catCount = top.filter(function(t) { var s2 = String(t.item.change_subtype||"").toLowerCase(); return catKey === "_weather" ? (s2.startsWith("weather") || s2 === "_extended_bad_weather" || s2 === "_saturated_bad_weather" || s2 === "_ft_peak_bad_weather" || s2 === "_weather_window" || s2 === "_weather_mobility_double" || s2 === "_weather_hazard_onset") : (s2.startsWith("calendar_") || s2 === "_audience_mismatch"); }).length;
        if (catCount >= 1) continue;
      }
      var _acCat = String(c.item.action_category || c.item.change_subtype || "other").toLowerCase();
      _catCounts[_acCat] = (_catCounts[_acCat] || 0) + 1;
      if (_catCounts[_acCat] > MAX_PER_CAT) continue;
      top.push(c);
    }

    // ---- Resolve sowhat: render fallback now, store payload for async replacement ----
    var _aiSowhatPayload = [];
    for (var si = 0; si < top.length; si++) {
