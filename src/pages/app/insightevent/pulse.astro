    });

    // Radar strip toggles — v5: accordéon (un volet ouvert à la fois), état mémorisé par site,
    // carte Concurrence initialisée au premier dépliage (Leaflet lazy).
    const _radarOpenKey = "ms_radar_open_" + currentLocationId;
    const _setVoletOpen = (id, open) => {
      const body = root.querySelector(`[data-radar-body="${id}"]`);
