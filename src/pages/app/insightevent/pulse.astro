---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { Show } from "@clerk/astro/components";
import PiloterBottomBar from "../../../components/PiloterBottomBar.astro";

const location_id =
  Astro.locals && typeof (Astro.locals as any).location_id === "string" && (Astro.locals as any).location_id.trim()
    ? (Astro.locals as any).location_id.trim()
    : null;

if (!location_id) {
  return Astro.redirect("/profile");
}
---

<Show when="signed-out" client:load>
  <script is:inline>window.location.href = "/sign-in";</script>
</Show>

<Show when="signed-in" client:load>
  <BaseLayout title="Pulse — Insight Event" hideSurveyCta={true} hideFooter={true}>

    <style is:inline>
      .mon-wrap {
        width: 100%;
        max-width: 720px;
        margin: 0 auto;
        padding: 20px 20px 160px 20px;
        box-sizing: border-box;
        overflow: visible;
      }

      .mon-card {
        background: #FFFFFF;
        border: 1px solid #E8EDF5;
        border-radius: 14px;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(17,24,39,0.06);
      }

      .mon-card-decision {
        background: rgba(29,59,179,0.04);
        border-left: 6px solid #0b37e5;
        padding: 24px;
        border-radius: 0;
      }

      .mon-panels {
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding-top: 16px;
      }

      .mon-kicker {
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.10em;
        text-transform: uppercase;
        color: #1D3BB3;
        line-height: 1.1;
        margin: 0 0 6px 0;
      }

      .mon-head {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
      }

      .mon-ico { width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
      .mon-ico svg { display: block; }

      .mon-tabs-bar {
        display: flex;
        justify-content: flex-start;
        align-items: flex-end;
        gap: 22px;
        padding: 0 24px;
        border-bottom: none;
        margin: 16px -24px -24px -24px;
      }

      .mon-tab {
        appearance: none;
        border: none;
        background: transparent;
        font-size: 14px;
        font-weight: 500;
        color: #94A3B8;
        padding: 0 0 16px 0;
        position: relative;
        cursor: pointer;
      }

      .mon-tab.is-active { color: #1D3BB3; }
      .mon-tab.is-active::after {
        content: "";
        position: absolute;
        left: 0; bottom: 0;
        height: 3px; width: 100%;
        background: #1D3BB3;
        border-radius: 3px;
      }

      .mon-feed-item {
        display: flex; align-items: flex-start; gap: 12px;
        padding: 14px 0; border-bottom: 1px solid #F3F4F6;
      }
      .mon-feed-item:last-child { border-bottom: none; }
      .mon-feed-line1 { font-size: 14px; font-weight: 700; color: #111827; line-height: 1.3; margin-bottom: 3px; }
      .mon-feed-line2 { font-size: 13px; color: #374151; line-height: 1.4; margin-bottom: 2px; }
      .mon-feed-line3 { font-size: 12px; color: #6B7280; }
      .mon-feed-line4 { font-size: 12px; color: #6B7280; }

      .mon-vigilance-item {
        display: flex; align-items: flex-start; gap: 10px;
        font-size: 14px; color: #374151; line-height: 1.45;
        padding: 8px 0; border-bottom: 1px solid #F3F4F6;
      }
      .mon-vigilance-item:last-child { border-bottom: none; }

      .mon-status-ok   { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 600; color: #059669; }
      .mon-loading { padding: 40px 0; text-align: center; color: #9CA3AF; font-size: 14px; }
      .mon-error { padding: 20px; background: rgba(220,38,38,0.06); border-radius: 10px; color: #B91C1C; font-size: 13px; margin-top: 16px; }

      .mon-statut-safe { background: var(--color-pill-safe-bg); color: var(--color-pill-safe-text); padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
      .mon-statut-warn { background: var(--color-pill-warn-bg); color: var(--color-pill-warn-text); border: 1px solid var(--color-pill-warn-border); padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
      .mon-statut-risk { background: var(--color-pill-risk-bg); color: var(--color-pill-risk-text); border: 1px solid var(--color-pill-risk-border); padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }

      /* ---- Date pills ---- */
      .pls-pills {
        display: flex; gap: 6px; flex-wrap: wrap;
        padding: 12px 0 0 0;
      }

      .pls-pill {
        padding: 5px 12px; border-radius: 999px;
        font-size: 12px; font-weight: 600;
        border: 1px solid #e5e7eb;
        background: #fff; color: #6b7280;
        cursor: pointer; white-space: nowrap;
        transition: all 100ms;
        display: inline-flex; align-items: center; gap: 6px;
      }
      .pls-pill.is-today { border-color: #1D3BB3; color: #1D3BB3; }
      .pls-pill.is-active { background: #1D3BB3; border-color: #1D3BB3; color: #fff; }
      .pls-pill.has-crit  { border-color: #e24b4a; }
      .pls-pill.has-warn  { border-color: #ef9f27; }
      .pls-pill-dot {
        width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
      }

      /* ---- Location switcher ---- */
      .pls-loc-row {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 4px;
      }
      .pls-loc-name { font-size: 13px; font-weight: 600; color: #111827; }
      .pls-loc-addr { font-size: 12px; color: #9ca3af; }
      .pls-loc-btn {
        font-size: 12px; font-weight: 600; color: #1D3BB3;
        background: none; border: none; cursor: pointer; padding: 0;
      }

      .mon-context-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 8px; }
      .mon-context-cell { display: flex; flex-direction: column; gap: 2px; }
      .mon-context-label { font-size: 11px; color: #9CA3AF; text-transform: uppercase; letter-spacing: .06em; }
      .mon-context-value { font-size: 13px; color: #111827; }

      .mon-map-btn {
        height: 36px; border: 1px solid #E5E7EB; border-radius: 6px;
        background: #f9fafb; color: #6b7280;
        font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
        text-transform: uppercase; cursor: pointer;
      }
      .mon-map-btn.is-active { border-color: #0b37e5; color: #0b37e5; }

      /* ---- Daily Action Brief ---- */
      .ab-card { background:#fff; border:1px solid #E8EDF5; border-radius:0; overflow:hidden; margin-bottom:8px; }
      .ab-card-row { display:flex; }
      .ab-bar { width:3px; flex-shrink:0; }
      .ab-bar.ab-threat { background:#e24b4a; }
      .ab-bar.ab-warning { background:#ef9f27; }
      .ab-bar.ab-opportunity { background:#059669; }
      .ab-inner { flex:1; min-width:0; }
      .ab-summary { padding:14px 16px; cursor:pointer; }
      .ab-pills { display:flex; gap:5px; flex-wrap:wrap; margin-bottom:6px; }
      .ab-pill { font-size:9px; font-weight:700; padding:2px 7px; border-radius:0; text-transform:uppercase; letter-spacing:0.03em; }
      .ab-what { font-size:13px; font-weight:600; color:#111827; line-height:1.35; margin-bottom:4px; }
      .ab-sowhat { font-size:12px; color:#6B7280; line-height:1.4; }
      .ab-toggle { display:flex; align-items:center; padding:0 16px 12px; }
      .ab-toggle-btn { font-size:12px; font-weight:700; color:#1D3BB3; background:none; border:none; cursor:pointer; padding:0; font-family:inherit; display:flex; align-items:center; gap:5px; }
      .ab-actions { display:none; padding:0 16px 14px; border-top:1px solid #F3F4F6; }
      .ab-actions.is-open { display:block; }
      .ab-action-item { display:flex; align-items:flex-start; gap:10px; padding:10px 0; border-bottom:1px solid #F9FAFB; }
      .ab-action-item:last-of-type { border-bottom:none; }
      .ab-check { width:18px; height:18px; border:1.5px solid #d1d5db; border-radius:0; flex-shrink:0; margin-top:1px; display:flex; align-items:center; justify-content:center; cursor:pointer; background:#fff; transition:all 0.1s; }
      .ab-check.is-checked { background:#059669; border-color:#059669; }
      .ab-action-text { font-size:12.5px; color:#111827; line-height:1.4; }
      .ab-action-text.is-done { text-decoration:line-through; color:#6B7280; }
      .ab-action-meta { font-size:10px; color:#6B7280; margin-top:2px; }
      .ab-action-right { display:flex; flex-direction:column; align-items:flex-end; gap:4px; flex-shrink:0; margin-left:auto; padding-top:2px; }
      .ab-copy { font-size:10px; font-weight:600; color:#1D3BB3; background:none; border:none; cursor:pointer; padding:0; font-family:inherit; white-space:nowrap; }
      .ab-copy.is-copied { color:#059669; }
      .ab-progress { display:flex; align-items:center; gap:8px; margin-top:8px; }
      .ab-progress-bar { flex:1; height:3px; background:#E5E7EB; overflow:hidden; }
      .ab-progress-fill { height:100%; background:#059669; transition:width 0.3s; }
      .ab-progress-label { font-size:10px; color:#6B7280; white-space:nowrap; }
      .ab-help-link { display:block; margin-top:10px; padding-top:10px; border-top:1px solid #F3F4F6; font-size:11px; color:#1D3BB3; text-decoration:none; font-weight:500; }
      .ab-zero { background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.15); border-radius:0; padding:16px 18px; display:flex; align-items:center; gap:10px; font-size:13px; font-weight:500; color:#059669; }
      .ab-gen { font-size:10px; font-weight:600; color:#1D3BB3; background:none; border:none; cursor:pointer; padding:0; font-family:inherit; white-space:nowrap; }
      .ab-gen.is-loading { color:#9CA3AF; pointer-events:none; }
      .ab-draft-panel { display:none; margin-top:8px; padding:10px 12px; background:#f8fafc; border:1px solid #E8EDF5; border-radius:8px; font-size:12px; color:#111827; line-height:1.5; }
      .ab-draft-panel.is-open { display:block; }
      .ab-draft-panel pre { white-space:pre-wrap; word-break:break-word; margin:0 0 8px; font-family:inherit; font-size:12px; }
      .ab-draft-actions { display:flex; gap:12px; align-items:center; margin-top:6px; }
      .ab-draft-copy { font-size:11px; font-weight:600; color:#059669; background:none; border:none; cursor:pointer; padding:0; font-family:inherit; }
      .ab-draft-regen { font-size:11px; font-weight:600; color:#1D3BB3; background:none; border:none; cursor:pointer; padding:0; font-family:inherit; }
      .ab-draft-dismiss { font-size:11px; color:#9CA3AF; background:none; border:none; cursor:pointer; padding:0; font-family:inherit; }
      .ab-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:9999; align-items:flex-end; justify-content:center; }
      .ab-overlay.is-open { display:flex; }
      .ab-form-panel { background:#fff; width:100%; max-width:720px; border-top:3px solid #1D3BB3; padding:20px 20px 32px; animation:abSlideUp 0.2s ease-out; }
      @keyframes abSlideUp { from{transform:translateY(100%);opacity:0} to{transform:translateY(0);opacity:1} }
      .ab-form-title { font-size:14px; font-weight:700; color:#111827; margin-bottom:14px; }
      .ab-form-ctx { background:#f9fafb; border:1px solid #E8EDF5; padding:10px 12px; margin-bottom:14px; font-size:12px; color:#6B7280; line-height:1.4; }
      .ab-form-label { font-size:11px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#6B7280; margin-bottom:6px; }
      .ab-form-textarea { width:100%; padding:10px 12px; border:1px solid #E5E7EB; font-size:13px; color:#111827; background:#f9fafb; resize:vertical; min-height:80px; font-family:inherit; margin-bottom:14px; }
      .ab-form-submit { width:100%; padding:12px; background:#1D3BB3; color:#fff; border:none; font-size:14px; font-weight:700; cursor:pointer; font-family:inherit; }
      .ab-form-cancel { width:100%; padding:10px; background:none; color:#6B7280; border:none; font-size:13px; font-weight:500; cursor:pointer; font-family:inherit; margin-top:6px; }

    </style>

    <div class="mon-wrap">
      <!-- Location row -->
      <div class="pls-loc-row" style="margin-bottom:16px;">
        <div>
          <div class="pls-loc-name" id="pls-loc-name"></div>
          <div class="pls-loc-addr" id="pls-loc-addr"></div>
          <div id="pls-subtitle" style="font-size:11px;font-weight:600;letter-spacing:0.10em;text-transform:uppercase;color:#9CA3AF;margin-top:4px;">Veille opérationnelle · 7 jours</div>
        </div>
        <button type="button" class="pls-loc-btn" id="pls-loc-switch" style="display:none;">
          Changer de site
        </button>
      </div>

      <div id="pls-root">
        <div style="display:flex;align-items:center;justify-content:center;padding:24px 0;">
          <img src="/icons/load/ms_load_icon.gif" alt="" style="height:120px;width:auto;" loading="lazy" />
        </div>
      </div>
    </div>

    <!-- Action Brief — concierge help overlay -->
    <div class="ab-overlay" id="ab-help-overlay">
      <div class="ab-form-panel">
        <div class="ab-form-title">Besoin d'aide pour agir ?</div>
        <div class="ab-form-ctx" id="ab-help-ctx">Décrivez ce dont vous avez besoin. Notre équipe vous répond sous 2 heures.</div>
        <div class="ab-form-label">Votre demande</div>
        <textarea class="ab-form-textarea" id="ab-help-note" placeholder="Ex : aidez-moi à créer un post Instagram avec l'itinéraire alternatif."></textarea>
        <button class="ab-form-submit" id="ab-help-submit">Envoyer — réponse sous 2h</button>
        <button class="ab-form-cancel" id="ab-help-cancel">Annuler</button>
      </div>
    </div>

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script is:inline src="/map-markers.js"></script>
  
  <PiloterBottomBar active="veille" />

  </BaseLayout>
</Show>

<script is:inline define:vars={{ location_id }}>
(function () {

  // ----------------------------------------------------------------
  // Helpers (same as monitor.astro)
  // ----------------------------------------------------------------
  function escapeHtml(v) {
    return String(v ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#039;");
  }

  function normalizeYmd(v) {
    const s = String(v ?? "").trim();
    const m = s.match(/^(\d{4}-\d{2}-\d{2})/);
    return m ? m[1] : "";
  }

  function parseYmdToDate(ymd) {
    const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(String(ymd||"").trim());
    if (!m) return null;
    return new Date(Date.UTC(+m[1], +m[2]-1, +m[3]));
  }

  function fmtDateLong(ymd) {
    const d = parseYmdToDate(ymd);
    if (!d) return ymd;
    const s = new Intl.DateTimeFormat("fr-FR", { weekday:"long", day:"numeric", month:"long", year:"numeric" }).format(d);
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  function fmtDateShort(ymd) {
    const d = parseYmdToDate(ymd);
    if (!d) return ymd;
    const dow = ["LUN","MAR","MER","JEU","VEN","SAM","DIM"][((d.getUTCDay()+6)%7)];
    return `${dow} ${String(d.getUTCDate()).padStart(2,"0")}`;
  }

  function todayYmd() {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`;
  }

  function getToday() {
    const d = new Date();
    return new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
  }

  function addDays(dateUTC, n) {
    const d = new Date(dateUTC);
    d.setUTCDate(d.getUTCDate() + n);
    return d;
  }

  function ymdFromUTC(d) {
    return `${d.getUTCFullYear()}-${String(d.getUTCMonth()+1).padStart(2,"0")}-${String(d.getUTCDate()).padStart(2,"0")}`;
  }

  function getLastVisitTimestamp(key) {
    try { return parseInt(localStorage.getItem(key) || "0", 10) || 0; } catch { return 0; }
  }

  function setLastVisitTimestamp(key) {
    try { localStorage.setItem(key, String(Date.now())); } catch {}
  }

  function filterFeedByWindow(allFeed, lastVisitTs) {
    const today = getToday();
    const windowStart = ymdFromUTC(addDays(today, -7));
    const windowEnd   = ymdFromUTC(addDays(today, 6));
    const mobilityEnd = ymdFromUTC(addDays(today, 14));

    const competitionEnd = ymdFromUTC(addDays(today, 14));

    return allFeed.filter(a => {
      const affected = normalizeYmd(a?.affected_date);
      const feedDate = normalizeYmd(a?.feed_date);
      if (!affected) return false;

      const sub = String(a?.change_subtype || "").toLowerCase();
      const isMobility = String(a?.change_category || "").toLowerCase() === "mobility"
        || sub.startsWith("mobility_");
      const isWeather  = String(a?.change_category || "").toLowerCase() === "context" &&
                        sub === "weather_change";
      const isCompetition = sub === "competitor_event_launch" || sub === "competitor_audience_conflict"
        || sub === "competition_pressure_spike" || sub === "mega_event_activation"
        || sub === "competitor_event_ending" || sub === "mega_event_end";

      const maxDate = isMobility ? mobilityEnd : isCompetition ? competitionEnd : windowEnd;

      if (affected < windowStart || affected > maxDate) return false;
      if (isWeather && affected > windowEnd) return false;

      if (lastVisitTs > 0) {
        const fd = feedDate ? new Date(feedDate).getTime() : 0;
        if (fd > 0 && fd <= lastVisitTs) return false;
      }

      // Skip mobility items with no mode (unmatched road incidents)
      if (isMobility && !a?.mobility_mode) return false;

      return true;
    });
  }

  const BLOCK_LABELS = {
    attendance:   'FRÉQUENTATION',
    operations:   'EXPLOITATION',
    installation: 'INSTALLATION',
    context:      'CONTEXTE',
  };

  function computeStatusPill(day) {
    if (day?.is_forced_regime_c_flag === true) {
      return { cls: 'mon-statut-risk', label: 'À RISQUE' };
    }
    const all = [
      ...(day?.attendance   || []),
      ...(day?.operations   || []),
      ...(day?.installation || []),
      ...(day?.context      || []),
    ].filter(r => r.severity !== 'A');

    if (!all.length) {
      return { cls: 'mon-statut-safe', label: 'SANS RISQUE' };
    }

    const maxSev = all.reduce((max, r) => {
      return (['D','C','B'].indexOf(r.severity) < ['D','C','B'].indexOf(max) ? r.severity : max);
    }, 'B');

    const cls = (maxSev === 'D' || maxSev === 'C') ? 'mon-statut-risk' : 'mon-statut-warn';

    if (all.length === 1) {
      const block = all[0].block;
      const label = 'ALERTE ' + (BLOCK_LABELS[block] || block.toUpperCase());
      return { cls, label };
    }

    const count = all.length;
    return { cls, label: `${count} RISQUES` };
  }



  function next8Days() {
    const dates = [];
    const base = new Date();
    for (let i = 0; i < 7; i++) {
      const d = new Date(base);
      d.setDate(base.getDate() + i);
      dates.push(`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`);
    }
    return dates;
  }

  function pill(label, style) {
    return `<span style="display:inline-block;font-size:11px;font-weight:600;padding:2px 10px;border-radius:20px;${style}">${escapeHtml(label)}</span>`;
  }

  const GREEN  = "background:var(--color-pill-green-bg);color:var(--color-pill-green-text);";
  const YELLOW = "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);border:1px solid var(--color-pill-warn-border);";
  const AMBER  = "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);border:1px solid var(--color-pill-warn-border);";
  const RED    = "background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);border:1px solid var(--color-pill-risk-border);";

  function severityDots(level) {
    const l = Math.min(4, Math.max(1, Number(level)||1));
    return [1,2,3,4].map(i =>
      `<span style="width:8px;height:8px;border-radius:50%;display:inline-block;background:${i<=l?"#1D3BB3":"#E2E8F0"};"></span>`
    ).join("&nbsp;");
  }

  function iconSVG(kind) {
    if (kind==="alert")   return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 9v4" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"/><path d="M12 17h.01" stroke="#1D3BB3" stroke-width="3" stroke-linecap="round"/><path d="M10.3 4.3l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.7-2.7l-8-14a2 2 0 0 0-3.4 0z" stroke="#1D3BB3" stroke-width="1.6"/></svg>`;
    if (kind==="context") return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 2v3M17 2v3" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"/><path d="M3.5 9h17" stroke="#1D3BB3" stroke-width="1.6"/><path d="M6 5h12a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z" stroke="#1D3BB3" stroke-width="1.6"/></svg>`;
    return "";
  }

  function feedCatIcon(cat) {
    const c = String(cat||"").toLowerCase();
    if (c==="competition") return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M8 21v-7M12 21V3M16 21v-11"/></svg>`;
    if (c==="opportunity") return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>`;
    if (c==="context")     return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.3 4.3l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.7-2.7l-8-14a2 2 0 0 0-3.4 0z"/></svg>`;
    if (c==="mobility")    return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M7 16h10l1-6H6l1 6z"/><path d="M7 16l-1 4M17 16l1 4"/><path d="M9 10V7a3 3 0 0 1 6 0v3"/></svg>`;
    return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/></svg>`;
  }

  // ----------------------------------------------------------------
  // Feed rendering (identical to monitor.astro)
  // ----------------------------------------------------------------
  function feedModeIcon(mode) {
    const m = String(mode || "").toLowerCase();
    if (m === "metro" || m === "métro") return '<span style="width:16px;height:16px;border-radius:3px;display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;background:#EDE9FE;color:#5B21B6;">M</span>';
    if (m === "bus") return '<span style="width:16px;height:16px;border-radius:3px;display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;background:#DBEAFE;color:#1E40AF;">B</span>';
    if (m === "rer") return '<span style="width:16px;height:16px;border-radius:3px;display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;background:#FEF3C7;color:#92400E;">R</span>';
    if (m === "tram") return '<span style="width:16px;height:16px;border-radius:3px;display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;background:#D1FAE5;color:#065F46;">T</span>';
    if (m === "road") return '<span style="width:16px;height:16px;border-radius:3px;display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;background:#FEE2E2;color:#991B1B;">R</span>';
    return '';
  }

  function feedDistancePill(distM) {
    if (distM == null || !Number.isFinite(Number(distM))) return '';
    const d = Number(distM);
    const label = d < 1000 ? Math.round(d) + ' m' : (d / 1000).toFixed(1) + ' km';
    const cls = d < 500 ? 'background:#FEF2F2;color:#991B1B;' : d < 3000 ? 'background:#FFFBEB;color:#92400E;' : 'background:#F3F4F6;color:#6B7280;';
    return '<span style="display:inline-flex;align-items:center;font-size:10px;padding:1px 7px;border-radius:3px;font-weight:600;' + cls + '">' + label + '</span>';
  }

  function feedMobilityImpact(distM, mode) {
    const d = Number(distM || 0);
    const m = String(mode || "").toLowerCase();
    if (!d || !Number.isFinite(d)) return '';
    if (m === "road") {
      if (d < 2000) return 'Acc\u00e8s v\u00e9hicules impact\u00e9';
      return 'Impact livraisons / prestataires';
    }
    if (d < 500) return 'Impact acc\u00e8s clients';
    return 'Transport en commun';
  }
  
  function feedLine1(a) {
    const sub  = String(a?.change_subtype || "").toLowerCase();
    const d    = fmtDateShort(normalizeYmd(a?.affected_date));
    const ov   = a?.old_value != null ? String(a.old_value) : null;
    const nv   = a?.new_value != null ? String(a.new_value) : null;
    const delta = a?.score_delta != null ? Math.round(Number(a.score_delta)) : null;
    const name  = a?.event_label || "";
    const km    = a?.distance_m != null ? `${(Number(a.distance_m)/1000).toFixed(1)} km` : null;
    const mode  = String(a?.mobility_mode || "").toLowerCase();
    const lvlRain = Number(a?.lvl_rain || 0);
    const lvlWind = Number(a?.lvl_wind || 0);
    const lvlSnow = Number(a?.lvl_snow || 0);
    const lvlHeat = Number(a?.lvl_heat || 0);
    const lvlCold = Number(a?.lvl_cold || 0);

    function weatherType() {
      const max = Math.max(lvlRain, lvlWind, lvlSnow, lvlHeat, lvlCold);
      if (max === 0) return null;
      if (lvlRain === max) return "pluie";
      if (lvlSnow === max) return "neige";
      if (lvlWind === max) return "vent";
      if (lvlHeat === max) return "chaleur";
      return "froid";
    }

    function parseCompetitorNewValue() {
      const val = nv || "";
      const parts = val.split(" \u2014 ");
      return { compName: parts[0] || "", evName: parts[1] || "" };
    }

    if (sub === "score_up") {
      const sign = delta != null ? ` (+${delta} pts)` : "";
      return `${ov} \u2192 ${nv}${sign}`;
    }
    if (sub === "score_down") {
      const sign = delta != null ? ` (${delta} pts)` : "";
      return `${ov} \u2192 ${nv}${sign}`;
    }
    if (sub === "event_new") {
      const evLabel = name || "";
      return evLabel ? `${evLabel}${km ? " \u00b7 " + km : ""}` : (km || "Concurrent d\u00e9tect\u00e9");
    }
    if (sub === "competitor_event_launch") {
      const p = parseCompetitorNewValue();
      return `${p.compName}${p.evName ? " \u2014 " + p.evName : ""}${km ? " \u00b7 " + km : ""}`;
    }
    if (sub === "competitor_event_ending") {
      const p = parseCompetitorNewValue();
      return `${p.compName}${p.evName ? " \u2014 " + p.evName : ""}`;
    }
    if (sub === "competitor_audience_conflict") {
      const p = parseCompetitorNewValue();
      return `${p.compName}${p.evName ? " \u2014 " + p.evName : ""}${km ? " \u00b7 " + km : ""}`;
    }
    if (sub === "competition_pressure_spike") {
      const oldN = Number(ov || 0);
      const newN = Number(nv || 0);
      return newN > oldN ? "Pression concurrentielle en hausse" : "Pression concurrentielle en baisse";
    }
    if (sub === "mega_event_activation") return name || "M\u00e9ga-\u00e9v\u00e9nement";
    if (sub === "mega_event_end") return name || "Fin m\u00e9ga-\u00e9v\u00e9nement";
    if (sub === "weather_hazard_onset") {
      const type = weatherType();
      const label = type ? `Alerte ${type}` : "Alerte m\u00e9t\u00e9o";
      return `${label} : niveau ${ov || "?"} \u2192 ${nv || "?"}`;
    }
    if (sub === "weather_worsened") {
      const type = weatherType();
      const label = type ? `Alerte ${type} renforc\u00e9e` : "Alerte m\u00e9t\u00e9o renforc\u00e9e";
      return `${label}${ov && nv ? ` (niv. ${ov} \u2192 ${nv})` : ""}`;
    }
    if (sub === "weather_improved") {
      return `Conditions normalis\u00e9es${ov && nv ? ` (niv. ${ov} \u2192 ${nv})` : ""}`;
    }
    if (sub === "mobility_disruption") {
      if (name && name !== "Signal d\u00e9tect\u00e9" && name !== "Perturbation mobilit\u00e9") return name;
      const cat = a?.mobility_disruption_category || "";
      if (mode === "road") return cat || "Incident routier";
      return cat || "Perturbation mobilit\u00e9";
    }
    if (sub === "mobility_disruption_planned") {
      if (name && name !== "Signal d\u00e9tect\u00e9") return name;
      return "Travaux pr\u00e9vus";
    }
    if (sub === "mobility_disruption_resolved") {
      if (mode === "road") return "Circulation r\u00e9tablie";
      if (name && name !== "Signal d\u00e9tect\u00e9") return name.replace(/Travaux.*/, "Trafic r\u00e9tabli");
      return "Trafic r\u00e9tabli";
    }
    if (sub === "calendar_audience_shift") return nv || "Changement d\u2019audience";
    if (sub === "regime_change") return `Contexte : ${ov || "?"} \u2192 ${nv || "?"}`;
    if (sub === "ranking_up") return `${ov}e \u2192 ${nv}e position`;
    if (sub === "ranking_down") return `${ov}e \u2192 ${nv}e position`;
    if (sub === "baseline_validity_change") return null;
    if (sub === "medal_change") return null;
    if (sub === "context_change") return null;
    if (sub === "event_removed") return null;
    return `Signal \u00b7 ${d}`;
  }

  function feedLine2(a) {
    const sub  = String(a?.change_subtype || "").toLowerCase();
    const ov   = a?.old_value != null ? String(a.old_value) : null;
    const nv   = a?.new_value != null ? String(a.new_value) : null;
    const loc  = String(a?.location_type || "").toLowerCase();
    const locClient = String(a?.location_type_client || "").toLowerCase();
    const lvlRain = Number(a?.lvl_rain || 0);
    const lvlWind = Number(a?.lvl_wind || 0);
    const lvlSnow = Number(a?.lvl_snow || 0);
    const lvlHeat = Number(a?.lvl_heat || 0);
    const lvlCold = Number(a?.lvl_cold || 0);
    const venue = a?.event_venue_name || "";
    const city  = a?.city_name || "";
    const km    = a?.distance_m != null ? `${(Number(a.distance_m)/1000).toFixed(1)} km` : null;
    const distM = Number(a?.distance_m || 0);
    const aud1  = String(a?.primary_audience_1 || "").toLowerCase();
    const aud2  = String(a?.primary_audience_2 || "").toLowerCase();
    const activ = String(a?.company_activity_type || "").toLowerCase();
    const hasActiveEvent = Boolean(a?.has_active_event);
    const activeTitle = a?.active_event_title || null;
    const weatherSens = Number(a?.weather_sensitivity || 0);
    const capSens = String(a?.capacity_sensitivity || "").toLowerCase();
    const isOutdoorClient = locClient === "outdoor" || locClient === "mixed";

    function parseHours(s) {
      if (!s) return null;
      const m = String(s).match(/(\d{1,2})[h:]?(\d{0,2})\s*[-–]\s*(\d{1,2})[h:]?(\d{0,2})/i);
      if (!m) return null;
      const start = parseInt(m[1]) * 60 + (parseInt(m[2]) || 0);
      const end   = parseInt(m[3]) * 60 + (parseInt(m[4]) || 0);
      return { start, end };
    }

    function audienceLabel(code) {
      const map = { local: "résidents locaux", professionals: "professionnels", tourists: "touristes", students: "étudiants", families: "familles", seniors: "seniors" };
      return map[code] || code;
    }

    if (sub === "score_up") {
      if (lvlRain > 0) return "Amélioration des conditions de pluie.";
      if (lvlSnow > 0) return "Réduction du risque neige.";
      if (lvlWind > 0) return "Vent en baisse.";
      if (lvlHeat > 0) return "Chaleur moins intense.";
      if (lvlCold > 0) return "Froid moins intense.";
      return "Attractivité de la date en progression.";
    }

    if (sub === "score_down") {
      if (lvlRain > 0) {
        if (isOutdoorClient) return "Fortes pluies prévues — impact direct sur vos installations et la fréquentation.";
        return "Fortes pluies prévues — possible friction à l'entrée du site.";
      }
      if (lvlSnow > 0) return "Neige prévue — impact sur l'accès et la fréquentation.";
      if (lvlWind > 0) {
        if (isOutdoorClient) return "Vent fort prévu — vérifier la solidité des structures et signalétiques.";
        return "Vent fort prévu — impact sur les conditions d'exploitation.";
      }
      if (lvlHeat > 0) return "Chaleur forte prévue — impact sur le confort et la durée de présence.";
      if (lvlCold > 0) return "Grand froid prévu — impact sur la fréquentation.";
      return "Dégradation de l'attractivité de la date.";
    }

    if (sub === "event_new") {
      const venue = a?.event_venue_name || "";
      const city  = a?.city_name || "";
      const locPart = [venue, city].filter(Boolean).join(", ");
      return locPart || "Événement détecté à proximité.";
    }

    if (sub === "event_removed") return "";

    if (sub === "weather_worsened") {
      if (weatherSens >= 3) {
        if (isOutdoorClient) return "Impact direct sur vos installations et la fréquentation — sensibilité météo élevée.";
        return "Impact probable sur la fréquentation — votre activité est sensible aux conditions météo.";
      }
      if (isOutdoorClient) return "Impact direct sur les installations et la fréquentation.";
      if (locClient === "mixed") return "Impact probable sur les espaces extérieurs et la venue des visiteurs.";
      return "Légère friction possible à l'entrée du site.";
    }

    if (sub === "weather_improved") return "Risque météo réduit sur cette date.";

    if (sub === "mobility_disruption") {
      const mode = String(a?.mobility_mode || "").toLowerCase();
      const distM = Number(a?.distance_m || 0);
      if (hasActiveEvent && activeTitle) return `Acc\u00e8s impact\u00e9 pendant votre \u00e9v\u00e9nement \u201c${activeTitle}\u201d`;
      if (mode === "road") {
        if (distM > 0 && distM < 2000) return "Incident \u00e0 proximit\u00e9 \u2014 acc\u00e8s v\u00e9hicules perturb\u00e9";
        if (distM > 0) return "Incident routier \u2014 impact potentiel sur les livraisons";
        return "Incident routier d\u00e9tect\u00e9";
      }
      if (distM > 0 && distM < 500) return "Acc\u00e8s visiteurs impact\u00e9 \u2014 station la plus proche \u00e0 " + Math.round(distM) + " m";
      if (distM > 0) return "Ligne desservant votre zone \u2014 arr\u00eat le plus proche \u00e0 " + Math.round(distM) + " m";
      return "Acc\u00e8s au site potentiellement impact\u00e9";
    }

    if (sub === "ranking_up")   return "Cette date gagne en attractivit\u00e9 relative dans votre r\u00e9gion.";
    if (sub === "ranking_down") return "Cette date perd en attractivit\u00e9 relative dans votre r\u00e9gion.";
    if (sub === "competitor_event_launch") {
      return `\u00c9v\u00e9nement concurrent ouvert aujourd\u2019hui${km ? " \u00b7 " + km : ""}`;
    }
    if (sub === "competitor_event_ending") return "Se termine prochainement";
    if (sub === "competitor_audience_conflict") {
      return `M\u00eame public, m\u00eame date${km ? ", \u00e0 " + km : ""} \u2014 risque \u00e9lev\u00e9`;
    }
    if (sub === "competition_pressure_spike") {
      const count = nv || ov || "";
      return count ? `${count} \u00e9v\u00e9nements \u00e0 5 km` : "";
    }
    if (sub === "mega_event_activation") return "Impact attendu sur la fr\u00e9quentation et la mobilit\u00e9";
    if (sub === "mega_event_end") return "Retour \u00e0 la normale attendu";
    if (sub === "weather_hazard_onset") {
      if (isOutdoorClient) return "Impact direct sur vos installations et la fr\u00e9quentation.";
      return "Impact probable sur la fr\u00e9quentation.";
    }
    if (sub === "calendar_audience_shift") return "";
    if (sub === "mobility_disruption_planned") return "Perturbation programm\u00e9e \u2014 anticiper un plan d\u2019acc\u00e8s alternatif";
    if (sub === "mobility_disruption_resolved") {
      const mode = String(a?.mobility_mode || "").toLowerCase();
      if (mode === "road") return "Axe routier de nouveau accessible";
      return "Acc\u00e8s normalis\u00e9 \u2014 la ligne dessert \u00e0 nouveau votre zone";
    }
    if (sub === "regime_change") return "";
    if (sub === "baseline_validity_change") return "";
    if (sub === "medal_change") return "";
    if (sub === "context_change") return "";
    return "";
  }

  function feedLine3(a) {
    const sub = String(a?.change_subtype||"").toLowerCase();
    const cat = String(a?.change_category||"").toLowerCase();
    const parts = [];
    if (sub==="score_change"||cat==="opportunity") {
      const from = a?.old_value!=null ? Math.round(Number(a.old_value)) : null;
      const to   = a?.new_value!=null ? Math.round(Number(a.new_value)) : null;
      const delta = a?.score_delta!=null ? Math.round(Number(a.score_delta)) : (from!=null&&to!=null ? to-from : null);
      if (from!=null&&to!=null&&Number.isFinite(from)&&Number.isFinite(to)) { const sign=delta>=0?"+":""; parts.push(`Score : ${from} → ${to} (${sign}${delta})`); }
    } else if (cat==="competition"||sub==="event_new"||sub==="event_removed") {
      if (sub==="event_new") return "";
    }
    return parts.join(" · ");
  }

  function feedLine4(a) {
    const sub = String(a?.change_subtype || "").toLowerCase();
    if (sub === "event_new" || sub === "proximity" || sub === "industry_overlap" || sub === "audience_overlap" || sub === "industry_audience_overlap" || sub === "date_conflict") {
      const SUBTYPE_LABELS = {
        event_new: "Proximit\u00e9 g\u00e9ographique",
        proximity: "Proximit\u00e9 g\u00e9ographique",
        industry_overlap: "M\u00eame secteur",
        audience_overlap: "M\u00eame audience",
        industry_audience_overlap: "Secteur & audience",
        date_conflict: "M\u00eame date",
      };
      return `Menace : ${SUBTYPE_LABELS[sub] || "Signal concurrent"}`;
    }
    if (sub === "competitor_event_launch" || sub === "competitor_event_ending") return "Concurrent suivi";
    if (sub === "competitor_audience_conflict") return "Conflit : audience + date + proximit\u00e9";
    if (sub === "mobility_disruption" || sub === "mobility_disruption_planned" || sub === "mobility_disruption_resolved") {
      const distM = Number(a?.distance_m || 0);
      const mode = String(a?.mobility_mode || "").toLowerCase();
      const parts = [];
      if (distM > 0) parts.push(feedDistancePill(distM));
      const impact = feedMobilityImpact(distM, mode);
      if (impact) parts.push(impact);
      return parts.join(' \u00b7 ');
    }
    return "";
  }

  function renderFeedItems(items, showAll) {
    const filtered = showAll ? items : items.filter(f => Number(f?.alert_level||0) >= 2);
    const toggleHtml = `<div style="display:flex;justify-content:flex-end;margin-bottom:12px;">
      <button type="button" id="pls-feed-toggle" style="font-size:12px;font-weight:600;color:#1D3BB3;background:none;border:none;padding:0;cursor:pointer;">
        ${showAll ? "Réduire" : `Voir tout (${items.length})`}
      </button></div>`;

    if (!filtered.length) return toggleHtml + `<div style="text-align:center;padding:32px 0;color:#9CA3AF;font-size:14px;">Aucun signal détecté.</div>`;

    const byDate = new Map();
    for (const a of filtered) {
      const d = normalizeYmd(a?.affected_date);
      if (!byDate.has(d)) byDate.set(d, []);
      byDate.get(d).push(a);
    }

    return toggleHtml + [...byDate.entries()].sort((a,b) => b[0].localeCompare(a[0])).map(([d, dayItems]) => {
      const hasLocLabels = dayItems.some(a => a?.location_label);
      let itemsHtml = "";
      if (hasLocLabels) {
        const byLoc = new Map();
        for (const a of dayItems) {
          const lbl = a?.location_label || "—";
          if (!byLoc.has(lbl)) byLoc.set(lbl, []);
          byLoc.get(lbl).push(a);
        }
        itemsHtml = [...byLoc.entries()].map(([locLabel, locItems]) => {
          const locItemsHtml = locItems.map((a, idx) => {
            const line1 = feedLine1(a);
            const line2 = feedLine2(a);
            const line3 = feedLine3(a);
            const line4 = feedLine4(a);
            const cat = String(a?.change_category||"").toLowerCase();
            const lvl = Number(a?.alert_level)||1;
            const isLast = idx===locItems.length-1;
            return `
              <div style="padding:14px 0;display:flex;align-items:flex-start;gap:12px;border-left:3px solid ${lvl>=3?"var(--color-pill-risk-border)":lvl>=2?"var(--color-pill-warn-border)":"var(--color-pill-green-text)"};padding-left:10px;${isLast?"":"border-bottom:1px solid #F3F4F6;"}">
                <div style="flex:0 0 auto;width:24px;display:flex;align-items:center;justify-content:center;margin-top:2px;">${feedCatIcon(cat)}</div>
                <div style="flex:1;min-width:0;">
                  <div class="mon-feed-line1">${escapeHtml(line1)}</div>
                  ${line2?`<div class="mon-feed-line2">${escapeHtml(line2)}</div>`:""}
                  ${line3?`<div class="mon-feed-line3">${escapeHtml(line3)}</div>`:""}
                  ${line4?`<div class="mon-feed-line4">${escapeHtml(line4)}</div>`:""}
                </div>
              </div>`;
          }).join("");
          return `
            <div style="margin-bottom:4px;">
              <div style="font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#1D3BB3;padding:10px 0 4px 0;">${escapeHtml(locLabel)}</div>
              ${locItemsHtml}
            </div>`;
        }).join("");
      } else {
        itemsHtml = dayItems.map((a, idx) => {
          const line1 = feedLine1(a);
          const line2 = feedLine2(a);
          const line3 = feedLine3(a);
          const cat = String(a?.change_category||"").toLowerCase();
          const lvl = Number(a?.alert_level)||1;
          const isLast = idx===dayItems.length-1;
          return `
            <div style="padding:14px 0;display:flex;align-items:flex-start;gap:12px;border-left:3px solid ${lvl>=3?"var(--color-pill-risk-border)":lvl>=2?"var(--color-pill-warn-border)":"var(--color-pill-green-text)"};padding-left:10px;${isLast?"":"border-bottom:1px solid #F3F4F6;"}">
              <div style="flex:0 0 auto;width:24px;display:flex;align-items:center;justify-content:center;margin-top:2px;">${feedCatIcon(cat)}</div>
              <div style="flex:1;min-width:0;">
                <div class="mon-feed-line1">${escapeHtml(line1)}</div>
                ${line2?`<div class="mon-feed-line2">${escapeHtml(line2)}</div>`:""}
                ${line3?`<div class="mon-feed-line3">${escapeHtml(line3)}</div>`:""}
              </div>
            </div>`;
        }).join("");
      }

      const dateLabel = (() => {
        const today = todayYmd();
        if (d === today) return "Aujourd'hui";
        const dt = parseYmdToDate(d);
        if (!dt) return d;
        const currentYear = new Date().getFullYear();
        const opts = dt.getUTCFullYear() !== currentYear
          ? { weekday:"long", day:"numeric", month:"long", year:"numeric" }
          : { weekday:"long", day:"numeric", month:"long" };
        const raw = new Intl.DateTimeFormat("fr-FR", opts).format(dt);
        return raw.charAt(0).toUpperCase() + raw.slice(1);
      })();

      return `
        <div style="margin-bottom:16px;">
          <div style="background:#fff;border:1px solid #E8EDF5;border-radius:12px;padding:0 16px;box-shadow:0 1px 4px rgba(17,24,39,0.04);">
            <div style="font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(17,24,39,0.38);padding:14px 0 10px 0;border-bottom:1px solid #F3F4F6;">
              ${escapeHtml(dateLabel)}
            </div>
            ${itemsHtml}
          </div>
        </div>`;
    }).join("");
  }

  // ----------------------------------------------------------------
  // Concurrents suivis section (UNTOUCHED — reference model)
  // ----------------------------------------------------------------
  function renderSuivisMonitorSection(signals, eventDate, followedCount) {
    if (signals.length === 0) {
      if (!followedCount) return "";
      return `
        <div class="mon-card">
          <div class="mon-head">
            <div class="mon-ico">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div>
              <div class="mon-kicker" style="margin:0;">Concurrents suivis</div>
              <div style="font-size:13px;color:#6B7280;margin-top:4px;">Aucun signal détecté. <a href="/app/insightevent/suivis" style="color:#1D3BB3;text-decoration:none;">Gérer mes suivis →</a></div>
            </div>
          </div>
        </div>`;
    }

    const fmtDate = (iso) => {
      if (!iso) return "—";
      const months = ["jan.","fév.","mars","avr.","mai","juin","juil.","août","sept.","oct.","nov.","déc."];
      const raw = String(iso).slice(0,10);
      const parts = raw.split("-");
      return parseInt(parts[2]) + " " + months[parseInt(parts[1])-1] + " " + parts[0];
    };

    const fmtDateRange = (start, end) => {
      const s = fmtDate(start);
      if (!end) return s;
      const e = fmtDate(end);
      return `${s} → ${e}`;
    };

    const byComp = new Map();
    for (const s of signals) {
      const cid = s.competitor_id || "unknown";
      if (!byComp.has(cid)) byComp.set(cid, []);
      byComp.get(cid).push(s);
    }

    const compEntries = [...byComp.entries()].sort((a, b) => {
      const aOverlaps = a[1].filter(s => s.industry_overlap || s.audience_overlap || s.distance_flag).length;
      const bOverlaps = b[1].filter(s => s.industry_overlap || s.audience_overlap || s.distance_flag).length;
      if (bOverlaps !== aOverlaps) return bOverlaps - aOverlaps;
      const aMax = Math.max(...a[1].map(s => Number(s.conflict_score || 0)));
      const bMax = Math.max(...b[1].map(s => Number(s.conflict_score || 0)));
      return bMax - aMax;
    });

    const totalSignals = signals.length;
    const totalComps = compEntries.length;

    const cardsHtml = compEntries.map(([cid, compSignals]) => {
      const first = compSignals[0];
      const name = first.competitor_name || "Concurrent";
      const rating = first.google_rating;
      const ratingCount = first.google_rating_count;
      const photo = first.google_photos;
      const distM = first.distance_from_location_m;
      const distKm = distM ? (Number(distM) / 1000).toFixed(1) : null;

      const hasAudienceOverlap = compSignals.some(s => s.audience_overlap);
      const hasIndustryOverlap = compSignals.some(s => s.industry_overlap);
      const hasDistanceFlag = compSignals.some(s => s.distance_flag);
      const hasAnyOverlap = hasAudienceOverlap || hasIndustryOverlap || hasDistanceFlag;

      const launches = compSignals.filter(s => s.is_launch);
      const active = compSignals.filter(s => s.is_active && !s.is_launch);
      const upcoming = compSignals.filter(s => s.is_upcoming && !s.is_active && !s.is_launch);

      const AUDIENCE_FR = {
        local: "résidents locaux", professionals: "professionnels",
        tourists: "touristes", students: "étudiants",
        families: "familles", seniors: "seniors",
        general_public: "grand public", art_lovers: "amateurs d'art",
        mixed: "public mixte"
      };
      const locAuds = [first.location_primary_audience_1, first.location_primary_audience_2].filter(Boolean);
      
      const compAuds = [first.competitor_primary_audience, first.competitor_secondary_audience].filter(Boolean);
      const sharedCompAuds = compAuds.filter(a => locAuds.includes(a)).map(a => AUDIENCE_FR[a] || a);
      
      const eventAuds = [...new Set(compSignals.map(s => s.event_primary_audience).filter(Boolean))];
      const sharedEventAuds = eventAuds.filter(a => locAuds.includes(a)).map(a => AUDIENCE_FR[a] || a);
      
      const shortEvents = compSignals.filter(s => {
        if (!s.event_date_end) return true;
        const start = new Date(normalizeYmd(s.event_date?.value ?? s.event_date));
        const end = new Date(normalizeYmd(s.event_date_end?.value ?? s.event_date_end));
        return (end - start) / 86400000 < 14;
      });
      const longEvents = compSignals.filter(s => {
        if (!s.event_date_end) return false;
        const start = new Date(normalizeYmd(s.event_date?.value ?? s.event_date));
        const end = new Date(normalizeYmd(s.event_date_end?.value ?? s.event_date_end));
        return (end - start) / 86400000 >= 14;
      });

      let takeaway = "";
      let takeawayAccent = "#1D3BB3";

      if (sharedEventAuds.length > 0 && launches.length > 0) {
        takeaway = `Lancement ciblant ${sharedEventAuds.join(" et ")}${distKm ? ` à ${distKm} km` : ""} — captation directe de votre audience.`;
        takeawayAccent = "#E24B4A";
      } else if (sharedEventAuds.length > 0 && shortEvents.length > 0) {
        takeaway = `${shortEvents.length} événement${shortEvents.length > 1 ? "s" : ""} ciblant ${sharedEventAuds.join(" et ")}${distKm ? ` à ${distKm} km` : ""} — concurrence directe sur votre public.`;
        takeawayAccent = "#E24B4A";
      } else if (sharedCompAuds.length > 0 && sharedEventAuds.length === 0) {
        const eventAudLabels = eventAuds.map(a => AUDIENCE_FR[a] || a).join(", ");
        takeaway = eventAudLabels
          ? `Concurrent ciblant ${sharedCompAuds.join(" et ")}, mais programmation actuelle orientée ${eventAudLabels} — impact limité.`
          : `Concurrent ciblant ${sharedCompAuds.join(" et ")}${distKm ? ` à ${distKm} km` : ""} — surveiller la programmation.`;
        takeawayAccent = "#EF9F27";
      } else if (sharedEventAuds.length > 0 && longEvents.length > 0 && shortEvents.length === 0) {
        takeaway = `Programmation longue ciblant ${sharedEventAuds.join(" et ")} — présence continue, impact diffus.`;
        takeawayAccent = "#EF9F27";
      } else if (hasIndustryOverlap && !hasAudienceOverlap) {
        takeaway = `Même secteur, public différent${distKm ? ` (${distKm} km)` : ""} — concurrence indirecte.`;
        takeawayAccent = "#1D3BB3";
      } else if (hasDistanceFlag && !hasAudienceOverlap && !hasIndustryOverlap) {
        const compAudLabel = compAuds.map(a => AUDIENCE_FR[a] || a).join(", ");
        takeaway = compAudLabel
          ? `Cible ${compAudLabel}${distKm ? ` à ${distKm} km` : ""} — public différent du vôtre.`
          : `À proximité${distKm ? ` (${distKm} km)` : ""} — faible risque.`;
        takeawayAccent = "#1D3BB3";
      } else if (!hasAnyOverlap) {
        takeaway = "";
        takeawayAccent = "#9CA3AF";
      } else {
        takeaway = `${compSignals.length} événement${compSignals.length > 1 ? "s" : ""} détecté${compSignals.length > 1 ? "s" : ""}${distKm ? ` à ${distKm} km` : ""}.`;
        takeawayAccent = "#1D3BB3";
      }

      const initials = name.split(" ").map(w => w[0]).join("").slice(0, 2).toUpperCase();
      const photoHtml = photo
        ? `<img style="width:52px;height:52px;border-radius:8px;object-fit:cover;flex-shrink:0;" src="${escapeHtml(photo)}" alt="">`
        : `<div style="width:52px;height:52px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:500;font-size:16px;color:#0C447C;background:#E6F1FB;flex-shrink:0;">${escapeHtml(initials)}</div>`;

      const ratingHtml = rating
        ? `<span style="color:#854F0B;font-weight:500;">★ ${rating}${ratingCount ? ` · ${Number(ratingCount).toLocaleString('fr-FR')} avis` : ''}</span>`
        : '';

      const threatLevel = first.entity_threat_level || null;
      const threatIndustryTier = first.entity_threat_industry_tier || null;
      const threatSeasonality = first.entity_threat_seasonality_flag === true;
      const THREAT_PILL = { high: { bg: "var(--color-pill-risk-bg)", fg: "var(--color-pill-risk-text)", t: "Menace \u00e9lev\u00e9e" }, moderate: { bg: "var(--color-pill-warn-bg)", fg: "var(--color-pill-warn-text)", t: "Menace mod\u00e9r\u00e9e" }, low: { bg: "var(--color-pill-source-low-bg)", fg: "var(--color-pill-source-low-text)", t: "Menace faible" } };
      const INDUSTRY_PILL = { direct: { bg: "var(--color-pill-risk-bg)", fg: "var(--color-pill-risk-text)", t: "M\u00eame secteur" }, partial: { bg: "var(--color-pill-risk-bg)", fg: "var(--color-pill-risk-text)", t: "Secteur proche" }, contextual: { bg: "var(--color-pill-source-low-bg)", fg: "var(--color-pill-source-low-text)", t: "Secteur diff\u00e9rent" } };
      const tp = THREAT_PILL[threatLevel] || null;
      const ip = INDUSTRY_PILL[threatIndustryTier] || null;
      const sharedAudLabel = sharedEventAuds.length ? sharedEventAuds.join(", ") : (sharedCompAuds.length ? sharedCompAuds.join(", ") : null);
      const pillParts = [];
      if (tp) pillParts.push(`<span style="font-size:10px;font-weight:600;padding:2px 9px;border-radius:4px;background:${tp.bg};color:${tp.fg};">${escapeHtml(tp.t)}</span>`);
      if (ip) pillParts.push(`<span style="font-size:10px;font-weight:600;padding:2px 9px;border-radius:4px;background:${ip.bg};color:${ip.fg};">${escapeHtml(ip.t)}</span>`);
      if (sharedAudLabel) pillParts.push(`<span style="font-size:10px;font-weight:600;padding:2px 9px;border-radius:4px;background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);">Cible : ${escapeHtml(sharedAudLabel)}</span>`);
      if (threatSeasonality) pillParts.push('<span style="font-size:10px;font-weight:600;padding:2px 9px;border-radius:4px;background:var(--color-pill-info-bg);color:var(--color-pill-info-text);">M\u00eame saisonnalit\u00e9</span>');
      const flagsHtml = pillParts.length ? `<div style="display:flex;gap:5px;flex-wrap:wrap;">${pillParts.join("")}</div>` : '';

      function renderEventRows(events, maxVisible, defaultDotColor) {
        if (!events.length) return "";
        const visible = events.slice(0, maxVisible);
        const hidden = events.slice(maxVisible);
        function eventDotColor(s) {
          if (s.audience_overlap) return "var(--color-dot-audience)";
          if (s.industry_overlap) return "var(--color-dot-industry)";
          if (s.distance_flag) return "var(--color-dot-proximity)";
          return "var(--color-dot-neutral)";
        }
        function eventThreatLine(s) {
          const evAud = s.event_primary_audience ? (AUDIENCE_FR[s.event_primary_audience] || s.event_primary_audience) : null;
          if (s.audience_overlap && s.industry_overlap) return '<div style="font-size:11px;color:var(--color-pill-risk-text);margin-top:3px;">Concurrence directe \u2014 m\u00eame public, m\u00eame secteur</div>';
          if (s.audience_overlap) return '<div style="font-size:11px;color:var(--color-pill-risk-text);margin-top:3px;">Capte votre audience' + (evAud ? ' \u2014 ' + escapeHtml(evAud) : '') + '</div>';
          if (s.industry_overlap) return '<div style="font-size:11px;color:var(--color-pill-warn-text);margin-top:3px;">M\u00eame secteur, public diff\u00e9rent</div>';
          if (s.date_conflict) return '<div style="font-size:11px;color:var(--color-pill-risk-text);margin-top:3px;">Conflit de date avec votre \u00e9v\u00e9nement</div>';
          return '';
        }
        let html = visible.map(s => {
          const evName = s.event_name || "\u2014";
          const venue = s.venue_name || "";
          const dateStr = s.event_date_end
            ? fmtDateRange(normalizeYmd(s.event_date?.value ?? s.event_date), normalizeYmd(s.event_date_end?.value ?? s.event_date_end))
            : fmtDate(normalizeYmd(s.event_date?.value ?? s.event_date));
          const detailParts = [dateStr, venue].filter(Boolean);
          return `<div style="display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:0.5px solid #F3F4F6;">
            <span style="width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:5px;background:${eventDotColor(s)};"></span>
            <div style="flex:1;min-width:0;">
              <div style="font-size:13px;color:var(--color-text-primary);line-height:1.35;">${escapeHtml(evName)}</div>
              ${detailParts.length ? `<div style="font-size:11px;color:var(--color-text-secondary);margin-top:2px;">${escapeHtml(detailParts.join(' \u00b7 '))}</div>` : ''}
              ${eventThreatLine(s)}
            </div>
          </div>`;
        }).join("");
        if (hidden.length) {
          const hiddenHtml = hidden.map(s => {
            const evName = s.event_name || "\u2014";
            const venue = s.venue_name || "";
            const dateStr = s.event_date_end
              ? fmtDateRange(normalizeYmd(s.event_date?.value ?? s.event_date), normalizeYmd(s.event_date_end?.value ?? s.event_date_end))
              : fmtDate(normalizeYmd(s.event_date?.value ?? s.event_date));
            const detailParts = [dateStr, venue].filter(Boolean);
            return `<div class="ms-comp-extra" style="display:none;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:0.5px solid #F3F4F6;">
              <span style="width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:5px;background:${eventDotColor(s)};"></span>
              <div style="flex:1;min-width:0;">
                <div style="font-size:13px;color:var(--color-text-primary);line-height:1.35;">${escapeHtml(evName)}</div>
                ${detailParts.length ? `<div style="font-size:11px;color:var(--color-text-secondary);margin-top:2px;">${escapeHtml(detailParts.join(' \u00b7 '))}</div>` : ''}
                ${eventThreatLine(s)}
              </div>
            </div>`;
          }).join("");
          html += hiddenHtml;
          html += `<div style="padding:8px 0 0;"><button type="button" onclick="this.parentElement.style.display='none';this.closest('.ms-comp-card').querySelectorAll('.ms-comp-extra').forEach(e=>e.style.display='flex');" style="font-size:11px;font-weight:500;color:var(--color-brand-blue);background:none;border:none;padding:0;cursor:pointer;">+${hidden.length} \u00e9v\u00e9nement${hidden.length > 1 ? 's' : ''} \u2192</button></div>`;
        }
        return html;
      }

      function section(label, content) {
        if (!content) return "";
        return `<div style="font-size:10px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:#9CA3AF;padding:14px 0 6px;border-top:0.5px solid #F3F4F6;margin-top:12px;">${escapeHtml(label)}</div>${content}`;
      }

      const launchesHtml = launches.length ? section("Lancements événements concurrents", renderEventRows(launches, 3, "#E24B4A")) : "";
      const activeHtml = active.length ? section("Événements en cours", renderEventRows(active, 3, "#1D3BB3")) : "";
      const upcomingHtml = upcoming.length ? section("À venir", renderEventRows(upcoming, 3, "#EF9F27")) : "";

      return `<div class="ms-comp-card" style="background:#fff;border:0.5px solid #E8EDF5;border-radius:12px;overflow:hidden;">
        <div style="display:flex;align-items:center;gap:12px;padding:16px 20px;">
          ${photoHtml}
          <div style="flex:1;min-width:0;">
            <div style="font-size:15px;font-weight:500;color:#111827;margin:0 0 2px;">${escapeHtml(name)}</div>
            <div style="font-size:12px;color:#6B7280;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
              ${ratingHtml}
              ${distKm ? `<span>${distKm} km</span>` : ''}
            </div>
          </div>
        </div>
        <div style="padding:0 20px 16px;">
          ${flagsHtml}
          ${takeaway ? `<div style="font-size:12px;color:#111827;background:#F9FAFB;border-radius:8px;padding:10px 14px;margin-top:${hasAnyOverlap ? '10' : '0'}px;line-height:1.45;border-left:3px solid ${takeawayAccent};">${escapeHtml(takeaway)}</div>` : ''}
          ${launchesHtml}
          ${activeHtml}
          ${upcomingHtml}
        </div>
      </div>`;
    }).join("");

    return `<div style="padding:0;">
      <div style="display:flex;flex-direction:column;gap:10px;">${cardsHtml}</div>
      <div style="padding:12px 0 0;display:flex;justify-content:flex-end;">
        <a href="/app/insightevent/suivis" style="font-size:12px;color:var(--color-brand-blue);text-decoration:none;">Gérer mes suivis \u2192</a>
      </div>
    </div>`;
  }

  // ================================================================
  // DAILY ACTION BRIEF — V0 (Beta)
  // Threats + Opportunities, inline action checklists, localStorage,
  // channel routing, clipboard copy
  // ================================================================

  // Channel constants — used for future agent routing + clipboard context
  var CH_GBP = "gbp";           // Google Business Profile
  var CH_INSTAGRAM = "instagram";
  var CH_EMAIL = "email";
  var CH_SMS = "sms";
  var CH_INTERNAL = "internal";  // On-site / team operations (no external channel)
  var CH_PHONE = "phone";        // Phone/WhatsApp to suppliers, partners

  // ---- Clipboard text generator ----
  // Produces a ready-to-paste message from the card context + action text
  function briefClipboardText(cardWhat, cardSowhat, actionText) {
    // Strip HTML tags from what
    var cleanWhat = String(cardWhat||"").replace(/<[^>]+>/g,"");
    return cleanWhat + "\n" + actionText;
  }

  // ---- Action catalog: change_subtype → card config + action list ----
  // actions[]: { text, meta, key, channel }
  // channel: one of CH_* constants — where this action would execute
  // Returns null if not actionable for this signal.

  var BRIEF_TEMPLATES = {
    // ---- THREATS ----
    mobility_disruption: function(a, prof) {
      var mode = String(a.mobility_mode||"").toLowerCase();
      var distM = Number(a.distance_m||0);
      var modeName = mode==="bus"?"Bus":mode==="metro"||mode==="métro"?"Métro":mode==="rer"?"RER":mode==="tram"?"Tram":mode==="road"?"Route":"Transport";
      var line = a.event_label||a.mobility_disruption_category||"";
      var distLabel = distM>0?(distM<1000?Math.round(distM)+" m":(distM/1000).toFixed(1)+" km"):"";
      var isRoad = mode==="road";
      var isClose = distM > 0 && distM < 500;
      var isMid = distM >= 500 && distM < 2000;
      var barClass = isClose ? "ab-threat" : "ab-warning";
      var urgStyle = isClose ? "background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);" : "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);";
      return {
        type:"threat", barClass:barClass,
        urgencyPill:{label:isClose?"Urgent":"Cette semaine",style:urgStyle},
        typePill:{label:"Mobilit\u00e9",style:"background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);"},
        what: line ? escapeHtml(line)+(distLabel?" \u00e0 "+distLabel:"") : "Perturbation "+modeName+(distLabel?" \u00e0 "+distLabel:""),
        sowhat: isClose
          ? "Arr\u00eat desservant votre site perturb\u00e9. D\u00e9tour probable pour vos visiteurs."
          : isRoad ? "Axe routier perturb\u00e9 \u2014 impact potentiel sur les livraisons."
          : isMid ? "Ligne desservant votre zone perturb\u00e9e. Acc\u00e8s visiteurs ralenti."
          : "Perturbation d\u00e9tect\u00e9e dans votre secteur. Impact limit\u00e9.",
        actions: isClose ? [
          {text:"Publier l\u2019itin\u00e9raire alternatif sur Google Business Profile",meta:"Communication \u00b7 Urgent",key:"access_comm",channel:CH_GBP},
          {text:"Mettre \u00e0 jour la signal\u00e9tique d\u2019acc\u00e8s sur place",meta:"Exploitation \u00b7 Acc\u00e8s",key:"onsite_ops",channel:CH_INTERNAL},
          isRoad
            ? {text:"Pr\u00e9venir vos prestataires / livreurs",meta:"Coordination \u00b7 Fournisseurs",key:"supplier_coord",channel:CH_PHONE}
            : {text:"Pr\u00e9voir un accueil renforc\u00e9 pour orienter les visiteurs",meta:"Exploitation \u00b7 Accueil",key:"staff_adjust",channel:CH_INTERNAL},
        ] : [
          {text:"Surveiller l\u2019\u00e9volution de la perturbation",meta:"Exploitation \u00b7 Veille",key:"onsite_ops",channel:CH_INTERNAL},
          isRoad
            ? {text:"Pr\u00e9venir vos prestataires si livraisons pr\u00e9vues",meta:"Coordination \u00b7 Fournisseurs",key:"supplier_coord",channel:CH_PHONE}
            : {text:"Informer votre \u00e9quipe de la perturbation",meta:"Coordination \u00b7 \u00c9quipe",key:"staff_adjust",channel:CH_INTERNAL},
        ],
      };
    },
    mobility_disruption_planned: function(a, prof) {
      var line = a.event_label||"Travaux pr\u00e9vus";
      var distM = Number(a.distance_m||0);
      var distLabel = distM>0?(distM<1000?Math.round(distM)+" m":(distM/1000).toFixed(1)+" km"):"";
      var isClose = distM > 0 && distM < 1000;
      return {
        type:"threat", barClass:"ab-warning",
        urgencyPill:{label:"Cette semaine",style:"background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);"},
        typePill:{label:"Mobilit\u00e9",style:"background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);"},
        what: escapeHtml(line)+(distLabel?" \u00e0 "+distLabel:"")+" \u2014 perturbation programm\u00e9e",
        sowhat: isClose
          ? "Travaux pr\u00e9vus \u00e0 proximit\u00e9 imm\u00e9diate. Pr\u00e9parez un plan d\u2019acc\u00e8s alternatif."
          : "Perturbation programm\u00e9e dans votre secteur. Impact limit\u00e9 mais \u00e0 anticiper.",
        actions: isClose ? [
          {text:"Pr\u00e9parer un plan d\u2019acc\u00e8s alternatif et l\u2019afficher",meta:"Exploitation \u00b7 Acc\u00e8s",key:"onsite_ops",channel:CH_INTERNAL},
          {text:"Informer votre \u00e9quipe et vos prestataires",meta:"Coordination \u00b7 \u00c9quipe",key:"staff_adjust",channel:CH_INTERNAL},
          {text:"Pr\u00e9venir vos visiteurs par email",meta:"Communication \u00b7 Visiteurs",key:"visitor_comm",channel:CH_EMAIL},
        ] : [
