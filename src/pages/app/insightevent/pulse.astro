        var eid = row.getAttribute('data-eng-dispo-row'), loc = row.getAttribute('data-eng-dispo-loc');
        var status = btn.getAttribute('data-eng-dispo-btn');
        row.querySelectorAll('[data-eng-dispo-btn]').forEach(function(b){ b.style.opacity = (b === btn) ? '1' : '0.4'; b.style.fontWeight = (b === btn) ? '700' : ''; });
