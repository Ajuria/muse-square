              ${locItemsHtml}
            </div>`;
        }).join("");
      } else {
        itemsHtml = dayItems.map((a, idx) => {
          const line1 = feedLine1(a);
          const line2 = feedLine2(a);
          const line3 = feedLine3(a);
          const cat = String(a?.change_category||"").toLowerCase();
          const lvl = Number(a?.alert_level)||1;
          const isLast = idx===dayItems.length-1;
          return `
            <div style="padding:14px 0;display:flex;align-items:flex-start;gap:12px;border-left:3px solid ${lvl>=3?"var(--color-pill-risk-border)":lvl>=2?"var(--color-pill-warn-border)":"var(--color-pill-green-text)"};padding-left:10px;${isLast?"":"border-bottom:1px solid #F3F4F6;"}">
              <div style="flex:0 0 auto;width:24px;display:flex;align-items:center;justify-content:center;margin-top:2px;">${feedCatIcon(cat)}</div>
