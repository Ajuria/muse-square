            return '<button type="button" data-goal-key="' + g.key + '" aria-pressed="' + (sel ? 'true' : 'false') + '" style="font-size:12px;font-weight:600;padding:6px 12px;border:1px solid ' + (sel ? '#1D3BB3' : '#E5E7EB') + ';background:' + (sel ? '#1D3BB3' : '#fff') + ';color:' + (sel ? '#fff' : '#6B7280') + ';cursor:pointer;font-family:inherit;">' + escapeHtml(g.label) + '</button>';
          }).join("")
        + '</div>'
      + '</div>'
      + '</div>'
    );

    // Actions-menées counter (single-site; baseline from dbt table, bumped live on card_done)
    var _cardsDone = (!isMultisite && data.activity && data.activity.cards_done != null) ? Number(data.activity.cards_done) : null;
    var counterHtml = (_cardsDone != null)
      ? '<div style="display:flex;align-items:center;gap:6px;margin-bottom:12px;"><span style="font-size:11px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#059669;">\u2713 <span data-actions-counter>' + _cardsDone + '</span> actions men\u00e9es</span></div>'
      : "";

    // Assemble
    root.innerHTML = pillsHtml + verdictHtml +
      `<div style="margin-bottom:20px;"><p style="font-size:11px;letter-spacing:0.07em;text-transform:uppercase;color:var(--color-text-muted);font-weight:500;margin:0 0 10px;">Mon environnement</p><div style="background:var(--color-bg-recessed);border:1px solid var(--color-border);border-radius:10px;overflow:hidden;">${opsStrip}${perfStrip}${concStrip}</div></div>` + goalSelectorHtml + counterHtml + briefHtml + feedHtml;
    applySowhatClamp(root);

    // Engagement cards — merged into Fil d'actualité, scoped to the SAME sites the feed
    // covers (all in-view aggregate sites, or the single viewed site) so they behave like
    // system cards. data._locations is the aggregate site set; single-site => [currentLocationId].
    // (_engLocLabels désormais remplie en tête de rendu — voir isMultisite plus haut.)
    _engagementLocs = isMultisite
      ? (data._locations || []).map(function(l){ return l && l.location_id; }).filter(Boolean)
      : [currentLocationId];
    renderEngagements(_engagementLocs);

    // ---- Wire event handlers ----

    // Pills
    root.querySelectorAll("[data-pill-date]").forEach(btn => {
      btn.addEventListener("click", async () => {
