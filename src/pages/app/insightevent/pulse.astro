    }

    // Daily Action Brief
    var briefHtml = renderDailyBrief(allFeed, data.profile || {}, currentDay, selectedDate, currentLocationId, days, followedCount, _effGoalKey);

    // Strip 1: Score
    const score = currentDay.opportunity_score;
