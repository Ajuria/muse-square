      false, { chip: threatChip });

    // Feed
    var _feedCoveredTypes = (typeof window.getActionCandidateTypes === 'function' && window._lastActionCandidates) ? window.getActionCandidateTypes(window._lastActionCandidates, selectedDate) : {};
    const feedHtml = renderFeed(allFeed, isMultisite, _feedCoveredTypes);

    // Verdict hero (v1 — single grounded line; no delta/segment)
    const _vBest = (Array.isArray(sortedDays) && sortedDays.length) ? sortedDays[0] : null;
    const _vBestYmd = _vBest ? normalizeYmd(_vBest.date) : "";
    const _vIsBest = _vBestYmd && _vBestYmd === selectedDate;
    const _vBestDt = _vBestYmd ? parseYmdToDate(_vBestYmd) : null;
    const _vBestWeekday = _vBestDt ? ["lundi","mardi","mercredi","jeudi","vendredi","samedi","dimanche"][((_vBestDt.getUTCDay()+6)%7)] : "";
    // ↓↓↓ EDITABLE COPY ↓↓↓
    const verdictLine = (_vIsBest || !_vBestWeekday)
      ? `${regimeLabel}. Meilleure fenêtre de la semaine.`
      : `${regimeLabel}. ${_vBestWeekday.charAt(0).toUpperCase() + _vBestWeekday.slice(1)} est plus favorable cette semaine.`;
    // ↑↑↑ EDITABLE COPY ↑↑↑
    const _vScore = (score != null && Number.isFinite(Number(score)));
    // Radar v5 \u2014 le header porte le score ET s'ouvre sur sa preuve : \u00ab Pourquoi ce score \u00bb
