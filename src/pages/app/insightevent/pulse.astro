  // ----------------------------------------------------------------
  // Locations
  // ----------------------------------------------------------------
  async function fetchLocations() {
    const res = await fetch("/api/profile/locations", { cache:"no-store" });
    const json = await res.json().catch(()=>null);
    return Array.isArray(json?.locations) ? json.locations : [];
  }

  // ----------------------------------------------------------------
  // Fetch
  // ----------------------------------------------------------------
  const dates = next8Days();

  // ---- Back-nav cache (stale-while-revalidate) ----
  // Returning to pulse is a full page reload -> a blank ~27-query wait. Cache the last monitor
  // payload per (location, date-window) in sessionStorage so a return paints INSTANTLY from cache
  // while the live fetch below repaints. The date-window in the key auto-invalidates the cache each
  // day. sessionStorage is tab-scoped, so it never leaks across users/tabs.
  // v2: payload schema gained sales_summary (radar v5) — v1 cached payloads must never paint
  // a false « Aucune donnée de ventes » cold-start on accounts that HAVE sales.
  function pulseCacheKey(loc) { return "ms_pulse_v2_" + loc + "_" + dates.join(","); }
  function readPulseCache(loc) {
    try {
      var raw = sessionStorage.getItem(pulseCacheKey(loc));
      if (!raw) return null;
      var obj = JSON.parse(raw);
      return (obj && obj.data && obj.data.ok) ? obj.data : null;
    } catch (e) { return null; }
  }
  function writePulseCache(loc, data) {
    try { sessionStorage.setItem(pulseCacheKey(loc), JSON.stringify({ ts: Date.now(), data: data })); } catch (e) {}
  }

  async function fetchPulse(loc) {
    const qs = new URLSearchParams();
    qs.set("location_id", loc);
    qs.set("selected_dates", dates.join(","));
    qs.set("light", "1"); // pulse renders no delta_att attribution -> primary day uses the lighter 'brief' slice
    const res = await fetch("/api/insight/monitor?"+qs.toString(), {cache:"no-store"});
    const json = await res.json().catch(()=>null);
    if (!res.ok||!json?.ok) throw new Error(json?.error||"Erreur API");
    writePulseCache(loc, json);
    return json;
  }

  async function fetchCompetitorSignals(date, locationId) {
    if (!date) return { signals: [], followed_count: 0, followed_competitors: [], top_threats: [] };
    try {
      // locationId optionnel (radar v5) : la vue agrégée fetch par site ; sans lui, le site de session.
      const res = await fetch(
        `/api/competitive/competitor-signals?selected_date=${encodeURIComponent(date)}`
        + (locationId ? `&location_id=${encodeURIComponent(locationId)}` : "")
      );
      const json = await res.json().catch(() => null);
      return {
        signals: (json?.ok && Array.isArray(json.signals)) ? json.signals : [],
        followed_count: json?.followed_count ?? 0,
        followed_competitors: (json?.ok && Array.isArray(json.followed_competitors)) ? json.followed_competitors : [],
        top_threats: (json?.ok && Array.isArray(json.top_threats)) ? json.top_threats : [],
      };
    } catch { return { signals: [], followed_count: 0, followed_competitors: [], top_threats: [] }; }
  }

  // ----------------------------------------------------------------
  // Boot
  // ----------------------------------------------------------------
  let currentLocationId = location_id;
  let allLocations = [];

  (async function boot() {
    const root = document.getElementById("pls-root");
    try {
      // Fire the primary site's pulse immediately — location_id is known server-side, so it
      // need not wait on fetchLocations(). Memoize per-location so the multisite branch reuses
      // this in-flight request (currentLocationId is always one of the user's sites) instead of
      // issuing a duplicate monitor call.
      const _pulseCache = new Map();
      function pulseFor(id) {
        if (!_pulseCache.has(id)) _pulseCache.set(id, fetchPulse(id));
        return _pulseCache.get(id);
      }
      const primaryPulse = pulseFor(currentLocationId);

      // Radar v5 (18/07) — LA fusion multi-sites, extraite en fonction UNIQUE : utilisée par la
      // peinture cache-first ET par le chemin live — jamais deux implémentations qui divergent.
      // Retourne mergedData avec all_feed NON filtré (le caller applique filterFeedByWindow).
      // Radar v5 (18/07) — fusion Concurrence multi-sites, extraite en fonction UNIQUE (loader +
      // refetch per-day des pilules) : suivis dédupliqués par competitor_id (min distance), signaux
      // par competitor_event_id, compte = max (jamais une somme qui double-compte).
      function fuseCompetitorSignals(csAll) {
        const out = {};
        const _csFollowedById = new Map();
          const _csSignalsById = new Map();
          let _csTopThreats = [];
          csAll.forEach(function(cs){
            (cs.followed_competitors || []).forEach(function(fc){
              var prev = _csFollowedById.get(fc.competitor_id);
              if (!prev || (fc.distance_km != null && (prev.distance_km == null || Number(fc.distance_km) < Number(prev.distance_km)))) _csFollowedById.set(fc.competitor_id, fc);
            });
            (cs.signals || []).forEach(function(s){
              var k = String(s.competitor_event_id || (s.competitor_id + "|" + s.event_name));
              if (!_csSignalsById.has(k)) _csSignalsById.set(k, s);
            });
            if ((cs.top_threats || []).length > _csTopThreats.length) _csTopThreats = cs.top_threats;
          });
          out._competitor_signals = Array.from(_csSignalsById.values());
          out._competitor_followed_count = csAll.reduce(function(m, cs){ return Math.max(m, Number(cs.followed_count || 0)); }, 0);
          out._top_threats = _csTopThreats;
          out._followed_competitors = Array.from(_csFollowedById.values());
          return { signals: out._competitor_signals, followed_count: out._competitor_followed_count, top_threats: out._top_threats, followed_competitors: out._followed_competitors };
      }

      function buildMergedFromValid(valid, locs) {
          const mergedFeedRaw = valid.flatMap(({ data, loc }) =>
            (data.all_feed || []).map(a => ({ ...a, location_id: loc.location_id, location_label: loc.company_name || loc.location_id }))
          );
          // Dedup regional signals that are identical within the same region
          const REGIONAL_SUBTYPES = new Set([
            "weather_hazard_onset", "weather_worsened", "weather_improved",
            "calendar_audience_shift", "regime_change",
            "mega_event_activation", "mega_event_end",
          ]);
          const seenRegional = new Set();
          const mergedFeed = mergedFeedRaw.filter(a => {
            const sub = String(a?.change_subtype || "").toLowerCase();
            if (!REGIONAL_SUBTYPES.has(sub)) return true;
            const key = sub + "|" + String(a?.affected_date || "") + "|" + String(a?.old_value || "") + "|" + String(a?.new_value || "");
            if (seenRegional.has(key)) return false;
            seenRegional.add(key);
            return true;
          });

          const dateMap = new Map();
          for (const { data } of valid) {
            for (const day of (data.days || [])) {
              const ymd = String(day.date || "").slice(0, 10);
              const existing = dateMap.get(ymd);
              if (!existing) {
                dateMap.set(ymd, { ...day });
              } else {
                if (day.opportunity_score !== null && (existing.opportunity_score === null || day.opportunity_score < existing.opportunity_score)) {
                  existing.opportunity_score = day.opportunity_score;
                }
                // Merge regime: keep worst (C > B > A)
                const REGIME_ORDER = { A: 0, B: 1, C: 2 };
                const existingRegime = String(existing.opportunity_regime || "B").toUpperCase();
                const dayRegime = String(day.opportunity_regime || "B").toUpperCase();
                if ((REGIME_ORDER[dayRegime] || 0) > (REGIME_ORDER[existingRegime] || 0)) {
                  existing.opportunity_regime = day.opportunity_regime;
                }
                if (day.is_forced_regime_c_flag) existing.is_forced_regime_c_flag = true;
                existing.attendance   = [...(existing.attendance   || []), ...(day.attendance   || [])];
                existing.operations   = [...(existing.operations   || []), ...(day.operations   || [])];
                existing.installation = [...(existing.installation || []), ...(day.installation || [])];
                existing.context      = [...(existing.context      || []), ...(day.context      || [])];
              }
            }
          }
          const mergedDays = [...dateMap.values()];

          const mergedProfile = valid[0].data.profile || null;

          const mergedData = {
            ok: true,
            profile: mergedProfile,
            days: mergedDays,
            all_feed: mergedFeed,
            action_candidates: valid.flatMap(({ data, loc }) =>
              (data.action_candidates || []).map(ac => ({ ...ac, location_id: ac.location_id || loc.location_id, location_label: loc.company_name || loc.location_id }))
            ),
            _locations: locs,
            competitor_followed_count: valid.reduce((sum, { data }) => sum + Number(data.competitor_followed_count ?? 0), 0),
            _siteData: valid.map(({ data, loc }) => ({
              location_id: loc.location_id,
              label: loc.company_name || loc.location_id,
              profile: data.profile || null,
              days: data.days || [],
            })),
          };

          // Radar v5 — agrégat multi-sites du sales_summary : sommes par date sur tous les sites
          // (CA, ventes, moyenne 30 j, même-jour-semaine-passée sont additives ; les % sont
          // RECALCULÉS sur les sommes — même convention « pourcent » que le mart, vérifiée sur
          // fct_client_sales_signals_daily). robust_z n'est pas agrégeable → null => chip neutre,
          // jamais de couleur inventée sur l'agrégat.
          // HONNÊTETÉ des bases de comparaison : une moyenne 30 j (ou un même-jour-semaine) qui ne
          // couvre PAS tous les sites contribuant au CA de la date produirait un % faux (CA total
          // comparé à une base partielle) → la base et son % ne sont émis que si CHAQUE site
          // contributeur de la date porte la valeur. Un site sans ligne à une date (fermé, ou import
          // en retard) contribue 0 au total — indiscernables l'un de l'autre, on somme ce qui existe.
          const _ssByDate = new Map();
          for (const { data } of valid) {
            for (const r of (data.sales_summary || [])) {
              const k = String((r.date && r.date.value) || r.date || "").slice(0, 10);
              if (!k) continue;
              const e = _ssByDate.get(k) || { date: k, daily_revenue: 0, daily_transactions: 0, revenue_30d_avg: 0, revenue_same_weekday_last_week: 0, _sites: 0, _avgCount: 0, _swCount: 0 };
              e._sites++;
              e.daily_revenue += Number(r.daily_revenue) || 0;
              e.daily_transactions += Number(r.daily_transactions) || 0;
              if (r.revenue_30d_avg != null && Number.isFinite(Number(r.revenue_30d_avg))) { e.revenue_30d_avg += Number(r.revenue_30d_avg); e._avgCount++; }
              if (r.revenue_same_weekday_last_week != null && Number.isFinite(Number(r.revenue_same_weekday_last_week))) { e.revenue_same_weekday_last_week += Number(r.revenue_same_weekday_last_week); e._swCount++; }
              _ssByDate.set(k, e);
            }
          }
          mergedData.sales_summary = Array.from(_ssByDate.values())
            .sort((a, b) => b.date.localeCompare(a.date)).slice(0, 8)
            .map(e => {
              const fullAvg = e._avgCount === e._sites && e.revenue_30d_avg > 0;
              const fullSw = e._swCount === e._sites && e.revenue_same_weekday_last_week > 0;
              return {
                date: e.date,
                daily_revenue: e.daily_revenue,
                daily_transactions: e.daily_transactions,
                avg_basket: e.daily_transactions > 0 ? e.daily_revenue / e.daily_transactions : null,
                revenue_30d_avg: fullAvg ? e.revenue_30d_avg : null,
                revenue_vs_30d_avg_pct: fullAvg ? ((e.daily_revenue - e.revenue_30d_avg) / e.revenue_30d_avg) * 100 : null,
                revenue_same_weekday_last_week: fullSw ? e.revenue_same_weekday_last_week : null,
                revenue_vs_last_week_pct: fullSw ? ((e.daily_revenue - e.revenue_same_weekday_last_week) / e.revenue_same_weekday_last_week) * 100 : null,
                revenue_robust_z: null,
              };
            });
          return mergedData;
      }


      const locs = await fetchLocations().catch(() => []);
      allLocations = locs;

      const isMultisite = locs.length > 1;

      const nameEl   = document.getElementById("pls-loc-name");
      const addrEl   = document.getElementById("pls-loc-addr");
      const switchBtn = document.getElementById("pls-loc-switch");
      const subtitleEl = document.getElementById("pls-subtitle");

      if (switchBtn) switchBtn.style.display = "none";

      if (isMultisite) {
        if (nameEl) nameEl.textContent = "Tous mes sites";
        if (addrEl) addrEl.textContent = `${locs.length} sites surveillés`;
        if (subtitleEl) subtitleEl.textContent = `Veille opérationnelle · 7 jours · ${locs.length} sites`;

        // Peinture cache-first (18/07) : la vue agrégée n'exploitait JAMAIS le cache par site que
        // fetchPulse écrit — chaque reload attendait N monitors à vide. Tous les sites en cache →
        // fusion depuis le cache et paint IMMÉDIAT, le live ci-dessous repeint (stale-while-
        // revalidate, même pattern que le single-site). TOUT-OU-RIEN : un agrégat partiel
        // afficherait des totaux faux — mieux vaut l'attente que le mensonge.
        try {
          const cachedValid = locs.map(function(l){ const c = readPulseCache(l.location_id); return c ? { data: c, loc: l } : null; });
          if (locs.length && cachedValid.every(Boolean)) {
            const cm = buildMergedFromValid(cachedValid, locs);
            cm.all_feed = filterFeedByWindow(cm.all_feed, 0);
            renderPulse(cm, todayYmd(), "radar");
          }
        } catch (e) {}

        const results = await Promise.all(
          locs.map(l => pulseFor(l.location_id).then(d => ({ data: d, loc: l })).catch(() => null))
        );
        const valid = results.filter(Boolean);
        // Track page view (fire-and-forget)
        fetch("/api/analytics/track", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ event: "page_view", location_id: locs[0]?.location_id || null, action_key: "pulse" }),
        }).catch(function(){});
        if (!valid.length) throw new Error("Aucune donnée disponible.");

        const mergedData = buildMergedFromValid(valid, locs);

        mergedData.all_feed = filterFeedByWindow(mergedData.all_feed, 0);
        renderPulse(mergedData, todayYmd(), "radar");

        var _locIdForSecondary = locs[0]?.location_id || currentLocationId;
        // The aggregated feed shows cards from every venue, so rule/team caches must be
        // fetched per venue — otherwise a card matches the wrong venue's rules (or none).
        var _feedLocIds = (locs || []).map(function(l){ return l && l.location_id; }).filter(Boolean);
        if (_locIdForSecondary && _feedLocIds.indexOf(_locIdForSecondary) < 0) _feedLocIds.push(_locIdForSecondary);
        var _ruleFetches = [];
        _feedLocIds.forEach(function(lid){ _ruleFetches.push(fetchTeamMembers(lid), fetchAlertRules(lid), fetchAutomationRules(lid), fetchCardStates(lid)); });
        // Radar v5 (17/07) : la Concurrence est PAR SITE côté serveur (signaux, suivis, menaces) —
        // un seul fetch sur le site de session ne couvrait qu'un site en vue agrégée. Fetch par
        // site (ownership vérifié par l'endpoint), stash sur valid[i]._cs pour le switch, et FUSION
        // pour « Tous mes sites » : suivis dédupliqués par competitor_id (on garde la ligne au site
        // le plus proche — la distance par site n'a pas de sens agrégée autrement), signaux
        // dédupliqués par competitor_event_id, compte = les lignes de suivi du user (clerk-scoped,
        // identique dans chaque réponse — jamais une somme qui double-compterait).
        const _csAll = await Promise.all([
          Promise.all(valid.map(function(v){
            return fetchCompetitorSignals(todayYmd(), v.loc.location_id)
              .then(function(cs){ v._cs = cs; return cs; })
              .catch(function(){ var cs = { signals: [], followed_count: 0, top_threats: [], followed_competitors: [] }; v._cs = cs; return cs; });
          })),
          fetchPendingFeedback(_locIdForSecondary),
          fetchSavedDrafts(_locIdForSecondary),
          fetchChannelConfigs(_locIdForSecondary),
        ].concat(_ruleFetches)).then(function(r){ return r[0]; });
        const _fused = fuseCompetitorSignals(_csAll);
        mergedData._competitor_signals = _fused.signals;
        mergedData._competitor_followed_count = _fused.followed_count;
        mergedData._top_threats = _fused.top_threats;
        mergedData._followed_competitors = _fused.followed_competitors;
        renderPulse(mergedData, todayYmd(), "radar");

        // Site filter — switch between the aggregate ("Tous mes sites") and a single site.
        // Re-renders from data already fetched (per-venue rule/team/card-state caches are
        // populated for every site), so switching is instant and needs no re-fetch.
        var siteSelect = document.getElementById("pls-site-select");
        if (siteSelect) {
          // Radar v5 (17/07) : le switch DOIT déplacer currentLocationId — sinon la vue « site X »
          // continue de charger les commitments (volet Opérations, cartes engagement) et la clé
          // d'objectif du site de SESSION. Retour « Tous mes sites » → restaure la session.
          var _sessionLocationId = currentLocationId;
          siteSelect.innerHTML = '<option value="__all__">Tous mes sites</option>'
            + locs.map(function(l){ return '<option value="' + escapeHtml(l.location_id) + '">' + escapeHtml(l.company_name || l.location_id) + '</option>'; }).join("");
          if (nameEl) nameEl.style.display = "none";
          siteSelect.style.display = "";
          siteSelect.addEventListener("change", function(){
            var id = siteSelect.value;
            if (!id || id === "__all__") {
              currentLocationId = _sessionLocationId;
              if (addrEl) addrEl.textContent = locs.length + " sites surveillés";
              if (subtitleEl) subtitleEl.textContent = "Veille opérationnelle · 7 jours · " + locs.length + " sites";
              renderPulse(mergedData, todayYmd(), "radar");
              return;
            }
            var hit = valid.find(function(v){ return v.loc.location_id === id; });
            if (!hit) return;
            currentLocationId = id;
            if (addrEl) addrEl.textContent = hit.loc.company_address || "";
            if (subtitleEl) subtitleEl.textContent = "Veille opérationnelle · 7 jours";
            var d = Object.assign({}, hit.data);
            d.all_feed = filterFeedByWindow((hit.data.all_feed || []).map(function(a){ return Object.assign({}, a, { location_id: hit.loc.location_id, location_label: hit.loc.company_name || hit.loc.location_id }); }), 0);
            d.action_candidates = (hit.data.action_candidates || []).map(function(ac){ return Object.assign({}, ac, { location_id: ac.location_id || hit.loc.location_id, location_label: hit.loc.company_name || hit.loc.location_id }); });
            d._locations = [];
            // Concurrence par site (17/07) : chaque site a SES signaux/suivis (fetch par site au
            // chargement agrégé, _cs) — jamais ceux du site de session réutilisés pour un autre site.
            var _cs = hit._cs || { signals: [], followed_count: mergedData._competitor_followed_count, top_threats: [], followed_competitors: [] };
            d._competitor_signals = _cs.signals;
            d._competitor_followed_count = _cs.followed_count;
            d._top_threats = _cs.top_threats;
            d._followed_competitors = _cs.followed_competitors;
            renderPulse(d, todayYmd(), "radar");
          });
        }

      } else {
        const currentLoc = locs.find(l => l.location_id === currentLocationId);

        // Stale-while-revalidate: paint a cached payload instantly so returning to pulse isn't a
        // blank wait for the live monitor fetch below. The live `data` repaints when it resolves.
        const _cached = readPulseCache(currentLocationId);
        if (_cached) {
          try {
            if (nameEl) nameEl.textContent = currentLoc?.company_name || _cached.profile?.city_name || "Mon site";
            if (addrEl) addrEl.textContent = currentLoc?.company_address || "";
            _cached.all_feed = filterFeedByWindow(_cached.all_feed || [], 0);
            _cached._locations = [];
            renderPulse(_cached, todayYmd(), "radar");
          } catch (e) {}
        }

        const data = await primaryPulse;

        if (nameEl) nameEl.textContent = currentLoc?.company_name || data.profile?.city_name || "Mon site";
        if (addrEl) addrEl.textContent = currentLoc?.company_address || "";

        data.all_feed = filterFeedByWindow(data.all_feed || [], 0);
        data._locations = [];
        renderPulse(data, todayYmd(), "radar");

        const [csResult] = await Promise.all([
          fetchCompetitorSignals(todayYmd()).catch(() => ({ signals: [], followed_count: 0, top_threats: [] })),
          fetchPendingFeedback(currentLocationId),
          fetchSavedDrafts(currentLocationId),
          fetchChannelConfigs(currentLocationId),
          fetchTeamMembers(currentLocationId),
          fetchAlertRules(currentLocationId),
          fetchAutomationRules(currentLocationId),
          fetchCardStates(currentLocationId),
        ]);
        data._competitor_signals = csResult.signals;
        data._competitor_followed_count = csResult.followed_count;
        data._top_threats = csResult.top_threats;
        data._followed_competitors = csResult.followed_competitors || [];
        renderPulse(data, todayYmd(), "radar");
      }

    } catch(e) {
      if (root) root.innerHTML = `<div class="mon-error">${escapeHtml(e?.message||"Erreur de chargement.")}</div>`;
      console.error(e);
    }
  })();

})();
</script>