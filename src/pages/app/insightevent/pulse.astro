              <div style="flex:1;min-width:0;">
                <div style="font-size:13px;color:var(--color-text-primary);line-height:1.35;">${escapeHtml(evName)}</div>
                ${detailParts.length ? `<div style="font-size:11px;color:var(--color-text-secondary);margin-top:2px;">${escapeHtml(detailParts.join(' \u00b7 '))}</div>` : ''}
                ${eventThreatLine(s)}
              </div>
            </div>`;
          }).join("");
          html += hiddenHtml;
          html += `<div style="padding:8px 0 0;"><button type="button" onclick="this.parentElement.style.display='none';this.closest('.ms-comp-card').querySelectorAll('.ms-comp-extra').forEach(e=>e.style.display='flex');" style="font-size:11px;font-weight:500;color:var(--color-brand-blue);background:none;border:none;padding:0;cursor:pointer;">+${hidden.length} \u00e9v\u00e9nement${hidden.length > 1 ? 's' : ''} \u2192</button></div>`;
        }
        return html;
      }

      function section(label, content) {
        if (!content) return "";
        return `<div style="font-size:10px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:#9CA3AF;padding:14px 0 6px;border-top:0.5px solid #F3F4F6;margin-top:12px;">${escapeHtml(label)}</div>${content}`;
      }

      const launchesHtml = launches.length ? section("Lancements événements concurrents", renderEventRows(launches, 3, "#E24B4A")) : "";
      const activeHtml = active.length ? section("Événements en cours", renderEventRows(active, 3, "#1D3BB3")) : "";
      const upcomingHtml = upcoming.length ? section("À venir", renderEventRows(upcoming, 3, "#EF9F27")) : "";

      return `<div class="ms-comp-card" style="background:#fff;border:0.5px solid #E8EDF5;border-radius:12px;overflow:hidden;">
        <div style="display:flex;align-items:center;gap:12px;padding:16px 20px;">
          ${photoHtml}
          <div style="flex:1;min-width:0;">
            <div style="font-size:15px;font-weight:500;color:#111827;margin:0 0 2px;">${escapeHtml(name)}</div>
            <div style="font-size:12px;color:#6B7280;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
