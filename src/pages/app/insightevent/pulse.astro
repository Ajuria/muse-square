    const _vAlert = Number(currentDay.alert_level_max || 0);
    const _vAlertSv = _vAlert > 0 ? sevStyle(_vAlert >= 3 ? "alerte" : "attention") : null;
    const verdictHtml = `<div style="margin-top:26px;margin-bottom:16px;padding-top:22px;border-top:1px solid var(--color-border);">`
      + `<div data-hero-toggle style="cursor:pointer;">`
