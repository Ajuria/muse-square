    if (sub === "regime_change") { var _rvMap2 = {"A":1,"B":2,"C":3,"D":4}; var _ovR2 = _rvMap2[String(ov||"").toUpperCase()] || 0; var _nvR2 = _rvMap2[String(nv||"").toUpperCase()] || 0; if (_nvR2 > _ovR2) return "Plus d\u2019\u00e9v\u00e9nements en comp\u00e9tition pour l\u2019attention de votre public."; if (_nvR2 < _ovR2) return "Moins de comp\u00e9tition sur cette date \u2014 opportunit\u00e9 de visibilit\u00e9."; return ""; }
    if (sub === "sales_underperformance") {
      try { var _sp2 = JSON.parse(a?.data_payload || "{}"); } catch(e) { var _sp2 = {}; }
      var _sp2Comp = _sp2.top_competitor || "";
      var _sp2Pr = _sp2.pressure_ratio != null ? "\u00d7" + Number(_sp2.pressure_ratio).toFixed(1) : "";
      if (_sp2Comp) return "Concurrent principal : " + _sp2Comp + (_sp2Pr ? " \u2014 pression " + _sp2Pr : "");
      if (_sp2Pr) return "Pression concurrentielle " + _sp2Pr;
