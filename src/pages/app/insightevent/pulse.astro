    const THREAT_LABELS_FR = { high: "Menace \u00e9lev\u00e9e", moderate: "Menace mod\u00e9r\u00e9e", low: "Menace faible" };
    let threatPrimary, threatSecondary, _threatLevel;
    if (totalComps > 0) {
      const _worstLabel = THREAT_LABELS_FR[worstThreatLevel] || null;
      const _hasConflict = (worstThreatLevel === "high" || hasAnyAudOverlap);
      threatPrimary = _hasConflict ? escapeHtml(_worstLabel || "Conflit direct") : "Aucun conflit direct";
      _threatLevel = _hasConflict ? (worstThreatLevel === "high" ? "alerte" : "attention") : "favorable";
      const _tp = [`${totalComps} concurrent${totalComps > 1 ? "s" : ""} suivi${totalComps > 1 ? "s" : ""}`];
      if (totalActiveEvents > 0) _tp.push(`${totalActiveEvents} évén. actif${totalActiveEvents > 1 ? "s" : ""}`);
