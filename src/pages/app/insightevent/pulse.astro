  function renderEngagements(locationIds) {
    // Engagement cards are FULL action cards (card_type=engagement) rendered through the
    // system .ab-card anatomy, as the FIRST cards in Actions du jour (mount =
    // #pls-engagement-cards), with Agir menu per state + "Action menée ?" disposition — NOT
    // a feed row and NOT in Fil d'actualité. Scoped to the SAME sites the feed covers (in-view
    // aggregate sites, each with its own ownership check, merged), so they behave exactly like
    // system cards. Separate persistent fetch, so the daily-candidate regen never wipes them.
    var mount = document.getElementById('pls-engagement-cards');
    if (!mount) return;
    var locs = (locationIds || []).filter(Boolean);
    if (!locs.length) { mount.innerHTML = ''; return; }
    Promise.all(locs.map(function(loc){
      return fetch('/api/commitments?location_id=' + encodeURIComponent(loc))
        .then(function(res){ return res.json(); })
        .then(function(j){ return (j && j.ok && Array.isArray(j.items)) ? j.items : []; })
        .catch(function(){ return []; });
    })).then(function(lists){
      var items = [];
      lists.forEach(function(l){ items = items.concat(l); });
      var pastMount = document.getElementById('pls-past-actions');
      if (!items.length) { mount.innerHTML = ''; if (pastMount) pastMount.innerHTML = ''; renderEngagementFeedLog([]); if (typeof fillOpsVolet === 'function') fillOpsVolet([], []); return; }
      // newest first across all sites (updated_at may serialize as {value})
      items.sort(function(a, b){
        var av = (a.updated_at && a.updated_at.value) ? a.updated_at.value : a.updated_at;
        var bv = (b.updated_at && b.updated_at.value) ? b.updated_at.value : b.updated_at;
        return String(bv || '').localeCompare(String(av || ''));
      });
      window._engById = {};
      items.forEach(function(r){ window._engById[String(r.commitment_id)] = r; });
      // #4: a cancelled commitment that is a PARENT of a child was ADJUSTED (superseded), not abandoned.
      var _parents = {}; items.forEach(function(r){ if (r.parent_commitment_id) _parents[String(r.parent_commitment_id)] = true; });
      items.forEach(function(r){ r.__hasChild = !!_parents[String(r.commitment_id)]; });
      // Phase 2 — split: ACTIVE (open/pending) → "En cours"; PAST (resolved/expired/cancelled) → collapsed Bilan.
      var _active = items.filter(function(r){ return r.status === 'open' || r.status === 'pending'; });
      var _past = items.filter(function(r){ return r.status !== 'open' && r.status !== 'pending'; });
      // Radar v5 — le volet Opérations est le résumé hélicoptère de CES items (aucun 2e fetch).
      if (typeof fillOpsVolet === 'function') fillOpsVolet(_active, _past);
      var _enHdr = '<div style="font-size:11px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:#9ca3af;margin:0 0 10px 2px;">Vos actions en cours</div>';
      mount.innerHTML = _active.length ? (_enHdr + _active.map(function(r, i){ return _cgActionCardHtml(r, i); }).join('')) : '';
      wireEngagementCards(mount);
      applySowhatClamp(mount);
      if (pastMount) {
        pastMount.innerHTML = _past.length
          ? '<details><summary style="cursor:pointer;font-size:11px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:#9ca3af;padding:6px 2px;">Mes actions passées · ' + _past.length + '</summary><div style="margin-top:12px;">' + _past.map(function(r, i){ return _cgActionCardHtml(r, i); }).join('') + '</div></details>'
          : '';
        if (_past.length) wireEngagementCards(pastMount);
      }
      renderEngagementFeedLog(items);
    });
  }

  function renderPulse(data, selectedDate, activeView) {
    activeView = activeView || "radar";
    const root = document.getElementById("pls-root");
    if (!root) return;
    if (!_goalInit) {
      _goalInit = true;
      var _lsGoal = null;
      try { _lsGoal = localStorage.getItem(_goalStoreKey()); } catch (e) {}
      if (_lsGoal) _activeGoalKey = _lsGoal;
      else if (data.active_goal) _activeGoalKey = String((data.active_goal.goal != null ? data.active_goal.goal : data.active_goal) || "");
    }
    var _effGoalKey = _activeGoalKey || "";

    const days = Array.isArray(data.days) ? data.days : [];
    window._lastActionCandidates = Array.isArray(data.action_candidates) ? data.action_candidates : [];
    const dayMap = new Map(days.map(d => [normalizeYmd(d.date), d]));
    const currentDay = dayMap.get(selectedDate) || days[0] || null;
    const allFeed = Array.isArray(data.all_feed) ? data.all_feed : [];
    const competitorSignals = data._competitor_signals || [];
    competitorSignals._followedCompetitors = data._followed_competitors || [];
    const followedCount = Number(data._competitor_followed_count ?? data.competitor_followed_count ?? 0);
    const isMultisite = Array.isArray(data._locations) && data._locations.length > 1;
    // Map location_id → nom de site, remplie AVANT renderDailyBrief : les cartes d'action
    // système (renderActionCandidates → chip-n site du builder) la lisent au premier paint.
    // (Déplacée d'après root.innerHTML — elle n'existait qu'après le rendu des candidates.)
    window._engLocLabels = {};
    if (isMultisite && Array.isArray(data._locations)) data._locations.forEach(function(l){ if (l && l.location_id) window._engLocLabels[l.location_id] = l.company_name || l.label || ''; });

    if (!currentDay) {
      root.innerHTML = `<div class="mon-error">Aucune donnée disponible.</div>`;
      return;
    }

    const today = todayYmd();

    // ---- Navigator (7-day score-bar strip) ----
    const navMaxScore = days.reduce(function(m, d) {
      const s = Number(d && d.opportunity_score);
      return (Number.isFinite(s) && s > m) ? s : m;
    }, 0);
    const pillsHtml = `<p style="font-size:11px;letter-spacing:0.07em;text-transform:uppercase;color:var(--color-text-tertiary);font-weight:500;margin:22px 0 10px;">7 jours à venir &middot; choisissez un jour</p>`
      + `<div style="display:flex;align-items:flex-end;gap:4px;">`
      + dates.map(ymd => {
        const d = dayMap.get(ymd);
        const sc = d != null ? Number(d.opportunity_score) : NaN;
        const hasScore = Number.isFinite(sc);
        const isToday = ymd === today;
        const isSel = ymd === selectedDate;
        const barPx = (hasScore && navMaxScore > 0) ? Math.max(3, Math.round(sc / navMaxScore * 65)) : 3;
        const dt = parseYmdToDate(ymd);
        const dowFr = dt ? ["Lun","Mar","Mer","Jeu","Ven","Sam","Dim"][((dt.getUTCDay()+6)%7)] : "";
        const dayLabel = isToday ? "Auj." : (dt ? `${dowFr} ${dt.getUTCDate()}` : ymd);
        return `<button type="button" class="pls-col${isSel ? " is-sel" : ""}" data-pill-date="${ymd}">`
          + `<div class="pls-sc">${hasScore ? sc.toFixed(1) : "\u2014"}</div>`
          + `<div class="pls-ba"><div class="pls-bar${isSel ? " is-now" : ""}" style="height:${barPx}px;"></div></div>`
          + `<div class="pls-dy${isSel ? " is-now" : ""}">${escapeHtml(dayLabel)}</div>`
        + `</button>`;
      }).join("")
      + `</div>`;

    // ---- Alerts (severity != A, shown as strips before radar) ----
    const dayAlertsRaw = [
      ...(currentDay.attendance || []),
      ...(currentDay.operations || []),
      ...(currentDay.installation || []),
      ...(currentDay.context || []),
    ].filter(r => r.severity !== "A");
    var _seenAlerts = {};
    const dayAlerts = [];
    for (var ai = 0; ai < dayAlertsRaw.length; ai++) {
      var ar = dayAlertsRaw[ai];
      var ak = String(ar.block||"") + "|" + String(ar.sentence||"");
      if (_seenAlerts[ak]) continue;
      _seenAlerts[ak] = true;
      dayAlerts.push(ar);
    }

    let alertsHtml = "";
    if (dayAlerts.length > 0) {
      alertsHtml = `<div style="display:flex;flex-direction:column;gap:6px;margin-bottom:12px;">
        ${dayAlerts.slice(0, 5).map(a => {
          const isCrit = a.severity === "D" || a.severity === "C";
          const bg = isCrit ? "#fef2f2" : "#fffbeb";
          const border = isCrit ? "#dc2626" : "#f59e0b";
          const labelColor = isCrit ? "#991b1b" : "#92400e";
          const icon = isCrit ? '<span style="width:8px;height:8px;border-radius:50%;background:#dc2626;display:inline-block;"></span>' : '<span style="width:8px;height:8px;border-radius:50%;background:#f59e0b;display:inline-block;"></span>';
          const blockLabel = BLOCK_LABELS[a.block] || a.block.toUpperCase();
          return `<div style="display:flex;align-items:flex-start;gap:10px;padding:10px 14px;border-radius:8px;background:${bg};border-left:3px solid ${border};">
            <span style="display:flex;align-items:center;margin-top:2px;">${icon}</span>
            <div style="flex:1;">
              <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:${labelColor};margin-bottom:1px;">${escapeHtml(blockLabel)}</div>
              <div style="font-size:12.5px;color:#1f2937;line-height:1.4;">${escapeHtml(a.sentence)}</div>
            </div>
          </div>`;
        }).join("")}
      </div>`;
    } else {
      alertsHtml = '<div style="display:flex;flex-direction:column;gap:4px;margin-bottom:12px;padding:8px 12px;background:rgba(16,185,129,0.06);border-radius:8px;"><div style="display:flex;align-items:center;gap:6px;"><span style="color:#059669;font-size:13px;">\u2713</span><span style="font-size:12.5px;color:#059669;font-weight:500;">Aucune alerte</span></div><div style="font-size:11.5px;color:#6B7280;padding-left:21px;">Trafic routier et transports en commun fluides</div></div>';
    }

    // ---- Carte view ----
    if (activeView === "carte") {
      const mapLocs = isMultisite ? data._locations : null;
      const primaryLoc = mapLocs ? (mapLocs.find(l => l.is_primary) || mapLocs[0]) : null;
      const defaultLocId = primaryLoc ? primaryLoc.location_id : location_id;

      const mapSwitcher = mapLocs ? `
        <div style="display:flex;align-items:center;gap:0;border:0.5px solid #E5E7EB;border-radius:8px;overflow:hidden;margin-bottom:8px;">
          ${mapLocs.map((l, i) => {
            const isDefault = l.location_id === defaultLocId;
            return `<button type="button" data-map-loc="${escapeHtml(l.location_id)}" style="flex:1;padding:10px 14px;font-size:13px;font-weight:${isDefault?'500':'400'};color:${isDefault?'#111827':'#9CA3AF'};background:${isDefault?'#fff':'#F9FAFB'};border:none;border-right:${i<mapLocs.length-1?'0.5px solid #E5E7EB':'none'};cursor:pointer;font-family:inherit;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
              ${escapeHtml(l.company_name || l.location_id)}
            </button>`;
          }).join('')}
        </div>` : '';

      const backBtn = `<button type="button" id="pls-back-radar" style="display:flex;align-items:center;gap:6px;margin-bottom:12px;padding:6px 0;background:none;border:none;font-size:13px;font-weight:600;color:#1D3BB3;cursor:pointer;font-family:inherit;">← Retour au radar</button>`;

      root.innerHTML = pillsHtml + `<div style="height:12px;"></div>` + backBtn + mapSwitcher +
        `<iframe id="pls-map-iframe" src="/app/insightevent/map?location_id=${encodeURIComponent(defaultLocId)}&date=${encodeURIComponent(selectedDate)}&embed=1${data._mapMode ? '&mode=' + encodeURIComponent(data._mapMode) : ''}" style="width:100%;height:600px;border:none;border-radius:14px;display:block;"></iframe>`;

      // Wire pills
      root.querySelectorAll("[data-pill-date]").forEach(btn => {
        btn.addEventListener("click", async () => {
          const d = btn.getAttribute("data-pill-date");
          if (!d) return;
          const csResult = await fetchCompetitorSignals(d).catch(() => ({ signals: [], followed_count: 0 }));
          data._competitor_signals = csResult.signals;
          data._competitor_followed_count = csResult.followed_count;
          data._top_threats = csResult.top_threats;
          renderPulse(data, d, "radar");
        });
      });

      // Wire back button
      const backEl = root.querySelector("#pls-back-radar");
      if (backEl) backEl.addEventListener("click", () => renderPulse(data, selectedDate, "radar"));

      // Wire map site selector
      root.querySelectorAll("[data-map-loc]").forEach(btn => {
        btn.addEventListener("click", () => {
          const locId = btn.getAttribute("data-map-loc");
          const iframe = root.querySelector("#pls-map-iframe");
          if (iframe && locId) {
            iframe.src = "about:blank";
            setTimeout(() => {
              iframe.src = `/app/insightevent/map?location_id=${encodeURIComponent(locId)}&date=${encodeURIComponent(selectedDate)}&embed=1`;
            }, 0);
          }
          root.querySelectorAll("[data-map-loc]").forEach(b => {
            const isAct = b === btn;
            b.style.fontWeight = isAct ? '500' : '400';
            b.style.color = isAct ? '#111827' : '#9CA3AF';
            b.style.background = isAct ? '#fff' : '#F9FAFB';
          });
        });
      });

      // Map height listener
      window.__plsMapHeightListener && window.removeEventListener("message", window.__plsMapHeightListener);
      window.__plsMapHeightListener = function(e) {
        if (e.data?.type === "map-height" && typeof e.data.height === "number" && e.data.height > 100) {
          const iframe = root.querySelector("#pls-map-iframe");
          if (iframe) iframe.style.height = e.data.height + "px";
        }
      };
      window.addEventListener("message", window.__plsMapHeightListener);

      return;
    }

    // ---- Concurrents potentiels view ----
    if (activeView === "concurrents") {
      const topThreats = data._top_threats || [];

      const AUDIENCE_FR = {
        local: "résidents locaux", professionals: "professionnels",
        tourists: "touristes", students: "étudiants",
        families: "familles", seniors: "seniors",
        general_public: "grand public", art_lovers: "amateurs d'art",
        mixed: "public mixte"
      };
      const INDUSTRY_TIER_FR = { direct: "Même secteur", partial: "Secteur proche", contextual: "Secteur différent" };

      function renderThreatCard(tc) {
        const name = tc.competitor_name || "Concurrent";
        const distKm = tc.distance_km != null ? Number(tc.distance_km).toFixed(1) : null;
        const indLabel = INDUSTRY_TIER_FR[tc.industry_match_tier] || "";
        const locAuds = [tc.location_primary_audience_1, tc.location_primary_audience_2].filter(Boolean);
        const compAuds = [tc.competitor_primary_audience, tc.competitor_secondary_audience].filter(Boolean);
        const sharedAuds = compAuds.filter(function(a) { return locAuds.includes(a); }).map(function(a) { return AUDIENCE_FR[a] || a; });
        var audLine = "";
        if (sharedAuds.length > 0) {
          audLine = "Cible les mêmes audiences : " + sharedAuds.join(", ");
        } else if (compAuds.length > 0) {
          audLine = "Cible : " + compAuds.map(function(a) { return AUDIENCE_FR[a] || a; }).join(", ");
        }
        const initials = name.split(" ").map(function(w) { return (w[0] || ""); }).join("").slice(0, 2).toUpperCase();
        const detailParts = [];
        if (tc.competitor_industry_code) detailParts.push("Secteur : " + escapeHtml(tc.competitor_industry_code));
        if (tc.competitor_google_rating) detailParts.push("\u2605 " + tc.competitor_google_rating + (tc.competitor_google_rating_count ? " \u00b7 " + Number(tc.competitor_google_rating_count).toLocaleString("fr-FR") + " avis" : ""));

        return '<div class="ms-threat-card" style="background:#fff;border:0.5px solid #E8EDF5;border-radius:10px;overflow:hidden;margin-bottom:6px;">'
          + '<div style="display:flex;align-items:center;gap:10px;padding:12px 14px;">'
            + '<div style="width:36px;height:36px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-weight:500;font-size:13px;color:#0C447C;background:#E6F1FB;flex-shrink:0;">' + escapeHtml(initials) + '</div>'
            + '<div style="flex:1;min-width:0;">'
              + '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">'
                + '<span style="font-size:13px;font-weight:500;color:#111827;">' + escapeHtml(name) + '</span>'
                + (distKm ? '<span style="font-size:11px;color:#6b7280;">' + escapeHtml(distKm + ' km') + '</span>' : '')
              + '</div>'
              + '<div style="display:flex;align-items:center;gap:6px;margin-top:3px;flex-wrap:wrap;">'
                + threatChipHtml(tc.threat_level)
                + (indLabel ? '<span style="font-size:11px;color:#6b7280;">' + escapeHtml(indLabel) + '</span>' : '')
              + '</div>'
              + (audLine ? '<div style="font-size:11px;color:#374151;margin-top:3px;">' + escapeHtml(audLine) + '</div>' : '')
            + '</div>'
            + '<div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;">'
              + '<button type="button" data-follow-threat="' + escapeHtml(tc.competitor_id) + '" data-follow-name="' + escapeHtml(name) + '" style="padding:4px 10px;border-radius:6px;border:1px solid #dbeafe;background:#eff6ff;font-size:11px;font-weight:600;color:#1e40af;cursor:pointer;white-space:nowrap;font-family:inherit;">Suivre \u2192</button>'
              + '<button type="button" data-threat-enrich="' + escapeHtml(tc.competitor_id) + '" data-enrich-name="' + escapeHtml(name) + '" data-enrich-city="" data-enrich-distance="' + (distKm || '') + '" data-enrich-industry="' + escapeHtml(tc.competitor_industry_code || '') + '" style="font-size:10px;color:#1D3BB3;background:none;border:none;padding:0;cursor:pointer;font-family:inherit;">Voir plus \u2192</button>'
            + '</div>'
          + '</div>'
          + '<div data-threat-detail="' + escapeHtml(tc.competitor_id) + '" style="display:none;padding:0 14px 10px;border-top:0.5px solid #F3F4F6;"></div>'
        + '</div>';
      }

      const backBtn = '<button type="button" id="pls-back-radar" style="display:flex;align-items:center;gap:6px;margin-bottom:12px;padding:6px 0;background:none;border:none;font-size:13px;font-weight:600;color:#1D3BB3;cursor:pointer;font-family:inherit;">\u2190 Retour au radar</button>';

      const headerHtml = '<div style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#374151;margin-bottom:12px;">Concurrents potentiels · ' + topThreats.length + '</div>';

      const cardsHtml = topThreats.length > 0
        ? topThreats.map(function(tc) { return renderThreatCard(tc); }).join('')
        : '<div style="text-align:center;padding:32px 0;color:#9CA3AF;font-size:14px;">Aucun concurrent potentiel détecté.</div>';

      root.innerHTML = pillsHtml + '<div style="height:12px;"></div>' + backBtn + headerHtml + cardsHtml;

      // Wire pills
      root.querySelectorAll("[data-pill-date]").forEach(function(btn) {
        btn.addEventListener("click", async function() {
          const d = btn.getAttribute("data-pill-date");
          if (!d) return;
          const csResult = await fetchCompetitorSignals(d).catch(function() { return { signals: [], followed_count: 0, top_threats: [] }; });
          data._competitor_signals = csResult.signals;
          data._competitor_followed_count = csResult.followed_count;
          data._top_threats = csResult.top_threats;
          renderPulse(data, d, "radar");
        });
      });

      // Wire back
      const backEl = root.querySelector("#pls-back-radar");
      if (backEl) backEl.addEventListener("click", function() { renderPulse(data, selectedDate, "radar"); });

      // Wire Voir plus enrich
      root.querySelectorAll("[data-threat-enrich]").forEach(function(btn) {
        btn.addEventListener("click", async function(e) {
          e.stopPropagation();
          const compId = btn.getAttribute("data-threat-enrich");
          const card = btn.closest(".ms-threat-card");
          if (!card) return;
          const detail = card.querySelector("[data-threat-detail]");
          if (!detail) return;

          if (detail.style.display !== "none" && detail.innerHTML.trim()) {
            detail.style.display = "none";
            btn.textContent = "Voir plus \u2192";
            return;
          }

          detail.style.display = "block";
          detail.innerHTML = '<div style="font-size:12px;color:#9CA3AF;padding:8px 0;display:flex;align-items:center;gap:8px;"><span style="width:10px;height:10px;border:1.5px solid #E5E7EB;border-top-color:#1D3BB3;border-radius:50%;display:inline-block;animation:ms-spin 0.7s linear infinite;flex-shrink:0;"></span>Recherche en cours\u2026</div>';
          btn.textContent = "R\u00e9duire \u2191";

          try {
            var res = await fetch("/api/insight/enrich-event", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({
                event_label: btn.getAttribute("data-enrich-name") || "",
                description: "",
                city_name: btn.getAttribute("data-enrich-city") || "",
                event_venue_name: "",
                event_uid: null,
                city_id: null,
                distance_m: btn.getAttribute("data-enrich-distance") ? Number(btn.getAttribute("data-enrich-distance")) * 1000 : null,
                radius_bucket: null,
                industry_code: btn.getAttribute("data-enrich-industry") || null,
              }),
            });
            var json = await res.json().catch(function() { return null; });
            if (!json?.ok || !json?.data) throw new Error("Réponse invalide");
            var d = json.data;
            var rows = [
              d.confirmed_dates      ? ["Dates",        d.confirmed_dates]      : null,
              d.venue_name           ? ["Lieu",          d.venue_name]           : null,
              d.venue_capacity       ? ["Capacit\u00e9", d.venue_capacity]       : null,
              d.organizer            ? ["Organisateur",  d.organizer]            : null,
              d.estimated_attendance ? ["Fr\u00e9quentation", d.estimated_attendance] : null,
            ].filter(Boolean);
            var tags = d.audience_profile ? d.audience_profile.split(/[,;]/).map(function(t) { return t.trim(); }).filter(Boolean) : [];
            detail.innerHTML = '<div style="background:#F9FAFB;border:0.5px solid #E5E7EB;border-radius:10px;overflow:hidden;margin-top:8px;">'
              + (rows.length ? '<div style="display:grid;grid-template-columns:1fr 1fr;">' + rows.map(function(r, i) {
                return '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;' + (i % 2 === 0 && i < rows.length - 1 ? 'border-right:0.5px solid #F3F4F6;' : '') + '">'
                  + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:3px;">' + escapeHtml(r[0]) + '</div>'
                  + '<div style="font-size:13px;color:#111827;line-height:1.4;">' + escapeHtml(String(r[1])) + '</div>'
                + '</div>';
              }).join('') + '</div>' : '')
              + (tags.length ? '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
                + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:6px;">Audience</div>'
                + '<div style="display:flex;flex-wrap:wrap;gap:5px;">' + tags.map(function(t) { return plsChip(t, { bg: "#EFF6FF", fg: "#1D4ED8" }); }).join('') + '</div>'
              + '</div>' : '')
              + (d.business_takeaway ? '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
                + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:5px;">Impact pour votre activit\u00e9</div>'
                + '<div style="font-size:12px;color:#111827;line-height:1.55;">' + escapeHtml(d.business_takeaway) + '</div>'
              + '</div>' : '')
              + '<div style="padding:9px 14px;display:flex;justify-content:space-between;align-items:center;">'
                + '<div style="font-size:10px;letter-spacing:0.07em;text-transform:uppercase;color:#9CA3AF;display:flex;align-items:center;gap:5px;">'
                  + '<span style="width:6px;height:6px;border-radius:50%;background:#059669;display:inline-block;flex-shrink:0;"></span>'
                  + 'Agent IA \u00b7 web'
                + '</div>'
                + (d.source_url ? '<a href="' + escapeHtml(d.source_url) + '" target="_blank" rel="noopener" style="font-size:12px;color:#1D3BB3;text-decoration:none;">Source officielle \u2192</a>' : '')
              + '</div>'
            + '</div>';
          } catch(err) {
            detail.innerHTML = '<div style="font-size:12px;color:#B91C1C;padding:8px 0;">Donn\u00e9es non disponibles.</div>';
            btn.textContent = "Voir plus \u2192";
          }
        });
      });

