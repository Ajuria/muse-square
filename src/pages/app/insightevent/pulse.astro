      if (!_ovD3) { var _wType3 = weatherType(); if (_wType3 && _ovRaw3.match(/^\d+$/)) { var _wKey3 = {"pluie":"rain","neige":"snow","vent":"wind","chaleur":"heat","froid":"cold"}[_wType3] || ""; _ovD3 = WDESC3[_wKey3 + ":" + _ovRaw3]; } if (!_ovD3) { var _wp3 = _ovRaw3.split(":"); var _wt3 = {"wind":"vent","rain":"pluie","snow":"neige","heat":"chaleur","cold":"froid","storm":"orage","fog":"brouillard"}[_wp3[0]] || "m\u00e9t\u00e9o"; _ovD3 = _wp3[1] ? _wt3 + " niveau " + _wp3[1] : _wt3; } }
      return "Am\u00e9lioration : " + (_ovD3 || "conditions") + " en baisse";
    }
    if (sub === "mobility_disruption") {
      if (name && name !== "Signal d\u00e9tect\u00e9" && name !== "Perturbation mobilit\u00e9") return name;
      const cat = a?.mobility_disruption_category || "";
      if (mode === "road") return cat || "Incident routier";
      return cat || "Perturbation mobilit\u00e9";
    }
    if (sub === "mobility_disruption_planned") {
      if (name && name !== "Signal d\u00e9tect\u00e9") return name;
