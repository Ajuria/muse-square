    const _threatSev = sevStyle(_threatLevel === "favorable" ? "neutre" : _threatLevel);
    const threatTitle = "Menaces concurrentielles";
    const threatChip = { label: threatPrimary, bg: _threatSev.bg, fg: _threatSev.fg };
    const threatAccent = _threatSev.ac;

    // Radar v5 — 3 volets, couleur = signal (neutres tant que rien ne mérite l'attention).
