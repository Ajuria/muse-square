  function feedLine3(a) {
    const sub = String(a?.change_subtype||"").toLowerCase();
    const cat = String(a?.change_category||"").toLowerCase();
    const parts = [];
    if (sub==="score_change"||cat==="opportunity") {
      const from = a?.old_value!=null ? Math.round(Number(a.old_value)) : null;
      const to   = a?.new_value!=null ? Math.round(Number(a.new_value)) : null;
      const delta = a?.score_delta!=null ? Math.round(Number(a.score_delta)) : (from!=null&&to!=null ? to-from : null);
      if (from!=null&&to!=null&&Number.isFinite(from)&&Number.isFinite(to)) { const sign=delta>=0?"+":""; parts.push(`Score : ${from} → ${to} (${sign}${delta})`); }
    } else if (cat==="competition"||sub==="event_new"||sub==="event_removed") {
      if (sub==="event_new") return "";
    }
    return parts.join(" · ");
  }

  function feedLine4(a) {
    const sub = String(a?.change_subtype || "").toLowerCase();
    if (sub === "event_new" || sub === "proximity" || sub === "industry_overlap" || sub === "audience_overlap" || sub === "industry_audience_overlap" || sub === "date_conflict") {
      const SUBTYPE_LABELS = {
        event_new: "Proximit\u00e9 g\u00e9ographique",
        proximity: "Proximit\u00e9 g\u00e9ographique",
        industry_overlap: "M\u00eame secteur",
        audience_overlap: "M\u00eame audience",
        industry_audience_overlap: "Secteur & audience",
        date_conflict: "M\u00eame date",
      };
      return `Menace : ${SUBTYPE_LABELS[sub] || "Signal concurrent"}`;
    }
    if (sub === "competitor_event_launch" || sub === "competitor_event_ending") return "Concurrent suivi";
    if (sub === "competitor_audience_conflict") return "Conflit : audience + date + proximit\u00e9";
    if (sub === "mobility_disruption" || sub === "mobility_disruption_planned" || sub === "mobility_disruption_resolved") {
      const distM = Number(a?.distance_m || 0);
      const mode = String(a?.mobility_mode || "").toLowerCase();
      const parts = [];
      if (distM > 0) parts.push(feedDistancePill(distM));
      const impact = feedMobilityImpact(distM, mode);
      if (impact) parts.push(impact);
      return parts.join(' \u00b7 ');
    }
    return "";
  }

  function renderFeedItems(items, showAll) {
    const filtered = showAll ? items : items.filter(f => Number(f?.alert_level||0) >= 2);
    const toggleHtml = `<div style="display:flex;justify-content:flex-end;margin-bottom:12px;">
      <button type="button" id="pls-feed-toggle" style="font-size:12px;font-weight:600;color:#1D3BB3;background:none;border:none;padding:0;cursor:pointer;">
        ${showAll ? "Réduire" : `Voir tout (${items.length})`}
      </button></div>`;

    if (!filtered.length) return toggleHtml + `<div style="text-align:center;padding:32px 0;color:#9CA3AF;font-size:14px;">Aucun signal détecté.</div>`;

    const byDate = new Map();
    for (const a of filtered) {
      const d = normalizeYmd(a?.affected_date);
      if (!byDate.has(d)) byDate.set(d, []);
      byDate.get(d).push(a);
    }

    return toggleHtml + [...byDate.entries()].sort((a,b) => b[0].localeCompare(a[0])).map(([d, dayItems]) => {
      const hasLocLabels = dayItems.some(a => a?.location_label);
      let itemsHtml = "";
      if (hasLocLabels) {
        const byLoc = new Map();
        for (const a of dayItems) {
          const lbl = a?.location_label || "—";
          if (!byLoc.has(lbl)) byLoc.set(lbl, []);
          byLoc.get(lbl).push(a);
        }
        itemsHtml = [...byLoc.entries()].map(([locLabel, locItems]) => {
          const locItemsHtml = locItems.map((a, idx) => {
            const line1 = feedLine1(a);
            const line2 = feedLine2(a);
            const line3 = feedLine3(a);
            const line4 = feedLine4(a);
            const cat = String(a?.change_category||"").toLowerCase();
            const lvl = Number(a?.alert_level)||1;
            const isLast = idx===locItems.length-1;
            return `
              <div style="padding:14px 0;display:flex;align-items:flex-start;gap:12px;border-left:3px solid ${lvl>=3?"var(--color-pill-risk-border)":lvl>=2?"var(--color-pill-warn-border)":"var(--color-pill-green-text)"};padding-left:10px;${isLast?"":"border-bottom:1px solid #F3F4F6;"}">
                <div style="flex:0 0 auto;width:24px;display:flex;align-items:center;justify-content:center;margin-top:2px;">${feedCatIcon(cat)}</div>
                <div style="flex:1;min-width:0;">
                  <div class="mon-feed-line1">${escapeHtml(line1)}</div>
                  ${line2?`<div class="mon-feed-line2">${escapeHtml(line2)}</div>`:""}
                  ${line3?`<div class="mon-feed-line3">${escapeHtml(line3)}</div>`:""}
                  ${line4?`<div class="mon-feed-line4">${escapeHtml(line4)}</div>`:""}
                </div>
              </div>`;
          }).join("");
          return `
            <div style="margin-bottom:4px;">
              <div style="font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#1D3BB3;padding:10px 0 4px 0;">${escapeHtml(locLabel)}</div>
              ${locItemsHtml}
            </div>`;
        }).join("");
      } else {
        itemsHtml = dayItems.map((a, idx) => {
          const line1 = feedLine1(a);
          const line2 = feedLine2(a);
          const line3 = feedLine3(a);
          const cat = String(a?.change_category||"").toLowerCase();
          const lvl = Number(a?.alert_level)||1;
          const isLast = idx===dayItems.length-1;
          return `
            <div style="padding:14px 0;display:flex;align-items:flex-start;gap:12px;border-left:3px solid ${lvl>=3?"var(--color-pill-risk-border)":lvl>=2?"var(--color-pill-warn-border)":"var(--color-pill-green-text)"};padding-left:10px;${isLast?"":"border-bottom:1px solid #F3F4F6;"}">
              <div style="flex:0 0 auto;width:24px;display:flex;align-items:center;justify-content:center;margin-top:2px;">${feedCatIcon(cat)}</div>
              <div style="flex:1;min-width:0;">
                <div class="mon-feed-line1">${escapeHtml(line1)}</div>
                ${line2?`<div class="mon-feed-line2">${escapeHtml(line2)}</div>`:""}
                ${line3?`<div class="mon-feed-line3">${escapeHtml(line3)}</div>`:""}
              </div>
            </div>`;
        }).join("");
      }

      const dateLabel = (() => {
        const today = todayYmd();
        if (d === today) return "Aujourd'hui";
        const dt = parseYmdToDate(d);
        if (!dt) return d;
        const currentYear = new Date().getFullYear();
        const opts = dt.getUTCFullYear() !== currentYear
          ? { weekday:"long", day:"numeric", month:"long", year:"numeric" }
          : { weekday:"long", day:"numeric", month:"long" };
        const raw = new Intl.DateTimeFormat("fr-FR", opts).format(dt);
        return raw.charAt(0).toUpperCase() + raw.slice(1);
      })();

      return `
        <div style="margin-bottom:16px;">
          <div style="background:#fff;border:1px solid #E8EDF5;border-radius:12px;padding:0 16px;box-shadow:0 1px 4px rgba(17,24,39,0.04);">
            <div style="font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(17,24,39,0.38);padding:14px 0 10px 0;border-bottom:1px solid #F3F4F6;">
              ${escapeHtml(dateLabel)}
            </div>
            ${itemsHtml}
          </div>
        </div>`;
    }).join("");
  }

  // ----------------------------------------------------------------
  // Concurrents suivis section (UNTOUCHED — reference model)
  // ----------------------------------------------------------------
  function renderSuivisMonitorSection(signals, eventDate, followedCount) {
    if (signals.length === 0) {
      if (!followedCount) return "";
      return `
        <div class="mon-card">
          <div class="mon-head">
            <div class="mon-ico">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div>
              <div class="mon-kicker" style="margin:0;">Concurrents suivis</div>
              <div style="font-size:13px;color:#6B7280;margin-top:4px;">Aucun signal détecté. <a href="/app/insightevent/suivis" style="color:#1D3BB3;text-decoration:none;">Gérer mes suivis →</a></div>
            </div>
          </div>
        </div>`;
    }

    const fmtDate = (iso) => {
      if (!iso) return "—";
      const months = ["jan.","fév.","mars","avr.","mai","juin","juil.","août","sept.","oct.","nov.","déc."];
      const raw = String(iso).slice(0,10);
      const parts = raw.split("-");
      return parseInt(parts[2]) + " " + months[parseInt(parts[1])-1] + " " + parts[0];
    };

    const fmtDateRange = (start, end) => {
      const s = fmtDate(start);
      if (!end) return s;
      const e = fmtDate(end);
      return `${s} → ${e}`;
    };

    const byComp = new Map();
    for (const s of signals) {
      const cid = s.competitor_id || "unknown";
      if (!byComp.has(cid)) byComp.set(cid, []);
      byComp.get(cid).push(s);
    }

    const compEntries = [...byComp.entries()].sort((a, b) => {
      const aOverlaps = a[1].filter(s => s.industry_overlap || s.audience_overlap || s.distance_flag).length;
      const bOverlaps = b[1].filter(s => s.industry_overlap || s.audience_overlap || s.distance_flag).length;
      if (bOverlaps !== aOverlaps) return bOverlaps - aOverlaps;
      const aMax = Math.max(...a[1].map(s => Number(s.conflict_score || 0)));
      const bMax = Math.max(...b[1].map(s => Number(s.conflict_score || 0)));
      return bMax - aMax;
    });

    const totalSignals = signals.length;
    const totalComps = compEntries.length;

    const cardsHtml = compEntries.map(([cid, compSignals]) => {
      const first = compSignals[0];
      const name = first.competitor_name || "Concurrent";
      const rating = first.google_rating;
      const ratingCount = first.google_rating_count;
      const photo = first.google_photos;
      const distM = first.distance_from_location_m;
      const distKm = distM ? (Number(distM) / 1000).toFixed(1) : null;

      const hasAudienceOverlap = compSignals.some(s => s.audience_overlap);
      const hasIndustryOverlap = compSignals.some(s => s.industry_overlap);
      const hasDistanceFlag = compSignals.some(s => s.distance_flag);
      const hasAnyOverlap = hasAudienceOverlap || hasIndustryOverlap || hasDistanceFlag;

      const launches = compSignals.filter(s => s.is_launch);
      const active = compSignals.filter(s => s.is_active && !s.is_launch);
      const upcoming = compSignals.filter(s => s.is_upcoming && !s.is_active && !s.is_launch);

      const AUDIENCE_FR = {
        local: "résidents locaux", professionals: "professionnels",
        tourists: "touristes", students: "étudiants",
        families: "familles", seniors: "seniors",
        general_public: "grand public", art_lovers: "amateurs d'art",
        mixed: "public mixte"
      };
      const locAuds = [first.location_primary_audience_1, first.location_primary_audience_2].filter(Boolean);
      
      const compAuds = [first.competitor_primary_audience, first.competitor_secondary_audience].filter(Boolean);
      const sharedCompAuds = compAuds.filter(a => locAuds.includes(a)).map(a => AUDIENCE_FR[a] || a);
      
      const eventAuds = [...new Set(compSignals.map(s => s.event_primary_audience).filter(Boolean))];
      const sharedEventAuds = eventAuds.filter(a => locAuds.includes(a)).map(a => AUDIENCE_FR[a] || a);
      
      const shortEvents = compSignals.filter(s => {
        if (!s.event_date_end) return true;
        const start = new Date(normalizeYmd(s.event_date?.value ?? s.event_date));
        const end = new Date(normalizeYmd(s.event_date_end?.value ?? s.event_date_end));
        return (end - start) / 86400000 < 14;
      });
      const longEvents = compSignals.filter(s => {
        if (!s.event_date_end) return false;
        const start = new Date(normalizeYmd(s.event_date?.value ?? s.event_date));
        const end = new Date(normalizeYmd(s.event_date_end?.value ?? s.event_date_end));
        return (end - start) / 86400000 >= 14;
      });

      let takeaway = "";
      let takeawayAccent = "#1D3BB3";

      if (sharedEventAuds.length > 0 && launches.length > 0) {
        takeaway = `Lancement ciblant ${sharedEventAuds.join(" et ")}${distKm ? ` à ${distKm} km` : ""} — captation directe de votre audience.`;
        takeawayAccent = "#E24B4A";
      } else if (sharedEventAuds.length > 0 && shortEvents.length > 0) {
        takeaway = `${shortEvents.length} événement${shortEvents.length > 1 ? "s" : ""} ciblant ${sharedEventAuds.join(" et ")}${distKm ? ` à ${distKm} km` : ""} — concurrence directe sur votre public.`;
        takeawayAccent = "#E24B4A";
      } else if (sharedCompAuds.length > 0 && sharedEventAuds.length === 0) {
        const eventAudLabels = eventAuds.map(a => AUDIENCE_FR[a] || a).join(", ");
        takeaway = eventAudLabels
          ? `Concurrent ciblant ${sharedCompAuds.join(" et ")}, mais programmation actuelle orientée ${eventAudLabels} — impact limité.`
          : `Concurrent ciblant ${sharedCompAuds.join(" et ")}${distKm ? ` à ${distKm} km` : ""} — surveiller la programmation.`;
        takeawayAccent = "#EF9F27";
      } else if (sharedEventAuds.length > 0 && longEvents.length > 0 && shortEvents.length === 0) {
        takeaway = `Programmation longue ciblant ${sharedEventAuds.join(" et ")} — présence continue, impact diffus.`;
        takeawayAccent = "#EF9F27";
      } else if (hasIndustryOverlap && !hasAudienceOverlap) {
        takeaway = `Même secteur, public différent${distKm ? ` (${distKm} km)` : ""} — concurrence indirecte.`;
        takeawayAccent = "#1D3BB3";
      } else if (hasDistanceFlag && !hasAudienceOverlap && !hasIndustryOverlap) {
        const compAudLabel = compAuds.map(a => AUDIENCE_FR[a] || a).join(", ");
        takeaway = compAudLabel
          ? `Cible ${compAudLabel}${distKm ? ` à ${distKm} km` : ""} — public différent du vôtre.`
          : `À proximité${distKm ? ` (${distKm} km)` : ""} — faible risque.`;
        takeawayAccent = "#1D3BB3";
      } else if (!hasAnyOverlap) {
        takeaway = "";
        takeawayAccent = "#9CA3AF";
      } else {
        takeaway = `${compSignals.length} événement${compSignals.length > 1 ? "s" : ""} détecté${compSignals.length > 1 ? "s" : ""}${distKm ? ` à ${distKm} km` : ""}.`;
        takeawayAccent = "#1D3BB3";
      }

      const initials = name.split(" ").map(w => w[0]).join("").slice(0, 2).toUpperCase();
      const photoHtml = photo
        ? `<img style="width:52px;height:52px;border-radius:8px;object-fit:cover;flex-shrink:0;" src="${escapeHtml(photo)}" alt="">`
        : `<div style="width:52px;height:52px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:500;font-size:16px;color:#0C447C;background:#E6F1FB;flex-shrink:0;">${escapeHtml(initials)}</div>`;

      const ratingHtml = rating
        ? `<span style="color:#854F0B;font-weight:500;">★ ${rating}${ratingCount ? ` · ${Number(ratingCount).toLocaleString('fr-FR')} avis` : ''}</span>`
        : '';

      const threatLevel = first.entity_threat_level || null;
      const threatIndustryTier = first.entity_threat_industry_tier || null;
      const threatSeasonality = first.entity_threat_seasonality_flag === true;
      const THREAT_PILL = { high: { bg: "var(--color-pill-risk-bg)", fg: "var(--color-pill-risk-text)", t: "Menace \u00e9lev\u00e9e" }, moderate: { bg: "var(--color-pill-warn-bg)", fg: "var(--color-pill-warn-text)", t: "Menace mod\u00e9r\u00e9e" }, low: { bg: "var(--color-pill-source-low-bg)", fg: "var(--color-pill-source-low-text)", t: "Menace faible" } };
      const INDUSTRY_PILL = { direct: { bg: "var(--color-pill-risk-bg)", fg: "var(--color-pill-risk-text)", t: "M\u00eame secteur" }, partial: { bg: "var(--color-pill-risk-bg)", fg: "var(--color-pill-risk-text)", t: "Secteur proche" }, contextual: { bg: "var(--color-pill-source-low-bg)", fg: "var(--color-pill-source-low-text)", t: "Secteur diff\u00e9rent" } };
      const tp = THREAT_PILL[threatLevel] || null;
      const ip = INDUSTRY_PILL[threatIndustryTier] || null;
      const sharedAudLabel = sharedEventAuds.length ? sharedEventAuds.join(", ") : (sharedCompAuds.length ? sharedCompAuds.join(", ") : null);
      const pillParts = [];
      if (tp) pillParts.push(`<span style="font-size:10px;font-weight:600;padding:2px 9px;border-radius:4px;background:${tp.bg};color:${tp.fg};">${escapeHtml(tp.t)}</span>`);
      if (ip) pillParts.push(`<span style="font-size:10px;font-weight:600;padding:2px 9px;border-radius:4px;background:${ip.bg};color:${ip.fg};">${escapeHtml(ip.t)}</span>`);
      if (sharedAudLabel) pillParts.push(`<span style="font-size:10px;font-weight:600;padding:2px 9px;border-radius:4px;background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);">Cible : ${escapeHtml(sharedAudLabel)}</span>`);
      if (threatSeasonality) pillParts.push('<span style="font-size:10px;font-weight:600;padding:2px 9px;border-radius:4px;background:var(--color-pill-info-bg);color:var(--color-pill-info-text);">M\u00eame saisonnalit\u00e9</span>');
      const flagsHtml = pillParts.length ? `<div style="display:flex;gap:5px;flex-wrap:wrap;">${pillParts.join("")}</div>` : '';

      function renderEventRows(events, maxVisible, defaultDotColor) {
