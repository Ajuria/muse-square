    if (sub === "calendar_audience_shift") return nv || "Changement d\u2019audience";
    if (sub === "regime_change") { var _rvMap = {"A":1,"B":2,"C":3,"D":4}; var _ovR = _rvMap[String(ov||"").toUpperCase()] || 0; var _nvR = _rvMap[String(nv||"").toUpperCase()] || 0; if (_nvR > _ovR) return "Environnement plus concurrentiel"; if (_nvR < _ovR) return "Environnement concurrentiel all\u00e9g\u00e9"; return "Changement de contexte"; }
