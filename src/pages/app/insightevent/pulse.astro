    const opsStrip = renderRadarStrip("ops", "clipboard-check", "Opérations en cours",
      '<span data-ops-secondary><span class="pls-sk" style="display:inline-block;width:130px;height:10px;vertical-align:middle;"></span></span>',
      '<div id="pls-ops-volet"><div style="padding:6px 0 2px;"><div class="pls-sk" style="height:12px;width:70%;margin-bottom:9px;"></div><div class="pls-sk" style="height:10px;width:45%;"></div></div></div>',
      true, { chip: { label: '<span data-ops-chip></span>', bg: "transparent", fg: "#475569" } });

    // Volet 2 : Performance de l'entreprise — sales_summary du monitor (8 derniers jours de CA).
    const _ss = Array.isArray(data.sales_summary) ? data.sales_summary : [];
    // undefined = payload antérieur au champ (vieux serveur / vieux cache) — on dit
    // « indisponible », jamais « aucune donnée » (faux pour un compte qui a des ventes).
    const _ssMissing = (data.sales_summary === undefined);
    const _ssLatest = _ss.length ? _ss[0] : null;
    let perfSecondary = _ssMissing ? "Données de ventes indisponibles" : "Aucune donnée de ventes", perfChip = null, perfAccent = "";
    if (_ssLatest) {
      const _ssIsToday = normalizeYmd(_ssLatest.date) === todayYmd();
      const _ssTx = Number(_ssLatest.daily_transactions || 0);
      perfSecondary = "CA " + (_ssIsToday ? "du jour" : "du " + fmtDateShort(normalizeYmd(_ssLatest.date)))
        + " : " + _cgEur(_ssLatest.daily_revenue) + (_ssTx > 0 ? " · " + _ssTx + " ventes" : "");
      const _ssPct = Number(_ssLatest.revenue_vs_30d_avg_pct);
      const _ssZ = Number(_ssLatest.revenue_robust_z);
      if (Number.isFinite(_ssPct)) {
        // Couleur seulement hors bande (|z| >= 2) — un jour normal reste neutre.
