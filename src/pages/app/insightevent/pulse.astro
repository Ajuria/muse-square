    window.__pendingAiSowhat = _aiSowhatPayload.length > 0 ? { payload: _aiSowhatPayload, profile: prof, day: currentDay } : null;

    if (top.length === 0) {
      if (!followedCount) {
        return '<div style="margin-bottom:20px;">'
          + '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">'
            + '<span style="font-size:11px;font-weight:700;letter-spacing:0.10em;text-transform:uppercase;color:#1D3BB3;">Vos actions du jour</span>'
            + '<span style="font-size:11px;color:#9ca3af;">1 action</span>'
          + '</div>'
          + '<div class="ab-card"><div class="ab-card-row"><div class="ab-bar" style="background:#1D3BB3;"></div><div class="ab-inner">'
            + '<div class="ab-summary"><div style="display:flex;align-items:flex-start;gap:12px;">'
              + '<div class="ab-cat-icon ab-cat-icon-intelligence" style="margin-top:2px;">\ud83c\udfaf</div>'
              + '<div style="flex:1;min-width:0;">'
                + '<div class="ab-pills"><span class="ab-pill" style="background:#EEF2FF;color:#1D3BB3;">Configuration</span></div>'
