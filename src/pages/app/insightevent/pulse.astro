        + `<div style="display:flex;align-items:flex-start;gap:20px;flex-wrap:wrap;margin-top:12px;">`
          + `<div style="flex-shrink:0;"><span style="font-size:46px;font-weight:600;line-height:0.85;letter-spacing:-0.02em;color:var(--color-text-primary);">${_vScore ? Number(score).toFixed(1) : "\u2014"}</span>${_vScore ? `<span style="font-size:16px;color:var(--color-text-muted);">/10</span>` : ""}</div>`
          + `<div style="flex:1;min-width:220px;">`
            + `<p style="font-size:19px;font-weight:600;line-height:1.4;margin:0;letter-spacing:-0.01em;color:var(--color-text-primary);">${escapeHtml(verdictLine)}</p>`
            + (weekRankShort ? `<p style="font-size:12px;color:var(--color-text-secondary);margin:4px 0 0;">${escapeHtml(weekRankShort)}</p>` : "")
          + `</div>`
        + `</div>`
        + `<div style="display:flex;align-items:center;gap:10px;margin-top:10px;">`
          + `<span style="font-size:12px;color:#1D3BB3;font-weight:500;display:inline-flex;align-items:center;gap:4px;">Pourquoi ce score <svg data-hero-chevron viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;transition:transform 0.15s;"><path d="M6 9l6 6 6-6"/></svg></span>`
          + (_vAlertSv ? plsChip("Vigilance niv. " + _vAlert, _vAlertSv) : "")
        + `</div>`
