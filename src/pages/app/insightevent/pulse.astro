      return count ? `${count} \u00e9v\u00e9nements \u00e0 5 km` : "";
    }
    if (sub === "mega_event_activation") { var _mn2 = nv && nv !== "true" && nv !== "false" ? nv : ""; return _mn2 ? _mn2 + " \u2014 anticipez l\u2019impact sur votre fr\u00e9quentation" : "\u00c9v\u00e9nement majeur \u00e0 proximit\u00e9 \u2014 anticipez l\u2019impact sur votre fr\u00e9quentation"; }
    if (sub === "mega_event_end") { var _mn2e = nv && nv !== "true" && nv !== "false" ? nv : ""; return _mn2e ? "Fin de " + _mn2e + " \u2014 fen\u00eatre pour reprendre la visibilit\u00e9" : "La pression retombe \u2014 fen\u00eatre pour reprendre la visibilit\u00e9"; }
    if (sub === "weather_hazard_onset") {
