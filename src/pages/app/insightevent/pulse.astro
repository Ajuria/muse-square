---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { Show } from "@clerk/astro/components";
import PiloterBottomBar from "../../../components/PiloterBottomBar.astro";

const location_id =
  Astro.locals && typeof (Astro.locals as any).location_id === "string" && (Astro.locals as any).location_id.trim()
    ? (Astro.locals as any).location_id.trim()
    : null;

if (!location_id) {
  return Astro.redirect("/profile");
}
---

<Show when="signed-out" client:load>
  <script is:inline>window.location.href = "/sign-in";</script>
</Show>

<Show when="signed-in" client:load>
  <BaseLayout title="Pulse — Insight Event" hideSurveyCta={true} hideFooter={true}>

    <style is:inline>
      .mon-wrap {
        width: 100%;
        max-width: 720px;
        margin: 0 auto;
        padding: 20px 20px 160px 20px;
        box-sizing: border-box;
        overflow: visible;
      }

      .mon-card {
        background: #FFFFFF;
        border: 1px solid #E8EDF5;
        border-radius: 14px;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(17,24,39,0.06);
      }

      .mon-card-decision {
        background: rgba(29,59,179,0.04);
        border-left: 6px solid #0b37e5;
        padding: 24px;
        border-radius: 0;
      }

      .mon-panels {
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding-top: 16px;
      }

      .mon-kicker {
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.10em;
        text-transform: uppercase;
        color: #1D3BB3;
        line-height: 1.1;
        margin: 0 0 6px 0;
      }

      .mon-head {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
      }

      .mon-ico { width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
      .mon-ico svg { display: block; }

      .mon-tabs-bar {
        display: flex;
        justify-content: flex-start;
        align-items: flex-end;
        gap: 22px;
        padding: 0 24px;
        border-bottom: none;
        margin: 16px -24px -24px -24px;
      }

      .mon-tab {
        appearance: none;
        border: none;
        background: transparent;
        font-size: 14px;
        font-weight: 500;
        color: #94A3B8;
        padding: 0 0 16px 0;
        position: relative;
        cursor: pointer;
      }

      .mon-tab.is-active { color: #1D3BB3; }
      .mon-tab.is-active::after {
        content: "";
        position: absolute;
        left: 0; bottom: 0;
        height: 3px; width: 100%;
        background: #1D3BB3;
        border-radius: 3px;
      }

      .mon-feed-item {
        display: flex; align-items: flex-start; gap: 12px;
        padding: 14px 0; border-bottom: 1px solid #F3F4F6;
      }
      .mon-feed-item:last-child { border-bottom: none; }
      .mon-feed-line1 { font-size: 14px; font-weight: 700; color: #111827; line-height: 1.3; margin-bottom: 3px; }
      .mon-feed-line2 { font-size: 13px; color: #374151; line-height: 1.4; margin-bottom: 2px; }
      .mon-feed-line3 { font-size: 12px; color: #6B7280; }

      .mon-vigilance-item {
        display: flex; align-items: flex-start; gap: 10px;
        font-size: 14px; color: #374151; line-height: 1.45;
        padding: 8px 0; border-bottom: 1px solid #F3F4F6;
      }
      .mon-vigilance-item:last-child { border-bottom: none; }

      .mon-status-ok   { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 600; color: #059669; }
      .mon-loading { padding: 40px 0; text-align: center; color: #9CA3AF; font-size: 14px; }
      .mon-error { padding: 20px; background: rgba(220,38,38,0.06); border-radius: 10px; color: #B91C1C; font-size: 13px; margin-top: 16px; }

      .mon-statut-safe { background: var(--color-pill-safe-bg); color: var(--color-pill-safe-text); padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
      .mon-statut-warn { background: var(--color-pill-warn-bg); color: var(--color-pill-warn-text); border: 1px solid var(--color-pill-warn-border); padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
      .mon-statut-risk { background: var(--color-pill-risk-bg); color: var(--color-pill-risk-text); border: 1px solid var(--color-pill-risk-border); padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }

      /* ---- Date pills ---- */
      .pls-pills {
        display: flex; gap: 6px; flex-wrap: wrap;
        padding: 12px 0 0 0;
      }

      .pls-pill {
        padding: 5px 12px; border-radius: 999px;
        font-size: 12px; font-weight: 600;
        border: 1px solid #e5e7eb;
        background: #fff; color: #6b7280;
        cursor: pointer; white-space: nowrap;
        transition: all 100ms;
        display: inline-flex; align-items: center; gap: 6px;
      }
      .pls-pill.is-today { border-color: #1D3BB3; color: #1D3BB3; }
      .pls-pill.is-active { background: #1D3BB3; border-color: #1D3BB3; color: #fff; }
      .pls-pill.has-crit  { border-color: #e24b4a; }
      .pls-pill.has-warn  { border-color: #ef9f27; }
      .pls-pill-dot {
        width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
      }

      /* ---- Location switcher ---- */
      .pls-loc-row {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 4px;
      }
      .pls-loc-name { font-size: 13px; font-weight: 600; color: #111827; }
      .pls-loc-addr { font-size: 12px; color: #9ca3af; }
      .pls-loc-btn {
        font-size: 12px; font-weight: 600; color: #1D3BB3;
        background: none; border: none; cursor: pointer; padding: 0;
      }

      .mon-context-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 8px; }
      .mon-context-cell { display: flex; flex-direction: column; gap: 2px; }
      .mon-context-label { font-size: 11px; color: #9CA3AF; text-transform: uppercase; letter-spacing: .06em; }
      .mon-context-value { font-size: 13px; color: #111827; }

      .mon-map-btn {
        height: 36px; border: 1px solid #E5E7EB; border-radius: 6px;
        background: #f9fafb; color: #6b7280;
        font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
        text-transform: uppercase; cursor: pointer;
      }
      .mon-map-btn.is-active { border-color: #0b37e5; color: #0b37e5; }
    </style>

    <div class="mon-wrap">
      <!-- Location row -->
      <div class="pls-loc-row" style="margin-bottom:16px;">
        <div>
          <div class="pls-loc-name" id="pls-loc-name"></div>
          <div class="pls-loc-addr" id="pls-loc-addr"></div>
          <div id="pls-subtitle" style="font-size:11px;font-weight:600;letter-spacing:0.10em;text-transform:uppercase;color:#9CA3AF;margin-top:4px;">Veille opérationnelle · 7 jours</div>
        </div>
        <button type="button" class="pls-loc-btn" id="pls-loc-switch" style="display:none;">
          Changer de site
        </button>
      </div>

      <div id="pls-root">
        <div style="display:flex;align-items:center;justify-content:center;padding:24px 0;">
          <img src="/icons/load/ms_load_icon.gif" alt="" style="height:120px;width:auto;" loading="lazy" />
        </div>
      </div>
    </div>

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script is:inline src="/map-markers.js"></script>
  
  <PiloterBottomBar active="veille" />

  </BaseLayout>
</Show>

<script is:inline define:vars={{ location_id }}>
(function () {

  // ----------------------------------------------------------------
  // Helpers (same as monitor.astro)
  // ----------------------------------------------------------------
  function escapeHtml(v) {
    return String(v ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#039;");
  }

  function normalizeYmd(v) {
    const s = String(v ?? "").trim();
    const m = s.match(/^(\d{4}-\d{2}-\d{2})/);
    return m ? m[1] : "";
  }

  function parseYmdToDate(ymd) {
    const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(String(ymd||"").trim());
    if (!m) return null;
    return new Date(Date.UTC(+m[1], +m[2]-1, +m[3]));
  }

  function fmtDateLong(ymd) {
    const d = parseYmdToDate(ymd);
    if (!d) return ymd;
    const s = new Intl.DateTimeFormat("fr-FR", { weekday:"long", day:"numeric", month:"long", year:"numeric" }).format(d);
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  function fmtDateShort(ymd) {
    const d = parseYmdToDate(ymd);
    if (!d) return ymd;
    const dow = ["LUN","MAR","MER","JEU","VEN","SAM","DIM"][((d.getUTCDay()+6)%7)];
    return `${dow} ${String(d.getUTCDate()).padStart(2,"0")}`;
  }

  function todayYmd() {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`;
  }

  function getToday() {
    const d = new Date();
    return new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
  }

  function addDays(dateUTC, n) {
    const d = new Date(dateUTC);
    d.setUTCDate(d.getUTCDate() + n);
    return d;
  }

  function ymdFromUTC(d) {
    return `${d.getUTCFullYear()}-${String(d.getUTCMonth()+1).padStart(2,"0")}-${String(d.getUTCDate()).padStart(2,"0")}`;
  }

  function getLastVisitTimestamp(key) {
    try { return parseInt(localStorage.getItem(key) || "0", 10) || 0; } catch { return 0; }
  }

  function setLastVisitTimestamp(key) {
    try { localStorage.setItem(key, String(Date.now())); } catch {}
  }

  function filterFeedByWindow(allFeed, lastVisitTs) {
    const today = getToday();
    const windowStart = ymdFromUTC(addDays(today, -7));
    const windowEnd   = ymdFromUTC(addDays(today, 6));
    const mobilityEnd = ymdFromUTC(addDays(today, 14));

    return allFeed.filter(a => {
      const affected = normalizeYmd(a?.affected_date);
      const feedDate = normalizeYmd(a?.feed_date);
      if (!affected) return false;

      const isMobility = String(a?.change_category || "").toLowerCase() === "mobility";
      const isWeather  = String(a?.change_category || "").toLowerCase() === "context" &&
                        String(a?.change_subtype  || "").toLowerCase() === "weather_change";

      const maxDate = (isMobility) ? mobilityEnd : windowEnd;

      // Date window check
      if (affected < windowStart || affected > maxDate) return false;

      // Weather: only show within 6 days forward
      if (isWeather && affected > windowEnd) return false;

      // Return visit: only new signals since last load
      if (lastVisitTs > 0) {
        const fd = feedDate ? new Date(feedDate).getTime() : 0;
        if (fd > 0 && fd <= lastVisitTs) return false;
      }

      return true;
    });
  }

  const BLOCK_LABELS = {
    attendance:   'FRÉQUENTATION',
    operations:   'EXPLOITATION',
    installation: 'INSTALLATION',
    context:      'CONTEXTE',
  };

  function computeStatusPill(day) {
    if (day?.is_forced_regime_c_flag === true) {
      return { cls: 'mon-statut-risk', label: 'À RISQUE' };
    }
    const all = [
      ...(day?.attendance   || []),
      ...(day?.operations   || []),
      ...(day?.installation || []),
      ...(day?.context      || []),
    ].filter(r => r.severity !== 'A');

    if (!all.length) {
      return { cls: 'mon-statut-safe', label: 'SANS RISQUE' };
    }

    const maxSev = all.reduce((max, r) => {
      return (['D','C','B'].indexOf(r.severity) < ['D','C','B'].indexOf(max) ? r.severity : max);
    }, 'B');

    const cls = (maxSev === 'D' || maxSev === 'C') ? 'mon-statut-risk' : 'mon-statut-warn';

    if (all.length === 1) {
      const block = all[0].block;
      const label = 'ALERTE ' + (BLOCK_LABELS[block] || block.toUpperCase());
      return { cls, label };
    }

    const count = all.length;
    return { cls, label: `${count} RISQUES` };
  }



  function next8Days() {
    const dates = [];
    const base = new Date();
    for (let i = 0; i < 7; i++) {
      const d = new Date(base);
      d.setDate(base.getDate() + i);
      dates.push(`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`);
    }
    return dates;
  }

  function pill(label, style) {
    return `<span style="display:inline-block;font-size:11px;font-weight:600;padding:2px 10px;border-radius:20px;${style}">${escapeHtml(label)}</span>`;
  }

  const GREEN  = "background:var(--color-pill-green-bg);color:var(--color-pill-green-text);";
  const YELLOW = "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);border:1px solid var(--color-pill-warn-border);";
  const AMBER  = "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);border:1px solid var(--color-pill-warn-border);";
  const RED    = "background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);border:1px solid var(--color-pill-risk-border);";

  function severityDots(level) {
    const l = Math.min(4, Math.max(1, Number(level)||1));
    return [1,2,3,4].map(i =>
      `<span style="width:8px;height:8px;border-radius:50%;display:inline-block;background:${i<=l?"#1D3BB3":"#E2E8F0"};"></span>`
    ).join("&nbsp;");
  }

  function iconSVG(kind) {
    if (kind==="alert")   return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 9v4" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"/><path d="M12 17h.01" stroke="#1D3BB3" stroke-width="3" stroke-linecap="round"/><path d="M10.3 4.3l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.7-2.7l-8-14a2 2 0 0 0-3.4 0z" stroke="#1D3BB3" stroke-width="1.6"/></svg>`;
    if (kind==="context") return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 2v3M17 2v3" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"/><path d="M3.5 9h17" stroke="#1D3BB3" stroke-width="1.6"/><path d="M6 5h12a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z" stroke="#1D3BB3" stroke-width="1.6"/></svg>`;
    return "";
  }

  function feedCatIcon(cat) {
    const c = String(cat||"").toLowerCase();
    if (c==="competition") return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M8 21v-7M12 21V3M16 21v-11"/></svg>`;
    if (c==="opportunity") return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>`;
    if (c==="context")     return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.3 4.3l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.7-2.7l-8-14a2 2 0 0 0-3.4 0z"/></svg>`;
    if (c==="mobility")    return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M7 16h10l1-6H6l1 6z"/><path d="M7 16l-1 4M17 16l1 4"/><path d="M9 10V7a3 3 0 0 1 6 0v3"/></svg>`;
    return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/></svg>`;
  }

  // ----------------------------------------------------------------
  // Feed rendering (identical to monitor.astro)
  // ----------------------------------------------------------------
  function feedLine1(a) {
    const sub  = String(a?.change_subtype || "").toLowerCase();
    const d    = fmtDateShort(normalizeYmd(a?.affected_date));
    const ov   = a?.old_value != null ? String(a.old_value) : null;
    const nv   = a?.new_value != null ? String(a.new_value) : null;
    const delta = a?.score_delta != null ? Math.round(Number(a.score_delta)) : null;
    const name  = a?.event_label || "";
    const km    = a?.distance_m != null ? `${(Number(a.distance_m)/1000).toFixed(1)} km` : null;
    const lvlRain = Number(a?.lvl_rain || 0);
    const lvlWind = Number(a?.lvl_wind || 0);
    const lvlSnow = Number(a?.lvl_snow || 0);
    const lvlHeat = Number(a?.lvl_heat || 0);
    const lvlCold = Number(a?.lvl_cold || 0);

    function weatherType() {
      const max = Math.max(lvlRain, lvlWind, lvlSnow, lvlHeat, lvlCold);
      if (max === 0) return null;
      if (lvlRain === max) return "pluie";
      if (lvlSnow === max) return "neige";
      if (lvlWind === max) return "vent";
      if (lvlHeat === max) return "chaleur";
      return "froid";
    }

    if (sub === "score_up") {
      const sign = delta != null ? ` (+${delta} pts)` : "";
      return `Indice en hausse · ${ov} → ${nv}${sign}`;
    }
    if (sub === "score_down") {
      const sign = delta != null ? ` (${delta} pts)` : "";
      return `Indice en baisse · ${ov} → ${nv}${sign}`;
    }
    if (sub === "event_new") {
      const parts = [`Concurrent détecté · ${d}`];
      if (name) parts.push(name);
      if (km) parts.push(km);
      return parts.join(" · ");
    }
    if (sub === "event_removed") return `Concurrent retiré · ${d}`;
    if (sub === "weather_worsened") {
      const type = weatherType();
      const label = type ? `Alerte ${type} renforcée` : "Alerte météo renforcée";
      return `${label} · ${d}${ov && nv ? ` (niv. ${ov} → ${nv})` : ""}`;
    }
    if (sub === "weather_improved") {
      return `Conditions météo normalisées · ${d}${ov && nv ? ` (niv. ${ov} → ${nv})` : ""}`;
    }
    if (sub === "mobility_disruption") {
      const count = ov || "1";
      return `Perturbation mobilité · ${d} · ${count} incident(s)`;
    }
    if (sub === "ranking_up")   return `Classement amélioré · ${ov}e → ${nv}e position`;
    if (sub === "ranking_down") return `Classement dégradé · ${ov}e → ${nv}e position`;
    if (sub === "context_change") return null;
    return `Signal · ${d}`;
  }

  function feedLine2(a) {
    const sub  = String(a?.change_subtype || "").toLowerCase();
    const loc  = String(a?.location_type || "").toLowerCase();
    const locClient = String(a?.location_type_client || "").toLowerCase();
    const lvlRain = Number(a?.lvl_rain || 0);
    const lvlWind = Number(a?.lvl_wind || 0);
    const lvlSnow = Number(a?.lvl_snow || 0);
    const lvlHeat = Number(a?.lvl_heat || 0);
    const lvlCold = Number(a?.lvl_cold || 0);
    const venue = a?.event_venue_name || "";
    const city  = a?.city_name || "";
    const km    = a?.distance_m != null ? `${(Number(a.distance_m)/1000).toFixed(1)} km` : null;
    const distM = Number(a?.distance_m || 0);
    const aud1  = String(a?.primary_audience_1 || "").toLowerCase();
    const aud2  = String(a?.primary_audience_2 || "").toLowerCase();
    const activ = String(a?.company_activity_type || "").toLowerCase();
    const hasActiveEvent = Boolean(a?.has_active_event);
    const activeTitle = a?.active_event_title || null;
    const weatherSens = Number(a?.weather_sensitivity || 0);
    const capSens = String(a?.capacity_sensitivity || "").toLowerCase();
    const isOutdoorClient = locClient === "outdoor" || locClient === "mixed";

    function parseHours(s) {
      if (!s) return null;
      const m = String(s).match(/(\d{1,2})[h:]?(\d{0,2})\s*[-–]\s*(\d{1,2})[h:]?(\d{0,2})/i);
      if (!m) return null;
      const start = parseInt(m[1]) * 60 + (parseInt(m[2]) || 0);
      const end   = parseInt(m[3]) * 60 + (parseInt(m[4]) || 0);
      return { start, end };
    }

    function audienceLabel(code) {
      const map = { local: "résidents locaux", professionals: "professionnels", tourists: "touristes", students: "étudiants", families: "familles", seniors: "seniors" };
      return map[code] || code;
    }

    if (sub === "score_up") {
      if (lvlRain > 0) return "Amélioration des conditions de pluie.";
      if (lvlSnow > 0) return "Réduction du risque neige.";
      if (lvlWind > 0) return "Vent en baisse.";
      if (lvlHeat > 0) return "Chaleur moins intense.";
      if (lvlCold > 0) return "Froid moins intense.";
      return "Attractivité de la date en progression.";
    }

    if (sub === "score_down") {
      if (lvlRain > 0) {
        if (isOutdoorClient) return "Fortes pluies prévues — impact direct sur vos installations et la fréquentation.";
        return "Fortes pluies prévues — possible friction à l'entrée du site.";
      }
      if (lvlSnow > 0) return "Neige prévue — impact sur l'accès et la fréquentation.";
      if (lvlWind > 0) {
        if (isOutdoorClient) return "Vent fort prévu — vérifier la solidité des structures et signalétiques.";
        return "Vent fort prévu — impact sur les conditions d'exploitation.";
      }
      if (lvlHeat > 0) return "Chaleur forte prévue — impact sur le confort et la durée de présence.";
      if (lvlCold > 0) return "Grand froid prévu — impact sur la fréquentation.";
      return "Dégradation de l'attractivité de la date.";
    }

    if (sub === "event_new") {
      const parts = [];
      if (distM > 0 && distM <= 500) {
        parts.push(`Concurrent à ${Math.round(distM)} m`);
      } else if (distM > 0) {
        parts.push(`À ${km} de votre site`);
      } else if (venue) {
        parts.push(venue);
      } else if (city) {
        parts.push(city);
      }
      const audParts = [aud1, aud2].filter(Boolean);
      if (audParts.length) {
        parts.push(`cible potentielle : ${audParts.map(audienceLabel).join(", ")}`);
      }
      if (hasActiveEvent && activeTitle) {
        parts.push(`pendant votre événement "${activeTitle}"`);
      }
      const oh = parseHours(a?.operating_hours);
      if (oh) {
        parts.push(`vos horaires d'ouverture : ${Math.floor(oh.start/60)}h–${Math.floor(oh.end/60)}h`);
      }
      return parts.length ? parts.join(" — ") + "." : km ? `À ${km} de votre site.` : "Concurrent détecté dans votre zone.";
    }

    if (sub === "event_removed") return "";

    if (sub === "weather_worsened") {
      if (weatherSens >= 3) {
        if (isOutdoorClient) return "Impact direct sur vos installations et la fréquentation — sensibilité météo élevée.";
        return "Impact probable sur la fréquentation — votre activité est sensible aux conditions météo.";
      }
      if (isOutdoorClient) return "Impact direct sur les installations et la fréquentation.";
      if (locClient === "mixed") return "Impact probable sur les espaces extérieurs et la venue des visiteurs.";
      return "Légère friction possible à l'entrée du site.";
    }

    if (sub === "weather_improved") return "Risque météo réduit sur cette date.";

    if (sub === "mobility_disruption") {
      if (hasActiveEvent && activeTitle) return `Accès au site potentiellement impacté pendant votre événement "${activeTitle}".`;
      if (capSens === "high" || capSens === "élevée") return "Accès perturbé — votre activité dépend d'une fréquentation élevée.";
      return "Accès au site potentiellement impacté.";
    }

    if (sub === "ranking_up")   return "Cette date gagne en attractivité relative dans votre région.";
    if (sub === "ranking_down") return "Cette date perd en attractivité relative dans votre région.";
    if (sub === "context_change") return "";
    return "";
  }

  function feedLine3(a) {
    const sub = String(a?.change_subtype||"").toLowerCase();
    const cat = String(a?.change_category||"").toLowerCase();
    const parts = [];
    if (sub==="score_change"||cat==="opportunity") {
      const from = a?.old_value!=null ? Math.round(Number(a.old_value)) : null;
      const to   = a?.new_value!=null ? Math.round(Number(a.new_value)) : null;
      const delta = a?.score_delta!=null ? Math.round(Number(a.score_delta)) : (from!=null&&to!=null ? to-from : null);
      if (from!=null&&to!=null&&Number.isFinite(from)&&Number.isFinite(to)) { const sign=delta>=0?"+":""; parts.push(`Score : ${from} → ${to} (${sign}${delta})`); }
    } else if (cat==="competition"||sub==="event_new"||sub==="event_removed") {
      const name = a?.event_label||a?.event_name||"";
      const km   = a?.distance_m!=null ? `${(Number(a.distance_m)/1000).toFixed(1)} km` : "";
      if (name&&km) parts.push(`${name} · ${km}`);
      else if (name) parts.push(name);
    }
    return parts.join(" · ");
  }

  function renderFeedItems(items, showAll) {
    const filtered = showAll ? items : items.filter(f => Number(f?.alert_level||0) >= 2);
    const toggleHtml = `<div style="display:flex;justify-content:flex-end;margin-bottom:12px;">
      <button type="button" id="pls-feed-toggle" style="font-size:12px;font-weight:600;color:#1D3BB3;background:none;border:none;padding:0;cursor:pointer;">
        ${showAll ? "Réduire" : `Voir tout (${items.length})`}
      </button></div>`;

    if (!filtered.length) return toggleHtml + `<div style="text-align:center;padding:32px 0;color:#9CA3AF;font-size:14px;">Aucun signal détecté.</div>`;

    const byDate = new Map();
    for (const a of filtered) {
      const d = normalizeYmd(a?.affected_date);
      if (!byDate.has(d)) byDate.set(d, []);
      byDate.get(d).push(a);
    }

    return toggleHtml + [...byDate.entries()].sort((a,b) => b[0].localeCompare(a[0])).map(([d, dayItems]) => {
      // Sub-group by location_label if present (multisite)
      const hasLocLabels = dayItems.some(a => a?.location_label);
      let itemsHtml = "";
      if (hasLocLabels) {
        const byLoc = new Map();
        for (const a of dayItems) {
          const lbl = a?.location_label || "—";
          if (!byLoc.has(lbl)) byLoc.set(lbl, []);
          byLoc.get(lbl).push(a);
        }
        itemsHtml = [...byLoc.entries()].map(([locLabel, locItems]) => {
          const locItemsHtml = locItems.map((a, idx) => {
            const line1 = feedLine1(a);
            const line2 = feedLine2(a);
            const line3 = feedLine3(a);
            const cat = String(a?.change_category||"").toLowerCase();
            const lvl = Number(a?.alert_level)||1;
            const isLast = idx===locItems.length-1;
            return `
              <div style="padding:14px 0;display:flex;align-items:flex-start;gap:12px;border-left:3px solid ${lvl>=3?"var(--color-pill-risk-border)":lvl>=2?"var(--color-pill-warn-border)":"var(--color-pill-green-text)"};padding-left:10px;${isLast?"":"border-bottom:1px solid #F3F4F6;"}">
                <div style="flex:0 0 auto;width:24px;display:flex;align-items:center;justify-content:center;margin-top:2px;">${feedCatIcon(cat)}</div>
                <div style="flex:1;min-width:0;">
                  <div class="mon-feed-line1">${escapeHtml(line1)}</div>
                  ${line2?`<div class="mon-feed-line2">${escapeHtml(line2)}</div>`:""}
                  ${line3?`<div class="mon-feed-line3">${escapeHtml(line3)}</div>`:""}
                </div>
              </div>`;
          }).join("");
          return `
            <div style="margin-bottom:4px;">
              <div style="font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#1D3BB3;padding:10px 0 4px 0;">${escapeHtml(locLabel)}</div>
              ${locItemsHtml}
            </div>`;
        }).join("");
      } else {
        itemsHtml = dayItems.map((a, idx) => {
          const line1 = feedLine1(a);
          const line2 = feedLine2(a);
          const line3 = feedLine3(a);
          const cat = String(a?.change_category||"").toLowerCase();
          const lvl = Number(a?.alert_level)||1;
          const isLast = idx===dayItems.length-1;
          return `
            <div style="padding:14px 0;display:flex;align-items:flex-start;gap:12px;border-left:3px solid ${lvl>=3?"var(--color-pill-risk-border)":lvl>=2?"var(--color-pill-warn-border)":"var(--color-pill-green-text)"};padding-left:10px;${isLast?"":"border-bottom:1px solid #F3F4F6;"}">
              <div style="flex:0 0 auto;width:24px;display:flex;align-items:center;justify-content:center;margin-top:2px;">${feedCatIcon(cat)}</div>
              <div style="flex:1;min-width:0;">
                <div class="mon-feed-line1">${escapeHtml(line1)}</div>
                ${line2?`<div class="mon-feed-line2">${escapeHtml(line2)}</div>`:""}
                ${line3?`<div class="mon-feed-line3">${escapeHtml(line3)}</div>`:""}
              </div>
            </div>`;
        }).join("");
      }

      const dateLabel = (() => {
        const today = todayYmd();
        if (d === today) return "Aujourd'hui";
        const dt = parseYmdToDate(d);
        if (!dt) return d;
        const currentYear = new Date().getFullYear();
        const opts = dt.getUTCFullYear() !== currentYear
          ? { weekday:"long", day:"numeric", month:"long", year:"numeric" }
          : { weekday:"long", day:"numeric", month:"long" };
        const raw = new Intl.DateTimeFormat("fr-FR", opts).format(dt);
        return raw.charAt(0).toUpperCase() + raw.slice(1);
      })();

      return `
        <div style="margin-bottom:16px;">
          <div style="background:#fff;border:1px solid #E8EDF5;border-radius:12px;padding:0 16px;box-shadow:0 1px 4px rgba(17,24,39,0.04);">
            <div style="font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(17,24,39,0.38);padding:14px 0 10px 0;border-bottom:1px solid #F3F4F6;">
              ${escapeHtml(dateLabel)}
            </div>
            ${itemsHtml}
          </div>
        </div>`;
    }).join("");
  }

  // ----------------------------------------------------------------
  // Context card (identical to monitor.astro renderContext)
  // ----------------------------------------------------------------
  function renderContextRows(day, profile) {
    const aud1 = profile?.primary_audience_1 ?? null;
    const aud2 = profile?.primary_audience_2 ?? null;
    const locationType = profile?.location_type ?? null;
    const isOutdoorOrMixed = locationType==="outdoor"||locationType==="mixed";
    const audienceFrMap = { local:"Résidents locaux", professionals:"Professionnels", tourists:"Touristes", students:"Étudiants", families:"Familles", seniors:"Seniors" };
    const dt = parseYmdToDate(normalizeYmd(day?.date||""));
    const isWeekend = dt ? (dt.getUTCDay()===0||dt.getUTCDay()===6) : false;
    const hasVacation = Boolean(day?.vacation_name);
    const hasHoliday  = Boolean(day?.holiday_name);

    function audAvail(type) {
      const t = String(type||"").toLowerCase();
      let avail = false;
      if (t==="local") avail=isWeekend||hasVacation||hasHoliday;
      else if (t==="professionals") avail=!isWeekend;
      else if (t==="tourists") avail=isWeekend||hasVacation||hasHoliday;
      else if (t==="families") avail=isWeekend||hasVacation;
      else if (t==="students") avail=isWeekend||hasVacation;
      else if (t==="seniors") avail=true;
      else avail=isWeekend||hasVacation||hasHoliday;
      return avail ? {label:"Disponible",style:GREEN} : {label:"Peu disponible",style:RED};
    }
    function mobLabel(delta) {
      if (delta>=0) return {label:"Fluide",style:GREEN};
      if (delta>=-4) return {label:"Perturbé",style:YELLOW};
      return {label:"Fortement perturbé",style:RED};
    }
    function row(label, content, ctaTab) {
      const cta = ctaTab ? `<button type="button" data-switch-tab="${ctaTab}" style="font-size:11px;font-weight:600;color:#1D3BB3;background:none;border:none;padding:0;cursor:pointer;white-space:nowrap;">Voir →</button>` : "";
      return `<div style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;"><span style="display:flex;align-items:center;"><span style="font-size:13px;color:#6b7280;width:200px;flex-shrink:0;">${escapeHtml(label)}</span>${content}</span>${cta}</div>`;
    }
    function section(label, rowsHtml) {
      return `<div><div style="font-size:11px;font-weight:700;letter-spacing:0.10em;text-transform:uppercase;color:#111827;padding:12px 0 2px 0;">${escapeHtml(label)}</div>${rowsHtml}</div>`;
    }
    function divider() { return `<div style="height:1px;background:#F3F4F6;margin:4px 0 0 0;"></div>`; }

    const count500    = Number(day?.events_within_500m_count)||0;
    const count5km    = Number(day?.events_within_5km_count)||0;
    const deltaEvents = Number(day?.delta_att_events_pct??0);
    const concStyle   = deltaEvents>3 ? RED : GREEN;
    const concLabel   = deltaEvents>3 ? "Élevée" : deltaEvents<-3 ? "Basse" : "Normale";
    const deltaAtt    = Number(day?.delta_att_mobility_pct??0);
    const deltaOps    = Number(day?.delta_ops_mobility_car_pct??0);
    const attMob      = mobLabel(deltaAtt);
    const opsMob      = mobLabel(deltaOps);
    const alertMax    = Number(day?.alert_level_max??0);
    const freqLabel   = alertMax===0 ? "Aucune alerte" : `Alerte niv. ${alertMax}`;
    const freqStyle   = alertMax===0 ? GREEN : alertMax<=2 ? YELLOW : RED;
    const lvlWind=Number(day?.lvl_wind??0), lvlRain=Number(day?.lvl_rain??0), lvlSnow=Number(day?.lvl_snow??0);
    const instLevel   = Math.max(lvlWind,lvlRain,lvlSnow);
    const instLabel   = instLevel===0?"Aucun risque":instLevel===1?"Risque faible":instLevel===2?"Risque modéré":"Risque élevé";
    const instStyle   = instLevel===0?GREEN:instLevel===1?YELLOW:instLevel===2?YELLOW:RED;

    const audienceRows = [aud1,aud2].filter(Boolean).length
      ? [aud1,aud2].filter(Boolean).map(a => { const av=audAvail(a); return row(audienceFrMap[a]||a, pill(av.label,av.style)); }).join("")
      : row("—", pill(isWeekend||hasVacation||hasHoliday?"Disponible":"Peu disponible", isWeekend||hasVacation||hasHoliday?GREEN:RED));

    return section("Audience", audienceRows)
      + divider()
      + section("Concurrence", row(`${count500} événements < 500m`, pill(concLabel,concStyle)) + row(`${count5km} événements < 5km`, pill(concLabel,concStyle)))
      + divider()
      + section("Accessibilité", row("Visiteurs < 5km", pill(attMob.label,attMob.style)) + row("Prestataires < 10km", pill(opsMob.label,opsMob.style)))
      + divider()
      + section("Exploitation", isOutdoorOrMixed
          ? row("Impact fréquentation", pill(freqLabel,freqStyle)) + row("Risque installation", pill(instLabel,instStyle))
          : row("Impact fréquentation", pill(freqLabel,freqStyle)));
  }
  
  function renderContext(day, profile) {
    return `
      <div class="mon-card">
        <div class="mon-head" style="margin-bottom:0;cursor:pointer;" id="pls-context-toggle">
          <div style="display:flex;align-items:center;gap:12px;flex:1;">
            <div class="mon-ico">${iconSVG("context")}</div>
            <div class="mon-kicker" style="margin:0;">Contexte de référence</div>
          </div>
          <svg id="pls-context-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round" style="transition:transform 200ms;flex-shrink:0;transform:rotate(180deg);">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </div>
        <div id="pls-context-body" style="margin-top:16px;">
          ${renderContextRows(day, profile)}
        </div>
      </div>`;
  }

  // ----------------------------------------------------------------
  // Recap tab
  // ----------------------------------------------------------------
  function renderRecap(currentDay, allFeed, profile, siteData) {
    const isMultisiteFeed = allFeed.some(a => a?.location_label);

    if (isMultisiteFeed) {
      siteData = Array.isArray(siteData) ? siteData : [];

      // ---- Points de vigilance: one row per site, worst risk first ----
      const siteVigilance = siteData.map(s => {
        const dayForDate = (s.days || []).find(d => normalizeYmd(d.date) === normalizeYmd(currentDay?.date));
        const risks = [...(dayForDate?.attendance||[]),...(dayForDate?.operations||[]),...(dayForDate?.installation||[]),...(dayForDate?.context||[])]
          .filter(r => r.severity !== "A")
          .sort((a,b) => ({D:0,C:1,B:2}[a.severity]??3)-({D:0,C:1,B:2}[b.severity]??3));
        return { label: s.label, topRisk: risks[0] || null, hasRisk: risks.length > 0 };
      }).sort((a,b) => {
        const sev = r => r?.topRisk?.severity;
        const order = {D:0,C:1,B:2};
        const av = order[sev(a)] ?? 3;
        const bv = order[sev(b)] ?? 3;
        return av - bv;
      });

      const riskyCount = siteVigilance.filter(s => s.hasRisk).length;
      const vigPillCls = riskyCount === 0 ? 'mon-statut-safe' : siteVigilance.some(s => s.topRisk?.severity === 'D' || s.topRisk?.severity === 'C') ? 'mon-statut-risk' : 'mon-statut-warn';
      const vigPillLabel = riskyCount === 0 ? 'TOUS SITES OK' : `${riskyCount} SITE${riskyCount>1?'S':''} À SURVEILLER`;

      const dotColor = s => (s === 'D' || s === 'C') ? 'var(--color-pill-risk-border)' : 'var(--color-pill-warn-border)';

      const vigilanceRows = siteVigilance.map((s, idx) => {
        const isLast = idx === siteVigilance.length - 1;
        const dot = s.hasRisk
          ? `<span style="width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:4px;background:${dotColor(s.topRisk?.severity)};display:inline-block;"></span>`
          : `<span style="width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:4px;border:1px solid #D1FAE5;background:#D1FAE5;display:inline-block;"></span>`;
        const sentence = s.hasRisk ? s.topRisk.sentence : "Aucun point de vigilance";
        const sentenceColor = s.hasRisk ? '#111827' : '#9CA3AF';
        return `<div style="display:flex;align-items:flex-start;gap:10px;padding:10px 0;${isLast?'':'border-bottom:1px solid #F3F4F6;'}">
          ${dot}
          <div style="flex:1;min-width:0;">
            <div style="font-size:11px;font-weight:600;letter-spacing:0.10em;text-transform:uppercase;color:#1D3BB3;margin-bottom:3px;">${escapeHtml(s.label)}</div>
            <div style="font-size:13px;color:${sentenceColor};line-height:1.35;">${escapeHtml(sentence)}</div>
          </div>
          <div style="font-size:12px;color:#9CA3AF;flex-shrink:0;margin-top:2px;">→</div>
        </div>`;
      }).join('');

      const vigilanceMultiHtml = `
        <div class="mon-card" style="padding:0;">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-bottom:1px solid #F3F4F6;">
            <div style="display:flex;align-items:center;gap:10px;">${iconSVG("alert")}<div class="mon-kicker" style="margin:0;">Points de vigilance</div></div>
            <span class="${vigPillCls}" style="font-size:11px;padding:4px 10px;">${vigPillLabel}</span>
          </div>
          <div style="padding:0 20px;">${vigilanceRows}</div>
        </div>`;

      // ---- Signals card ----
      const dayFeed = allFeed.filter(a => normalizeYmd(a?.affected_date) === normalizeYmd(currentDay?.date));
      const hasCritDay = dayFeed.some(a => Number(a?.alert_level||0) >= 3);
      const hasWarnDay = !hasCritDay && dayFeed.some(a => Number(a?.alert_level||0) >= 2);
      const statusBg    = hasCritDay ? "#FCEBEB" : hasWarnDay ? "#FEF3C7" : "rgba(16,185,129,0.1)";
      const statusColor = hasCritDay ? "#791F1F" : hasWarnDay ? "#92400E" : "#059669";
      const statusLabel = hasCritDay
        ? `⚠ ${dayFeed.filter(a=>Number(a?.alert_level||0)>=3).length} signal(aux) critique(s) · tous sites`
        : hasWarnDay ? `⚠ ${dayFeed.filter(a=>Number(a?.alert_level||0)>=2).length} signal(aux) à surveiller · tous sites`
        : "✓ Rien de nouveau sur tous les sites";

      const byLoc = new Map();
      for (const a of dayFeed) {
        const lbl = a?.location_label || "—";
        if (!byLoc.has(lbl)) byLoc.set(lbl, []);
        byLoc.get(lbl).push(a);
      }

      const feedHtml = byLoc.size === 0
        ? `<div style="text-align:center;padding:24px 0;color:#9CA3AF;font-size:14px;">Aucun signal pour cette date.</div>`
        : [...byLoc.entries()].map(([locLabel, locItems]) => {
            const locItemsHtml = locItems.slice(0,4).map((a, idx) => {
              const line1 = feedLine1(a);
              const line2 = feedLine2(a);
              const cat = String(a?.change_category||"").toLowerCase();
              const lvl = Number(a?.alert_level)||1;
              const isLast = idx === Math.min(locItems.length,4)-1;
              return `<div style="padding:11px 0;display:flex;align-items:flex-start;gap:10px;border-left:3px solid ${lvl>=3?"var(--color-pill-risk-border)":lvl>=2?"var(--color-pill-warn-border)":"var(--color-pill-green-text)"};padding-left:10px;${isLast?"":"border-bottom:1px solid #F3F4F6;"}">
                <div style="flex:0 0 auto;width:20px;display:flex;align-items:center;justify-content:center;margin-top:1px;">${feedCatIcon(cat)}</div>
                <div style="flex:1;min-width:0;">
                  <div class="mon-feed-line1">${escapeHtml(line1)}</div>
                  ${line2?`<div class="mon-feed-line2">${escapeHtml(line2)}</div>`:""}
                </div>
              </div>`;
            }).join("");
            return `<div style="margin-bottom:4px;">
              <div style="font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#1D3BB3;padding:10px 0 4px 0;">${escapeHtml(locLabel)}</div>
              ${locItemsHtml}
              ${locItems.length>4?`<div style="padding:8px 0 2px 0;"><button type="button" data-switch-tab="alertes" style="font-size:11px;font-weight:600;color:#1D3BB3;background:none;border:none;padding:0;cursor:pointer;">+${locItems.length-4} signaux →</button></div>`:""}
            </div>`;
          }).join("");

      const signalsCardHtml = `
        <div class="mon-card">
          <span style="display:inline-block;padding:4px 10px;border-radius:6px;font-size:13px;font-weight:500;background:${statusBg};color:${statusColor};margin-bottom:${byLoc.size?'12':'0'}px;">${statusLabel}</span>
          ${feedHtml}
        </div>`;

      // ---- Contexte de référence: tab switcher per site ----
      const ctxTabs = siteData.map((s, i) =>
        `<button type="button" data-ctx-tab="${i}"
          style="font-size:13px;font-weight:${i===0?'500':'400'};color:${i===0?'#111827':'#9CA3AF'};padding:10px 14px;border:none;border-right:${i<siteData.length-1?'0.5px solid #E5E7EB':'none'};background:${i===0?'#fff':'#F9FAFB'};cursor:pointer;font-family:inherit;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;">
          ${escapeHtml(s.label)}
        </button>`
      ).join('');

      const ctxTabBarHtml = siteData.length > 1
        ? `<div style="display:flex;border-bottom:0.5px solid #E5E7EB;overflow-x:auto;" id="pls-ctx-tabbar">${ctxTabs}</div>`
        : '';

      const firstSiteDay = (siteData[0]?.days||[]).find(d => normalizeYmd(d.date) === normalizeYmd(currentDay?.date)) || currentDay;
      const firstSiteProfile = siteData[0]?.profile || profile;

      const contextCardHtml = `
        <div class="mon-card" style="padding:0;">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 20px 0 20px;">
            <div style="display:flex;align-items:center;gap:10px;">${iconSVG("context")}<div class="mon-kicker" style="margin:0;">Contexte de référence</div></div>
          </div>
          ${ctxTabBarHtml}
          <div id="pls-ctx-body" style="padding:0 20px 16px;">
            ${renderContextRows(firstSiteDay, firstSiteProfile)}
          </div>
        </div>`;

      return `<div class="mon-panels" data-site-data='${escapeHtml(JSON.stringify(siteData.map((s,i) => ({i, location_id: s.location_id, label: s.label}))))}'>${vigilanceMultiHtml}${signalsCardHtml}${contextCardHtml}</div>`;
    }

    const alerts = allFeed.filter(a => Number(a?.alert_level||0) >= 2 && normalizeYmd(a?.affected_date) === normalizeYmd(currentDay?.date));
    const hasCrit = alerts.some(a => Number(a?.alert_level)>=3);
    const hasWatch = !hasCrit && alerts.some(a => Number(a?.alert_level)>=2);

    const statusBg    = hasCrit?"#FCEBEB":hasWatch?"#FEF3C7":"rgba(16,185,129,0.1)";
    const statusColor = hasCrit?"#791F1F":hasWatch?"#92400E":"#059669";
    const statusLabel = hasCrit
      ? `⚠ ${alerts.length} signal${alerts.length>1?"aux":""} critique${alerts.length>1?"s":""}`
      : hasWatch ? `⚠ ${alerts.length} signal${alerts.length>1?"aux":""} à surveiller`
      : "✓ Rien de nouveau";

    const last3 = [...alerts]
      .sort((a,b) => String(b?.feed_date||"").localeCompare(String(a?.feed_date||"")))
      .slice(0,3);

    const last3Html = last3.length ? `
      <div style="margin-top:16px;border-top:1px solid #F3F4F6;padding-top:4px;">
        <div style="font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:rgba(17,24,39,0.4);padding:10px 0 6px 0;">Derniers signaux</div>
        ${last3.map((a,idx) => {
          const line1=feedLine1(a), line2=feedLine2(a);
          const lvl=Number(a?.alert_level)||1;
          const dir=String(a?.direction||"").toLowerCase();
          const pStyle=(dir==="up"||dir==="improved")?GREEN:(dir==="down"||dir==="worsened"||lvl>=3)?RED:YELLOW;
          const pLabel=(dir==="up"||dir==="improved")?"En hausse":(dir==="down"||dir==="worsened")?"En baisse":"Changement";
          const isLast=idx===last3.length-1;
          return `<div style="padding:12px 0;display:flex;align-items:flex-start;gap:12px;${isLast?"":"border-bottom:1px solid #F3F4F6;}"}">
            <div style="flex:0 0 auto;width:20px;display:flex;align-items:center;justify-content:center;margin-top:2px;">${feedCatIcon(String(a?.change_category||""))}</div>
            <div style="flex:1;min-width:0;">
              <div style="font-size:13px;font-weight:700;color:#111827;line-height:1.3;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">${escapeHtml(line1)}${pill(pLabel,pStyle)}</div>
              ${line2?`<div style="font-size:12px;color:#374151;margin-top:2px;">${escapeHtml(line2)}</div>`:""}
            </div></div>`;
        }).join("")}
      </div>` : "";

    const statusHtml = `
      <div class="mon-card">
        <span style="display:inline-block;padding:4px 10px;border-radius:6px;font-size:13px;font-weight:500;background:${statusBg};color:${statusColor};">${statusLabel}</span>
        ${last3Html}
        ${alerts.length>3?`<div style="padding:8px 0 0 0;display:flex;justify-content:flex-end;"><button type="button" data-switch-tab="alertes" style="font-size:12px;font-weight:600;color:#1D3BB3;background:none;border:none;padding:0;cursor:pointer;">Voir les ${alerts.length} signaux →</button></div>`:""}
      </div>`;

    const vigilance = [...(currentDay.attendance||[]),...(currentDay.operations||[]),...(currentDay.installation||[]),...(currentDay.context||[])]
      .filter(r => r.severity!=="A")
      .sort((a,b) => ({D:0,C:1,B:2}[a.severity]??3)-({D:0,C:1,B:2}[b.severity]??3))
      .slice(0,5);

    const dotColor = s => s === "D" ? "var(--color-pill-risk-border)" : "var(--color-pill-warn-border)";

    const vigilanceHtml = vigilance.length ? `
      <div class="mon-card">
        <div class="mon-head">${iconSVG("alert")}<div class="mon-kicker" style="margin:0;">Points de vigilance</div></div>
        ${vigilance.map(r => `
          <div class="mon-vigilance-item">
            <span style="width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:5px;background:${dotColor(r.severity)};display:inline-block;"></span>
            <span>${escapeHtml(r.sentence)}</span>
          </div>`).join("")}
      </div>` : `
      <div class="mon-card">
        <span class="mon-status-ok">✓ Aucun point de vigilance</span>
        <div style="font-size:13px;color:#6b7280;margin-top:6px;">Conditions favorables pour la journée.</div>
      </div>`;

    return `<div class="mon-panels">${vigilanceHtml}${statusHtml}${renderContext(currentDay, profile)}</div>`;
  }

  // ----------------------------------------------------------------
  // Tab bar
  // ----------------------------------------------------------------
  function renderTabBar(activeTab) {
    const tabs = [{id:"recap",label:"Situation"},{id:"carte",label:"Environnement"},{id:"alertes",label:"Signaux"}];
    return `<div class="mon-tabs-bar">
      ${tabs.map(t => `<button type="button" class="mon-tab ${activeTab===t.id?"is-active":""}" data-tab="${escapeHtml(t.id)}">${escapeHtml(t.label)}</button>`).join("")}
    </div>`;
  }

  // ----------------------------------------------------------------
  // Main render
  // ----------------------------------------------------------------
  function renderPulse(data, selectedDate, activeTab) {
    activeTab = activeTab || "recap";
    const root = document.getElementById("pls-root");
    if (!root) return;

    const days = Array.isArray(data.days) ? data.days : [];
    const dayMap = new Map(days.map(d => [normalizeYmd(d.date), d]));
    const currentDay = dayMap.get(selectedDate) || days[0] || null;
    const allFeed = Array.isArray(data.all_feed) ? data.all_feed : [];
    const profile = data.profile || null;

    if (!currentDay) {
      root.innerHTML = `<div class="mon-error">Aucune donnée disponible.</div>`;
      return;
    }

    const score   = currentDay.opportunity_score ?? null;
    const hasRisk = currentDay.is_major_realization_risk_flag === true;
    const statusPill = computeStatusPill(currentDay);

    // Pills
    const today = todayYmd();
    const pillsHtml = `<div class="pls-pills">
      ${dates.map(ymd => {
        const d = dayMap.get(ymd);
        const allRisks = [...(d?.attendance||[]),...(d?.operations||[]),...(d?.installation||[])];
        const hasCrit = allRisks.some(r => r.severity==="D"||r.severity==="C");
        const hasWarn = !hasCrit && allRisks.some(r => r.severity==="B");
        const isActive = ymd===selectedDate;
        let cls = "pls-pill";
        if (isActive) cls+=" is-active";
        else if (ymd===today) cls+=" is-today";
        else if (hasCrit) cls+=" has-crit";
        else if (hasWarn) cls+=" has-warn";
        const label = ymd===today ? "Aujourd'hui" : fmtDateShort(ymd);
        const dotColor = isActive ? "#fff" : hasCrit ? "#e24b4a" : hasWarn ? "#ef9f27" : null;
        const dot = dotColor ? `<span class="pls-pill-dot" style="background:${dotColor};"></span>` : "";
        return `<button type="button" class="${cls}" data-pill-date="${ymd}">${escapeHtml(label)}${dot}</button>`;
      }).join("")}
    </div>`;

    // Header
    const headerHtml = `
      <div class="mon-card-decision" style="margin-bottom:0;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">
          <div>
            <div style="font-size:11px;font-weight:700;letter-spacing:0.10em;text-transform:uppercase;color:#1D3BB3;margin-bottom:6px;">
              ${escapeHtml(fmtDateLong(selectedDate))}
            </div>
            ${score!==null ? `
              <div style="display:flex;align-items:baseline;gap:6px;">
                <span style="font-size:42px;font-weight:500;color:#111827;line-height:1;">${escapeHtml(String(score))}</span>
                <span style="font-size:16px;color:#9CA3AF;">/10</span>
              </div>` : ""}
          </div>
          <span class="${statusPill.cls}">${escapeHtml(statusPill.label)}</span>
        </div>
        ${renderTabBar(activeTab)}
      </div>`;

    // Tab content
    let tabContent = "";
    if (activeTab==="recap") {
      tabContent = renderRecap(currentDay, allFeed, profile, data._siteData || []);
    } else if (activeTab==="alertes") {
      const showAll = (window.__plsFeedShowAll===true);
      tabContent = `<div class="mon-panels"><div style="padding-top:8px;">${renderFeedItems(allFeed, showAll)}</div></div>`;
      setTimeout(() => {
        const btn = root.querySelector("#pls-feed-toggle");
        if (btn) btn.addEventListener("click", () => { window.__plsFeedShowAll=!showAll; renderPulse(data, selectedDate, "alertes"); });
      }, 0);
    } else if (activeTab==="carte") {
      const mapLocs = Array.isArray(data._locations) && data._locations.length > 1
        ? data._locations
        : null;
      const primaryLoc = mapLocs ? (mapLocs.find(l => l.is_primary) || mapLocs[0]) : null;
      const defaultLocId = primaryLoc ? primaryLoc.location_id : location_id;
      tabContent = `
        <div class="mon-panels">
          ${mapLocs ? `
            <div style="display:flex;align-items:center;gap:0;border:0.5px solid #E5E7EB;border-radius:8px;overflow:hidden;margin-top:8px;">
              ${mapLocs.map((l, i) => {
                const isDefault = l.location_id === defaultLocId;
                return `<button type="button"
                  data-map-loc="${escapeHtml(l.location_id)}"
                  style="flex:1;padding:10px 14px;font-size:13px;font-weight:${isDefault?'500':'400'};color:${isDefault?'#111827':'#9CA3AF'};background:${isDefault?'#fff':'#F9FAFB'};border:none;border-right:${i<mapLocs.length-1?'0.5px solid #E5E7EB':'none'};cursor:pointer;font-family:inherit;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                  ${escapeHtml(l.company_name || l.location_id)}
                </button>`;
              }).join('')}
            </div>` : ''}
          <iframe id="pls-map-iframe"
            src="/app/insightevent/map?location_id=${encodeURIComponent(defaultLocId)}&date=${encodeURIComponent(selectedDate)}&embed=1"
            style="width:100%;height:600px;border:none;border-radius:14px;margin-top:8px;display:block;"
          ></iframe>
        </div>`;
    }

    root.innerHTML = pillsHtml + `<div style="height:12px;"></div>` + headerHtml + tabContent;

    // Wire pills
    root.querySelectorAll("[data-pill-date]").forEach(btn => {
      btn.addEventListener("click", () => {
        const d = btn.getAttribute("data-pill-date");
        if (d) renderPulse(data, d, "recap");
      });
    });

    // Wire tabs
    root.querySelectorAll(".mon-tab[data-tab]").forEach(btn => {
      btn.addEventListener("click", () => {
        const t = btn.getAttribute("data-tab");
        if (t) renderPulse(data, selectedDate, t);
      });
    });

    // Wire context toggle
    const toggleBtn  = root.querySelector("#pls-context-toggle");
    const ctxBody    = root.querySelector("#pls-context-body");
    const ctxChevron = root.querySelector("#pls-context-chevron");
    if (toggleBtn && ctxBody) {
      toggleBtn.addEventListener("click", (e) => {
        if (e.target.closest("[data-switch-tab]")) return;
        const isOpen = ctxBody.style.display!=="none";
        ctxBody.style.display = isOpen?"none":"block";
        if (ctxChevron) ctxChevron.style.transform = isOpen?"":"rotate(180deg)";
      });
    }

    // Wire tab-switch CTAs
    root.querySelectorAll("[data-switch-tab]").forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation(); e.preventDefault();
        const t = btn.getAttribute("data-switch-tab");
        if (t) renderPulse(data, selectedDate, t);
      });
    });

    // Wire multisite context tab switcher
    const ctxTabBar = root.querySelector("#pls-ctx-tabbar");
    if (ctxTabBar && data._siteData) {
      ctxTabBar.querySelectorAll("[data-ctx-tab]").forEach(btn => {
        btn.addEventListener("click", () => {
          const idx = Number(btn.getAttribute("data-ctx-tab"));
          const site = data._siteData[idx];
          if (!site) return;
          const siteDay = (site.days||[]).find(d => normalizeYmd(d.date) === normalizeYmd(selectedDate)) || currentDay;
          const ctxBody = root.querySelector("#pls-ctx-body");
          if (ctxBody) ctxBody.innerHTML = renderContextRows(siteDay, site.profile);
          ctxTabBar.querySelectorAll("[data-ctx-tab]").forEach(b => {
            const isActive = b === btn;
            b.style.fontWeight = isActive ? '500' : '400';
            b.style.color = isActive ? '#111827' : '#9CA3AF';
            b.style.background = isActive ? '#fff' : '#F9FAFB';
          });
        });
      });
    }

    // Wire map site selector
    if (activeTab === "carte") {
      root.querySelectorAll("[data-map-loc]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const locId = btn.getAttribute("data-map-loc");
          const iframe = root.querySelector("#pls-map-iframe");
          if (iframe && locId) {
            iframe.src = "about:blank";
            setTimeout(() => {
              iframe.src = `/app/insightevent/map?location_id=${encodeURIComponent(locId)}&date=${encodeURIComponent(selectedDate)}&embed=1`;
            }, 0);
          }
          root.querySelectorAll("[data-map-loc]").forEach(b => {
            const isActive = b === btn;
            b.style.fontWeight = isActive ? '500' : '400';
            b.style.color = isActive ? '#111827' : '#9CA3AF';
            b.style.background = isActive ? '#fff' : '#F9FAFB';
          });
        });
      });
    }

    if (activeTab==="carte") {
      const iframe = root.querySelector("iframe");
      if (iframe) {
        window.__plsMapHeightListener && window.removeEventListener("message", window.__plsMapHeightListener);
        window.__plsMapHeightListener = function(e) {
          if (e.data?.type === "map-height" && typeof e.data.height === "number" && e.data.height > 100) {
            iframe.style.height = e.data.height + "px";
          }
        };
        window.addEventListener("message", window.__plsMapHeightListener);
      }
    }
  }

  // ----------------------------------------------------------------
  // Locations
  // ----------------------------------------------------------------
  async function fetchLocations() {
    const res = await fetch("/api/profile/locations", { cache:"no-store" });
    const json = await res.json().catch(()=>null);
    return Array.isArray(json?.locations) ? json.locations : [];
  }

  // ----------------------------------------------------------------
  // Fetch
  // ----------------------------------------------------------------
  const dates = next8Days();

  async function fetchPulse(loc) {
    const qs = new URLSearchParams();
    qs.set("location_id", loc);
    qs.set("selected_dates", dates.join(","));
    const res = await fetch("/api/insight/monitor?"+qs.toString(), {cache:"no-store"});
    const json = await res.json().catch(()=>null);
    if (!res.ok||!json?.ok) throw new Error(json?.error||"Erreur API");
    return json;
  }

  // ----------------------------------------------------------------
  // Boot
  // ----------------------------------------------------------------
  let currentLocationId = location_id;
  let allLocations = [];

  (async function boot() {
    const root = document.getElementById("pls-root");
    try {
      const locs = await fetchLocations().catch(() => []);
      allLocations = locs;

      const isMultisite = locs.length > 1;

      const nameEl   = document.getElementById("pls-loc-name");
      const addrEl   = document.getElementById("pls-loc-addr");
      const switchBtn = document.getElementById("pls-loc-switch");
      const subtitleEl = document.getElementById("pls-subtitle");

      // Hide "Changer de site" in multisite mode
      if (switchBtn) switchBtn.style.display = "none";

      if (isMultisite) {
        // Multisite: fetch all locations in parallel
        if (nameEl) nameEl.textContent = "Tous mes sites";
        if (addrEl) addrEl.textContent = `${locs.length} sites surveillés`;
        if (subtitleEl) subtitleEl.textContent = `Veille opérationnelle · 7 jours · ${locs.length} sites`;

        const results = await Promise.all(
          locs.map(l => fetchPulse(l.location_id).then(d => ({ data: d, loc: l })).catch(() => null))
        );
        const valid = results.filter(Boolean);
        if (!valid.length) throw new Error("Aucune donnée disponible.");

        // Merge all_feed arrays, tagging each signal with location_label
        const mergedFeed = valid.flatMap(({ data, loc }) =>
          (data.all_feed || []).map(a => ({ ...a, location_label: loc.company_name || loc.location_id }))
        );

        // Merge days: worst score per date across all sites
        const dateMap = new Map();
        for (const { data } of valid) {
          for (const day of (data.days || [])) {
            const ymd = String(day.date || "").slice(0, 10);
            const existing = dateMap.get(ymd);
            if (!existing) {
              dateMap.set(ymd, { ...day });
            } else {
              // Worst opportunity_score (lower = worse)
              if (day.opportunity_score !== null && (existing.opportunity_score === null || day.opportunity_score < existing.opportunity_score)) {
                existing.opportunity_score = day.opportunity_score;
              }
              // Worst is_forced_regime_c_flag
              if (day.is_forced_regime_c_flag) existing.is_forced_regime_c_flag = true;
              // Worst risk blocks: merge arrays
              existing.attendance   = [...(existing.attendance   || []), ...(day.attendance   || [])];
              existing.operations   = [...(existing.operations   || []), ...(day.operations   || [])];
              existing.installation = [...(existing.installation || []), ...(day.installation || [])];
              existing.context      = [...(existing.context      || []), ...(day.context      || [])];
            }
          }
        }
        const mergedDays = [...dateMap.values()];

        // Use profile from primary location (first valid result)
        const mergedProfile = valid[0].data.profile || null;

        const mergedData = {
          ok: true,
          profile: mergedProfile,
          days: mergedDays,
          all_feed: mergedFeed,
          _locations: locs,
          _siteData: valid.map(({ data, loc }) => ({
            location_id: loc.location_id,
            label: loc.company_name || loc.location_id,
            profile: data.profile || null,
            days: data.days || [],
          })),
        };

        const LS_KEY = "ms_pulse_last_visit";
        const lastVisit = getLastVisitTimestamp(LS_KEY);
        mergedData.all_feed = filterFeedByWindow(mergedData.all_feed, lastVisit);
        setLastVisitTimestamp(LS_KEY);
        renderPulse(mergedData, todayYmd(), "recap");

      } else {
        // Single site: original behaviour
        const currentLoc = locs.find(l => l.location_id === currentLocationId);
        const data = await fetchPulse(currentLocationId);

        if (nameEl) nameEl.textContent = currentLoc?.company_name || data.profile?.city_name || "Mon site";
        if (addrEl) addrEl.textContent = currentLoc?.company_address || "";

        const LS_KEY = "ms_pulse_last_visit";
        const lastVisit = getLastVisitTimestamp(LS_KEY);
        data.all_feed = filterFeedByWindow(data.all_feed || [], lastVisit);
        setLastVisitTimestamp(LS_KEY);
        data._locations = [];
        renderPulse(data, todayYmd(), "recap");
      }

    } catch(e) {
      if (root) root.innerHTML = `<div class="mon-error">${escapeHtml(e?.message||"Erreur de chargement.")}</div>`;
      console.error(e);
    }
  })();

})();
</script>