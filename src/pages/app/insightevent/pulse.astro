            var tags = d.audience_profile ? d.audience_profile.split(/[,;]/).map(function(t) { return t.trim(); }).filter(Boolean) : [];
            detail.innerHTML = '<div style="background:#F9FAFB;border:0.5px solid #E5E7EB;border-radius:10px;overflow:hidden;margin-top:8px;">'
              + (rows.length ? '<div style="display:grid;grid-template-columns:1fr 1fr;">' + rows.map(function(r, i) {
                return '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;' + (i % 2 === 0 && i < rows.length - 1 ? 'border-right:0.5px solid #F3F4F6;' : '') + '">'
                  + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:3px;">' + escapeHtml(r[0]) + '</div>'
                  + '<div style="font-size:13px;color:#111827;line-height:1.4;">' + escapeHtml(String(r[1])) + '</div>'
                + '</div>';
              }).join('') + '</div>' : '')
              + (tags.length ? '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
                + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:6px;">Audience</div>'
                + '<div style="display:flex;flex-wrap:wrap;gap:5px;">' + tags.map(function(t) { return '<span style="font-size:11px;font-weight:500;padding:2px 9px;border-radius:20px;background:#EFF6FF;color:#1D4ED8;">' + escapeHtml(t) + '</span>'; }).join('') + '</div>'
              + '</div>' : '')
              + (d.business_takeaway ? '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
                + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:5px;">Impact pour votre activit\u00e9</div>'
                + '<div style="font-size:12px;color:#111827;line-height:1.55;">' + escapeHtml(d.business_takeaway) + '</div>'
              + '</div>' : '')
              + '<div style="padding:9px 14px;display:flex;justify-content:space-between;align-items:center;">'
                + '<div style="font-size:10px;letter-spacing:0.07em;text-transform:uppercase;color:#9CA3AF;display:flex;align-items:center;gap:5px;">'
                  + '<span style="width:6px;height:6px;border-radius:50%;background:#059669;display:inline-block;flex-shrink:0;"></span>'
                  + 'Agent IA \u00b7 web'
                + '</div>'
                + (d.source_url ? '<a href="' + escapeHtml(d.source_url) + '" target="_blank" rel="noopener" style="font-size:12px;color:#1D3BB3;text-decoration:none;">Source officielle \u2192</a>' : '')
              + '</div>'
            + '</div>';
          } catch(err) {
            detail.innerHTML = '<div style="font-size:12px;color:#B91C1C;padding:8px 0;">Donn\u00e9es non disponibles.</div>';
            btn.textContent = "Voir plus \u2192";
          }
        });
      });

      // Wire Suivre CTA
      root.querySelectorAll("[data-follow-threat]").forEach(function(btn) {
        btn.addEventListener("click", async function(e) {
          e.stopPropagation();
          const compId = btn.getAttribute("data-follow-threat");
          const compName = btn.getAttribute("data-follow-name") || "";
          if (!compId) return;
          btn.disabled = true;
          btn.textContent = "...";
          try {
            const res = await fetch("/api/competitive/add-competitor", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ competitor_id: compId, competitor_name: compName }),
            });
            const json = await res.json().catch(function() { return null; });
            if (res.ok && json?.ok) {
              btn.textContent = "Suivi";
              btn.style.background = "#dcfce7";
              btn.style.borderColor = "#bbf7d0";
              btn.style.color = "#166534";
            } else {
              btn.textContent = "Erreur";
              btn.style.background = "#fef2f2";
              btn.style.borderColor = "#fecaca";
              btn.style.color = "#991b1b";
            }
          } catch(err) {
            btn.textContent = "Erreur";
            btn.disabled = false;
          }
        });
      });

      return;
    }

    // ---- RADAR VIEW (default) ----

    // Enrich competition feed items with threat data from competitor signals
    var compSigs = Array.isArray(data._competitor_signals) ? data._competitor_signals : [];
    for (var fi = 0; fi < allFeed.length; fi++) {
      var feedItem = allFeed[fi];
      var fSub = String(feedItem.change_subtype || "").toLowerCase();
      if (fSub !== "competitor_event_launch" && fSub !== "competitor_audience_conflict" && fSub !== "competitor_event_ending" && fSub !== "competition_pressure_spike") continue;
      var fEntityId = feedItem.entity_id || null;
      var fNewValue = String(feedItem.new_value || "");
      var fCompName = fNewValue.split(" \u2014 ")[0] || "";
      // Match by entity_id first, then by competitor name
      var matched = null;
      for (var ci = 0; ci < compSigs.length; ci++) {
        if (fEntityId && compSigs[ci].competitor_event_id === fEntityId) { matched = compSigs[ci]; break; }
      }
      if (!matched && fCompName) {
        for (var ci = 0; ci < compSigs.length; ci++) {
          if (String(compSigs[ci].competitor_name || "").toLowerCase() === fCompName.toLowerCase()) { matched = compSigs[ci]; break; }
        }
      }
    }

    // Daily Action Brief
    var briefHtml = renderDailyBrief(allFeed, data.profile || {}, currentDay, selectedDate, currentLocationId, days, followedCount, (data.active_goal && data.active_goal.goal) ? String(data.active_goal.goal) : "");

    // Strip 1: Score
    const score = currentDay.opportunity_score;
    const regime = String(currentDay.opportunity_regime || "B").toUpperCase();
    const regimeLabel = regime === "A" ? "Contexte favorable" : regime === "C" ? "Contexte défavorable" : "Conditions normales";

    // weekRank
    const sortedDays = [...days].filter(d => d.opportunity_score != null).sort((a, b) => (b.opportunity_score ?? 0) - (a.opportunity_score ?? 0));
    const rankIdx = sortedDays.findIndex(d => normalizeYmd(d.date) === normalizeYmd(currentDay.date));
    const rank = rankIdx >= 0 ? rankIdx + 1 : null;
    const totalDays = sortedDays.length;
    let weekRankShort = "";
    if (rank === 1) weekRankShort = "Meilleur jour de la semaine";
    else if (rank === totalDays) weekRankShort = "Jour le moins favorable de la semaine";
    else if (rank != null && totalDays > 0) weekRankShort = `${rank}e meilleur jour de la semaine`;

    const scoreSummary = score != null
      ? `Score jour : ${score} /10${weekRankShort ? ` · ${escapeHtml(weekRankShort)}` : ""} · ${escapeHtml(regimeLabel)}`
      : "Score indisponible";

    const scoreAlert = currentDay.is_forced_regime_c_flag ? "critical" : (dayAlerts.length > 0 ? "warning" : null);

    // Strip 2: Threats — recap across ALL followed competitors
    const compByComp = new Map();
    for (const s of competitorSignals) {
      const cid = s.competitor_id || "unknown";
      if (!compByComp.has(cid)) compByComp.set(cid, []);
      compByComp.get(cid).push(s);
    }
    const followedCompetitors = data._followed_competitors || [];
    const totalComps = Math.max(compByComp.size, followedCompetitors.length);
    const totalActiveEvents = competitorSignals.filter(s => s.is_active).length;

    // Find worst threat level across all competitors
    const THREAT_ORDER = { high: 3, moderate: 2, low: 1 };
    let worstThreatLevel = null;
    let worstThreatScore = 0;
    let hasAnyAudOverlap = false;
    for (const [, sigs] of compByComp) {
      const lvl = sigs[0]?.entity_threat_level || null;
      const ts = Number(sigs[0]?.entity_threat_score || 0);
      if (ts > worstThreatScore) { worstThreatScore = ts; worstThreatLevel = lvl; }
      if (sigs.some(s => s.audience_overlap)) hasAnyAudOverlap = true;
    }

    // Include threat levels from followed competitors without event signals
    for (const fc of followedCompetitors) {
      const ts = Number(fc.threat_score || 0);
      const lvl = fc.threat_level || null;
      if (ts > worstThreatScore) { worstThreatScore = ts; worstThreatLevel = lvl; }
    }

    const THREAT_LABELS_FR = { high: "Menace \u00e9lev\u00e9e", moderate: "Menace mod\u00e9r\u00e9e", low: "Menace faible" };
    let threatSummary = "";
    if (totalComps > 0) {
      const worstLabel = THREAT_LABELS_FR[worstThreatLevel] || null;
      const parts = [];
      parts.push(`Concurrents suivis : ${totalComps}`);
      if (totalActiveEvents > 0) {
        parts.push(`${totalActiveEvents} \u00e9v\u00e9n. actif${totalActiveEvents > 1 ? "s" : ""}`);
      }
      if (worstLabel) parts.push(escapeHtml(worstLabel));
      else if (hasAnyAudOverlap) parts.push("Chevauchement audience");
      threatSummary = parts.join(" \u00b7 ");
    } else {
      threatSummary = followedCount > 0 ? "Aucun conflit direct" : "Aucun concurrent suivi";
    }

    const threatAlert = (worstThreatLevel === "high" || hasAnyAudOverlap) ? "warning" : null;

    // Strip 3: Environnement concurrentiel — use competition_pressure_ratio for pressure label
    const envCount500 = Number(currentDay.events_within_500m_count || 0);
    const envCount5km = Number(currentDay.events_within_5km_count || 0);
    const pressureRatio = Number(currentDay.competition_pressure_ratio || 0);
    const hasBaseline = Boolean(currentDay.has_valid_baseline_flag);
    let envSummary = "";
    let envAlert = null;
    if (envCount5km === 0) {
      envSummary = `Autour de vous : 0 \u00e9v\u00e9nement \u00e0 5 km`;
    } else if (hasBaseline && pressureRatio > 1.2) {
      envSummary = `Autour de vous : ${envCount5km} \u00e9v\u00e9nements \u00e0 5 km \u00b7 Sup\u00e9rieur \u00e0 la moyenne`;
      envAlert = "warning";
    } else if (hasBaseline && pressureRatio < 0.8) {
      envSummary = `Contexte concurrentiel : ${envCount5km} \u00e9v\u00e9nements \u00e0 5 km \u00b7 Inf\u00e9rieur \u00e0 la moyenne`;
    } else if (hasBaseline) {
      envSummary = `Contexte concurrentiel : ${envCount5km} \u00e9v\u00e9nements \u00e0 5 km \u00b7 Dans la moyenne`;
    } else {
      envSummary = `Contexte concurrentiel : ${envCount5km} \u00e9v\u00e9nements \u00e0 5 km`;
    }

    // Build strips
    const strip1 = renderRadarStrip("score", "📈", scoreSummary, scoreAlert,
      renderScoreDetail(currentDay, days));

    const strip2 = renderRadarStrip("changes", "📡", envSummary, envAlert,
      renderChangeDetail(currentDay, data._top_threats || []));

    const strip3 = renderRadarStrip("threats", "🎯", threatSummary, threatAlert,
      renderThreatSummary(competitorSignals, selectedDate, followedCount, data._top_threats || []));

    // Feed
    var _feedCoveredTypes = (typeof window.getActionCandidateTypes === 'function' && window._lastActionCandidates) ? window.getActionCandidateTypes(window._lastActionCandidates, selectedDate) : {};
    const feedHtml = renderFeed(allFeed, isMultisite, _feedCoveredTypes);

    // Date header
    const dateHeaderHtml = `<div style="font-size:11px;font-weight:700;letter-spacing:0.10em;text-transform:uppercase;color:#1D3BB3;margin-bottom:12px;">${escapeHtml(fmtDateLong(selectedDate))}</div>`;

    // Weekly goal selector (single-site only — per-location goal is ambiguous when sites are merged)
    var GOAL_OPTS = [
      { key: "faire_venir", label: "Faire venir" },
      { key: "augmenter_panier", label: "Augmenter le panier" },
      { key: "plus_avis", label: "Plus d\u2019avis" },
      { key: "surveiller_marche", label: "Surveiller le march\u00e9" },
    ];
    var activeGoalKey = data.active_goal ? String((data.active_goal.goal != null ? data.active_goal.goal : data.active_goal) || "") : "";
    var goalSelectorHtml = isMultisite ? "" : (
      '<div style="margin-bottom:16px;" data-goal-selector>'
      + '<div style="font-size:11px;font-weight:700;letter-spacing:0.10em;text-transform:uppercase;color:#9CA3AF;margin-bottom:8px;">Objectif de la semaine</div>'
      + '<div style="display:flex;gap:6px;flex-wrap:wrap;">'
      + GOAL_OPTS.map(function(g) {
          var sel = g.key === activeGoalKey;
          return '<button type="button" data-goal-key="' + g.key + '" aria-pressed="' + (sel ? 'true' : 'false') + '" style="font-size:12px;font-weight:600;padding:6px 12px;border:1px solid ' + (sel ? '#1D3BB3' : '#E5E7EB') + ';background:' + (sel ? '#1D3BB3' : '#fff') + ';color:' + (sel ? '#fff' : '#6B7280') + ';cursor:pointer;font-family:inherit;">' + escapeHtml(g.label) + '</button>';
        }).join("")
      + '</div>'
      + '</div>'
    );

    // Actions-menées counter (single-site; baseline from dbt table, bumped live on card_done)
    var _cardsDone = (!isMultisite && data.activity && data.activity.cards_done != null) ? Number(data.activity.cards_done) : null;
    var counterHtml = (_cardsDone != null)
      ? '<div style="display:flex;align-items:center;gap:6px;margin-bottom:12px;"><span style="font-size:11px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#059669;">\u2713 <span data-actions-counter>' + _cardsDone + '</span> actions men\u00e9es</span></div>'
      : "";

    // Assemble
    root.innerHTML = pillsHtml + `<div style="height:12px;"></div>` + dateHeaderHtml + alertsHtml +
      `<div style="margin-bottom:20px;">${strip1}${strip2}${strip3}</div>` + goalSelectorHtml + counterHtml + briefHtml + feedHtml;

    // ---- Wire event handlers ----

    // Pills
    root.querySelectorAll("[data-pill-date]").forEach(btn => {
      btn.addEventListener("click", async () => {
        const d = btn.getAttribute("data-pill-date");
        if (!d) return;
        const csResult = await fetchCompetitorSignals(d).catch(() => ({ signals: [], followed_count: 0 }));
        data._competitor_signals = csResult.signals;
        data._competitor_followed_count = csResult.followed_count;
        renderPulse(data, d, "radar");
      });
    });

    // Weekly goal selector
    root.querySelectorAll("[data-goal-selector] [data-goal-key]").forEach(function(btn) {
      btn.addEventListener("click", function() {
        var key = btn.getAttribute("data-goal-key");
        var clear = btn.getAttribute("aria-pressed") === "true"; // re-tapping the active goal deselects
        var rowEl = btn.closest("[data-goal-selector]");
        if (rowEl) rowEl.querySelectorAll("[data-goal-key]").forEach(function(b) {
          var on = (!clear && b === btn);
          b.setAttribute("aria-pressed", on ? "true" : "false");
          b.style.border = "1px solid " + (on ? "#1D3BB3" : "#E5E7EB");
          b.style.background = on ? "#1D3BB3" : "#fff";
          b.style.color = on ? "#fff" : "#6B7280";
        });
        data.active_goal = clear ? null : { goal: key };
        fetch("/api/insight/set-goal", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(clear
            ? { location_id: currentLocationId, scope: "weekly", clear: true }
            : { location_id: currentLocationId, scope: "weekly", goal: key }),
        }).catch(function(){});
      });
    });

    // Radar strip toggles
    root.querySelectorAll("[data-radar-toggle]").forEach(btn => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-radar-toggle");
        const body = root.querySelector(`[data-radar-body="${id}"]`);
        const chevron = root.querySelector(`[data-radar-chevron="${id}"]`);
        if (!body) return;
        const isOpen = body.style.display !== "none";
        body.style.display = isOpen ? "none" : "block";
        if (chevron) chevron.style.transform = isOpen ? "none" : "rotate(180deg)";
      });
    });

    // Score / Fiabilité tab switching
    root.querySelectorAll("[data-score-tab]").forEach(function(btn) {
      btn.addEventListener("click", function() {
        var tab = btn.getAttribute("data-score-tab");
        var scorePanel = root.querySelector('[data-score-panel="score"]');
        var fiabPanel = root.querySelector('[data-score-panel="fiabilite"]');
        if (!scorePanel || !fiabPanel) return;
        scorePanel.style.display = tab === "score" ? "block" : "none";
        fiabPanel.style.display = tab === "fiabilite" ? "block" : "none";
        root.querySelectorAll("[data-score-tab]").forEach(function(b) {
          var isActive = b.getAttribute("data-score-tab") === tab;
          b.style.color = isActive ? "#1D3BB3" : "#94A3B8";
          b.style.borderBottom = isActive ? "2px solid #1D3BB3" : "2px solid transparent";
        });
        // Lazy-load accuracy data on first fiabilité click
        if (tab === "fiabilite" && !root._fiabiliteLoaded) {
          root._fiabiliteLoaded = true;
          var barsEl = root.querySelector("[data-fiabilite-bars]");
          var globalEl = root.querySelector("[data-fiabilite-global]");
          var metaEl = root.querySelector("[data-fiabilite-meta]");
          var badgeEl = root.querySelector("[data-fiabilite-badge]");
          fetch("/api/analytics/signal-accuracy?location_id=" + encodeURIComponent(location_id))
            .then(function(r) { return r.json(); })
            .then(function(json) {
              if (!json.ok || !json.signals) throw new Error("No data");
              var SIGNAL_DEFS = [
                { key: "competition", label: "Concurrence", icon: "\ud83d\udcca" },
                { key: "mobility", label: "Mobilit\u00e9", icon: "\ud83d\ude87" },
                { key: "weather", label: "M\u00e9t\u00e9o", icon: "\ud83c\udf26" },
              ];
              var available = SIGNAL_DEFS.filter(function(s) { return json.signals[s.key]; });
              var pending = SIGNAL_DEFS.filter(function(s) { return !json.signals[s.key]; });
              var totalSamples = 0;
              var globalAvg = 0;
              if (available.length) {
                globalAvg = Math.round(available.reduce(function(sum, s) { return sum + json.signals[s.key].accuracy_pct; }, 0) / available.length);
                totalSamples = available.reduce(function(sum, s) { return sum + json.signals[s.key].sample_size; }, 0);
              }
              var gc = "#1D3BB3";
              if (globalEl) {
                globalEl.innerHTML = available.length
                  ? '<span style="font-size:32px;font-weight:800;color:' + gc + ';line-height:1;">' + globalAvg + '</span><span style="font-size:14px;color:#9ca3af;">%</span>'
                  : '<span style="font-size:14px;color:#9ca3af;font-style:italic;">Donn\u00e9es insuffisantes</span>';
              }
              if (metaEl) metaEl.innerHTML = "30 derniers jours<br>" + totalSamples + " signaux";
              if (badgeEl) {
                if (available.length) {
                  badgeEl.style.background = "#EFF6FF";
                  badgeEl.style.color = "#1D3BB3";
                  badgeEl.textContent = globalAvg + "%";
                }
              }
              var barsHtml = "";
              available.forEach(function(s) {
                var d = json.signals[s.key];
                var pct = d.accuracy_pct;
                var bc = "#1D3BB3";
                var bbg = "#DBEAFE";
                barsHtml += '<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-top:0.5px solid #f3f4f6;">'
                  + '<span style="font-size:14px;flex-shrink:0;">' + s.icon + '</span>'
                  + '<span style="font-size:12px;color:#374151;font-weight:500;min-width:85px;">' + s.label + '</span>'
                  + '<div style="flex:1;height:6px;background:' + bbg + ';border-radius:3px;overflow:hidden;">'
                    + '<div style="width:' + pct + '%;height:100%;background:' + bc + ';border-radius:3px;"></div>'
                  + '</div>'
                  + '<span style="font-size:13px;font-weight:700;color:' + bc + ';min-width:36px;text-align:right;">' + pct + '%</span>'
                + '</div>';
              });
              pending.forEach(function(s) {
                barsHtml += '<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-top:0.5px solid #f3f4f6;opacity:0.45;">'
                  + '<span style="font-size:14px;flex-shrink:0;">' + s.icon + '</span>'
                  + '<span style="font-size:12px;color:#9ca3af;font-weight:500;min-width:85px;">' + s.label + '</span>'
                  + '<span style="font-size:11px;color:#9ca3af;font-style:italic;">En cours de collecte</span>'
                + '</div>';
              });
              if (barsEl) barsEl.innerHTML = barsHtml;
            })
            .catch(function() {
              if (barsEl) barsEl.innerHTML = '<div style="font-size:12px;color:#9ca3af;padding:8px 0;">Donn\u00e9es de fiabilit\u00e9 indisponibles.</div>';
              if (globalEl) globalEl.innerHTML = '<span style="font-size:14px;color:#9ca3af;font-style:italic;">Indisponible</span>';
            });
        }
      });
    });

    // Foot traffic day/week tabs
    root.querySelectorAll("[data-ft-tab]").forEach(btn => {
      btn.addEventListener("click", () => {
        const tab = btn.getAttribute("data-ft-tab");
        const dayView = root.querySelector("#ft-view-day");
        const weekView = root.querySelector("#ft-view-week");
        if (!dayView || !weekView) return;
        dayView.style.display = tab === "day" ? "block" : "none";
        weekView.style.display = tab === "week" ? "block" : "none";
        root.querySelectorAll("[data-ft-tab]").forEach(b => {
          const isActive = b.getAttribute("data-ft-tab") === tab;
          b.style.color = isActive ? "#185FA5" : "var(--color-text-secondary)";
          b.style.fontWeight = isActive ? "500" : "500";
          b.style.borderBottom = isActive ? "2px solid #185FA5" : "2px solid transparent";
        });
      });
    });

    // Foot traffic day/week tabs
    root.querySelectorAll("[data-ft-tab]").forEach(btn => {
      btn.addEventListener("click", () => {
        const tab = btn.getAttribute("data-ft-tab");
        const dayView = root.querySelector("#ft-view-day");
        const weekView = root.querySelector("#ft-view-week");
        if (!dayView || !weekView) return;
        dayView.style.display = tab === "day" ? "block" : "none";
        weekView.style.display = tab === "week" ? "block" : "none";
        root.querySelectorAll("[data-ft-tab]").forEach(b => {
          const isActive = b.getAttribute("data-ft-tab") === tab;
          b.style.color = isActive ? "#1D3BB3" : "#9ca3af";
          b.style.fontWeight = isActive ? "600" : "500";
          b.style.borderBottom = isActive ? "2px solid #1D3BB3" : "2px solid transparent";
        });
      });
    });

    // Carte CTA in strip 3
    root.querySelectorAll("[data-radar-carte]").forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        data._mapMode = null;
        renderPulse(data, selectedDate, "carte");
      });
    });

    // Competitor tab switching inside strip 3
    root.querySelectorAll("[data-comp-tab]").forEach(function(btn) {
      btn.addEventListener("click", function() {
        var tab = btn.getAttribute("data-comp-tab");
        root.querySelectorAll("[data-comp-tab]").forEach(function(b) {
          var isActive = b.getAttribute("data-comp-tab") === tab;
          b.style.color = isActive ? "#1D3BB3" : "#94A3B8";
          b.style.borderBottom = isActive ? "2px solid #1D3BB3" : "2px solid transparent";
        });
        root.querySelectorAll("[data-comp-panel]").forEach(function(p) {
          p.style.display = p.getAttribute("data-comp-panel") === tab ? "block" : "none";
        });
      });
    });
    // Suivre buttons inside potentiels tab
    root.querySelectorAll("[data-follow-threat]").forEach(function(btn) {
      btn.addEventListener("click", async function(e) {
        e.stopPropagation();
        var compId = btn.getAttribute("data-follow-threat");
        var compName = btn.getAttribute("data-follow-name") || "";
        if (!compId) return;
        btn.disabled = true;
        btn.textContent = "...";
        try {
          var res = await fetch("/api/competitive/add-competitor", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ competitor_id: compId, competitor_name: compName }),
          });
          var json = await res.json().catch(function() { return null; });
          if (res.ok && json && json.ok) {
            btn.textContent = "Suivi \u2713";
            btn.style.background = "#dcfce7";
            btn.style.borderColor = "#bbf7d0";
            btn.style.color = "#166534";
          } else {
            btn.textContent = "Erreur";
            btn.disabled = false;
          }
        } catch(err) {
          btn.textContent = "Erreur";
          btn.disabled = false;
        }
      });
    });

    // Feed "show all" button
    const feedShowAll = root.querySelector("#pls-v4-feed-show-all");
    if (feedShowAll) {
      feedShowAll.addEventListener("click", () => {
        window.__plsV4FeedShowAll = true;
        renderPulse(data, selectedDate, "radar");
      });
    }

    // Feed "Suivre" handlers (event_new)
    root.querySelectorAll("[data-feed-follow]").forEach(btn => {
      btn.addEventListener("click", async (e) => {
        e.stopPropagation();
        btn.disabled = true;
        btn.textContent = "...";
        const label = btn.getAttribute("data-follow-label") || "";
        const venue = btn.getAttribute("data-follow-venue") || "";
        const city = btn.getAttribute("data-follow-city") || "";
        const date = btn.getAttribute("data-follow-date") || "";
        const industry = btn.getAttribute("data-follow-industry") || "";
        try {
          const [compRes, evRes] = await Promise.all([
            venue && city ? fetch("/api/competitive/add-competitor", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ competitor_name: venue, city: city, industry_code: industry || null }),
            }) : Promise.resolve(null),
            label && city && date ? fetch("/api/competitive/add-event", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ event_name: label, event_city: city, date_start: date }),
            }) : Promise.resolve(null),
          ]);
          const compOk = !compRes || (await compRes.json().catch(() => null))?.ok;
          const evOk = !evRes || (await evRes.json().catch(() => null))?.ok;
          if (compOk || evOk) {
            btn.textContent = "Suivi \u2713";
            btn.style.background = "#dcfce7";
            btn.style.borderColor = "#bbf7d0";
            btn.style.color = "#166534";
          } else {
            btn.textContent = "Erreur";
            btn.style.background = "#fef2f2";
            btn.style.borderColor = "#fecaca";
            btn.style.color = "#991b1b";
            btn.disabled = false;
          }
        } catch {
          btn.textContent = "Erreur";
          btn.disabled = false;
        }
      });
    });

    // Feed "Voir plus" enrich handlers (event_new)
    root.querySelectorAll("[data-feed-enrich]").forEach(btn => {
      btn.addEventListener("click", async (e) => {
        e.stopPropagation();
        const idx = btn.getAttribute("data-feed-enrich");
        const panel = root.querySelector('[data-feed-enrich-panel="' + idx + '"]');
        if (!panel) return;

        if (panel.style.display !== "none" && panel.innerHTML.trim()) {
          panel.style.display = "none";
          btn.textContent = "Voir plus \u2192";
          return;
        }

        panel.style.display = "block";
        panel.innerHTML = '<div style="font-size:12px;color:#9CA3AF;padding:8px 0;display:flex;align-items:center;gap:8px;"><span style="width:10px;height:10px;border:1.5px solid #E5E7EB;border-top-color:#1D3BB3;border-radius:50%;display:inline-block;animation:ms-spin 0.7s linear infinite;flex-shrink:0;"></span>Recherche en cours\u2026</div>';
        btn.textContent = "R\u00e9duire \u2191";

        try {
          const res = await fetch("/api/insight/enrich-event", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              event_label: btn.getAttribute("data-enrich-label") || "",
              description: "",
              city_name: btn.getAttribute("data-enrich-city") || "",
              event_venue_name: btn.getAttribute("data-enrich-venue") || "",
              event_uid: btn.getAttribute("data-enrich-uid") || null,
              city_id: null,
              distance_m: btn.getAttribute("data-enrich-distance") ? Number(btn.getAttribute("data-enrich-distance")) : null,
              radius_bucket: null,
              industry_code: btn.getAttribute("data-enrich-industry") || null,
            }),
          });
          const json = await res.json().catch(() => null);
          if (!json?.ok || !json?.data) throw new Error("R\u00e9ponse invalide");
          const d = json.data;
          const rows = [
            d.confirmed_dates      ? ["Dates",        d.confirmed_dates]      : null,
            d.venue_name           ? ["Lieu",          d.venue_name]           : null,
            d.venue_capacity       ? ["Capacit\u00e9", d.venue_capacity]       : null,
            d.organizer            ? ["Organisateur",  d.organizer]            : null,
            d.estimated_attendance ? ["Fr\u00e9quentation", d.estimated_attendance] : null,
          ].filter(Boolean);
          const tags = d.audience_profile ? d.audience_profile.split(/[,;]/).map(t => t.trim()).filter(Boolean) : [];
          panel.innerHTML = '<div style="background:#F9FAFB;border:0.5px solid #E5E7EB;border-radius:10px;overflow:hidden;margin-top:4px;">'
            + (rows.length ? '<div style="display:grid;grid-template-columns:1fr 1fr;">' + rows.map((r, i) =>
              '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;' + (i % 2 === 0 && i < rows.length - 1 ? 'border-right:0.5px solid #F3F4F6;' : '') + '">'
              + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:3px;">' + escapeHtml(r[0]) + '</div>'
              + '<div style="font-size:13px;color:#111827;line-height:1.4;">' + escapeHtml(String(r[1])) + '</div>'
              + '</div>'
            ).join('') + '</div>' : '')
            + (tags.length ? '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
              + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:6px;">Audience</div>'
              + '<div style="display:flex;flex-wrap:wrap;gap:5px;">' + tags.map(t => '<span style="font-size:11px;font-weight:500;padding:2px 9px;border-radius:20px;background:#EFF6FF;color:#1D4ED8;">' + escapeHtml(t) + '</span>').join('') + '</div>'
              + '</div>' : '')
            + (d.business_takeaway ? '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
              + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:5px;">Impact pour votre activit\u00e9</div>'
              + '<div style="font-size:12px;color:#111827;line-height:1.55;">' + escapeHtml(d.business_takeaway) + '</div>'
              + '</div>' : '')
            + '<div style="padding:9px 14px;display:flex;justify-content:space-between;align-items:center;">'
              + '<div style="font-size:10px;letter-spacing:0.07em;text-transform:uppercase;color:#9CA3AF;display:flex;align-items:center;gap:5px;">'
                + '<span style="width:6px;height:6px;border-radius:50%;background:#059669;display:inline-block;flex-shrink:0;"></span>'
                + 'Agent IA \u00b7 web'
              + '</div>'
              + (d.source_url ? '<a href="' + escapeHtml(d.source_url) + '" target="_blank" rel="noopener" style="font-size:12px;color:#1D3BB3;text-decoration:none;">Source officielle \u2192</a>' : '')
            + '</div>'
          + '</div>';
        } catch {
          panel.innerHTML = '<div style="font-size:12px;color:#B91C1C;padding:4px 0;">Donn\u00e9es non disponibles.</div>';
          btn.textContent = "Voir plus \u2192";
        }
      });
    });

    // Daily Brief handlers
    wireBriefHandlers(root, currentLocationId, selectedDate);

    // ---- Async AI sowhat replacement ----
    if (window.__pendingAiSowhat) {
      var _sowhatCtx = window.__pendingAiSowhat;
      window.__pendingAiSowhat = null;
      fetchSowhat(_sowhatCtx.payload, _sowhatCtx.profile, _sowhatCtx.day).then(function(sowhatMap) {
        if (!sowhatMap) return;
        for (var sigId in sowhatMap) {
          var card = root.querySelector('.ab-card[data-signal-id="' + sigId + '"]');
          if (card) {
            var sowhatEl = card.querySelector(".ab-sowhat");
            if (sowhatEl) sowhatEl.textContent = sowhatMap[sigId];
          }
        }
      }).catch(function() {});
    }

    // Feed CTA handlers — links navigate directly, no JS needed
  }

  // ----------------------------------------------------------------
  // Locations
  // ----------------------------------------------------------------
  async function fetchLocations() {
    const res = await fetch("/api/profile/locations", { cache:"no-store" });
    const json = await res.json().catch(()=>null);
    return Array.isArray(json?.locations) ? json.locations : [];
  }

  // ----------------------------------------------------------------
  // Fetch
  // ----------------------------------------------------------------
  const dates = next8Days();

  async function fetchPulse(loc) {
    const qs = new URLSearchParams();
    qs.set("location_id", loc);
    qs.set("selected_dates", dates.join(","));
    const res = await fetch("/api/insight/monitor?"+qs.toString(), {cache:"no-store"});
    const json = await res.json().catch(()=>null);
    if (!res.ok||!json?.ok) throw new Error(json?.error||"Erreur API");
    return json;
  }

  async function fetchCompetitorSignals(date) {
    if (!date) return { signals: [], followed_count: 0, followed_competitors: [], top_threats: [] };
    try {
      const res = await fetch(
        `/api/competitive/competitor-signals?selected_date=${encodeURIComponent(date)}`
      );
      const json = await res.json().catch(() => null);
      return {
        signals: (json?.ok && Array.isArray(json.signals)) ? json.signals : [],
        followed_count: json?.followed_count ?? 0,
        followed_competitors: (json?.ok && Array.isArray(json.followed_competitors)) ? json.followed_competitors : [],
        top_threats: (json?.ok && Array.isArray(json.top_threats)) ? json.top_threats : [],
      };
    } catch { return { signals: [], followed_count: 0, followed_competitors: [], top_threats: [] }; }
  }

  // ----------------------------------------------------------------
  // Boot
  // ----------------------------------------------------------------
  let currentLocationId = location_id;
  let allLocations = [];

  (async function boot() {
    const root = document.getElementById("pls-root");
    try {
      const locs = await fetchLocations().catch(() => []);
      allLocations = locs;

      const isMultisite = locs.length > 1;

      const nameEl   = document.getElementById("pls-loc-name");
      const addrEl   = document.getElementById("pls-loc-addr");
      const switchBtn = document.getElementById("pls-loc-switch");
      const subtitleEl = document.getElementById("pls-subtitle");

      if (switchBtn) switchBtn.style.display = "none";

      if (isMultisite) {
        if (nameEl) nameEl.textContent = "Tous mes sites";
        if (addrEl) addrEl.textContent = `${locs.length} sites surveillés`;
        if (subtitleEl) subtitleEl.textContent = `Veille opérationnelle · 7 jours · ${locs.length} sites`;

        const results = await Promise.all(
          locs.map(l => fetchPulse(l.location_id).then(d => ({ data: d, loc: l })).catch(() => null))
        );
        const valid = results.filter(Boolean);
        // Track page view (fire-and-forget)
        fetch("/api/analytics/track", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ event: "page_view", location_id: locs[0]?.location_id || null, action_key: "pulse" }),
        }).catch(function(){});
        if (!valid.length) throw new Error("Aucune donnée disponible.");

        const mergedFeedRaw = valid.flatMap(({ data, loc }) =>
          (data.all_feed || []).map(a => ({ ...a, location_id: loc.location_id, location_label: loc.company_name || loc.location_id }))
        );
        // Dedup regional signals that are identical within the same region
        const REGIONAL_SUBTYPES = new Set([
          "weather_hazard_onset", "weather_worsened", "weather_improved",
          "calendar_audience_shift", "regime_change",
          "mega_event_activation", "mega_event_end",
        ]);
        const seenRegional = new Set();
        const mergedFeed = mergedFeedRaw.filter(a => {
          const sub = String(a?.change_subtype || "").toLowerCase();
          if (!REGIONAL_SUBTYPES.has(sub)) return true;
          const key = sub + "|" + String(a?.affected_date || "") + "|" + String(a?.old_value || "") + "|" + String(a?.new_value || "");
          if (seenRegional.has(key)) return false;
          seenRegional.add(key);
          return true;
        });

        const dateMap = new Map();
        for (const { data } of valid) {
          for (const day of (data.days || [])) {
            const ymd = String(day.date || "").slice(0, 10);
            const existing = dateMap.get(ymd);
            if (!existing) {
              dateMap.set(ymd, { ...day });
            } else {
              if (day.opportunity_score !== null && (existing.opportunity_score === null || day.opportunity_score < existing.opportunity_score)) {
                existing.opportunity_score = day.opportunity_score;
              }
              // Merge regime: keep worst (C > B > A)
              const REGIME_ORDER = { A: 0, B: 1, C: 2 };
              const existingRegime = String(existing.opportunity_regime || "B").toUpperCase();
              const dayRegime = String(day.opportunity_regime || "B").toUpperCase();
              if ((REGIME_ORDER[dayRegime] || 0) > (REGIME_ORDER[existingRegime] || 0)) {
                existing.opportunity_regime = day.opportunity_regime;
              }
              if (day.is_forced_regime_c_flag) existing.is_forced_regime_c_flag = true;
              existing.attendance   = [...(existing.attendance   || []), ...(day.attendance   || [])];
              existing.operations   = [...(existing.operations   || []), ...(day.operations   || [])];
              existing.installation = [...(existing.installation || []), ...(day.installation || [])];
              existing.context      = [...(existing.context      || []), ...(day.context      || [])];
            }
          }
        }
        const mergedDays = [...dateMap.values()];

        const mergedProfile = valid[0].data.profile || null;

        const mergedData = {
          ok: true,
          profile: mergedProfile,
          days: mergedDays,
          all_feed: mergedFeed,
          action_candidates: valid.flatMap(({ data, loc }) =>
            (data.action_candidates || []).map(ac => ({ ...ac, location_id: ac.location_id || loc.location_id, location_label: loc.company_name || loc.location_id }))
          ),
          _locations: locs,
          competitor_followed_count: valid.reduce((sum, { data }) => sum + Number(data.competitor_followed_count ?? 0), 0),
          _siteData: valid.map(({ data, loc }) => ({
            location_id: loc.location_id,
            label: loc.company_name || loc.location_id,
            profile: data.profile || null,
            days: data.days || [],
          })),
        };

        mergedData.all_feed = filterFeedByWindow(mergedData.all_feed, 0);
        renderPulse(mergedData, todayYmd(), "radar");

        var _locIdForSecondary = locs[0]?.location_id || currentLocationId;
        const [csResult] = await Promise.all([
          fetchCompetitorSignals(todayYmd()).catch(() => ({ signals: [], followed_count: 0, top_threats: [] })),
          fetchPendingFeedback(_locIdForSecondary),
          fetchSavedDrafts(_locIdForSecondary),
          fetchChannelConfigs(_locIdForSecondary),
          fetchTeamMembers(_locIdForSecondary),
        ]);
        mergedData._competitor_signals = csResult.signals;
        mergedData._competitor_followed_count = csResult.followed_count;
        mergedData._top_threats = csResult.top_threats;
        mergedData._followed_competitors = csResult.followed_competitors || [];
        renderPulse(mergedData, todayYmd(), "radar");

      } else {
        const currentLoc = locs.find(l => l.location_id === currentLocationId);
        const data = await fetchPulse(currentLocationId);

        if (nameEl) nameEl.textContent = currentLoc?.company_name || data.profile?.city_name || "Mon site";
        if (addrEl) addrEl.textContent = currentLoc?.company_address || "";

        data.all_feed = filterFeedByWindow(data.all_feed || [], 0);
        data._locations = [];
        renderPulse(data, todayYmd(), "radar");

        const [csResult] = await Promise.all([
          fetchCompetitorSignals(todayYmd()).catch(() => ({ signals: [], followed_count: 0, top_threats: [] })),
          fetchPendingFeedback(currentLocationId),
          fetchSavedDrafts(currentLocationId),
          fetchChannelConfigs(currentLocationId),
          fetchTeamMembers(currentLocationId),
        ]);
        data._competitor_signals = csResult.signals;
        data._competitor_followed_count = csResult.followed_count;
        data._top_threats = csResult.top_threats;
        data._followed_competitors = csResult.followed_competitors || [];
        renderPulse(data, todayYmd(), "radar");
      }

    } catch(e) {
      if (root) root.innerHTML = `<div class="mon-error">${escapeHtml(e?.message||"Erreur de chargement.")}</div>`;
      console.error(e);
    }
  })();

})();
</script>