        workspace.style.display = "block";
        workspace.innerHTML = '<div style="padding:20px 0;display:flex;align-items:center;justify-content:center;gap:8px;color:#9ca3af;font-size:11px;"><span style="width:10px;height:10px;border:1.5px solid #e5e7eb;border-top-color:#1D3BB3;border-radius:50%;display:inline-block;animation:ms-spin 0.7s linear infinite;flex-shrink:0;"></span>R\u00e9daction en cours\u2026</div>';

        var triggerBtn = root.querySelector('[data-agir-toggle="' + cardIdx + '"]');

        fetch("/api/insight/generate-action-draft", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        }).then(function(res) { return res.json(); }).then(function(json) {
          if (!json || !json.ok || !json.draft) throw new Error(json?.error || "Draft vide");
          var draft = json.draft;

          fetch("/api/analytics/track", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ event: "draft_generated", location_id: locationId, change_subtype: payload.change_subtype, action_key: payload.action_key, channel: channel, affected_date: parent ? parent.getAttribute("data-ab-draft-affected") || null : null }),
          }).catch(function(){});

          if (triggerBtn) { triggerBtn.style.color = "#1D3BB3"; triggerBtn.textContent = "Brouillon \u270e"; }

          workspace.innerHTML = buildWorkspaceHtml(cardIdx, channel, draft, !!json.is_styled, payload.change_subtype);
          wireWorkspaceButtons(cardIdx, channel, draft, payload, triggerBtn);

        }).catch(function(err) {
          workspace.innerHTML = '<div style="padding:14px;font-size:11px;color:#B91C1C;">Erreur : ' + escapeHtml(err?.message || "R\u00e9essayez") + '</div>';
          if (triggerBtn) { triggerBtn.style.color = "#1D3BB3"; triggerBtn.textContent = "Agir \u25be"; }
        });
      });
    });

    // Consulter — navigate to target view
    root.querySelectorAll("[data-agir-consult]").forEach(function(btn) {
      btn.addEventListener("click", function(e) {
        e.stopPropagation();
        var cardIdx = btn.getAttribute("data-agir-consult");
        var menu = root.querySelector('[data-agir-menu="' + cardIdx + '"]');
        if (menu) menu.style.display = "none";
        // Get action type and date from parent
        var parent = btn.closest("[data-ab-draft-sub]") || btn.closest(".ab-card");
        var actionType = parent ? parent.getAttribute("data-ab-draft-sub") || "" : "";
        var affected = parent ? parent.getAttribute("data-ab-draft-affected") || "" : "";
        var cardLocId = (parent ? parent.getAttribute("data-ab-draft-location") : "") || locationId;
        // Store day + profile data for instant load
        try {
          var key = "ms_signal_data_" + cardLocId + "_" + affected;
          sessionStorage.setItem(key, JSON.stringify({ day: currentDay || {}, prof: data.profile || {}, actionCandidate: null }));
        } catch(ex) {}
        // Navigate to insight page
        window.location.href = "/app/insightevent/insight?type=" + encodeURIComponent(actionType) + "&date=" + encodeURIComponent(affected) + "&location_id=" + encodeURIComponent(cardLocId);
      });
    });

    // Sauvegarder — bookmark card
    root.querySelectorAll("[data-agir-save-card]").forEach(function(btn) {
      btn.addEventListener("click", function(e) {
        e.stopPropagation();
        var cardIdx = btn.getAttribute("data-agir-save-card");
        var menu = root.querySelector('[data-agir-menu="' + cardIdx + '"]');
        if (menu) menu.style.display = "none";
        var parent = btn.closest("[data-ab-draft-sub]") || btn.closest(".ab-card");
        var sub = parent ? parent.getAttribute("data-ab-draft-sub") || "" : "";
        var affected = parent ? parent.getAttribute("data-ab-draft-affected") || "" : "";
        // Save to localStorage
        var bookmarks = {};
        try { bookmarks = JSON.parse(localStorage.getItem("ms_bookmarks_" + locationId) || "{}"); } catch(ex) {}
        bookmarks[sub + "_" + affected] = { action_type: sub, date: affected, saved_at: new Date().toISOString() };
        try { localStorage.setItem("ms_bookmarks_" + locationId, JSON.stringify(bookmarks)); } catch(ex) {}
        btn.textContent = "\ud83d\udcbe Sauvegard\u00e9 \u2713";
        btn.style.color = "#059669";
        setTimeout(function() { btn.textContent = "\ud83d\udcbe Sauvegarder"; btn.style.color = "#111827"; }, 2000);
        fetch("/api/analytics/track", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ event: "action_saved", location_id: locationId, change_subtype: sub, affected_date: affected }),
        }).catch(function(){});
      });
    });

    // Signaler — flag card as incorrect/irrelevant
    root.querySelectorAll("[data-agir-flag]").forEach(function(btn) {
      btn.addEventListener("click", function(e) {
        e.stopPropagation();
        var cardIdx = btn.getAttribute("data-agir-flag");
        var menu = root.querySelector('[data-agir-menu="' + cardIdx + '"]');
        if (menu) menu.style.display = "none";
        var parent = btn.closest("[data-ab-draft-sub]") || btn.closest(".ab-card");
        var sub = parent ? parent.getAttribute("data-ab-draft-sub") || "" : "";
        var affected = parent ? parent.getAttribute("data-ab-draft-affected") || "" : "";
        btn.textContent = "\ud83d\udea9 Signal\u00e9 \u2713";
        btn.style.color = "#059669";
        setTimeout(function() { btn.textContent = "\ud83d\udea9 Signaler"; btn.style.color = "#6b7280"; }, 2000);
        fetch("/api/analytics/confirm", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ location_id: locationId, confirmation: "dismissed", signal_type: sub, signal_ref_id: sub + "_" + affected, signal_date: affected }),
        }).catch(function(){});
      });
    });
 
    // Disposition — log card_done / card_already_done / card_not_done (Profile A: status only)
    root.querySelectorAll("[data-ab-dispo-row] [data-ab-dispo-btn]").forEach(function(btn) {
      btn.addEventListener("click", function(e) {
        e.stopPropagation();
        var row = btn.closest("[data-ab-dispo-row]");
        if (!row) return;
        var ev = btn.getAttribute("data-ab-dispo-btn");
        var instance = row.getAttribute("data-ab-dispo-instance") || null;
        var sub = row.getAttribute("data-ab-dispo-sub") || null;
        var cat = row.getAttribute("data-ab-dispo-cat") || null;
        var affected = row.getAttribute("data-ab-dispo-affected") || null;
        var locId = row.getAttribute("data-ab-dispo-location") || locationId;
        row.querySelectorAll("[data-ab-dispo-btn]").forEach(function(b) {
          if (b === btn) { b.style.opacity = "1"; b.style.fontWeight = "700"; }
          else { b.style.opacity = "0.4"; }
        });
        if (ev === "card_done") {
          var _cEl = root.querySelector("[data-actions-counter]");
          if (_cEl) { var _n = parseInt(_cEl.textContent, 10) || 0; _cEl.textContent = String(_n + 1); }
        }
        fetch("/api/analytics/track", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ event: ev, location_id: locId, card_instance_id: instance, action_type: sub, action_category: cat, change_subtype: sub, affected_date: affected }),
        }).catch(function(){});
      });
    });

    function wireWorkspaceButtons(cardIdx, channel, draft, payload, triggerBtn) {
      var workspace = document.getElementById("ab-card-" + cardIdx + "-workspace");
      if (!workspace) return;
 
      // Auto-resize + char count
      var bodyEl = workspace.querySelector('[data-ws-body="' + cardIdx + '"]');
      if (bodyEl) { autoResizeTextarea(bodyEl); bodyEl.addEventListener("input", function() { autoResizeTextarea(bodyEl); updateCharCount(cardIdx, channel); }); }
      var titleEl = workspace.querySelector('[data-ws-title="' + cardIdx + '"]');
      if (titleEl) titleEl.addEventListener("input", function() { updateCharCount(cardIdx, channel); });
      var hashEl = workspace.querySelector('[data-ws-hashtags="' + cardIdx + '"]');
      if (hashEl) hashEl.addEventListener("input", function() { updateCharCount(cardIdx, channel); });
 
      // Channel dropdown
      var chToggle = workspace.querySelector('[data-ch-toggle="' + cardIdx + '"]');
      var chMenu = workspace.querySelector('[data-ch-menu="' + cardIdx + '"]');
      if (chToggle && chMenu) {
        chToggle.addEventListener("click", function(ev) { ev.stopPropagation(); chMenu.style.display = chMenu.style.display === "none" ? "block" : "none"; });
      }
      workspace.querySelectorAll('[data-ch-select]').forEach(function(chBtn) {
        chBtn.addEventListener("click", function(ev) {
          ev.stopPropagation();
          var newCh = chBtn.getAttribute("data-ch-select");
          channel = newCh;
          workspace.innerHTML = buildWorkspaceHtml(cardIdx, newCh, draft, false, payload.change_subtype);
          wireWorkspaceButtons(cardIdx, newCh, draft, payload, triggerBtn);
        });
      });
 
      // Close
      var closeBtn = workspace.querySelector('[data-ws-close="' + cardIdx + '"]');
      if (closeBtn) closeBtn.addEventListener("click", function() {
        workspace.style.display = "none";
        workspace.innerHTML = "";
      });
 
      // Copy
      var copyBtn = workspace.querySelector('[data-ws-copy="' + cardIdx + '"]');
      if (copyBtn) copyBtn.addEventListener("click", function() {
        var bEl = workspace.querySelector('[data-ws-body="' + cardIdx + '"]');
        var tEl = workspace.querySelector('[data-ws-title="' + cardIdx + '"]');
        var hEl = workspace.querySelector('[data-ws-hashtags="' + cardIdx + '"]');
        var fullText = [tEl ? tEl.value : "", bEl ? bEl.value : "", hEl ? hEl.value : ""].filter(Boolean).join("\n\n");
        navigator.clipboard.writeText(fullText).then(function() {
          copyBtn.textContent = "Copi\u00e9 \u2713";
          setTimeout(function() { copyBtn.textContent = "Copier"; }, 2000);
        }).catch(function() {});
        updateBriefStatus(cardIdx, "copied");
        fetch("/api/analytics/track", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ event: "draft_copied", location_id: locationId, action_key: "draft", channel: channel, affected_date: triggerBtn.getAttribute("data-ab-draft-affected") || null }),
        }).catch(function(){});
      });
 
      // Save
      var saveBtn = workspace.querySelector('[data-ws-save="' + cardIdx + '"]');
      if (saveBtn) saveBtn.addEventListener("click", function() {
        var bEl = workspace.querySelector('[data-ws-body="' + cardIdx + '"]');
        var tEl = workspace.querySelector('[data-ws-title="' + cardIdx + '"]');
        var hEl = workspace.querySelector('[data-ws-hashtags="' + cardIdx + '"]');
        var rEl = workspace.querySelector('[data-ws-recipient="' + cardIdx + '"]');
        var draftData = { title: tEl ? tEl.value : "", body: bEl ? bEl.value : "", hashtags: hEl ? hEl.value : "", channel: channel };
        try { localStorage.setItem("ms_draft_" + locationId + "_" + cardIdx, JSON.stringify(draftData)); } catch(e) {}
        saveBtn.textContent = "\u2713 Enregistr\u00e9";
        saveBtn.style.background = "#f0fdf4";
        saveBtn.style.color = "#166534";
        saveBtn.style.borderColor = "#bbf7d0";
        setTimeout(function() { saveBtn.textContent = "Enregistrer"; saveBtn.style.background = "#f9fafb"; saveBtn.style.color = "#374151"; saveBtn.style.borderColor = "#e5e7eb"; }, 2000);
        updateBriefStatus(cardIdx, "saved");
        // Save to BigQuery
        fetch("/api/analytics/save-draft", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            location_id: locationId,
            signal_type: payload.change_subtype || "",
            channel: channel,
            card_what: payload.card_what || "",
            card_sowhat: payload.card_sowhat || "",
            affected_date: triggerBtn.getAttribute("data-ab-draft-affected") || null,
            severity: triggerBtn.closest(".ab-card")?.querySelector(".ab-pill")?.textContent || "",
            title: tEl ? tEl.value : "",
            body: bEl ? bEl.value : "",
            hashtags: hEl ? hEl.value : "",
            recipient: rEl ? rEl.value : "",
            original_ai_text: draft ? (draft.full_text || draft.body || "") : "",
            user_instruction: "",
          }),
        }).then(function() { _savedDraftsCache = null; }).catch(function(){});
        // Track event
        fetch("/api/analytics/track", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ event: "draft_saved", location_id: locationId, action_key: "draft", channel: channel, affected_date: triggerBtn.getAttribute("data-ab-draft-affected") || null }),
        }).catch(function(){});
      });
 
      // Regenerate
      var regenBtn = workspace.querySelector('[data-ws-regen="' + cardIdx + '"]');
      if (regenBtn) regenBtn.addEventListener("click", function() {
        workspace.innerHTML = '<div style="padding:20px 0;display:flex;align-items:center;justify-content:center;gap:8px;color:#9ca3af;font-size:11px;"><span style="width:10px;height:10px;border:1.5px solid #e5e7eb;border-top-color:#1D3BB3;border-radius:50%;display:inline-block;animation:ms-spin 0.7s linear infinite;flex-shrink:0;"></span>R\u00e9daction en cours\u2026</div>';
        fetch("/api/insight/generate-action-draft", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        }).then(function(res) { return res.json(); }).then(function(json) {
          if (!json || !json.ok || !json.draft) throw new Error("Draft vide");
          draft = json.draft;
          workspace.innerHTML = buildWorkspaceHtml(cardIdx, channel, draft, !!json.is_styled, payload.change_subtype);
          wireWorkspaceButtons(cardIdx, channel, draft, payload, triggerBtn);
        }).catch(function(err) {
          workspace.innerHTML = '<div style="padding:14px;font-size:11px;color:#B91C1C;">Erreur : ' + escapeHtml(err?.message || "R\u00e9essayez") + '</div>';
        });
      });

      // Ajuster (inline refinement)
      var adjustInput = workspace.querySelector('[data-ws-adjust="' + cardIdx + '"]');
      var adjustBtn = workspace.querySelector('[data-ws-adjust-submit="' + cardIdx + '"]');
      function submitAdjust() {
        if (!adjustInput || !adjustInput.value.trim()) return;
        var instruction = adjustInput.value.trim();
        adjustInput.value = "";
        workspace.innerHTML = '<div style="padding:20px 0;display:flex;align-items:center;justify-content:center;gap:8px;color:#9ca3af;font-size:11px;"><span style="width:10px;height:10px;border:1.5px solid #e5e7eb;border-top-color:#1D3BB3;border-radius:50%;display:inline-block;animation:ms-spin 0.7s linear infinite;flex-shrink:0;"></span>Ajustement en cours\u2026</div>';
        var adjustedPayload = JSON.parse(JSON.stringify(payload));
        adjustedPayload.user_instruction = instruction;
        fetch("/api/insight/generate-action-draft", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(adjustedPayload),
        }).then(function(res) { return res.json(); }).then(function(json) {
          if (!json || !json.ok || !json.draft) throw new Error("Draft vide");
          draft = json.draft;
          workspace.innerHTML = buildWorkspaceHtml(cardIdx, channel, draft, false, payload.change_subtype);
          wireWorkspaceButtons(cardIdx, channel, draft, payload, triggerBtn);
        }).catch(function(err) {
          workspace.innerHTML = '<div style="padding:14px;font-size:11px;color:#B91C1C;">Erreur : ' + escapeHtml(err?.message || "R\u00e9essayez") + '</div>';
        });
      }
      if (adjustBtn) adjustBtn.addEventListener("click", submitAdjust);
      if (adjustInput) adjustInput.addEventListener("keydown", function(ev) { if (ev.key === "Enter") { ev.preventDefault(); submitAdjust(); } });

      // Recipient dropdown
      var recipInput = workspace.querySelector('[data-ws-recipient="' + cardIdx + '"]');
      var recipDd = workspace.querySelector('[data-ws-recipient-dd="' + cardIdx + '"]');
      if (recipInput && recipDd) {
        // Add display label element
        var recipWrap = recipInput.closest('[data-ws-recipient-wrap]');
        var recipLabel = document.createElement('div');
        recipLabel.setAttribute('data-ws-recipient-label', cardIdx);
        recipLabel.style.cssText = 'font-size:12px;font-weight:500;color:#1D3BB3;margin-bottom:2px;display:none;cursor:pointer;';
        recipInput.parentNode.insertBefore(recipLabel, recipInput);
        // If suggested member pre-filled, show label
        if (recipInput.getAttribute('data-display-name')) {
          recipLabel.textContent = recipInput.getAttribute('data-display-name');
          recipLabel.style.display = 'block';
        }
        recipLabel.addEventListener('click', function() { recipLabel.style.display = 'none'; recipInput.value = ''; recipInput.focus(); });
        recipInput.addEventListener('focus', function() { recipDd.style.display = 'block'; });
        recipInput.addEventListener('input', function() { recipDd.style.display = 'block'; recipLabel.style.display = 'none'; });
        recipDd.querySelectorAll('[data-ws-pick-member]').forEach(function(opt) {
          opt.addEventListener('click', function() {
            var channelVal = opt.getAttribute('data-ws-pick-member');
            var nameSpan = opt.querySelector('span');
            var displayName = nameSpan ? nameSpan.textContent : '';
            recipInput.value = channelVal;
            recipLabel.textContent = displayName + ' \u00b7 ' + channelVal;
            recipLabel.style.display = 'block';
            recipDd.style.display = 'none';
          });
          opt.addEventListener('mouseenter', function() { opt.style.background = opt.style.background === 'rgb(245, 247, 255)' ? '#EBF0FF' : '#f9fafb'; });
          opt.addEventListener('mouseleave', function() { opt.style.background = ''; });
        });
        document.addEventListener('click', function(ev) { if (!recipInput.contains(ev.target) && !recipDd.contains(ev.target) && !recipLabel.contains(ev.target)) recipDd.style.display = 'none'; });
      }

      // Publish
      var pubBtn = workspace.querySelector('[data-ws-publish="' + cardIdx + '"]');
      if (pubBtn && !pubBtn.disabled) pubBtn.addEventListener("click", function() {
        var bEl = workspace.querySelector('[data-ws-body="' + cardIdx + '"]');
        var tEl = workspace.querySelector('[data-ws-title="' + cardIdx + '"]');
        var hEl = workspace.querySelector('[data-ws-hashtags="' + cardIdx + '"]');
        var rEl = workspace.querySelector('[data-ws-recipient="' + cardIdx + '"]');
        pubBtn.textContent = "Publication\u2026";
        pubBtn.style.opacity = "0.6";
        pubBtn.disabled = true;
        fetch("/api/channels/publish", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            channel: channel,
            location_id: locationId,
            title: tEl ? tEl.value : "",
            body: bEl ? bEl.value : "",
            hashtags: hEl ? hEl.value : "",
            recipient: rEl ? rEl.value : "",
            signal_type: payload.change_subtype || "",
            affected_date: triggerBtn.getAttribute("data-ab-draft-affected") || "",
          }),
        }).then(function(res) { return res.json(); }).then(function(json) {
          if (json && json.ok) {
            pubBtn.textContent = "Publi\u00e9 \u2713";
            pubBtn.style.background = "#f0fdf4";
            pubBtn.style.color = "#166534";
            pubBtn.style.borderColor = "#bbf7d0";
            pubBtn.style.opacity = "1";
            triggerBtn.style.color = "#059669";
            triggerBtn.textContent = "Trait\u00e9 \u2713";
            updateBriefStatus(cardIdx, "published");

            // Post-publish: save unknown recipient
            var rEl = workspace.querySelector('[data-ws-recipient="' + cardIdx + '"]');
            var recipVal = rEl ? rEl.value.trim() : "";
            if (recipVal && channel !== "internal") {
              var isKnown = (_teamMembersCache || []).some(function(m) { return (m.channels_contact || {})[channel] === recipVal; });
              if (!isKnown) {
                var savePrompt = document.createElement("div");
                savePrompt.style.cssText = "margin:10px 0 0;padding:14px 16px;border-radius:8px;background:#F5F7FF;border:1px solid #DBEAFE;";
                savePrompt.innerHTML = '<div style="font-size:13px;font-weight:600;color:#111827;margin-bottom:4px;">Enregistrer ce destinataire ?</div>'
                  + '<div style="font-size:11px;color:#6b7280;margin-bottom:12px;">' + escapeHtml(recipVal) + ' sera disponible pour vos prochaines publications.</div>'
                  + '<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">'
                    + '<input data-save-recip-fn placeholder="Pr\u00e9nom" style="border:1px solid #e5e7eb;border-radius:6px;padding:7px 10px;font-size:12px;color:#111827;outline:none;font-family:inherit;" />'
                    + '<input data-save-recip-ln placeholder="Nom" style="border:1px solid #e5e7eb;border-radius:6px;padding:7px 10px;font-size:12px;color:#111827;outline:none;font-family:inherit;" />'
                  + '</div>'
                  + '<input data-save-recip-role placeholder="R\u00f4le (optionnel)" style="width:100%;border:1px solid #e5e7eb;border-radius:6px;padding:7px 10px;font-size:12px;color:#111827;outline:none;font-family:inherit;margin-bottom:10px;box-sizing:border-box;" />'
                  + '<div style="display:flex;gap:8px;">'
                    + '<button type="button" data-save-recip-ok style="padding:7px 16px;border-radius:6px;font-size:12px;font-weight:600;background:#1D3BB3;color:#fff;border:none;cursor:pointer;font-family:inherit;">Enregistrer</button>'
                    + '<button type="button" data-save-recip-skip style="padding:7px 16px;border-radius:6px;font-size:12px;font-weight:600;background:#f9fafb;color:#6b7280;border:1px solid #e5e7eb;cursor:pointer;font-family:inherit;">Pas maintenant</button>'
                  + '</div>';
                workspace.appendChild(savePrompt);
                savePrompt.querySelector("[data-save-recip-skip]").addEventListener("click", function() { savePrompt.remove(); });
                savePrompt.querySelector("[data-save-recip-ok]").addEventListener("click", async function() {
                  var fnEl = savePrompt.querySelector("[data-save-recip-fn]");
                  var lnEl = savePrompt.querySelector("[data-save-recip-ln]");
                  var roleEl = savePrompt.querySelector("[data-save-recip-role]");
                  var fn = fnEl ? fnEl.value.trim() : "";
                  if (!fn) { fnEl.style.borderColor = "#ef4444"; return; }
                  var chContact = {};
                  chContact[channel] = recipVal;
                  this.disabled = true;
                  this.textContent = "...";
                  try {
                    var res = await fetch("/api/channels/team", {
                      method: "POST",
                      headers: { "content-type": "application/json" },
                      body: JSON.stringify({
                        location_id: locationId,
                        first_name: fn,
                        last_name: lnEl ? lnEl.value.trim() : "",
                        role: roleEl ? roleEl.value.trim() : "",
                        channels_contact: chContact,
                        signal_routing: {},
                      }),
                    });
                    var json2 = await res.json();
                    if (json2 && json2.ok) {
                      _teamMembersCache = null;
                      await fetchTeamMembers(locationId);
                      savePrompt.innerHTML = '<div style="display:flex;align-items:center;gap:8px;"><span style="color:#166534;">\u2713</span><span style="font-size:12px;color:#166534;font-weight:500;">Destinataire enregistr\u00e9</span></div>';
                      setTimeout(function() { savePrompt.remove(); }, 2000);
                    }
                  } catch(e) { this.textContent = "Erreur"; this.disabled = false; }
                });
              }
            }
          } else {
            pubBtn.textContent = "Erreur";
            pubBtn.style.color = "#B91C1C";
            pubBtn.style.opacity = "1";
            pubBtn.disabled = false;
            setTimeout(function() { pubBtn.textContent = "Publier \u2192"; pubBtn.style.color = "#1D3BB3"; pubBtn.style.borderColor = "#1D3BB3"; }, 2500);
          }
        }).catch(function() {
          pubBtn.textContent = "Publier \u2192";
          pubBtn.style.opacity = "1";
          pubBtn.disabled = false;
        });
      });

      // Library drawer
      var libBtn = workspace.querySelector('[data-ws-library="' + cardIdx + '"]');
      if (libBtn) libBtn.addEventListener("click", function() {
        var existing = document.getElementById("ms-draft-library");
        if (existing) { existing.remove(); return; }
        var drafts = _savedDraftsCache || [];
        var overlay = document.createElement("div");
        overlay.id = "ms-draft-library";
