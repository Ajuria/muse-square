        // en vue agrégée, le site AFFICHÉ sinon (l'ancien handler fetchait toujours le site de
        // session, et bloquait le render). Guard anti-course : seule la dernière date cliquée écrit.
        renderPulse(data, d, "radar");
        const _token = (window.__plsCsToken = (window.__plsCsToken || 0) + 1);
        try {
          const _isAgg = Array.isArray(data._locations) && data._locations.length > 1;
          const csResult = _isAgg
            ? fuseCompetitorSignals(await Promise.all(data._locations.map(l =>
                fetchCompetitorSignals(d, l.location_id).catch(() => ({ signals: [], followed_count: 0, top_threats: [], followed_competitors: [] })))))
            : await fetchCompetitorSignals(d, currentLocationId);
          if (window.__plsCsToken !== _token) return;
          data._competitor_signals = csResult.signals;
          data._competitor_followed_count = csResult.followed_count;
          if (Array.isArray(csResult.followed_competitors) && csResult.followed_competitors.length) data._followed_competitors = csResult.followed_competitors;
          renderPulse(data, d, "radar");
