      });
    });
    mount.querySelectorAll('[data-eng-modify]').forEach(function(b){ b.addEventListener('click', function(e){ e.stopPropagation(); _engCloseMenus(mount); _engModify(mount, b.getAttribute('data-eng-modify')); }); });
    mount.querySelectorAll('[data-eng-replicate]').forEach(function(b){ b.addEventListener('click', function(e){ e.stopPropagation(); _engCloseMenus(mount); _engReplicate(mount, b.getAttribute('data-eng-replicate')); }); });
    if (!window.__engCloserBound) { window.__engCloserBound = true; document.addEventListener('click', function(){ document.querySelectorAll('[data-eng-agir-menu]').forEach(function(m){ m.style.display = 'none'; }); }); }
