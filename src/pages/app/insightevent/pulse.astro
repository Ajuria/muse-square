    const _voletIds = Array.from(root.querySelectorAll("[data-radar-toggle]")).map(b => b.getAttribute("data-radar-toggle"));
    root.querySelectorAll("[data-radar-toggle]").forEach(btn => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-radar-toggle");
