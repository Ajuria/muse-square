<script is:inline define:vars={{ location_id }}>
(function () {

  // ----------------------------------------------------------------
  // Helpers (same as monitor.astro)
  // ----------------------------------------------------------------
  function escapeHtml(v) {
    return String(v ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#039;");
  }

  function normalizeYmd(v) {
    const s = String(v ?? "").trim();
    const m = s.match(/^(\d{4}-\d{2}-\d{2})/);
    return m ? m[1] : "";
  }

  function parseYmdToDate(ymd) {
    const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(String(ymd||"").trim());
    if (!m) return null;
    return new Date(Date.UTC(+m[1], +m[2]-1, +m[3]));
  }

  function fmtDateLong(ymd) {
    const d = parseYmdToDate(ymd);
    if (!d) return ymd;
    const s = new Intl.DateTimeFormat("fr-FR", { weekday:"long", day:"numeric", month:"long", year:"numeric" }).format(d);
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  function fmtDateShort(ymd) {
    const d = parseYmdToDate(ymd);
    if (!d) return ymd;
    const dow = ["LUN","MAR","MER","JEU","VEN","SAM","DIM"][((d.getUTCDay()+6)%7)];
    return `${dow} ${String(d.getUTCDate()).padStart(2,"0")}`;
  }

  function todayYmd() {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`;
  }

  function getToday() {
    const d = new Date();
    return new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
  }

  function addDays(dateUTC, n) {
    const d = new Date(dateUTC);
    d.setUTCDate(d.getUTCDate() + n);
    return d;
  }

  function ymdFromUTC(d) {
    return `${d.getUTCFullYear()}-${String(d.getUTCMonth()+1).padStart(2,"0")}-${String(d.getUTCDate()).padStart(2,"0")}`;
  }

  function getLastVisitTimestamp(key) {
    try { return parseInt(localStorage.getItem(key) || "0", 10) || 0; } catch { return 0; }
  }

  function setLastVisitTimestamp(key) {
    try { localStorage.setItem(key, String(Date.now())); } catch {}
  }

  function filterFeedByWindow(allFeed, lastVisitTs) {
    const today = getToday();
    const windowStart = ymdFromUTC(today);
    const windowEnd   = ymdFromUTC(addDays(today, 6));
    const mobilityEnd = ymdFromUTC(addDays(today, 14));
    const competitionEnd = ymdFromUTC(addDays(today, 14));
    return allFeed.filter(function(a) {
      var affected = normalizeYmd(a?.affected_date);
      var feedDate = normalizeYmd(a?.feed_date);
      if (!affected) return false;
      var sub = String(a?.change_subtype || "").toLowerCase();
      var isMobility = String(a?.change_category || "").toLowerCase() === "mobility" || sub.startsWith("mobility_");
      var isWeather = sub === "weather_worsened" || sub === "weather_improved" || sub === "weather_hazard_onset";
      var isCompetition = sub === "competitor_event_launch" || sub === "competitor_audience_conflict" || sub === "competition_pressure_spike" || sub === "mega_event_activation" || sub === "competitor_event_ending" || sub === "mega_event_end";
      var maxDate = isMobility ? mobilityEnd : isCompetition ? competitionEnd : windowEnd;
      if (affected < windowStart || affected > maxDate) return false;
      if (isWeather && affected > windowEnd) return false;
      if (lastVisitTs > 0) {
        var fd = feedDate ? new Date(feedDate).getTime() : 0;
        if (fd > 0 && fd <= lastVisitTs) return false;
      }
      if (isMobility && !a?.mobility_mode) return false;
      return true;
    });
  }

  const BLOCK_LABELS = {
    attendance:   'FRÉQUENTATION',
    operations:   'EXPLOITATION',
    installation: 'INSTALLATION',
    context:      'CONTEXTE',
  };

  function computeStatusPill(day) {
    if (day?.is_forced_regime_c_flag === true) {
      return { cls: 'mon-statut-risk', label: 'À RISQUE' };
    }
    const all = [
      ...(day?.attendance   || []),
      ...(day?.operations   || []),
      ...(day?.installation || []),
      ...(day?.context      || []),
    ].filter(r => r.severity !== 'A');

    if (!all.length) {
      return { cls: 'mon-statut-safe', label: 'SANS RISQUE' };
    }

    const maxSev = all.reduce((max, r) => {
      return (['D','C','B'].indexOf(r.severity) < ['D','C','B'].indexOf(max) ? r.severity : max);
    }, 'B');

    const cls = (maxSev === 'D' || maxSev === 'C') ? 'mon-statut-risk' : 'mon-statut-warn';

    if (all.length === 1) {
      const block = all[0].block;
      const label = 'ALERTE ' + (BLOCK_LABELS[block] || block.toUpperCase());
      return { cls, label };
    }

    const count = all.length;
    return { cls, label: `${count} RISQUES` };
  }

  function next8Days() {
    const dates = [];
    const base = new Date();
    for (let i = 0; i < 7; i++) {
      const d = new Date(base);
      d.setDate(base.getDate() + i);
      dates.push(`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`);
    }
    return dates;
  }

  function pill(label, style) {
    return `<span style="display:inline-block;font-size:11.5px;font-weight:600;padding:2px 10px;border-radius:20px;${style}">${escapeHtml(label)}</span>`;
  }

  const GREEN  = "background:var(--color-pill-green-bg);color:var(--color-pill-green-text);";
  const YELLOW = "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);border:1px solid var(--color-pill-warn-border);";
  const AMBER  = "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);border:1px solid var(--color-pill-warn-border);";
  const RED    = "background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);border:1px solid var(--color-pill-risk-border);";

  function severityDots(level) {
    const l = Math.min(4, Math.max(1, Number(level)||1));
    return [1,2,3,4].map(i =>
      `<span style="width:8px;height:8px;border-radius:50%;display:inline-block;background:${i<=l?"#1D3BB3":"#E2E8F0"};"></span>`
    ).join("&nbsp;");
  }

  function iconSVG(kind) {
    if (kind==="alert")   return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 9v4" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"/><path d="M12 17h.01" stroke="#1D3BB3" stroke-width="3" stroke-linecap="round"/><path d="M10.3 4.3l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.7-2.7l-8-14a2 2 0 0 0-3.4 0z" stroke="#1D3BB3" stroke-width="1.6"/></svg>`;
    if (kind==="context") return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 2v3M17 2v3" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"/><path d="M3.5 9h17" stroke="#1D3BB3" stroke-width="1.6"/><path d="M6 5h12a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z" stroke="#1D3BB3" stroke-width="1.6"/></svg>`;
    return "";
  }

  function feedCatIcon(cat) {
    const c = String(cat||"").toLowerCase();
    if (c==="competition") return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M8 21v-7M12 21V3M16 21v-11"/></svg>`;
    if (c==="opportunity") return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>`;
    if (c==="context")     return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.3 4.3l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.7-2.7l-8-14a2 2 0 0 0-3.4 0z"/></svg>`;
    if (c==="mobility")    return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M7 16h10l1-6H6l1 6z"/><path d="M7 16l-1 4M17 16l1 4"/><path d="M9 10V7a3 3 0 0 1 6 0v3"/></svg>`;
    return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/></svg>`;
  }

  // ----------------------------------------------------------------
  // Feed rendering (identical to monitor.astro)
  // ----------------------------------------------------------------
  function feedModeIcon(mode) {
    const m = String(mode || "").toLowerCase();
    if (m === "metro" || m === "métro") return '<span style="width:16px;height:16px;border-radius:3px;display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;background:#EDE9FE;color:#5B21B6;">M</span>';
    if (m === "bus") return '<span style="width:16px;height:16px;border-radius:3px;display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;background:#DBEAFE;color:#1E40AF;">B</span>';
    if (m === "rer") return '<span style="width:16px;height:16px;border-radius:3px;display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;background:#FEF3C7;color:#92400E;">R</span>';
    if (m === "tram") return '<span style="width:16px;height:16px;border-radius:3px;display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;background:#D1FAE5;color:#065F46;">T</span>';
    if (m === "road") return '<span style="width:16px;height:16px;border-radius:3px;display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;background:#FEE2E2;color:#991B1B;">R</span>';
    return '';
  }

  function feedDistancePill(distM) {
    if (distM == null || !Number.isFinite(Number(distM))) return '';
    const d = Number(distM);
    const label = d < 1000 ? Math.round(d) + ' m' : (d / 1000).toFixed(1) + ' km';
    const cls = d < 500 ? 'background:#FEF2F2;color:#991B1B;' : d < 3000 ? 'background:#FFFBEB;color:#92400E;' : 'background:#F3F4F6;color:#6B7280;';
    return '<span style="display:inline-flex;align-items:center;font-size:10px;padding:1px 7px;border-radius:3px;font-weight:600;' + cls + '">' + label + '</span>';
  }

  function feedMobilityImpact(distM, mode) {
    const d = Number(distM || 0);
    const m = String(mode || "").toLowerCase();
    if (!d || !Number.isFinite(d)) return '';
    if (m === "road") {
      if (d < 2000) return 'Acc\u00e8s v\u00e9hicules impact\u00e9';
      return 'Impact livraisons / prestataires';
    }
    if (d < 500) return 'Impact acc\u00e8s clients';
    return 'Transport en commun';
  }
  
  function feedLine1(a) {
    const sub  = String(a?.change_subtype || "").toLowerCase();
    const d    = fmtDateShort(normalizeYmd(a?.affected_date));
    const ov   = a?.old_value != null ? String(a.old_value) : null;
    const nv   = a?.new_value != null ? String(a.new_value) : null;
    const delta = a?.score_delta != null ? Math.round(Number(a.score_delta)) : null;
    const name  = a?.event_label || "";
    const km    = a?.distance_m != null ? `${(Number(a.distance_m)/1000).toFixed(1)} km` : null;
    const mode  = String(a?.mobility_mode || "").toLowerCase();
    const lvlRain = Number(a?.lvl_rain || 0);
    const lvlWind = Number(a?.lvl_wind || 0);
    const lvlSnow = Number(a?.lvl_snow || 0);
    const lvlHeat = Number(a?.lvl_heat || 0);
    const lvlCold = Number(a?.lvl_cold || 0);

    function weatherType() {
      const max = Math.max(lvlRain, lvlWind, lvlSnow, lvlHeat, lvlCold);
      if (max === 0) return null;
      if (lvlRain === max) return "pluie";
      if (lvlSnow === max) return "neige";
      if (lvlWind === max) return "vent";
      if (lvlHeat === max) return "chaleur";
      return "froid";
    }

    function parseCompetitorNewValue() {
      const val = nv || "";
      const parts = val.split(" \u2014 ");
      return { compName: parts[0] || "", evName: parts[1] || "" };
    }

    if (sub === "score_up") {
      var _drv = a?.score_driver_label || "";
      var _drvMap = {"m\u00e9t\u00e9o":"m\u00e9t\u00e9o favorable","concurrence":"faible concurrence","mobilit\u00e9":"acc\u00e8s am\u00e9lior\u00e9","calendrier":"contexte calendaire favorable"};
      var _drvLabel = _drvMap[_drv.toLowerCase()] || _drv || "";
      return "Score en hausse" + (_drvLabel ? " \u2014 " + _drvLabel : "");
    }
    if (sub === "score_down") {
      var _drv = a?.score_driver_label || "";
      var _drvMap = {"m\u00e9t\u00e9o":"m\u00e9t\u00e9o d\u00e9grad\u00e9e","concurrence":"forte pression concurrentielle","mobilit\u00e9":"acc\u00e8s perturb\u00e9","calendrier":"contexte calendaire d\u00e9favorable"};
      var _drvLabel = _drvMap[_drv.toLowerCase()] || _drv || "";
      return "Score en baisse" + (_drvLabel ? " \u2014 " + _drvLabel : "");
    }
    if (sub === "event_new") {
      const evLabel = name || "";
      return evLabel ? `${evLabel}${km ? " \u00b7 " + km : ""}` : (km || "Concurrent d\u00e9tect\u00e9");
    }
    if (sub === "competitor_event_launch") {
      const p = parseCompetitorNewValue();
      return `${p.compName}${p.evName ? " \u2014 " + p.evName : ""}${km ? " \u00b7 " + km : ""}`;
    }
    if (sub === "competitor_event_ending") {
      const p = parseCompetitorNewValue();
      return `${p.compName}${p.evName ? " \u2014 " + p.evName : ""}`;
    }
    if (sub === "competitor_audience_conflict") {
      const p = parseCompetitorNewValue();
      return `${p.compName}${p.evName ? " \u2014 " + p.evName : ""}${km ? " \u00b7 " + km : ""}`;
    }
    if (sub === "competition_pressure_spike") {
      const oldN = Number(ov || 0);
      const newN = Number(nv || 0);
      return newN > oldN ? "Pression concurrentielle en hausse" : "Pression concurrentielle en baisse";
    }
    if (sub === "mega_event_activation") { var _mn = nv && nv !== "true" && nv !== "false" ? nv : "M\u00e9ga-\u00e9v\u00e9nement d\u00e9tect\u00e9"; return _mn; }
    if (sub === "mega_event_end") { var _mn = nv && nv !== "true" && nv !== "false" ? "Fin : " + nv : "Fin de m\u00e9ga-\u00e9v\u00e9nement"; return _mn; }
    if (sub === "weather_hazard_onset") {
      var WDESC = {"wind:1":"Vent mod\u00e9r\u00e9","wind:2":"Vent fort","wind:3":"Vent tr\u00e8s fort","rain:1":"Pluie mod\u00e9r\u00e9e","rain:2":"Fortes pluies","rain:3":"Pluies intenses","rain:4":"Pluies extr\u00eames","snow:1":"Neige mod\u00e9r\u00e9e","snow:2":"Fortes neiges","snow:3":"Neiges intenses","heat:1":"Chaleur","heat:2":"Forte chaleur","heat:3":"Canicule","cold:1":"Froid","cold:2":"Grand froid","cold:3":"Froid extr\u00eame","storm:1":"Orage","storm:2":"Orage fort","storm:3":"Orage violent","fog:1":"Brouillard","fog:2":"Brouillard dense"};
      var _nvRaw = String(nv || "");
      var _nvD = WDESC[_nvRaw];
      if (!_nvD) { var _wType = weatherType(); if (_wType && _nvRaw.match(/^\d+$/)) { var _wKey = {"pluie":"rain","neige":"snow","vent":"wind","chaleur":"heat","froid":"cold"}[_wType] || ""; _nvD = WDESC[_wKey + ":" + _nvRaw]; } if (!_nvD) { var _wp = _nvRaw.split(":"); var _wt = {"wind":"Vent","rain":"Pluie","snow":"Neige","heat":"Chaleur","cold":"Froid","storm":"Orage","fog":"Brouillard"}[_wp[0]] || "Alerte m\u00e9t\u00e9o"; _nvD = _wp[1] ? _wt + " niveau " + _wp[1] : _wt; } }
      return _nvD;
    }
    if (sub === "weather_worsened") {
      var WDESC2 = {"wind:1":"Vent mod\u00e9r\u00e9","wind:2":"Vent fort","wind:3":"Vent tr\u00e8s fort","rain:1":"Pluie mod\u00e9r\u00e9e","rain:2":"Fortes pluies","rain:3":"Pluies intenses","rain:4":"Pluies extr\u00eames","snow:1":"Neige mod\u00e9r\u00e9e","snow:2":"Fortes neiges","snow:3":"Neiges intenses","heat:1":"Chaleur","heat:2":"Forte chaleur","heat:3":"Canicule","cold:1":"Froid","cold:2":"Grand froid","cold:3":"Froid extr\u00eame","storm:1":"Orage","storm:2":"Orage fort","storm:3":"Orage violent","fog:1":"Brouillard","fog:2":"Brouillard dense"};
      var _nvRaw2 = String(nv || "");
      var _nvD2 = WDESC2[_nvRaw2];
      if (!_nvD2) { var _wType2 = weatherType(); if (_wType2 && _nvRaw2.match(/^\d+$/)) { var _wKey2 = {"pluie":"rain","neige":"snow","vent":"wind","chaleur":"heat","froid":"cold"}[_wType2] || ""; _nvD2 = WDESC2[_wKey2 + ":" + _nvRaw2]; } if (!_nvD2) { var _wp2 = _nvRaw2.split(":"); var _wt2 = {"wind":"Vent","rain":"Pluie","snow":"Neige","heat":"Chaleur","cold":"Froid","storm":"Orage","fog":"Brouillard"}[_wp2[0]] || "Alerte m\u00e9t\u00e9o"; _nvD2 = _wp2[1] ? _wt2 + " niveau " + _wp2[1] : _wt2; } }
      return "Alerte renforc\u00e9e : " + _nvD2;
    }
    if (sub === "weather_improved") {
      var WDESC3 = {"wind:1":"Vent mod\u00e9r\u00e9","wind:2":"Vent fort","wind:3":"Vent tr\u00e8s fort","rain:1":"Pluie mod\u00e9r\u00e9e","rain:2":"Fortes pluies","rain:3":"Pluies intenses","rain:4":"Pluies extr\u00eames","snow:1":"Neige mod\u00e9r\u00e9e","snow:2":"Fortes neiges","snow:3":"Neiges intenses","heat:1":"Chaleur","heat:2":"Forte chaleur","heat:3":"Canicule","cold:1":"Froid","cold:2":"Grand froid","cold:3":"Froid extr\u00eame","storm:1":"Orage","storm:2":"Orage fort","storm:3":"Orage violent","fog:1":"Brouillard","fog:2":"Brouillard dense"};
      var _ovRaw3 = String(ov || "");
