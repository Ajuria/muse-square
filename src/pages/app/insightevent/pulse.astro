      + `<div data-hero-body style="display:none;padding-top:14px;">`
        + `<div style="background:var(--color-bg-recessed);border:1px solid var(--color-border);border-radius:10px;padding:2px 14px 14px;">${renderScoreDetail(currentDay, days)}</div>`
      + `</div>`
    + `</div>`;

    // Weekly goal — ONE goal for the whole account; picking it reorders the cards live.
    var GOAL_OPTS = [
      { key: "faire_venir", label: "Faire venir" },
      { key: "augmenter_panier", label: "Augmenter le CA" },
      { key: "plus_avis", label: "Plus d\u2019avis" },
      { key: "surveiller_marche", label: "Surveiller le march\u00e9" },
    ];
    // One weekly goal for the whole account — the header dropdown handles which site
    // you are looking at, so the goal no longer carries its own site picker.
    var activeGoalKey = _effGoalKey;
    var _goalChipLabel = activeGoalKey
      ? ("Objectif\u00a0: " + ((GOAL_OPTS.filter(function(g){ return g.key === activeGoalKey; })[0] || {}).label || ""))
      : "D\u00e9finir un objectif";
    var goalSelectorHtml = (
      '<div class="pls-goal" data-goal-selector>'
      + '<button type="button" class="pls-goal-chip" data-goal-chip-toggle aria-expanded="false">'
        + '<span data-goal-chip-label>' + escapeHtml(_goalChipLabel) + '</span>'
        + '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>'
      + '</button>'
      + '<div class="pls-goal-pop" data-goal-popover hidden>'
        + '<div class="eb" style="margin-bottom:6px;">Objectif de la semaine</div>'
        + '<div style="font-size:11px;color:#6B7280;margin-bottom:10px;line-height:1.4;">Les cartes qui servent cet objectif passent en t\u00eate de la liste.</div>'
        + '<div style="display:flex;gap:6px;flex-wrap:wrap;">'
        + GOAL_OPTS.map(function(g) {
