          ${launchesHtml}
          ${activeHtml}
          ${upcomingHtml}
          <div style="padding-top:8px;border-top:0.5px solid #F3F4F6;margin-top:8px;">
            <a href="/app/insightevent/competitor?id=${encodeURIComponent(cid)}" style="font-size:11px;font-weight:600;color:#1D3BB3;text-decoration:none;">Profil strat\u00e9gique \u2192</a>
          </div>
        </div>
