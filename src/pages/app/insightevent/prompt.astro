    <script is:inline>
      (function() {
        const greetEl = document.getElementById('ie-prompt-greeting');
        const titleEl = document.getElementById('ie-prompt-title');
        if (!greetEl || !titleEl) return;

        const days = ['Dimanche','Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'];
        const months = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
        const now = new Date();
        greetEl.textContent = `${days[now.getDay()]} ${now.getDate()} ${months[now.getMonth()]}`;

        const name = (titleEl.getAttribute('data-firstname') || '').trim();
        const greeting = name ? `Bonjour ${name}.` : 'Bonjour.';

        const hour = now.getHours();
        const morning = ['Que souhaitez-vous explorer ?','Par où commençons-nous ?','Quelle date souhaitez-vous évaluer ?','Quelle est votre prochaine décision ?'];
        const afternoon = ['Sur quoi travaillez-vous aujourd\'hui ?','Quelle décision préparez-vous ?','Quel événement planifiez-vous ?','Où en êtes-vous dans votre planification ?'];
        const evening = ['Quels risques souhaitez-vous anticiper ?','Que souhaitez-vous préparer pour demain ?','Quelle date souhaitez-vous sécuriser ?','Quel est votre prochain défi ?'];
        const pool = hour < 12 ? morning : hour < 18 ? afternoon : evening;
        const questions = pool[now.getDate() % pool.length];

        titleEl.innerHTML = `${greeting}<br>${questions}`;
      })();
    </script>

    <script is:inline>
    (function() {
      const CITIES = [
        {name:'Nîmes',id:'30189',dept:'30 – Occitanie'},
        {name:'Montpellier',id:'34172',dept:'34 – Occitanie'},
        {name:'Marseille',id:'13055',dept:'13 – PACA'},
        {name:'Paris',id:'75056',dept:'75 – Île-de-France'},
        {name:'Lyon',id:'69123',dept:'69 – Auvergne-Rhône-Alpes'},
        {name:'Toulouse',id:'31555',dept:'31 – Occitanie'},
        {name:'Bordeaux',id:'33063',dept:'33 – Nouvelle-Aquitaine'},
        {name:'Nice',id:'06088',dept:'06 – PACA'},
        {name:'Narbonne',id:'11262',dept:'11 – Occitanie'},
        {name:'Perpignan',id:'66136',dept:'66 – Occitanie'},
      ];

      let currentMode = 'planning';
      let openPath = null;

      const suggestionsEl = document.getElementById('ie-prompt-suggestions-label');
      const concurrenceEl = document.getElementById('ie-concurrence-section');
      const marketingEl   = document.getElementById('ie-marketing-section');
      const inputEl       = document.getElementById('ie-prompt-input');

      // Cards to show/hide per mode
      const planningCards = document.querySelectorAll('.ie-prompt-card');
      const finderForm    = document.getElementById('ie-finder-form');

      function setMode(m) {
        currentMode = m;
        closeAllPaths();

        // Planning cards + suggestions label
        const showPlanning = m === 'planning';
        if (suggestionsEl) suggestionsEl.style.display = showPlanning ? '' : 'none';
        planningCards.forEach(c => c.style.display = showPlanning ? 'flex' : 'none');
        if (finderForm) finderForm.style.display = 'none';
        const actionsLabel = document.getElementById('ie-prompt-actions-label');
        if (actionsLabel) actionsLabel.style.display = showPlanning ? '' : 'none';

        // Concurrence section
        if (concurrenceEl) concurrenceEl.style.display = m === 'concurrence' ? 'block' : 'none';

        // Marketing section
        if (marketingEl) marketingEl.style.display = m === 'marketing' ? 'block' : 'none';

        // Mode buttons
        document.querySelectorAll('.ie-mode-btn').forEach(btn => {
          const active = btn.dataset.mode === m;
          btn.classList.toggle('active', active);
        });

        // Input placeholder
        const ph = {
          planning: 'Posez votre question…',
          concurrence: 'Ajoutez un contexte ou validez directement…',
          marketing: 'Bientôt disponible…',
        };
        if (inputEl) inputEl.placeholder = ph[m] || 'Posez votre question…';
      }
      window.__ieSetMode = setMode;

      function closeAllPaths() {
        ['event','competitor','search'].forEach(p => {
          const form = document.getElementById('ie-form-' + p);
          const card = document.getElementById('ie-conc-' + p);
          const chev = document.getElementById('ie-chev-' + p);
          if (form) form.style.display = 'none';
          if (card) card.classList.remove('active');
          if (chev) chev.classList.remove('open');
        });
        openPath = null;
        const inputBar = document.getElementById('ie-prompt-input-bar');
        if (inputBar) inputBar.style.display = '';
      }

      function togglePath(p) {
        if (openPath === p) { closeAllPaths(); return; }
        closeAllPaths();
        openPath = p;
        const form = document.getElementById('ie-form-' + p);
        const card = document.getElementById('ie-conc-' + p);
        const chev = document.getElementById('ie-chev-' + p);
        if (form) form.style.display = 'block';
        if (p === 'event') initFlatpickrOnce();
        if (card) card.classList.add('active');
        if (chev) chev.classList.add('open');
        const inputBar = document.getElementById('ie-prompt-input-bar');
        if (inputBar) inputBar.style.display = 'none';
      }

      // Mode switcher clicks
      document.querySelectorAll('.ie-mode-btn').forEach(btn => {
        btn.addEventListener('click', () => setMode(btn.dataset.mode));
      });

      // Concurrence card clicks
      document.querySelectorAll('.ie-conc-card').forEach(card => {
        card.addEventListener('click', () => togglePath(card.dataset.path));
      });

      // Cancel buttons
      document.querySelectorAll('[data-close-path]').forEach(btn => {
        btn.addEventListener('click', (e) => { e.stopPropagation(); closeAllPaths(); });
      });

      // City autocomplete
      const zoneInput = document.getElementById('ie-search-zone');
      const cityDd    = document.getElementById('ie-search-city-dd');
      const zoneIdEl  = document.getElementById('ie-search-zone-id');

      if (zoneInput && cityDd) {
        zoneInput.addEventListener('input', () => filterCities(zoneInput.value));
        zoneInput.addEventListener('focus', () => filterCities(zoneInput.value));
        document.addEventListener('click', (e) => {
          if (!e.target.closest('#ie-search-zone') && !e.target.closest('#ie-search-city-dd'))
            cityDd.style.display = 'none';
        });
      }

      function filterCities(val) {
        if (!cityDd) return;
        if (!val || val.length < 1) { cityDd.style.display = 'none'; return; }
        const f = CITIES.filter(c => c.name.toLowerCase().startsWith(val.toLowerCase())).slice(0,5);
        if (!f.length) { cityDd.style.display = 'none'; return; }
        cityDd.innerHTML = f.map(c =>
          `<div data-city-name="${c.name}" data-city-id="${c.id}" style="padding:9px 12px;font-size:14px;cursor:pointer;color:#111827;">${c.name} <span style="color:#9CA3AF;font-size:12px;">· ${c.dept}</span></div>`
        ).join('');
        cityDd.querySelectorAll('[data-city-name]').forEach(opt => {
          opt.addEventListener('click', () => {
            if (zoneInput) zoneInput.value = opt.dataset.cityName;
            if (zoneIdEl)  zoneIdEl.value  = opt.dataset.cityId;
            cityDd.style.display = 'none';
          });
        });
        cityDd.style.display = 'block';
      }

      // Submit handlers — call existing API endpoints
      function escapeHtmlConc(s) {
        return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }

      function fmtDateFr(iso) {
        if (!iso) return '';
        const [y, m, d] = iso.split('-');
        const months = ['jan.','fév.','mars','avr.','mai','juin','juil.','août','sept.','oct.','nov.','déc.'];
        return `${parseInt(d)} ${months[parseInt(m)-1]} ${y}`;
      }

      function sourceStyle(sourceType, sourceSystem) {
        if (sourceSystem === 'user_confirmed' || sourceSystem === 'ms_database')
          return { label: 'Muse Square', bg: 'var(--color-pill-safe-bg)', color: 'var(--color-pill-safe-text)' };
        if (sourceType === 'Site officiel' || sourceType === 'Eventbrite' || sourceType === 'OpenAgenda')
          return { label: sourceType, bg: 'var(--color-pill-source-verified-bg)', color: 'var(--color-pill-source-verified-text)' };
        if (sourceType === 'LinkedIn' || sourceType === 'Annuaire pro')
          return { label: sourceType, bg: 'var(--color-pill-source-mid-bg)', color: 'var(--color-pill-source-mid-text)' };
        return { label: sourceType || 'Web', bg: 'var(--color-pill-source-low-bg)', color: 'var(--color-pill-source-low-text)' };
      }

      function renderCandidateCards(candidates, submittedLabel, noResultMsg, source) {
        const thread = document.getElementById('ie-thread');
        if (!thread) return;

        const existingLoader = document.getElementById('ie-evt-loading');
        if (existingLoader) existingLoader.remove();

        const aiRow = document.createElement('div');
        aiRow.className = 'ie-msg ie-msg-ai';

        if (!candidates.length) {
          aiRow.innerHTML = `<div class="ie-bubble-none" style="font-size:15px;color:var(--color-text-secondary);line-height:1.6;">
            ${escapeHtmlConc(noResultMsg || 'Aucun résultat trouvé pour cet événement. Vérifiez le nom et la ville, ou ajoutez-le manuellement via le lien source.')}
          </div>`;
          thread.appendChild(aiRow);
          aiRow.scrollIntoView({ block: 'end' });
          return;
        }

        const confLabel = (c) => {
          if (c === 'high')   return { text: 'Haute confiance',   cls: 'conf-high-pill' };
          if (c === 'medium') return { text: 'Confiance moyenne', cls: 'conf-med-pill' };
          return                     { text: 'Faible confiance',  cls: 'conf-low-pill' };
        };

        const cardsHtml = candidates.map((c, i) => {
          const cf = confLabel(c.confidence);
          const meta = [
            c.event_date_start ? `${fmtDateFr(c.event_date_start)}${c.event_date_end ? ' → ' + fmtDateFr(c.event_date_end) : ''}` : null,
            c.event_city || null,
            c.organizer_name || null,
            c.venue_name || null,
            c.estimated_attendance ? `~${c.estimated_attendance.toLocaleString('fr-FR')} visiteurs` : null,
          ].filter(Boolean).join(' · ');

          return `
            <div class="ie-card-blue" style="margin-bottom:10px;" id="ie-cand-${i}">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px;">
                <div class="ie-card-label" style="flex:1;min-width:0;">${escapeHtmlConc(c.event_name || 'Événement')}</div>
                <div style="display:flex;gap:6px;align-items:center;flex-shrink:0;margin-left:8px;">
                  ${(() => { const s = sourceStyle(c.source_type, c.source_system || (source === 'database' ? 'ms_database' : null)); return `<span style="font-size:10px;font-weight:600;padding:2px 7px;border-radius:20px;background:${s.bg};color:${s.color};">${escapeHtmlConc(s.label)}</span>`; })()}
                  <span style="font-size:11px;font-weight:500;padding:2px 8px;border-radius:20px;${cf.cls === 'conf-high-pill' ? 'background:var(--color-pill-source-verified-bg);color:var(--color-pill-source-verified-text);' : cf.cls === 'conf-med-pill' ? 'background:var(--color-pill-source-mid-bg);color:var(--color-pill-source-mid-text);' : 'background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);'}">${escapeHtmlConc(cf.text)}</span>
                </div>
              </div>
              ${meta ? `<div class="ie-card-row" style="margin-bottom:10px;">${escapeHtmlConc(meta)}</div>` : ''}
              ${c.description ? `<div class="ie-card-row" style="color:var(--color-text-secondary);margin-bottom:10px;display:-webkit-box;-webkit-box-orient:vertical;-webkit-line-clamp:2;overflow:hidden;">${escapeHtmlConc(c.description)}</div>` : ''}
              <div id="ie-cand-actions-${i}" style="padding-top:8px;border-top:0.5px solid rgba(0,0,0,0.06);margin-top:8px;">
                ${c.source_url ? `
                <div style="display:flex;justify-content:space-between;align-items:center;">
                  <span style="font-size:11px;color:#9CA3AF;">${escapeHtmlConc(new URL(c.source_url).hostname.replace('www.',''))}</span>
                  <a href="${escapeHtmlConc(c.source_url)}" target="_blank" rel="noopener" style="font-size:13px;font-weight:500;color:#1D3BB3;text-decoration:none;" data-src-idx="${i}">Vérifier la source →</a>
                </div>
                <div style="font-size:11px;color:#9CA3AF;margin-top:6px;">Vérifiez que cette source correspond bien à l'événement avant d'ajouter à votre veille.</div>
                ` : `
                <div style="display:flex;gap:20px;justify-content:flex-end;align-items:center;">
                  <button class="ie-conc-btn-ghost" data-cand-reject="${i}">Ce n'est pas ça</button>
                  <button class="ie-conc-btn-primary" data-cand-confirm="${i}">Ajouter à ma veille →</button>
                </div>
                `}
              </div>
            </div>
          `;
        }).join('');

        aiRow.innerHTML = `<div class="ie-bubble-none">
          <div class="ie-cand-header" style="font-size:14px;color:var(--color-text-secondary);margin-bottom:12px;">
            ${candidates.length} résultat${candidates.length > 1 ? 's' : ''} trouvé${candidates.length > 1 ? 's' : ''}. Confirmez l'événement à ajouter à votre veille.
          </div>
          ${cardsHtml}
        </div>`;

        thread.appendChild(aiRow);
        aiRow.scrollIntoView({ block: 'end' });

        aiRow.querySelectorAll('a[data-src-idx]').forEach(link => {
          link.addEventListener('click', () => {
            const idx = link.getAttribute('data-src-idx');
            const actionsEl = aiRow.querySelector(`#ie-cand-actions-${idx}`);
            if (actionsEl) {
              actionsEl.innerHTML = `
                <div style="display:flex;gap:20px;justify-content:flex-end;align-items:center;">
                  <button class="ie-conc-btn-ghost" data-cand-reject="${idx}">Ce n'est pas ça</button>
                  <button class="ie-conc-btn-primary" data-cand-confirm="${idx}">Ajouter à ma veille →</button>
                </div>
              `;
              actionsEl.querySelector(`[data-cand-confirm="${idx}"]`)?.addEventListener('click', async () => {
                const candidate = candidates[parseInt(idx)];
                const btn = actionsEl.querySelector(`[data-cand-confirm="${idx}"]`);
                btn.disabled = true;
                btn.textContent = '…';
                try {
                  await fetch('/api/competitive/add-event', {
                    method: 'POST',
                    headers: { 'content-type': 'application/json' },
                    body: JSON.stringify({ ...candidate, source_system: 'agent_auto' }),
                  }).then(r => r.json());
                  const card = document.getElementById(`ie-cand-${idx}`);
                  if (card) { card.style.opacity = '0.4'; card.querySelectorAll('button, a').forEach(b => b.disabled = true); }
                  const successRow = document.createElement('div');
                  successRow.className = 'ie-msg ie-msg-ai';
                  successRow.innerHTML = `<div class="ie-bubble-none" style="font-size:14px;color:#1D3BB3;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" style="display:inline;vertical-align:-2px;margin-right:6px;"><path d="M20 6L9 17l-5-5" stroke="#1D3BB3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>${escapeHtmlConc(candidate.event_name || 'Événement')} ajouté à votre veille. Gérez vos suivis dans Compte → Suivis.</div>`;
                  thread.appendChild(successRow);
                  successRow.scrollIntoView({ block: 'end' });
                } catch(e) {
                  btn.disabled = false;
                  btn.textContent = 'Ajouter à ma veille →';
                }
              });
              actionsEl.querySelector(`[data-cand-reject="${idx}"]`)?.addEventListener('click', () => {
                const card = document.getElementById(`ie-cand-${idx}`);
                if (card) card.remove();
                const remaining = aiRow.querySelectorAll('[id^="ie-cand-"]');
                const headerEl = aiRow.querySelector('.ie-cand-header');
                if (remaining.length === 0 && headerEl) headerEl.textContent = 'Aucun résultat retenu.';
              });
            }
          });
        });
      }

      const evtSubmit = document.getElementById('ie-evt-submit');
      if (evtSubmit) {
        evtSubmit.addEventListener('click', async () => {
          const name      = document.getElementById('ie-evt-name')?.value.trim();
          const city      = document.getElementById('ie-evt-city')?.value.trim();
          const dateStartRaw = document.getElementById('ie-evt-date-start')?.value.trim();
          const dateStart = (() => {
            const m = (dateStartRaw || '').match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
            return m ? `${m[3]}-${m[2]}-${m[1]}` : dateStartRaw;
          })();
          if (!name || !city || !dateStart) {
            document.getElementById('ie-evt-name')?.closest('.ie-conc-form-inner')
              ?.querySelectorAll('input')[0]?.focus();
            return;
          }

          const body = {
            event_name:     name,
            event_city:     city,
            date_start:     dateStart,
            date_end: (() => {
              const v = document.getElementById('ie-evt-date-end')?.value.trim() || '';
              const m = v.match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
              return m ? `${m[3]}-${m[2]}-${m[1]}` : (v || null);
            })(),
            organizer_name: document.getElementById('ie-evt-organizer')?.value.trim() || null,
            venue_name:     document.getElementById('ie-evt-venue')?.value.trim() || null,
            source_url:     document.getElementById('ie-evt-url')?.value.trim() || null,
          };

          const submittedLabel = [name, city, dateStart].filter(Boolean).join(' — ');

          evtSubmit.disabled = true;
          evtSubmit.textContent = 'Analyse en cours…';

          closeAllPaths();

          const thread = document.getElementById('ie-thread');
          const empty  = document.getElementById('ie-prompt-empty');
          if (empty) empty.setAttribute('hidden', 'true');
          if (thread) thread.removeAttribute('hidden');
          const evtLoadingRow = document.createElement('div');
          evtLoadingRow.className = 'ie-msg ie-msg-user';
          evtLoadingRow.innerHTML = `<div class="ie-bubble">${escapeHtmlConc(submittedLabel)}</div>`;
          if (thread) thread.appendChild(evtLoadingRow);
          const evtLoadingAiRow = document.createElement('div');
          evtLoadingAiRow.id = 'ie-evt-loading';
          evtLoadingAiRow.className = 'ie-msg ie-msg-ai';
          evtLoadingAiRow.innerHTML = `<div class="ie-bubble-none" style="display:flex;justify-content:center;width:100%;"><img src="/icons/load/ms_load_icon.gif" alt="Analyse en cours" style="height:140px;width:auto;" /></div>`;
          if (thread) { thread.appendChild(evtLoadingAiRow); evtLoadingAiRow.scrollIntoView({ block: 'end' }); }

          try {
            const check = await fetch('/api/competitive/check-event', {
              method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(body)
            }).then(r => r.json());

            console.log('[check-event] response:', JSON.stringify(check));

            if (check.ok && check.found_wrong_dates) {
              const knownCandidates = (check.known_editions || []).map((e) => ({
                event_name: e.event_name,
                event_date_start: e.event_start_date,
                event_date_end: e.event_end_date,
                date_start: e.event_start_date,
                date_end: e.event_end_date,
                event_city: e.city_name || body.event_city,
                organizer_name: null,
                venue_name: null,
                estimated_attendance: null,
                description: `Information disponible, mais dates non concordantes.`,
                confidence: 'medium',
                confidence_score: 0.7,
                source_url: null,
                _source: 'database',
              }));
              const search = await fetch('/api/competitive/search-event', {
                method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(body)
              }).then(r => r.json()).catch(() => ({ candidates: [] }));
              const webCandidates = (search.candidates || []).map((c) => ({ ...c, _source: 'web' }));
              const allCandidates = [...knownCandidates, ...webCandidates];
              renderCandidateCards(allCandidates, submittedLabel, 'Aucun résultat trouvé. Vérifiez le nom et la ville.', 'mixed');
            } else if (check.ok && check.exists && check.matches?.length > 0) {
              renderCandidateCards(check.matches, submittedLabel, null, 'database');
            } else {
              const search = await fetch('/api/competitive/search-event', {
                method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(body)
              }).then(r => r.json());
              renderCandidateCards(search.candidates || [], submittedLabel, null, 'web');
            }

          } catch(e) {
            renderCandidateCards([], submittedLabel);
          } finally {
            evtSubmit.disabled = false;
            evtSubmit.textContent = 'Continuer →';
          }
        });
      }

      const compSubmit = document.getElementById('ie-comp-submit');
      if (compSubmit) {
        compSubmit.addEventListener('click', async () => {
          const name   = document.getElementById('ie-comp-name')?.value.trim();
          const city   = document.getElementById('ie-comp-city')?.value.trim();
          const sector = document.getElementById('ie-comp-sector')?.value || null;
          const venue  = document.getElementById('ie-comp-venue')?.value.trim() || null;
          const url    = document.getElementById('ie-comp-url')?.value.trim() || null;

          if (!name || !city) {
            document.getElementById('ie-comp-name')?.focus();
            return;
          }

          const submittedLabel = [name, city].filter(Boolean).join(' — ');

          compSubmit.disabled = true;
          compSubmit.textContent = 'Analyse en cours…';
          closeAllPaths();

          const thread = document.getElementById('ie-thread');
          const empty  = document.getElementById('ie-prompt-empty');
          if (empty) empty.setAttribute('hidden', 'true');
          if (thread) thread.removeAttribute('hidden');
          const loadingRow = document.createElement('div');
          loadingRow.className = 'ie-msg ie-msg-user';
          loadingRow.innerHTML = `<div class="ie-bubble">${escapeHtmlConc(submittedLabel)}</div>`;
          if (thread) thread.appendChild(loadingRow);
          const loadingAiRow = document.createElement('div');
          loadingAiRow.id = 'ie-comp-loading';
          loadingAiRow.className = 'ie-msg ie-msg-ai';
          loadingAiRow.innerHTML = `<div class="ie-bubble-none" style="display:flex;justify-content:center;width:100%;"><img src="/icons/load/ms_load_icon.gif" alt="Analyse en cours" style="height:140px;width:auto;" /></div>`;
          if (thread) { thread.appendChild(loadingAiRow); loadingAiRow.scrollIntoView({ block: 'end' }); }

          const body = {
            competitor_name: name,
            competitor_city: city,
            industry_code:   sector || null,
            venue_name:      venue || null,
            source_url:      url || null,
          };

          try {
            // Step 1 — database lookup
            const check = await fetch('/api/competitive/check-competitor', {
              method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(body)
            }).then(r => r.json());

            console.log('[check-competitor] response:', JSON.stringify(check));

            if (check.ok && check.exists && check.matches?.length > 0) {
              // Found in DB — map to candidate card shape
              const dbCandidates = check.matches.map(m => ({
                competitor_name:      m.competitor_name,
                city:                 m.city,
                industry_code:        m.industry_code,
                industry_bucket:      m.industry_bucket,
                primary_audience:     m.primary_audience,
                secondary_audience:   m.secondary_audience,
                address:              m.address,
                description:          m.description,
                source_url:           m.source_url,
                google_rating:        m.google_rating,
                google_review_count:  m.google_review_count,
                google_review_summary: m.google_review_summary,
                photos:               m.photos,
                confidence:           m.confidence_score >= 0.9 ? 'high' : m.confidence_score >= 0.7 ? 'medium' : 'low',
                confidence_score:     m.confidence_score,
                is_user_vetted:       m.is_user_vetted,
                source_system:        m.source_system,
                _source:              'database',
              }));
              renderCompetitorCards(dbCandidates, submittedLabel, null, 'database');
            } else {
              // Step 2 — web search fallback
              const search = await fetch('/api/competitive/search-competitor', {
                method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(body)
              }).then(r => r.json()).catch(() => ({ candidates: [] }));

              console.log('[search-competitor] response:', JSON.stringify(search));

              const webCandidates = (search.candidates || []).map(c => ({ ...c, _source: 'web' }));
              renderCompetitorCards(webCandidates, submittedLabel, 'Aucun résultat trouvé. Vérifiez le nom et la ville.', 'web');
            }

          } catch(e) {
            console.error('[comp-submit]', e);
            renderCompetitorCards([], submittedLabel, 'Erreur réseau. Veuillez réessayer.', null);
          } finally {
            compSubmit.disabled = false;
            compSubmit.textContent = 'Continuer →';
          }
        });
      }

      function renderCompetitorCards(candidates, submittedLabel, noResultMsg, source) {
        const thread = document.getElementById('ie-thread');
        if (!thread) return;

        const existingLoader = document.getElementById('ie-comp-loading');
        if (existingLoader) existingLoader.remove();

        const aiRow = document.createElement('div');
        aiRow.className = 'ie-msg ie-msg-ai';

        if (!candidates.length) {
          aiRow.innerHTML = `<div class="ie-bubble-none" style="font-size:15px;color:var(--color-text-secondary);line-height:1.6;">
            ${escapeHtmlConc(noResultMsg || 'Aucun résultat trouvé. Vérifiez le nom et la ville.')}
          </div>`;
          thread.appendChild(aiRow);
          aiRow.scrollIntoView({ block: 'end' });
          return;
        }

        const confLabel = (c) => {
          if (c === 'high')   return { text: 'Haute confiance',   cls: 'conf-high-pill' };
          if (c === 'medium') return { text: 'Confiance moyenne', cls: 'conf-med-pill' };
          return                     { text: 'Faible confiance',  cls: 'conf-low-pill' };
        };

        const cardsHtml = candidates.map((c, i) => {
          const cf = confLabel(c.confidence);
          const meta = [
            c.city || null,
            c.industry_code || null,
            c.address || null,
            c.google_rating ? `★ ${c.google_rating}${c.google_review_count ? ` (${c.google_review_count} avis)` : ''}` : null,
          ].filter(Boolean).join(' · ');

          return `
            <div class="ie-card-blue" style="margin-bottom:10px;" id="ie-comp-cand-${i}">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px;">
                <div class="ie-card-label" style="flex:1;min-width:0;">${escapeHtmlConc(c.competitor_name || 'Concurrent')}</div>
                <div style="display:flex;gap:6px;align-items:center;flex-shrink:0;margin-left:8px;">
                  ${(() => { const s = sourceStyle(c.source_type, c.source_system); return `<span style="font-size:10px;font-weight:600;padding:2px 7px;border-radius:20px;background:${s.bg};color:${s.color};">${escapeHtmlConc(s.label)}</span>`; })()}
                  <span style="font-size:11px;font-weight:500;padding:2px 8px;border-radius:20px;${cf.cls === 'conf-high-pill' ? 'background:var(--color-pill-source-verified-bg);color:var(--color-pill-source-verified-text);' : cf.cls === 'conf-med-pill' ? 'background:var(--color-pill-source-mid-bg);color:var(--color-pill-source-mid-text);' : 'background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);'}">${escapeHtmlConc(cf.text)}</span>
                </div>
              </div>
              ${meta ? `<div class="ie-card-row" style="margin-bottom:6px;">${escapeHtmlConc(meta)}</div>` : ''}
              ${c.description ? `<div class="ie-card-row" style="color:var(--color-text-secondary);margin-bottom:8px;line-height:1.5;">${escapeHtmlConc(c.description)}</div>` : ''}
              ${c.source_sentence ? `<div class="ie-card-row" style="font-size:12px;color:#9CA3AF;margin-bottom:8px;font-style:italic;line-height:1.4;">"${escapeHtmlConc(c.source_sentence)}"</div>` : ''}
              <div id="ie-comp-actions-${i}" style="padding-top:8px;border-top:0.5px solid rgba(0,0,0,0.06);margin-top:8px;">
                ${c.source_url ? `
                <div style="display:flex;justify-content:space-between;align-items:center;">
                  <span style="font-size:11px;color:#9CA3AF;">${escapeHtmlConc(new URL(c.source_url).hostname.replace('www.',''))}</span>
                  <a href="${escapeHtmlConc(c.source_url)}" target="_blank" rel="noopener" style="font-size:13px;font-weight:500;color:#1D3BB3;text-decoration:none;" data-comp-src-idx="${i}">Vérifier la source →</a>
                </div>
                <div style="font-size:11px;color:#9CA3AF;margin-top:6px;">Vérifiez que cette source correspond bien au concurrent avant d'ajouter à votre veille.</div>
                ` : `
                <div style="display:flex;gap:20px;justify-content:flex-end;align-items:center;">
                  <button class="ie-conc-btn-ghost" data-comp-reject="${i}">Ce n'est pas ça</button>
                  <button class="ie-conc-btn-primary" data-comp-confirm="${i}">Ajouter à ma veille →</button>
                </div>
                `}
              </div>
            </div>
          `;
        }).join('');

        aiRow.innerHTML = `<div class="ie-bubble-none">
          <div class="ie-cand-header" style="font-size:14px;color:var(--color-text-secondary);margin-bottom:12px;">
            ${candidates.length} résultat${candidates.length > 1 ? 's' : ''} trouvé${candidates.length > 1 ? 's' : ''}. Confirmez le concurrent à ajouter à votre veille.
          </div>
          ${cardsHtml}
        </div>`;

        thread.appendChild(aiRow);
        aiRow.scrollIntoView({ block: 'end' });

        aiRow.querySelectorAll('a[data-comp-src-idx]').forEach(link => {
          link.addEventListener('click', () => {
            const idx = link.getAttribute('data-comp-src-idx');
            const actionsEl = aiRow.querySelector(`#ie-comp-actions-${idx}`);
            if (actionsEl) {
              actionsEl.innerHTML = `
                <div style="display:flex;gap:20px;justify-content:flex-end;align-items:center;">
                  <button class="ie-conc-btn-ghost" data-comp-reject="${idx}">Ce n'est pas ça</button>
                  <button class="ie-conc-btn-primary" data-comp-confirm="${idx}">Ajouter à ma veille →</button>
                </div>
              `;
              actionsEl.querySelector(`[data-comp-confirm="${idx}"]`)?.addEventListener('click', async () => {
                const candidate = candidates[parseInt(idx)];
                const btn = actionsEl.querySelector(`[data-comp-confirm="${idx}"]`);
                btn.disabled = true;
                btn.textContent = '…';
                try {
                  await fetch('/api/competitive/add-competitor', {
                    method: 'POST',
                    headers: { 'content-type': 'application/json' },
                    body: JSON.stringify({ ...candidate, source_system: 'user_confirmed' }),
                  }).then(r => r.json());
                  const card = document.getElementById(`ie-comp-cand-${idx}`);
                  if (card) { card.style.opacity = '0.4'; card.querySelectorAll('button, a').forEach(b => b.disabled = true); }
                  const successRow = document.createElement('div');
                  successRow.className = 'ie-msg ie-msg-ai';
                  successRow.innerHTML = `<div class="ie-bubble-none" style="font-size:14px;color:#1D3BB3;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" style="display:inline;vertical-align:-2px;margin-right:6px;"><path d="M20 6L9 17l-5-5" stroke="#1D3BB3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>${escapeHtmlConc(candidate.competitor_name || 'Concurrent')} ajouté à votre veille.</div>`;
                  thread.appendChild(successRow);
                  successRow.scrollIntoView({ block: 'end' });
                } catch(e) {
                  btn.disabled = false;
                  btn.textContent = 'Ajouter à ma veille →';
                }
              });
              actionsEl.querySelector(`[data-comp-reject="${idx}"]`)?.addEventListener('click', () => {
                const card = document.getElementById(`ie-comp-cand-${idx}`);
                if (card) card.remove();
                const remaining = aiRow.querySelectorAll('[id^="ie-comp-cand-"]');
                const headerEl = aiRow.querySelector('.ie-cand-header');
                if (remaining.length === 0 && headerEl) headerEl.textContent = 'Aucun résultat retenu.';
              });
            }
          });
        });
      }

      // Initialize
      setMode('planning');

      // Flatpickr date pickers — init lazily on first open
      let _fpInitDone = false;
      function initFlatpickrOnce() {
        if (_fpInitDone) return;
        if (!window.flatpickr) return;
        const locale = window.flatpickr.l10ns?.fr ? 'fr' : 'default';
        window.flatpickr('#ie-evt-date-start', {
          locale,
          dateFormat: 'd/m/Y',
          disableMobile: true,
        });
        window.flatpickr('#ie-evt-date-end', {
          locale,
          dateFormat: 'd/m/Y',
          disableMobile: true,
        });
        _fpInitDone = true;
      }
    })();
    </script>

    <script type="module" src="/scripts/ie-prompt.js" defer></script>

  </BaseLayout>
</Show>
