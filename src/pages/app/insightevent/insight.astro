        }
        wireActionBar(root, day, prof, feedItem);
      }

      // ════════════════════════════════════════════════════════════════
      // POURQUOI FACTS BUILDER — structured, mode-specific
      // ════════════════════════════════════════════════════════════════

      function buildPourquoiFacts(mode, day, prof, crawled, feedItem) {
        var facts = [];
        var aud1 = AUD_FR[prof.primary_audience_1] || prof.primary_audience_1 || '';
        var aud2 = AUD_FR[prof.primary_audience_2] || prof.primary_audience_2 || '';
        var audStr = aud1 + (aud2 ? ', ' + aud2 : '');
        var diff = (crawled && crawled.key_differentiators) || (crawled && crawled.current_offering) || prof.business_short_description || '';
        if (diff && (diff.indexOf('signaux contextuels') >= 0 || diff.indexOf('traduction automatique') >= 0 || diff.indexOf('Muse Square') >= 0 || diff.indexOf('muse square') >= 0)) diff = '';
        if (diff && diff.length > 120) diff = diff.substring(0, 120) + '\u2026';

        if (mode === 'meteo') {
          if (Number(prof.weather_sensitivity || 0) >= 3) facts.push({ label: 'Sensibilit\u00e9 m\u00e9t\u00e9o', value: prof.weather_sensitivity + '/5', text: '\u2014 impact direct sur votre fr\u00e9quentation' });
          var lt = String(prof.location_type || '').toLowerCase();
          if (lt === 'mixed' || lt === 'outdoor') facts.push({ label: 'Type d\u2019espace', value: LOC_FR[lt] || lt, text: '\u2014 installations ext\u00e9rieures expos\u00e9es' });
          if (Number(day.impact_weather_pct || 0) !== 0) facts.push({ label: 'Impact estim\u00e9', value: Math.round(Number(day.impact_weather_pct)) + '%', text: 'de fr\u00e9quentation' });
          if (diff) facts.push({ label: 'Votre atout', text: diff });
        } else if (mode === 'concurrence') {
          facts.push({ label: '\u00c9v\u00e9nements \u00e0 5 km', value: num(day.events_within_5km_count), text: 'dont ' + num(day.events_within_5km_same_bucket_count) + ' dans votre secteur' });
          facts.push({ label: 'Pression', value: ratio(day.competition_pressure_ratio), text: 'vs moyenne habituelle' });
          if (diff) facts.push({ label: 'Votre atout', text: diff });
          if (audStr) facts.push({ label: 'Votre cible', value: audStr, text: 'sollicit\u00e9e par ' + num(day.events_within_5km_same_bucket_count) + ' concurrents directs' });
        } else if (mode === 'opportunite') {
          var prOpp = Number(day.competition_pressure_ratio || 0);
          if (prOpp > 0 && prOpp < 0.8) facts.push({ label: 'Concurrence', value: num(day.events_within_5km_count), text: '\u00e9v\u00e9nements \u00e0 5 km \u2014 bien en dessous de la moyenne' });
          else facts.push({ label: 'Concurrence', value: num(day.events_within_5km_count), text: '\u00e9v\u00e9nements \u00e0 5 km' });
          facts.push({ label: 'Score', value: score10(day.opportunity_score_final_local) + '/10', text: '\u2014 conditions favorables' });
          if (diff) facts.push({ label: 'Votre atout', text: diff });
        } else if (mode === 'mobilite') {
          var tName = prof.nearest_transit_stop_name || '';
          var tLine = Array.isArray(prof.nearest_transit_line_name) ? prof.nearest_transit_line_name.join(', ') : (prof.nearest_transit_line_name || '');
          var tDist = prof.nearest_transit_stop_distance_m ? Math.round(Number(prof.nearest_transit_stop_distance_m)) + 'm' : '';
          if (tName) facts.push({ label: 'Station', value: tName + (tLine ? ' (ligne ' + tLine + ')' : ''), text: tDist ? '\u00e0 ' + tDist + ' de votre site' : '' });
          if (Number(day.delta_att_mobility_pct || 0) !== 0) facts.push({ label: 'Impact mobilit\u00e9', value: Math.round(Number(day.delta_att_mobility_pct)) + '%', text: 'de fr\u00e9quentation estim\u00e9e' });
          facts.push({ label: 'Acc\u00e8s visiteurs', text: 'Vos visiteurs viennent \u00e0 pied et en transports \u2014 impact direct' });
        } else if (mode === 'intelligence' && (feedItem.change_subtype === 'mega_event_activation' || feedItem.change_subtype === 'mega_event_end')) {
          var megaN = day.active_mega_event_name || feedItem.new_value || 'M\u00e9ga-\u00e9v\u00e9nement';
          if (megaN === 'true' || megaN === 'false') megaN = 'M\u00e9ga-\u00e9v\u00e9nement';
          facts.push({ label: '\u00c9v\u00e9nement', value: megaN, text: 'dans votre zone' });
          facts.push({ label: 'Score jour', value: score10(day.opportunity_score_final_local) + '/10' });
          if (Number(day.events_within_5km_count || 0) > 0) facts.push({ label: '\u00c9v\u00e9nements \u00e0 5 km', value: num(day.events_within_5km_count), text: 'dont ' + num(day.events_within_5km_same_bucket_count) + ' m\u00eame secteur' });
          if (audStr) facts.push({ label: 'Votre cible', value: audStr, text: '\u2014 pr\u00e9sente parmi les visiteurs de l\u2019\u00e9v\u00e9nement' });
          if (diff) facts.push({ label: 'Votre atout', text: diff });
        } else {
          // Intelligence / default
          if (Number(day.competition_pressure_ratio || 0) > 0) facts.push({ label: 'Pression', value: ratio(day.competition_pressure_ratio), text: 'niveau actuel' });
          facts.push({ label: 'Score', value: score10(day.opportunity_score_final_local) + '/10' });
          if (diff) facts.push({ label: 'Votre atout', text: diff });
        }

        return facts;
      }

