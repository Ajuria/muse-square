              + '<div class="fs-metric"><div class="fs-metric-label">Pression</div><div class="fs-metric-value" style="color:' + (pr >= 1.5 ? '#dc2626' : '#1a1d2e') + ';">' + ratio(day.competition_pressure_ratio) + '</div><div class="fs-metric-sub">vs moyenne</div></div>'
            + '</div>'
          + '</div>';

          // Competitors list — watched first
          var tc = day.top_competitors || [];
          if (tc.length > 0) {
            var watched = []; var notWatched = [];
            for (var ci = 0; ci < tc.length; ci++) {
              var c = tc[ci].e || tc[ci];
