        return { cat:'Ventes \u00b7 Positionnement', title:'\u00c9cart de positionnement produit', badge:{ label:'Intelligence', bg:'#EEF2FF', fg:'#1D3BB3' }, competitor_id:'', competitor_name:'', descriptif_orientation:'', claims:claims, sources:['Caisse \u2014 mix produit','Muse Square \u2014 concurrents suivis'] };
      }

      // ── Sales residual (surge / revenue_down): realized vs conditional expectation ──
      // Payload (verified live): daily_revenue, expected_revenue, residual_pct, residual_z,
      // transactions_delta_pct, basket_delta_pct, dominant_factor, driver, is_holiday,
      // is_vacation, pressure_ratio, weather_alert, events_5km, confidence_tier.
      // Conditions are listed as CONTEXT, not attribution (résidu associatif, non causal).
      function salesResidualClaimMap(a, prof, day) {
        var spec = window.ACTION_CARDS ? window.ACTION_CARDS[signal_type] : null;
        var isDown = signal_type === 'sales_revenue_down_wow';
        function sgn(v) { var n = Number(v); return (n >= 0 ? '+' : '') + frDec(Math.round(n)) + ' %'; }
        var claims = [];
        if (a.daily_revenue != null) claims.push({ claim:'CA réalisé ce jour', value: frInt(Math.round(Number(a.daily_revenue))) + ' €', source:'Caisse' });
        if (a.expected_revenue != null) claims.push({ claim:'Attendu par le modèle (jour, saison)', value: frInt(Math.round(Number(a.expected_revenue))) + ' €', source:'Muse Square — modèle' });
        if (a.residual_pct != null) {
          var rz = (a.residual_z != null) ? ' · ' + frDec(Math.abs(Number(a.residual_z)).toFixed(1)) + ' σ' : '';
          claims.push({ claim:'Signal statistique (vs modèle)', value: sgn(a.residual_pct) + rz, source:'Muse Square', computed:true });
        }
        var tx = a.transactions_delta_pct, bk = a.basket_delta_pct;
        if (tx != null && bk != null) {
          var dom = (a.dominant_factor === 'basket') ? 'porté par le panier moyen' : (a.dominant_factor === 'transactions') ? 'porté par le volume de ventes' : '';
          claims.push({ claim:'Décomposition', value:'ventes ' + sgn(tx) + ', panier ' + sgn(bk) + (dom ? ' — ' + dom : ''), source:'Caisse' });
        }
        if (a.is_vacation === true || a.is_vacation === 'true') claims.push({ claim:'Vacances scolaires', value:'Oui', source:'Calendrier' });
        if (a.is_holiday === true || a.is_holiday === 'true') claims.push({ claim:'Jour férié', value:'Oui', source:'Calendrier' });
        if (a.pressure_ratio != null) claims.push({ claim:'Pression concurrentielle', value:'×' + frDec(Number(a.pressure_ratio).toFixed(1)), source:'Muse Square' });
        if (a.weather_alert != null && Number(a.weather_alert) > 0) claims.push({ claim:'Alerte météo', value:'Niveau ' + Number(a.weather_alert), source:'Muse Square' });
        if (a.events_5km != null && Number(a.events_5km) > 0) claims.push({ claim:'Concurrence à 5 km', value: frInt(a.events_5km) + ' évén.', source:'Muse Square' });
        if (!claims.length) claims.push({ claim:'Signal', value: isDown ? 'CA sous vos jours comparables' : 'CA au-dessus de vos jours comparables', source:'Muse Square' });
        var tier = (window.msSalesConfidence ? window.msSalesConfidence(a) : String(a.confidence_tier || 'possible').toLowerCase());
        var TIER = { possible:{ label:'À confirmer', bg:'#EEF2FF', fg:'#6B7280' }, probable:{ label:'Probable', bg:'#E1F5EE', fg:'#0F6E56' }, confirme:{ label:'Confirmé', bg:'#E1F5EE', fg:'#0F6E56' } };
        var badge = TIER[tier] || TIER.possible;
        var cat = isDown ? 'Performance · CA sous vos jours comparables' : 'Performance · CA au-dessus de vos jours comparables';
        var title = (spec && spec.brand_label_fr) ? spec.brand_label_fr : (isDown ? 'CA sous vos jours comparables' : 'CA au-dessus de vos jours comparables');
        return { cat: cat, title: title, badge: badge, competitor_id:'', competitor_name:'', descriptif_orientation:'', claims: claims, sources:['Caisse — chiffre d’affaires quotidien','Muse Square — attendu conditionnel (résidu)'] };
      }

      CLAIM_MAPS.weather_hazard_onset = weatherClaimMap;
      CLAIM_MAPS.weather_worsened = weatherClaimMap;
      CLAIM_MAPS.weather_improved = weatherClaimMap;
      CLAIM_MAPS.extended_bad_weather_3d = weatherClaimMap;
      CLAIM_MAPS.calendar_audience_shift = calendarClaimMap;
      CLAIM_MAPS.mega_event_activation = megaClaimMap;
      CLAIM_MAPS.mega_event_end = megaClaimMap;
      CLAIM_MAPS.top_day_approaching = topDayClaimMap;
      CLAIM_MAPS.competition_pressure_spike = pressureSpikeClaimMap;
      CLAIM_MAPS.low_competition_window = lowCompClaimMap;
      CLAIM_MAPS.review_solicitation = reviewSolicitationClaimMap;
      CLAIM_MAPS.ft_peak_bad_weather = ftPeakBadWeatherClaimMap;
      CLAIM_MAPS.foreign_tourism_signal = foreignTourismClaimMap;
      CLAIM_MAPS.competitor_positioning_brief = positioningBriefClaimMap;
      CLAIM_MAPS.competitor_positioning_gap = positioningGapClaimMap;
      CLAIM_MAPS.sales_surge = salesResidualClaimMap;
      CLAIM_MAPS.sales_revenue_down_wow = salesResidualClaimMap;

      // Single named-entity competitor cards. Verified live: competitor_event_launch.
      // Add a type here only after its data_payload is verified on
      // semantic.vw_insight_event_action_candidates.
      var SINGLE_ENTITY_TYPES = ['competitor_event_launch', 'competitor_event_ending'];

      function singleEntityClaimMap(a, prof, day) {
        var parts = String(a.new_value || '').split(' \u2014 ');
        var name = parts[0] || a.competitor_name || 'Concurrent';
        var event = parts[1] || '';
        var tier = String(a.entity_threat_industry_tier || '').toLowerCase();
        var lvl = String(a.entity_threat_level || '').toLowerCase();
        var badge = (tier === 'contextual')
          ? { label: 'Contextuel', bg: '#EEF2FF', fg: '#1D3BB3' }
          : (THREAT_FR[lvl] || THREAT_FR.low);
        var distKm = (a.entity_threat_distance_km != null) ? Number(a.entity_threat_distance_km)
                   : (a.distance_m != null ? Number(a.distance_m) / 1000 : null);
        var distStr = (distKm != null) ? frDec((Math.round(distKm * 10) / 10).toFixed(1)) + ' km' : '\u2014';
        // audience_overlap_pct is a whole percent (0-100) in data_payload \u2014 render as-is, NO x100.
        var ov = (a.audience_overlap_pct != null) ? Number(a.audience_overlap_pct) : null;
        var overlapStr = (ov != null && ov > 0) ? Math.round(ov) + ' %' : '0 % \u2014 audiences distinctes';
        var ratingStr = (a.google_rating != null ? '\u2605 ' + frDec(a.google_rating) + ' / 5' : '\u2014')
          + (a.google_rating_count != null ? ' \u00b7 ' + frInt(a.google_rating_count) + ' avis' : '');
        var enr = null;
        try { enr = a.competitor_enriched_description ? (typeof a.competitor_enriched_description === 'string' ? JSON.parse(a.competitor_enriched_description) : a.competitor_enriched_description) : null; } catch(e) { enr = null; }
        var ending = (a.direction === 'ending') || (signal_type === 'competitor_event_ending');
        return {
          cat: ending ? 'Concurrence \u00b7 Fin d\u2019\u00e9v\u00e9nement' : 'Concurrence \u00b7 Lancement',
          title: name,
          badge: badge,
          competitor_id: a.competitor_id || '',
          competitor_name: name,
          descriptif_orientation: (a.competitor_id ? 'Ce que propose ce concurrent \u2014 pour situer le ' + (ending ? 'changement' : 'lancement') : ''),
          enriched_inline: enr,
          claims: [
            { claim: (ending ? 'Fin d\u2019\u00e9v\u00e9nement' : 'Lancement'), value: (event || '\u2014'), source: 'Site concurrent' },
            { claim: '\u00c0 proximit\u00e9', value: distStr, source: 'Muse Square' },
            { claim: 'Chevauchement d\u2019audience', value: overlapStr, source: 'Muse Square' },
            { claim: 'R\u00e9putation', value: ratingStr, source: 'Google' }
          ],
          sources: [
            'Muse Square \u2014 d\u00e9tection de lancement, distance, chevauchement',
            'Google \u2014 note et nombre d\u2019avis'
          ]
        };
      }

      // Aggregate tourism signals (no named entity). Verified payloads:
      // tourism_peak_window {tourism_index,is_peak,score}; tourist_high_season {+events_5km};
      // tourism_comp_squeeze {tourism_index,pressure_ratio,events_5km}. tourism_index rendered
      // as-is (0-100, no x100); payload `score` omitted (0-100 scale, not /10).
      function tourismClaimMap(a, prof, day) {
        var idx = (a.tourism_index != null) ? Math.round(Number(a.tourism_index)) : null;
        var claims = [{ claim:'Indice touristique r\u00e9gional', value: (idx != null ? String(idx) : '\u2014'), source:'Muse Square' }];
        var TS_FR = { high:'Haute', normal:'Normale', low:'Basse' };
        if (a.tourism_status && TS_FR[a.tourism_status]) claims.push({ claim:'Saison', value: TS_FR[a.tourism_status], source:'Muse Square' });
        var cat, title, badge;
        if (signal_type === 'tourism_comp_squeeze') {
          var pr = (a.pressure_ratio != null) ? Number(a.pressure_ratio) : 0;
          cat = 'Tourisme \u00b7 Concurrence';
          title = 'Flux touristique disput\u00e9';
          badge = (pr >= 1.8) ? { label:'Tr\u00e8s disput\u00e9', bg:'#FCEBEB', fg:'#A32D2D' }
                : { label:'Disput\u00e9', bg:'#FAEEDA', fg:'#854F0B' };
          if (a.events_5km != null) claims.push({ claim:'Concurrence \u00e0 5 km', value: frInt(a.events_5km) + ' \u00e9v\u00e9n.', source:'Muse Square' });
          if (a.pressure_ratio != null) claims.push({ claim:'Pression vs moyenne', value: '\u00d7' + frDec(a.pressure_ratio), source:'Muse Square' });
        } else if (signal_type === 'tourist_high_season') {
          cat = 'Tourisme \u00b7 Haute saison';
          title = 'Haute saison touristique';
          badge = { label:'Haute saison', bg:'#E1F5EE', fg:'#0F6E56' };
          if (a.is_peak) claims.push({ claim:'Pic de fr\u00e9quentation', value:'Oui', source:'Muse Square' });
          if (a.events_5km != null) claims.push({ claim:'Concurrence \u00e0 5 km', value: frInt(a.events_5km) + ' \u00e9v\u00e9n.', source:'Muse Square' });
        } else {
          cat = 'Tourisme \u00b7 Pic r\u00e9gional';
          title = 'Pic touristique r\u00e9gional';
          badge = { label:'Opportunit\u00e9', bg:'#E1F5EE', fg:'#0F6E56' };
          if (a.is_peak) claims.push({ claim:'Pic de fr\u00e9quentation', value:'Oui', source:'Muse Square' });
        }
        var sources = ['Muse Square \u2014 indice de fr\u00e9quentation touristique r\u00e9gionale'];
        if (signal_type === 'tourism_comp_squeeze') sources.push('Muse Square \u2014 comptages d\u2019\u00e9v\u00e9nements par rayon');
        return {
          cat: cat, title: title, badge: badge,
          competitor_id: '', competitor_name: '', descriptif_orientation: '',
          claims: claims, sources: sources
        };
      }

      function genericClaimMap(a, prof, day) {
        var spec = window.ACTION_CARDS ? window.ACTION_CARDS[signal_type] : null;
        var cat = (spec && spec.category_label_fr) ? spec.category_label_fr : 'Signal';
        var title = (spec && spec.brand_label_fr) ? spec.brand_label_fr : String(signal_type).replace(/_/g, ' ');
        var SKIP = { signal_type:1, change_subtype:1, direction:1, distance_m:1, radius_bucket:1, industry_code:1, score_driver_label:1, competitor_id:1, score_delta:1, event_label:1 };
        var LABELS = {
          events_500m:'\u00c9v\u00e9nements \u00e0 500 m', events_1km:'\u00c9v\u00e9nements \u00e0 1 km', events_5km:'\u00c9v\u00e9nements \u00e0 5 km', events_10km:'\u00c9v\u00e9nements \u00e0 10 km',
          pressure_ratio:'Pression vs moyenne', pct_same_sector:'M\u00eame secteur', score_driver:'Facteur dominant', score:'Score', regime:'R\u00e9gime', rank:'Rang',
          weather_alert:'Niveau d\u2019alerte m\u00e9t\u00e9o', alert_level:'Niveau d\u2019alerte', today_alert:'Alerte aujourd\u2019hui', yesterday_alert:'Alerte hier',
          tourism_index:'Indice touristique', is_peak:'Pic touristique', is_holiday:'Jour f\u00e9ri\u00e9', is_vacation:'Vacances scolaires', is_commercial:'\u00c9v\u00e9nement commercial', is_weekend:'Week-end',
          site_sensitivity:'Sensibilit\u00e9 m\u00e9t\u00e9o du site', consecutive_bad_days:'Jours d\u00e9grad\u00e9s cons\u00e9cutifs', preceding_bad_days:'Jours d\u00e9grad\u00e9s pr\u00e9c\u00e9dents',
          top_competitor:'Principal concurrent', top_threat_level:'Niveau de menace', top_competitor_distance_km:'Distance', top_competitor_overlap_pct:'Chevauchement d\u2019audience', top_threat_score:'Score de menace',
          mobility_disrupted:'Mobilit\u00e9 perturb\u00e9e', ft_rank:'Rang de fr\u00e9quentation', ft_peak_hour:'Pic habituel', ft_peak_busyness_pct:'Affluence au pic', tourism_status:'Saison', favorable_count:'Facteurs favorables', commercial_event_name:'\u00c9v\u00e9nement commercial',
          old_value:'Avant', new_value:'D\u00e9tect\u00e9'
        };
        var claims = [];
        for (var k in a) {
          if (!a.hasOwnProperty(k) || SKIP[k]) continue;
          var v = a[k];
          if (v == null || v === '' || v === 'Signal d\u00e9tect\u00e9' || v === 'true' || v === 'false') continue;
          if (typeof v === 'object') continue;
          if (typeof v === 'boolean') { if (!v) continue; claims.push({ claim: LABELS[k] || k.replace(/_/g, ' '), value: 'Oui', source: 'Muse Square' }); continue; }
          var val;
          if (/_pct$/.test(k) || k === 'pct_same_sector') { var nv = Number(v); val = (Math.abs(nv) <= 1 ? Math.round(nv * 100) : Math.round(nv)) + ' %'; }
          else if (k === 'pressure_ratio') { val = '\u00d7' + frDec(v); }
          else if (k === 'score') { val = score10(v) + ' / 10'; }
          else if (k === 'ft_peak_hour') { val = Math.round(Number(v)) + 'h'; }
          else if (k === 'tourism_status') { var TS_G = { high:'Haute', normal:'Normale', low:'Basse' }; val = TS_G[v] || String(v); }
          else if (typeof v === 'number') { val = frDec(Math.round(Number(v) * 100) / 100); }
          else { val = String(v); }
          claims.push({ claim: LABELS[k] || k.replace(/_/g, ' '), value: val, source: 'Muse Square' });
        }
        if (!claims.length) claims.push({ claim: 'Signal', value: title, source: 'Muse Square' });
        return { cat: cat, title: title, badge: { label: 'Signal', bg: '#EEF2FF', fg: '#1D3BB3' }, competitor_id: '', competitor_name: '', descriptif_orientation: '', claims: claims, sources: ['Muse Square \u2014 donn\u00e9es quotidiennes'] };
      }

      function renderClaimSkeleton(day, prof, feedItem, actionCandidate, spec, sowhat) {
        var m = (CLAIM_MAPS[signal_type] || (SINGLE_ENTITY_TYPES.indexOf(signal_type) >= 0 ? singleEntityClaimMap : genericClaimMap))(feedItem, prof, day);
        var ctx = '', act = '';
        if (sowhat && typeof sowhat === 'object') { ctx = sowhat.context || ''; act = sowhat.action || ''; }
        else { ctx = String(sowhat || ''); }

        var BR='#1D3BB3', BD='#E8EDF5', INK='#111827', SUB='#6B7280', MUTE='#9CA3AF';
        function zone(kicker, inner, last) {
          return '<div style="padding:18px 0;border-bottom:' + (last ? 'none' : '1px solid ' + BD) + ';">'
            + '<div style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:' + MUTE + ';margin-bottom:12px;">' + esc(kicker) + '</div>'
            + inner + '</div>';
        }

        function grp(label) {
          return '<div style="font-size:12px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:' + BR + ';margin:26px 0 2px;padding-bottom:6px;border-bottom:2px solid ' + BR + ';">' + esc(label) + '</div>';
        }
        var _isMov = (signal_type === 'sales_surge' || signal_type === 'sales_revenue_down_wow');
        var html = '';
        html += '<button class="fs-back" onclick="history.back()">\u2190 Retour</button>';
        html += '<div style="font-size:11px;font-weight:700;letter-spacing:0.10em;text-transform:uppercase;color:' + BR + ';">' + esc(m.cat) + '</div>'
          + '<div style="display:flex;align-items:center;gap:10px;margin:8px 0 4px;flex-wrap:wrap;">'
            + '<h1 style="font-size:21px;font-weight:600;margin:0;line-height:1.2;color:' + INK + ';">' + esc(m.title) + '</h1>'
            + '<span style="font-size:11px;font-weight:600;padding:3px 10px;background:' + m.badge.bg + ';color:' + m.badge.fg + ';">' + esc(m.badge.label) + '</span>'
          + '</div>';

        var synth = '<p id="fs-synth-ctx" style="font-size:15px;line-height:1.55;margin:0 0 10px;color:' + INK + ';">' + esc(ctx) + '</p>';
        if (act) synth += '<p style="font-size:14px;line-height:1.55;margin:0;color:' + BR + ';">' + esc(act) + '</p>';
        if (_isMov) html += grp('La source');
        html += zone('Synth\u00e8se', synth);

        var dec = '<div style="font-size:11px;color:' + MUTE + ';margin-bottom:4px;">Chaque affirmation ci-dessus, et la donn\u00e9e qui la fonde\u00a0:</div>';
        for (var i = 0; i < m.claims.length; i++) {
          var c = m.claims[i];
          dec += '<div style="padding:12px 0;border-bottom:0.5px solid #F3F4F6;">'
            + '<div style="display:flex;align-items:baseline;justify-content:space-between;gap:12px;">'
              + '<div style="font-size:13px;font-weight:600;color:' + INK + ';">' + esc(c.claim) + '</div>'
              + '<span style="font-size:10px;color:' + MUTE + ';white-space:nowrap;flex-shrink:0;">' + esc(c.source) + '</span>'
            + '</div>'
            + '<div style="font-size:14px;color:' + (c.computed ? SUB : INK) + ';margin-top:4px;' + (c.computed ? 'font-family:ui-monospace,monospace;' : '') + '">'
              + (c.computed ? '<span style="color:' + MUTE + ';margin-right:6px;">=</span>' : '') + esc(c.value)
            + '</div>'
          + '</div>';
        }
        html += zone('D\u00e9composition \u00b7 preuve', dec);

        if (m.enriched_inline) {
          var d = m.enriched_inline;
          var drows = [
            d.business_description   ? ['Profil', d.business_description] : null,
            d.current_offering       ? ['Offre actuelle', d.current_offering] : null,
            d.key_differentiators    ? ['Diff\u00e9renciateurs', d.key_differentiators] : null,
            d.event_examples         ? ['\u00c9v\u00e9nements r\u00e9cents', d.event_examples] : null,
            d.brand_positioning      ? ['Positionnement', d.brand_positioning] : null,
            d.partnerships_mentioned ? ['Partenariats', d.partnerships_mentioned] : null,
            d.accessibility_info     ? ['Accessibilit\u00e9', d.accessibility_info] : null
          ].filter(Boolean);
          var desc = m.descriptif_orientation ? '<div style="font-size:12px;color:' + SUB + ';margin-bottom:10px;">' + esc(m.descriptif_orientation) + '</div>' : '';
          desc += '<div style="background:#F9FAFB;border:0.5px solid #E5E7EB;">';
          for (var di = 0; di < drows.length; di++) {
            desc += '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
              + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:3px;">' + esc(drows[di][0]) + '</div>'
              + '<div style="font-size:13px;color:#111827;line-height:1.5;">' + esc(String(drows[di][1])) + '</div>'
            + '</div>';
          }
          desc += '<div style="padding:9px 14px;display:flex;justify-content:space-between;align-items:center;">'
            + '<span style="font-size:10px;letter-spacing:0.07em;text-transform:uppercase;color:#9CA3AF;display:inline-flex;align-items:center;gap:5px;"><span style="width:6px;height:6px;border-radius:50%;background:#059669;display:inline-block;"></span>Agent IA \u00b7 web</span>'
          + '</div></div>';
          html += zone('Descriptif', desc);
        } else if (m.descriptif_orientation) {
          var desc = '<div style="font-size:12px;color:' + SUB + ';margin-bottom:10px;">' + esc(m.descriptif_orientation) + '</div>'
            + '<button type="button" id="fs-desc-btn" style="font-size:12px;font-weight:600;color:' + BR + ';background:none;border:1px solid ' + BR + ';padding:7px 12px;cursor:pointer;font-family:inherit;">En savoir plus \u2192</button>'
            + '<div id="fs-desc-panel" style="display:none;margin-top:10px;"></div>';
          html += zone('Descriptif', desc);
        }

        var src = '<ul style="margin:0;padding-left:18px;font-size:13px;line-height:1.7;color:' + SUB + ';">';
        for (var si = 0; si < m.sources.length; si++) src += '<li>' + esc(m.sources[si]) + '</li>';
        src += '</ul>';
        if (m.competitor_name) {
          var mapsUrl = 'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(m.competitor_name);
          src += '<a href="' + esc(mapsUrl) + '" target="_blank" rel="noopener" class="fs-source" style="margin-top:10px;text-decoration:none;"><span class="fs-source-icon">\ud83d\udccd</span> Voir ' + esc(m.competitor_name) + ' sur Google Maps \u2192</a>';
        }
        // Analog / history layer — movement cards only (async fill post-render).
        var _isMovement = (signal_type === 'sales_surge' || signal_type === 'sales_revenue_down_wow');
        if (_isMovement) {
          html += grp('Contexte & informations liées');
          html += zone('Historique · jours comparables',
            '<div id="fs-analog-zone"><div style="font-size:12px;color:#9CA3AF;padding:4px 0;display:flex;align-items:center;gap:8px;"><span class="fs-loading-spin"></span> Recherche de jours comparables…</div></div>');
          html += zone('Environnement du jour · agent web',
            '<div id="fs-context-zone"><div style="font-size:12px;color:#9CA3AF;padding:4px 0;display:flex;align-items:center;gap:8px;"><span class="fs-loading-spin"></span> Recherche du contexte local…</div></div>');
        }

        html += zone('Sources', src, true);

        root.innerHTML = html;

        if (_isMovement) loadAnalogs(location_id, signal_date, document.getElementById('fs-analog-zone'));
        if (_isMovement) loadContext(feedItem, prof, day, document.getElementById('fs-context-zone'));

        var descBtn = document.getElementById('fs-desc-btn');
        if (descBtn) descBtn.addEventListener('click', function() {
          var panel = document.getElementById('fs-desc-panel');
          if (!panel) return;
          panel.style.display = 'block';
          panel.innerHTML = '<div style="font-size:12px;color:#9CA3AF;padding:8px 0;display:flex;align-items:center;gap:8px;"><span class="fs-loading-spin"></span> Recherche en cours\u2026</div>';
          descBtn.style.display = 'none';
          loadCompetitorDescriptif(m.competitor_id, m.competitor_name, panel, descBtn);
        });

        wireActionBar(root, day, prof, feedItem);
      }

      // Analog / history dossier section. Reads /api/insight/analogs (fct_client_day_analogs).
      // Two honest branches: named comparable days when they exist; "situation nouvelle"
      // when the day's condition configuration has no precedent in the recent history.
      var ANALOG_DOW_FR = { 1:'Dimanche', 2:'Lundi', 3:'Mardi', 4:'Mercredi', 5:'Jeudi', 6:'Vendredi', 7:'Samedi' };
      var ANALOG_WX_FR = { clair:'temps clair', normal:'temps normal', calme:'temps calme', perturbe:'temps perturbé', severe:'temps sévère' };
      var ANALOG_TIER_FR = { exact:'même configuration de conditions', dow_weather:'même jour + même météo', dow:'même jour de semaine' };
      function analogFrInt(n) { try { return Number(n).toLocaleString('fr-FR'); } catch(e) { return String(n); } }
      var ANALOG_MONTH_FR = ['janv.','févr.','mars','avr.','mai','juin','juil.','août','sept.','oct.','nov.','déc.'];
      function analogDateFr(iso) { try { var p = String(iso).split('-'); if (p.length !== 3) return String(iso); return parseInt(p[2], 10) + ' ' + ANALOG_MONTH_FR[parseInt(p[1], 10) - 1]; } catch(e) { return String(iso); } }
      function loadAnalogs(locId, date, container) {
        if (!container) return;
        fetch('/api/insight/analogs?location_id=' + encodeURIComponent(locId) + '&date=' + encodeURIComponent(date))
          .then(function(r) { return r.json(); })
          .then(function(j) {
            if (!j || !j.ok || !j.found || !j.analog) { container.innerHTML = analogEmptyHtml(); return; }
            container.innerHTML = analogHtml(j.analog);
            injectAnalogIntoSynthese(j.analog);
          })
          .catch(function() { container.innerHTML = analogEmptyHtml(); });
      }
      // Make the Synthèse headline explicit once the analog data is in: swap the
      // vague 'de vos jours comparables' for the real number + basis.
      function injectAnalogIntoSynthese(a) {
        try {
          var sc = document.getElementById('fs-synth-ctx');
          if (!sc || !a || a.is_unexplained || !a.analog_n || a.residual_vs_analog_pct == null) return;
          var dayFr = (a.dow != null && ANALOG_DOW_FR[a.dow]) ? ANALOG_DOW_FR[a.dow].toLowerCase() : 'jour';
          var pct = (a.residual_vs_analog_pct >= 0 ? '+' : '') + a.residual_vs_analog_pct + ' %';
          var basis = a.analog_n + ' derniers ' + dayFr + 's comparables' + (a.analog_median_revenue != null ? ' (médian ' + analogFrInt(a.analog_median_revenue) + ' €)' : '');
          sc.innerHTML = sc.innerHTML
            .replace(/(?:nettement )?au-dessus de vos jours comparables/, pct + ' au-dessus de vos ' + basis)
            .replace(/(?:nettement )?sous vos jours comparables/, pct + ' vs vos ' + basis);
        } catch(e) {}
      }
      function analogEmptyHtml() {
        return '<div style="font-size:13px;color:#6B7280;line-height:1.55;">Historique indisponible pour ce jour.</div>';
      }
      function analogHtml(a) {
        var MUTE = '#9CA3AF', INK = '#111827', SUB = '#6B7280';
        var dayFr = (a.dow != null && ANALOG_DOW_FR[a.dow]) ? ANALOG_DOW_FR[a.dow].toLowerCase() : 'jour';
        var wxFr = a.weather_band ? (ANALOG_WX_FR[a.weather_band] || a.weather_band) : '';
        var n = a.analog_n;
        // Basis reflects the ACTUAL match tier — never today's incidental weather.
        var basis;
        if (a.match_tier === 'exact') basis = 'vos ' + n + ' derniers ' + dayFr + 's à conditions identiques';
        else if (a.match_tier === 'dow_weather') basis = 'vos ' + n + ' derniers ' + dayFr + 's' + (wxFr ? ' par ' + wxFr : '');
        else basis = 'vos ' + n + ' derniers ' + dayFr + 's';
        if (a.is_unexplained || !a.analog_n) {
          return '<div style="font-size:14px;font-weight:600;color:' + INK + ';margin-bottom:6px;">Situation nouvelle</div>'
            + '<div style="font-size:13px;color:' + SUB + ';line-height:1.55;">'
            + 'Aucun ' + esc(dayFr) + ' comparable dans votre historique récent. Ce que vous observez aujourd’hui devient la première référence pour ce type de jour — à documenter.'
            + '</div>';
        }
        var head = '<div style="font-size:13px;color:' + INK + ';line-height:1.6;margin-bottom:10px;">'
          + 'Comparé à <strong>' + esc(basis) + '</strong>'
          + (a.analog_median_revenue != null ? ' (CA médian <strong>' + analogFrInt(a.analog_median_revenue) + ' €</strong>)' : '')
          + ' : aujourd’hui <strong>' + (a.daily_revenue != null ? analogFrInt(a.daily_revenue) + ' €' : '—') + '</strong>'
          + (a.residual_vs_analog_pct != null ? ', soit <strong>' + (a.residual_vs_analog_pct >= 0 ? '+' : '') + a.residual_vs_analog_pct + ' %</strong>' : '')
          + '.</div>'
          + '<div style="font-size:11px;color:' + MUTE + ';margin-bottom:2px;">Le détail de ces journées (les plus récentes) :</div>';
        var list = '';
        var arr = Array.isArray(a.analogs) ? a.analogs : [];
        for (var i = 0; i < arr.length && i < 6; i++) {
          var an = arr[i];
          var wx = an.weather_band ? (ANALOG_WX_FR[an.weather_band] || an.weather_band) : '';
          list += '<div style="padding:9px 0;border-bottom:0.5px solid #F3F4F6;display:flex;align-items:baseline;justify-content:space-between;gap:12px;">'
            + '<div style="font-size:13px;color:' + INK + ';">' + esc(analogDateFr(an.date)) + '</div>'
            + '<div style="font-size:13px;color:' + SUB + ';white-space:nowrap;">'
              + (an.revenue != null ? analogFrInt(an.revenue) + ' €' : '—')
              + (wx ? ' · ' + esc(wx) : '')
              + (an.events != null ? ' · ' + an.events + ' évén.' : '')
            + '</div>'
          + '</div>';
        }
        return head + list;
      }

      // Environment crawl (agent web) — /api/insight/enrich-context. Explains the
      // real-world context around the venue that day (events, commercial period, météo).
      function loadContext(a, prof, day, container) {
        if (!container) return;
        var payload = {
          location_id: location_id,
          date: signal_date,
          city_name: (prof && (prof.city_name || prof.location_city)) || (day && day.city_name) || null,
          driver: (a && a.driver != null) ? a.driver : null,
          is_vacation: (a && a.is_vacation != null) ? a.is_vacation : null,
          is_holiday: (a && a.is_holiday != null) ? a.is_holiday : null,
          commercial_event: (a && a.commercial_event_name) ? a.commercial_event_name : null,
          events_5km: (a && a.events_5km != null) ? a.events_5km : null,
          business_short_description: (prof && (prof.business_short_description || prof.company_activity_type)) || null
        };
        fetch('/api/insight/enrich-context', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(payload) })
          .then(function(r) { return r.json(); })
          .then(function(j) {
            if (!j || !j.ok || !j.data) { container.innerHTML = contextEmptyHtml(); return; }
            container.innerHTML = contextHtml(j.data);
          })
          .catch(function() { container.innerHTML = contextEmptyHtml(); });
      }
      function contextEmptyHtml() {
        return '<div style="font-size:13px;color:#6B7280;line-height:1.55;">Aucun contexte particulier trouvé pour cette journée.</div>';
      }
      function contextHost(u) { try { return String(u).replace(/^https?:\/\//, '').split('/')[0]; } catch(e) { return String(u); } }
      function contextHtml(d) {
        var INK = '#111827', SUB = '#6B7280', MUTE = '#9CA3AF';
        if (!d.takeaway && (!d.key_factors || !d.key_factors.length)) return contextEmptyHtml();
        var html = '';
        if (d.takeaway) html += '<div style="font-size:14px;color:' + INK + ';line-height:1.55;margin-bottom:10px;">' + esc(d.takeaway) + '</div>';
        if (d.key_factors && d.key_factors.length) {
          html += '<ul style="margin:0 0 10px;padding-left:18px;font-size:13px;line-height:1.6;color:' + SUB + ';">';
          for (var i = 0; i < d.key_factors.length; i++) html += '<li>' + esc(d.key_factors[i]) + '</li>';
          html += '</ul>';
        }
        if (d.sources && d.sources.length) {
          var links = [];
          for (var s = 0; s < d.sources.length; s++) { var u = String(d.sources[s]); links.push('<a href="' + esc(u) + '" target="_blank" rel="noopener" style="color:#1D3BB3;text-decoration:none;">' + esc(contextHost(u)) + '</a>'); }
          html += '<div style="font-size:11px;color:' + MUTE + ';">Sources : ' + links.join(' · ') + '</div>';
        }
        html += '<div style="font-size:10px;letter-spacing:0.07em;text-transform:uppercase;color:' + MUTE + ';margin-top:8px;display:inline-flex;align-items:center;gap:5px;"><span style="width:6px;height:6px;border-radius:50%;background:#059669;display:inline-block;"></span>Agent IA · web</div>';
        return html;
      }

      function loadCompetitorDescriptif(competitorId, competitorName, panel, btn) {
        fetch('/api/competitive/competitor-signals?location_id=' + encodeURIComponent(location_id))
          .then(function(r) { return r.json(); })
          .then(function(j) {
            var found = null;
            if (j && j.ok) {
              var pools = [].concat(j.followed_competitors || [], j.signals || []);
              for (var i = 0; i < pools.length; i++) {
                if (String(pools[i].competitor_id) === String(competitorId) && pools[i].auto_enriched_description) { found = pools[i]; break; }
              }
            }
            if (found) renderDescriptifFromEnrichment(found, panel);
            else crawlDescriptif(competitorName, panel, btn);
          })
          .catch(function() { crawlDescriptif(competitorName, panel, btn); });
      }

      function renderDescriptifFromEnrichment(comp, panel) {
        var d = {};
        try { d = typeof comp.auto_enriched_description === 'string' ? JSON.parse(comp.auto_enriched_description) : (comp.auto_enriched_description || {}); } catch(e) { d = {}; }
        var rows = [
          d.business_description   ? ['Profil',                d.business_description]   : null,
          d.current_offering       ? ['Offre actuelle',        d.current_offering]       : null,
          d.event_examples         ? ['\u00c9v\u00e9nements r\u00e9cents', d.event_examples] : null,
          d.brand_positioning      ? ['Positionnement',        d.brand_positioning]      : null,
          d.partnerships_mentioned ? ['Partenariats',          d.partnerships_mentioned] : null,
          d.accessibility_info     ? ['Accessibilit\u00e9',     d.accessibility_info]     : null
        ].filter(Boolean);
        var inner = '<div style="background:#F9FAFB;border:0.5px solid #E5E7EB;">';
        for (var i = 0; i < rows.length; i++) {
          inner += '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
            + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:3px;">' + esc(rows[i][0]) + '</div>'
            + '<div style="font-size:13px;color:#111827;line-height:1.5;">' + esc(String(rows[i][1])) + '</div>'
          + '</div>';
        }
        inner += '<div style="padding:9px 14px;display:flex;justify-content:space-between;align-items:center;">'
          + '<span style="font-size:10px;letter-spacing:0.07em;text-transform:uppercase;color:#9CA3AF;display:inline-flex;align-items:center;gap:5px;"><span style="width:6px;height:6px;border-radius:50%;background:#059669;display:inline-block;"></span>Agent IA \u00b7 web</span>'
          + (comp.city ? '<a href="https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent((comp.competitor_name || '') + ' ' + comp.city) + '" target="_blank" rel="noopener" style="font-size:12px;color:#1D3BB3;text-decoration:none;">Localiser \u2192</a>' : '')
        + '</div></div>';
        panel.innerHTML = inner;
      }

      function crawlDescriptif(name, panel, btn) {
        fetch('/api/insight/enrich-event', {
          method:'POST', headers:{ 'content-type':'application/json' },
          body: JSON.stringify({ event_label: name, description:'', city_name:'', event_venue_name:'', event_uid:null, city_id:null, distance_m:null, radius_bucket:null, industry_code:null })
        }).then(function(r) { return r.json(); }).then(function(json) {
          if (!json || !json.ok || !json.data) throw new Error('x');
          var d = json.data;
          var rows = [
            d.business_description ? ['Profil', d.business_description] : null,
            d.current_offering    ? ['Offre',  d.current_offering]    : null,
            d.business_takeaway   ? ['Impact pour votre activit\u00e9', d.business_takeaway] : null
          ].filter(Boolean);
          var inner = '<div style="background:#F9FAFB;border:0.5px solid #E5E7EB;">';
          for (var i = 0; i < rows.length; i++) {
            inner += '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
              + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:3px;">' + esc(rows[i][0]) + '</div>'
              + '<div style="font-size:13px;color:#111827;line-height:1.5;">' + esc(String(rows[i][1])) + '</div>'
            + '</div>';
          }
          inner += '<div style="padding:9px 14px;display:flex;justify-content:space-between;align-items:center;">'
            + '<span style="font-size:10px;letter-spacing:0.07em;text-transform:uppercase;color:#9CA3AF;display:inline-flex;align-items:center;gap:5px;"><span style="width:6px;height:6px;border-radius:50%;background:#059669;display:inline-block;"></span>Agent IA \u00b7 web</span>'
            + (d.source_url ? '<a href="' + esc(d.source_url) + '" target="_blank" rel="noopener" style="font-size:12px;color:#1D3BB3;text-decoration:none;">Source officielle \u2192</a>' : '')
          + '</div></div>';
          panel.innerHTML = inner;
        }).catch(function() {
          panel.innerHTML = '<div style="font-size:12px;color:#B91C1C;padding:4px 0;">Donn\u00e9es non disponibles.</div>';
          if (btn) btn.style.display = '';
        });
      }

      // ── Try sessionStorage first ──
      var cachedData = null;
      try {
        var key = "ms_signal_data_" + location_id + "_" + signal_date;
        var raw = sessionStorage.getItem(key);
        if (raw) cachedData = JSON.parse(raw);
      } catch(e) {}

      if (cachedData && !(isActionType && signal_instance && !cachedData.actionCandidate)) {
        renderPage(cachedData.day, cachedData.prof, cachedData.actionCandidate);
      } else {
        var dates = signal_date || new Date().toISOString().slice(0,10);
        fetch("/api/insight/monitor?location_id=" + encodeURIComponent(location_id) + "&selected_dates=" + encodeURIComponent(dates))
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (!data || !data.ok) throw new Error("Donn\u00e9es indisponibles");
            var day = (data.days || []).find(function(d) {
              var dd = (d.date && d.date.value) ? d.date.value : String(d.date || '');
              return dd.slice(0,10) === signal_date;
            }) || data.days[0] || {};
            var prof = data.profile || {};
            var ac = null;
            if (isActionType && data.action_candidates) {
              if (signal_instance) {
                ac = data.action_candidates.find(function(c) { return String(c.card_instance_id) === String(signal_instance); }) || null;
              }
              if (!ac) ac = data.action_candidates.find(function(c) { return c.action_type === signal_type; }) || null;
            }
            renderPage(day, prof, ac);
          })
          .catch(function(err) {
            loader.innerHTML = '<span style="color:#B91C1C;">Erreur : ' + esc(err.message) + '</span>';
          });
      }

      // ════════════════════════════════════════════════════════════════
      // RENDER PAGE
      // ════════════════════════════════════════════════════════════════

      function renderPage(day, prof, actionCandidate) {
        if (day.opportunity_score != null && day.opportunity_score_final_local == null) day.opportunity_score_final_local = day.opportunity_score;
        if (day.opportunity_medal == null && day.opportunity_regime) day.opportunity_medal = day.opportunity_regime;

        var spec = window.ACTION_CARDS ? window.ACTION_CARDS[signal_type] : null;
        var mode = getMode(signal_type, spec);
        var crawled = parseCrawled(prof);
        var html = '';

        // ── Build feed item for sowhat ──
        // Robust to both candidate shapes: monitor.ts hands data_payload as an
        // object; the Pulse cache (__msCardByIdx) hands a card object with the
        // payload flattened onto it (and no nested data_payload). Flatten a
        // nested payload if present (object or JSON string), then copy any
        // direct fields the candidate already carries.
        var feedItem = {};
        if (actionCandidate) {
          var dp = actionCandidate.data_payload;
          if (typeof dp === 'string') { try { dp = JSON.parse(dp); } catch(e) { dp = null; } }
          if (dp && typeof dp === 'object') { for (var k in dp) { if (dp.hasOwnProperty(k)) feedItem[k] = dp[k]; } }
          for (var ck in actionCandidate) {
            if (actionCandidate.hasOwnProperty(ck) && ck !== 'data_payload' && !feedItem.hasOwnProperty(ck)) {
              feedItem[ck] = actionCandidate[ck];
            }
          }
        }
        feedItem.change_subtype = signal_type;

        // ── Compute sowhat ──
        var sowhat = '';
        if (spec) { try { sowhat = spec.sowhat(feedItem, prof, day, 'signal'); } catch(e) {} }

        // ── NEW: claim -> proof skeleton (curated map, else generic fallback) ──
        if (CLAIM_MAPS[signal_type] || (isActionType && actionCandidate && actionCandidate.data_payload)) {
          renderClaimSkeleton(day, prof, feedItem, actionCandidate, spec, sowhat);
          return;
        }

        // ── Back button ──
        html += '<button class="fs-back" onclick="history.back()">\u2190 Retour</button>';

        // ── Hero — minimal: category + title only ──
        if (spec) {
          var cat = spec.category_label_fr;
          var catClass = CAT_CLASS[cat] || 'cat-intelligence';
          var catColor = CAT_COLOR[cat] || '#1e3a5f';
          // For mobility: dynamic title with transport info
          var heroTitle = spec.brand_label_fr;
          if (mode === 'mobilite' && prof.nearest_transit_stop_name) {
            var tLine = Array.isArray(prof.nearest_transit_line_name) ? prof.nearest_transit_line_name.join(', ') : (prof.nearest_transit_line_name || '');
            heroTitle = 'Perturbation' + (tLine ? ' ligne ' + tLine : '') + ' \u2014 ' + prof.nearest_transit_stop_name;
          }
          html += '<div class="fs-hero ' + catClass + '">'
            + '<div class="fs-hero-cat" style="color:' + catColor + ';">' + esc(spec.icon) + ' ' + esc(cat) + '</div>'
            + '<div class="fs-hero-title">' + esc(heroTitle) + '</div>'
          + '</div>';
        } else if (isGenericTopic) {
          var topicLabels = { weather:'M\u00e9t\u00e9o', competition:'Concurrence', mobility:'Mobilit\u00e9', score:'Score du jour', calendar:'Calendrier' };
          var topicClasses = { weather:'cat-meteo', competition:'cat-concurrence', mobility:'cat-urgent', score:'cat-intelligence', calendar:'cat-intelligence' };
          html += '<div class="fs-hero ' + (topicClasses[signal_type] || 'cat-intelligence') + '">'
            + '<div class="fs-hero-cat" style="color:#1e3a5f;">' + esc(topicLabels[signal_type] || signal_type) + '</div>'
            + '<div class="fs-hero-title">' + esc(topicLabels[signal_type] || signal_type) + ' \u2014 ' + esc(signal_date) + '</div>'
          + '</div>';
        }

        // ════════════════════════════════════════════════════════════
        // MODE: MÉTÉO
        // ════════════════════════════════════════════════════════════
        if (mode === 'meteo') {
          var alertLevel = Number(day.alert_level_max || 0);
          var alertFr = alertLevel >= 3 ? 'critique' : alertLevel >= 2 ? 's\u00e9v\u00e8re' : alertLevel >= 1 ? 'mod\u00e9r\u00e9' : 'faible';
          var alertBg = alertLevel >= 2 ? '#fecaca' : alertLevel >= 1 ? '#fed7aa' : '#e5e7eb';
          var alertCol = alertLevel >= 2 ? '#991b1b' : alertLevel >= 1 ? '#9a3412' : '#6b7280';
          var impactWPct = Number(day.impact_weather_pct || 0);
          var deltaW = Number(day.delta_att_weather_total_pct || day.impact_weather_pct || 0);

          // Weather hero card
          html += '<div class="fs-weather-card">'
            + '<div class="fs-weather-card-top">'
              + '<span class="fs-weather-emoji">' + weatherEmoji(day.weather_code) + '</span>'
              + '<div style="flex:1;">'
                + '<div class="fs-weather-temp">' + (day.temperature_2m_max != null ? Math.round(Number(day.temperature_2m_max)) : '\u2014') + '\u00b0 <span class="fs-weather-temp-lo">/ ' + (day.temperature_2m_min != null ? Math.round(Number(day.temperature_2m_min)) : '\u2014') + '\u00b0</span></div>'
                + '<div class="fs-weather-cond">' + esc(day.weather_label_fr || '') + '</div>'
              + '</div>'
              + '<div class="fs-alert-badge" style="background:' + alertBg + ';color:' + alertCol + ';">Alerte ' + alertFr + '</div>'
            + '</div>'
            + '<div class="fs-weather-card-bottom">'
              + '<div><div class="fs-weather-stat-label">Vent</div><div class="fs-weather-stat-value">' + num(day.wind_speed_10m_max) + ' km/h</div></div>'
              + '<div><div class="fs-weather-stat-label">Pr\u00e9cipitations</div><div class="fs-weather-stat-value">' + (day.precipitation_sum_mm != null ? Number(day.precipitation_sum_mm).toFixed(1) : '\u2014') + ' mm</div></div>'
              + '<div style="margin-left:auto;text-align:right;">'
                + '<div class="fs-weather-stat-label">Impact fr\u00e9quentation</div>'
                + '<div style="font-size:24px;font-weight:700;color:' + (impactWPct < -5 ? '#dc2626' : '#16a34a') + ';margin-top:2px;">' + Math.round(impactWPct) + '%</div>'
              + '</div>'
            + '</div>'
          + '</div>';

          // Impact KPIs
          html += '<div class="fs-section">'
            + '<div class="fs-section-title">Impact sur votre site</div>'
            + '<div class="fs-grid">'
              + '<div class="fs-metric"><div class="fs-metric-label">Sensibilit\u00e9 m\u00e9t\u00e9o</div><div class="fs-metric-value" style="color:' + (Number(prof.weather_sensitivity || 0) >= 3 ? '#dc2626' : '#1a1d2e') + ';">' + (prof.weather_sensitivity || '\u2014') + ' <span class="fs-metric-unit">/5</span></div><div class="fs-metric-sub">' + (Number(prof.weather_sensitivity || 0) >= 3 ? '\u00e9lev\u00e9e' : 'mod\u00e9r\u00e9e') + '</div></div>'
