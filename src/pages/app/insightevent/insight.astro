              + '<div class="fs-metric"><div class="fs-metric-label">\u00c0 1 km</div><div class="fs-metric-value">' + num(day.events_within_1km_count) + '</div><div class="fs-metric-sub">\u00e9v\u00e9nements</div></div>'
