          + '</a>';
        }

        // Mobility source
        if (mode === 'mobilite') {
          html += '<a href="https://ratp.fr" target="_blank" rel="noopener" class="fs-source">'
            + '<span class="fs-source-icon">\ud83d\ude87</span> RATP \u2014 info trafic'
          + '</a>';
        }

        // Mega event source
        if (mode === 'intelligence') {
          var tcSrc = day.top_competitors || [];
          var megaSrc = tcSrc.length > 0 ? (tcSrc[0].e || tcSrc[0]) : null;
          if (megaSrc && megaSrc.event_url && (signal_type === 'mega_event_activation' || signal_type === 'mega_event_end')) {
