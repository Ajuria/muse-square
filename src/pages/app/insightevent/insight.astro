        // Competitor URLs — only for concurrence mode
        if (mode === 'concurrence') {
          var tc3 = day.top_competitors || [];
          for (var si2 = 0; si2 < Math.min(tc3.length, 3); si2++) {
            var sc = tc3[si2].e || tc3[si2];
            if (sc.event_url) {
              html += '<a href="' + esc(sc.event_url) + '" target="_blank" rel="noopener" class="fs-source">'
