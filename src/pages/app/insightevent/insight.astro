                + '<div><div class="fs-disruption-label">Station</div><div class="fs-disruption-val">' + esc(tName) + '</div></div>'
                + '<div><div class="fs-disruption-label">Distance</div><div class="fs-disruption-val">' + (tDist > 0 ? tDist + 'm de votre site' : '\u2014') + '</div></div>'
                + '<div><div class="fs-disruption-label">Impact estim\u00e9</div><div class="fs-disruption-val" style="color:' + (mobImpact < -5 ? '#dc2626' : '#1a1d2e') + ';">' + Math.round(mobImpact) + '%</div></div>'
                + '<div><div class="fs-disruption-label">Source</div><div class="fs-disruption-val">Muse Square</div></div>'
              + '</div>'
            + '</div>'
          + '</div>';

          // Impact KPIs
          html += '<div class="fs-section">'
