                + '</div>' : '')
                + (d.business_takeaway ? '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
                  + '<div style="font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#1D3BB3;margin-bottom:5px;">Impact pour votre activit\u00e9</div>'
