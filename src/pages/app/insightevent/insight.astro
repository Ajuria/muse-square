          return 'Informez votre \u00e9quipe et adaptez votre accueil aux conditions du jour.';
        }
        if (mode === 'concurrence') return 'D\u00e9marquez-vous maintenant \u2014 communiquez votre diff\u00e9renciant avant que votre visibilit\u00e9 ne soit dilu\u00e9e.';
        if (mode === 'opportunite') return 'Publiez maintenant \u2014 c\u2019est le moment o\u00f9 votre message aura le plus d\u2019impact.';
        if (mode === 'mobilite') return 'Communiquez un itin\u00e9raire alternatif \u00e0 vos visiteurs et adaptez votre signal\u00e9tique.';
