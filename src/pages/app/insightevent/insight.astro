            var megaOrg = megaMatchedInTC && megaComp ? (megaComp.organizer_name || '') : '';
            var megaDist = megaMatchedInTC && megaComp ? megaComp.distance_m : null;
            var megaAtt = megaMatchedInTC && megaComp ? megaComp.estimated_attendance : null;
            var megaUrl = megaMatchedInTC && megaComp ? megaComp.event_url : null;
            var megaSearchUrl = 'https://www.google.com/search?q=' + encodeURIComponent(megaDisplayName);
            html += '<div class="fs-section">'
              + '<div class="fs-section-title">\u00c9v\u00e9nement concern\u00e9</div>'
              + '<div class="fs-mega-card">'
                + '<div class="fs-mega-name">' + esc(megaDisplayName) + '</div>'
                + (megaOrg && megaOrg !== megaDisplayName ? '<div class="fs-mega-org">' + esc(megaOrg) + '</div>' : '')
                + '<div class="fs-mega-stats">'
                  + (megaAtt ? '<div><span class="fs-mega-bold">' + Math.round(Number(megaAtt) / 1000) + 'k</span> visiteurs</div>' : '')
                  + (megaDist ? '<div><span class="fs-mega-bold">' + distFmt(megaDist) + '</span> de votre site</div>' : '')
                + '</div>'
                + (megaUrl ? '<a href="' + esc(megaUrl) + '" target="_blank" rel="noopener" class="fs-mega-link">\ud83d\udd17 En savoir plus \u2192</a>' : '<button type="button" data-mega-enrich="' + esc(megaDisplayName) + '" class="fs-mega-link" style="background:none;border:none;cursor:pointer;font-family:inherit;font-size:inherit;color:inherit;padding:0;text-align:left;">\ud83d\udd17 En savoir plus \u2192</button>')
                + '<div data-mega-enrich-panel style="display:none;margin-top:10px;"></div>'
              + '</div>'
            + '</div>';
          }

          // Day KPIs — relevant for intelligence
          html += '<div class="fs-section">'
            + '<div class="fs-section-title">Donn\u00e9es du jour</div>'
            + '<div class="fs-grid">'
              + '<div class="fs-metric"><div class="fs-metric-label">Score</div><div class="fs-metric-value">' + score10(day.opportunity_score_final_local) + ' <span class="fs-metric-unit">/10</span></div></div>'
              + '<div class="fs-metric"><div class="fs-metric-label">R\u00e9gime</div><div class="fs-metric-value">' + esc(day.opportunity_regime || '\u2014') + '</div></div>'
              + '<div class="fs-metric"><div class="fs-metric-label">Facteur</div><div class="fs-metric-value sm">' + esc(day.primary_score_driver_label_fr || '\u2014') + '</div></div>'
              + '<div class="fs-metric"><div class="fs-metric-label">M\u00e9daille</div><div class="fs-metric-value">' + esc(day.opportunity_medal || '\u2014') + '</div></div>'
            + '</div>'
          + '</div>';
        }

        // ════════════════════════════════════════════════════════════
        // MODE: OPPORTUNITÉ
        // ════════════════════════════════════════════════════════════
        if (mode === 'opportunite') {
          var prOpp = Number(day.competition_pressure_ratio || 0);
          var pressureLabel = prOpp < 0.5 ? 'Tr\u00e8s faible' : prOpp < 0.8 ? 'Faible' : prOpp < 1.2 ? 'Normale' : prOpp < 1.5 ? '\u00c9lev\u00e9e' : 'Tr\u00e8s \u00e9lev\u00e9e';
          var pressureColor = prOpp < 0.8 ? '#16a34a' : prOpp < 1.2 ? '#1a1d2e' : '#dc2626';

          html += '<div class="fs-section">'
            + '<div class="fs-section-title">Conditions du jour</div>'
            + '<div class="fs-grid">'
              + '<div class="fs-metric"><div class="fs-metric-label">Score</div><div class="fs-metric-value" style="color:#16a34a;">' + score10(day.opportunity_score_final_local) + ' <span class="fs-metric-unit">/10</span></div></div>'
              + '<div class="fs-metric"><div class="fs-metric-label">Concurrence</div><div class="fs-metric-value sm" style="color:' + pressureColor + ';">' + esc(pressureLabel) + '</div><div class="fs-metric-sub">' + num(day.events_within_5km_count) + ' \u00e9v\u00e9nements \u00e0 5 km</div></div>'
              + '<div class="fs-metric"><div class="fs-metric-label">M\u00e9t\u00e9o</div><div class="fs-metric-value sm" style="color:' + (Number(day.alert_level_max || 0) === 0 ? '#16a34a' : '#92400e') + ';">' + esc(day.weather_label_fr || '\u2014') + '</div><div class="fs-metric-sub">' + (day.temperature_2m_max != null ? Math.round(Number(day.temperature_2m_max)) + '\u00b0C' : '') + '</div></div>'
            + '</div>'
          + '</div>';

          // Calendar context if present
          var calItems = [];
          if (day.holiday_name) calItems.push(day.holiday_name);
          if (day.vacation_name) calItems.push(day.vacation_name);
          if (day.commercial_events && day.commercial_events.length > 0) {
            for (var ei = 0; ei < day.commercial_events.length; ei++) {
              calItems.push(day.commercial_events[ei].event_name || '');
            }
          }
          if (calItems.length > 0) {
            html += '<div class="fs-section">'
              + '<div class="fs-section-title">Contexte calendaire</div>'
              + '<div style="display:flex;flex-wrap:wrap;gap:6px;">';
            for (var cli = 0; cli < calItems.length; cli++) {
              html += '<span style="font-size:12px;padding:6px 12px;background:#f7f8fb;border-radius:8px;color:#374151;font-weight:500;">' + esc(calItems[cli]) + '</span>';
            }
            html += '</div></div>';
          }
        }

        // ════════════════════════════════════════════════════════════
        // MODE: MOBILITÉ
        // ════════════════════════════════════════════════════════════
        if (mode === 'mobilite') {
          var tName = prof.nearest_transit_stop_name || '';
          var tLine2 = Array.isArray(prof.nearest_transit_line_name) ? prof.nearest_transit_line_name.join(', ') : (prof.nearest_transit_line_name || '');
          var tDist = prof.nearest_transit_stop_distance_m ? Math.round(Number(prof.nearest_transit_stop_distance_m)) : 0;
          var mobImpact = Number(day.delta_att_mobility_pct || 0);

          // Disruption card
          html += '<div class="fs-section">'
            + '<div class="fs-section-title">D\u00e9tail de la perturbation</div>'
            + '<div class="fs-disruption-card">'
              + '<div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">'
                + (tLine2 ? '<div class="fs-disruption-line">' + esc(tLine2) + '</div>' : '')
                + '<div>'
