            html += '<a href="/app/insightevent/map?location_id=' + encodeURIComponent(location_id) + '&date=' + encodeURIComponent(signal_date) + '&embed=1" class="fs-map-link">'
              + '\ud83d\uddfa Voir sur la carte \u2192'
            + '</a>';
            html += '</div>';
          }
        }

        // ════════════════════════════════════════════════════════════
        // MODE: INTELLIGENCE
        // ════════════════════════════════════════════════════════════
        if (mode === 'intelligence') {
          // Mega event card if available
          var tcMega = day.top_competitors || [];
          var megaName = (feedItem.new_value && feedItem.new_value !== 'true' && feedItem.new_value !== 'false') ? feedItem.new_value : (day.active_mega_event_name || null);
          var megaComp = null;
          var megaMatchedInTC = false;
          if (megaName && tcMega.length > 0) {
            for (var mi = 0; mi < tcMega.length; mi++) { var me = tcMega[mi].e || tcMega[mi]; if (me.event_label && megaName.indexOf(me.event_label) >= 0) { megaComp = me; megaMatchedInTC = true; break; } }
          }
          if ((signal_type === 'mega_event_activation' || signal_type === 'mega_event_end') && (megaName || megaComp)) {
