            var adjustedPayload = { action_key: "draft", channel: ch, change_subtype: signal_type, signal: feedItem, card_what: signal_type, card_sowhat: "", user_instruction: instruction };
            fetch("/api/insight/generate-action-draft", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(adjustedPayload) })
              .then(function(r) { return r.json(); })
              .then(function(json) { if (!json || !json.ok || !json.draft) throw new Error("Draft vide"); renderWorkspace(ch, json.draft); })
              .catch(function(err) { panel.innerHTML = '<div style="padding:20px 16px;font-size:12px;color:#B91C1C;">Erreur : ' + esc(err?.message || "R\u00e9essayez") + '</div>'; });
          }
          if (adjustBtn) adjustBtn.addEventListener("click", submitAdjust);
          if (adjustInput) adjustInput.addEventListener("keydown", function(e) { if (e.key === "Enter") { e.preventDefault(); submitAdjust(); } });

          var pubBtn = document.getElementById("fs-ws-publish");
          if (pubBtn) pubBtn.addEventListener("click", function() {
            var b = document.getElementById("fs-ws-body"); var t = document.getElementById("fs-ws-title"); var h = document.getElementById("fs-ws-hashtags"); var r = document.getElementById("fs-recip-input");
            pubBtn.textContent = "Publication\u2026"; pubBtn.style.opacity = "0.6"; pubBtn.disabled = true;
            fetch("/api/channels/publish", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ channel: ch, location_id: location_id, title: t ? t.value : "", body: b ? b.value : "", hashtags: h ? h.value : "", recipient: r ? r.value : "", signal_type: signal_type, affected_date: signal_date }) })
              .then(function(res) { return res.json(); }).then(function(json) {
                if (json && json.ok) { pubBtn.textContent = "Publi\u00e9 \u2713"; pubBtn.style.background = "#f0fdf4"; pubBtn.style.color = "#166534"; pubBtn.style.borderColor = "#bbf7d0"; pubBtn.style.opacity = "1"; }
                else { pubBtn.textContent = "Erreur"; pubBtn.style.color = "#B91C1C"; pubBtn.style.opacity = "1"; pubBtn.disabled = false; setTimeout(function() { pubBtn.textContent = "Publier \u2192"; pubBtn.style.color = "#1D3BB3"; pubBtn.style.borderColor = "#1D3BB3"; }, 2500); }
              }).catch(function() { pubBtn.textContent = "Publier \u2192"; pubBtn.style.opacity = "1"; pubBtn.disabled = false; });
          });

          var autoBtn = document.getElementById("fs-ws-automate");
          if (autoBtn) autoBtn.addEventListener("click", function() {
            var ROUTING_MAP = {weather_worsened:'weather',weather_hazard_onset:'weather',weather_improved:'weather',competitor_event_launch:'competition',competitor_audience_conflict:'competition',competition_pressure_spike:'competition',mobility_disruption:'mobility',mobility_disruption_planned:'mobility',score_up:'opportunity',score_down:'opportunity'};
            var sigCat = ROUTING_MAP[signal_type] || 'competition';
            var r = document.getElementById("fs-recip-input");
            autoBtn.disabled = true; autoBtn.textContent = "\u26a1 ...";
            fetch("/api/channels/automation", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ location_id: location_id, signal_category: sigCat, channel: ch, recipient: r ? r.value : "", require_approval: true, frequency: "first_occurrence" }) })
              .then(function(res) { return res.json(); }).then(function(json) {
                if (json && json.ok) { autoBtn.textContent = "\u2713 R\u00e8gle cr\u00e9\u00e9e"; autoBtn.style.background = "#f0fdf4"; autoBtn.style.color = "#166534"; autoBtn.style.borderColor = "#bbf7d0"; }
                else { autoBtn.textContent = "Erreur"; autoBtn.disabled = false; setTimeout(function() { autoBtn.textContent = "\u26a1 Automatiser"; }, 2000); }
              }).catch(function() { autoBtn.textContent = "\u26a1 Automatiser"; autoBtn.disabled = false; });
          });

          if (showRecipient) {
            var recipInput = document.getElementById("fs-recip-input");
            var recipDD = document.getElementById("fs-recip-dd");
            var recipDisplay = document.getElementById("fs-recip-display");
            fetchTeam().then(function(members) {
              var contactField = ch === "email" ? "email" : ch === "slack" ? "slack" : ch === "whatsapp" ? "whatsapp" : null;
              if (!contactField) return;
              var chMembers = members.filter(function(m) { return m.channels_contact && m.channels_contact[contactField]; });
              if (!chMembers.length) return;
              var ROUTING_MAP = {weather_worsened:'weather',weather_hazard_onset:'weather',competitor_event_launch:'competition',competition_pressure_spike:'competition',mobility_disruption:'mobility',score_up:'opportunity',score_down:'opportunity'};
              var sigCat = ROUTING_MAP[signal_type] || '';
              var suggested = sigCat ? chMembers.find(function(m) { var r = m.signal_routing || {}; return r[sigCat] === true || r[sigCat] === 'true'; }) : null;
              if (suggested) {
                recipInput.value = suggested.channels_contact[contactField];
                recipDisplay.textContent = (suggested.first_name || '') + ' ' + (suggested.last_name || '') + ' \u00b7 ' + suggested.channels_contact[contactField];
                recipDisplay.style.display = "block"; recipInput.style.display = "none";
              }
              recipDisplay.addEventListener("click", function() { recipDisplay.style.display = "none"; recipInput.style.display = "block"; recipInput.value = ""; recipInput.focus(); });
              var ddHtml = '';
              if (suggested) {
                ddHtml += '<div data-fs-pick="' + esc(suggested.channels_contact[contactField]) + '" data-fs-pick-name="' + esc((suggested.first_name||'') + ' ' + (suggested.last_name||'')) + '" style="padding:10px 12px;cursor:pointer;background:#F5F7FF;border-bottom:1px solid #f3f4f6;"><div style="display:flex;align-items:center;justify-content:space-between;"><div><span style="font-size:13px;font-weight:600;color:#111827;">' + esc((suggested.first_name||'') + ' ' + (suggested.last_name||'')) + '</span><span style="font-size:11px;color:#9ca3af;margin-left:6px;">' + esc(suggested.role||'') + '</span></div><span style="font-size:9px;font-weight:700;padding:2px 6px;border-radius:3px;background:#DCFCE7;color:#166534;">Sugg\u00e9r\u00e9</span></div><div style="font-size:11px;color:#6b7280;margin-top:2px;">' + esc(suggested.channels_contact[contactField]) + '</div></div>';
              }
              chMembers.filter(function(m) { return !suggested || m.member_id !== suggested.member_id; }).forEach(function(m) {
                ddHtml += '<div data-fs-pick="' + esc(m.channels_contact[contactField]) + '" data-fs-pick-name="' + esc((m.first_name||'') + ' ' + (m.last_name||'')) + '" style="padding:10px 12px;cursor:pointer;"><span style="font-size:13px;font-weight:500;color:#111827;">' + esc((m.first_name||'') + ' ' + (m.last_name||'')) + '</span><span style="font-size:11px;color:#9ca3af;margin-left:6px;">' + esc(m.role||'') + '</span><div style="font-size:11px;color:#6b7280;margin-top:1px;">' + esc(m.channels_contact[contactField]) + '</div></div>';
              });
              ddHtml += '<div style="padding:8px 12px;border-top:1px solid #f3f4f6;font-size:11px;color:#9ca3af;">Ou saisissez directement</div>';
              recipDD.innerHTML = ddHtml;
              recipInput.addEventListener("focus", function() { recipDD.style.display = "block"; });
              recipDD.querySelectorAll("[data-fs-pick]").forEach(function(opt) {
                opt.addEventListener("click", function() {
                  recipInput.value = opt.getAttribute("data-fs-pick");
                  recipDisplay.textContent = opt.getAttribute("data-fs-pick-name") + ' \u00b7 ' + opt.getAttribute("data-fs-pick");
                  recipDisplay.style.display = "block"; recipInput.style.display = "none"; recipDD.style.display = "none";
                });
              });
              document.addEventListener("click", function(e) { if (!recipInput.contains(e.target) && !recipDD.contains(e.target) && !recipDisplay.contains(e.target)) recipDD.style.display = "none"; });
            });
          }
        }
      }
    })();
    </script>
    <PiloterBottomBar />
  </BaseLayout>
</Show>