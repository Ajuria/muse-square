---
/**
 * Competitor Strategic Profile Page
 * URL: /app/insightevent/competitor?id=COMPETITOR_ID
 *
 * Standalone page — does NOT load data in pulse.
 * All data fetched client-side via /api/competitive/competitor-profile
 */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { Show } from "@clerk/astro/components";
import PiloterBottomBar from "../../../components/PiloterBottomBar.astro";
export const prerender = false;

const location_id =
  (Astro.locals &&
    typeof (Astro.locals as any).location_id === "string" &&
    (Astro.locals as any).location_id.trim())
    ? (Astro.locals as any).location_id.trim()
    : null;

if (!location_id) {
  return Astro.redirect("/app/insightevent/pulse");
}
---

<BaseLayout title="Profil concurrent — Muse Square" hideSurveyCta={true} hideFooter={true}>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.44.0/dist/tabler-icons.min.css" crossorigin="anonymous" />
  <div id="cp-root" style="max-width:680px;margin:0 auto;padding:16px 12px 140px;">
    <div id="cp-loading" style="text-align:center;padding:80px 0;color:#888;font-size:14px;">Chargement du profil\u2026</div>
    <div id="cp-content" style="display:none;"></div>
    <div id="cp-error" style="display:none;text-align:center;padding:80px 0;color:#c00;font-size:14px;"></div>
  </div>
  <PiloterBottomBar active="veille" />
</BaseLayout>

  <script is:inline define:vars={{ location_id }}>
    // @ts-nocheck
    (function() {
      var params = new URLSearchParams(window.location.search);
      var competitorId = (params.get("id") || "").trim();
      if (!competitorId) {
        document.getElementById("cp-loading").style.display = "none";
        document.getElementById("cp-error").style.display = "block";
        document.getElementById("cp-error").textContent = "Identifiant concurrent manquant.";
        return;
      }

      fetch("/api/competitive/competitor-profile?id=" + encodeURIComponent(competitorId))
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (!d.ok) {
            document.getElementById("cp-loading").style.display = "none";
            document.getElementById("cp-error").style.display = "block";
            document.getElementById("cp-error").textContent = d.error || "Erreur inconnue";
            return;
          }
          document.getElementById("cp-loading").style.display = "none";
          document.getElementById("cp-content").style.display = "block";
          renderProfile(d);
        })
        .catch(function(e) {
          document.getElementById("cp-loading").style.display = "none";
          document.getElementById("cp-error").style.display = "block";
          document.getElementById("cp-error").textContent = e.message || "Erreur r\u00e9seau";
        });

      function esc(s) {
        if (!s) return "";
        var d = document.createElement("div");
        d.textContent = String(s);
        return d.innerHTML;
      }

      function timeAgo(dateStr) {
        if (!dateStr) return "";
        var diff = Date.now() - new Date(dateStr).getTime();
        var days = Math.floor(diff / 86400000);
        if (days < 1) return "aujourd\u0027hui";
        if (days === 1) return "il y a 1j";
        if (days < 7) return "il y a " + days + "j";
        var weeks = Math.floor(days / 7);
        if (weeks < 5) return "il y a " + weeks + " sem.";
        var months = Math.floor(days / 30);
        return "il y a " + months + " mois";
      }

      function threatColor(level) {
        if (level === "critical") return "#A32D2D";
        if (level === "high") return "#D85A30";
        if (level === "medium") return "#BA7517";
        return "#5F5E5A";
      }

      function renderProfile(d) {
        var dir = d.directory;
        var thr = d.threat;
        var usr = d.user;
        var analysis = d.analysis;
        var alerts = d.alerts || [];
        var events = d.events || [];
        var enriched = dir.enriched;
        var userEnriched = usr ? usr.enriched : null;

        var initials = (dir.competitor_name || "??").split(" ").map(function(w) { return w[0]; }).join("").substring(0, 2).toUpperCase();
        var distLabel = thr && thr.distance_km != null ? (thr.distance_km < 1 ? Math.round(thr.distance_km * 1000) + " m" : thr.distance_km.toFixed(1) + " km") : "";
        var industryLabel = dir.industry_code ? dir.industry_code.replace(/_/g, " ") : "";
        var subtitle = [distLabel, industryLabel, dir.city].filter(Boolean).join(" \u00b7 ");

        var threatScore = thr ? (thr.threat_score * 10).toFixed(1) : "\u2014";
        var overlapPct = thr && thr.audience_overlap_pct != null ? Math.round(thr.audience_overlap_pct) + "%" : "\u2014";
        var gRating = dir.google_rating != null ? Number(dir.google_rating).toFixed(1) : "\u2014";
        var gCount = dir.google_rating_count != null ? (dir.google_rating_count >= 1000 ? (dir.google_rating_count / 1000).toFixed(1) + "k" : String(dir.google_rating_count)) : "\u2014";

        var verdict = analysis ? analysis.verdict : (enriched ? "Analyse en cours\u2026" : "Enrichissement non disponible \u2014 ajoutez une URL source pour activer l\u0027analyse.");
        var tColor = thr ? threatColor(thr.threat_level) : "#5F5E5A";

        var html = "";

        // ── Back ──
        html += '<div style="margin-bottom:16px;">';
        html += '<a href="/app/insightevent/pulse" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;color:#5F5E5A;text-decoration:none;padding:6px 12px;border:0.5px solid rgba(0,0,0,0.12);border-radius:8px;">';
        html += '<i class="ti ti-arrow-left" style="font-size:14px"></i> Retour au radar</a></div>';

        // ── Summary card ──
        html += '<div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:20px;margin-bottom:16px;">';
        html += '<div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">';
        html += '<div style="width:44px;height:44px;border-radius:10px;background:#534AB7;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:500;font-size:15px;">' + esc(initials) + '</div>';
        html += '<div style="flex:1;min-width:0;">';
        html += '<div style="font-size:16px;font-weight:500;color:#111;">' + esc(dir.competitor_name) + '</div>';
        html += '<div style="font-size:12px;color:#888;">' + esc(subtitle) + '</div>';
        html += '</div>';
        html += '<i class="ti ti-dots" style="font-size:18px;color:#bbb;cursor:pointer;"></i>';
        html += '</div>';

        // KPIs
        html += '<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:16px;">';
        var kpis = [
          { val: threatScore, label: "MENACE", color: tColor },
          { val: overlapPct, label: "OVERLAP", color: "#534AB7" },
          { val: gRating, label: "NOTE GOOGLE", color: "#111" },
          { val: gCount, label: "AVIS", color: "#111" }
        ];
        for (var k = 0; k < kpis.length; k++) {
          html += '<div style="text-align:center;padding:12px 4px;background:#F8F8F6;border-radius:8px;">';
          html += '<div style="font-size:22px;font-weight:500;color:' + kpis[k].color + ';">' + kpis[k].val + '</div>';
          html += '<div style="font-size:10px;font-weight:500;color:#888;letter-spacing:0.5px;margin-top:2px;">' + kpis[k].label + '</div>';
          html += '</div>';
        }
        html += '</div>';

        // Verdict
        html += '<div style="border-left:3px solid ' + tColor + ';padding:10px 14px;background:#F8F8F6;border-radius:0;font-size:13px;color:#333;line-height:1.6;">';
        html += esc(verdict);
        html += '</div>';
        html += '</div>';

        // ── Tabs ──
        html += '<div style="display:flex;gap:8px;margin-bottom:20px;">';
        html += '<button class="cp-tab" data-tab="profil" style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;background:#111;color:#fff;border:none;font-size:13px;font-weight:500;cursor:pointer;font-family:inherit;"><i class="ti ti-layout-grid" style="font-size:14px"></i> Profil</button>';
        html += '<button class="cp-tab" data-tab="actus" style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;background:#fff;color:#111;border:0.5px solid rgba(0,0,0,0.12);font-size:13px;font-weight:500;cursor:pointer;font-family:inherit;"><i class="ti ti-activity" style="font-size:14px"></i> Actualit\u00e9s</button>';
        html += '</div>';

        // ── Tab: Profil ──
        html += '<div id="cp-tab-profil">';
        html += renderProfilTab(dir, enriched, usr, userEnriched, analysis);
        html += '</div>';

        // ── Tab: Actualités ──
        html += '<div id="cp-tab-actus" style="display:none;">';
        html += renderActusTab(alerts, events);
        html += '</div>';

        // ── Footer ──
        html += '<div style="text-align:center;font-size:11px;color:#aaa;margin-top:24px;">';
        html += '<i class="ti ti-circle-filled" style="font-size:6px;vertical-align:middle;color:#1D9E75;margin-right:4px;"></i>';
        html += 'Agent IA \u00b7 crawl web + Google Business \u00b7 mis \u00e0 jour ' + timeAgo(dir.updated_at || dir.created_at);
        html += '</div>';

        // ── Sticky bar ──
        html += '<div style="position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:0.5px solid rgba(0,0,0,0.1);padding:12px 16px;display:flex;gap:12px;justify-content:center;z-index:100;">';
        html += '<button onclick="window.location.href=\'/app/insightevent/pulse\'" style="flex:1;max-width:320px;padding:12px;border:0.5px solid rgba(0,0,0,0.12);border-radius:12px;background:#fff;font-size:14px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;font-family:inherit;color:#111;"><i class="ti ti-pencil" style="font-size:16px"></i> Communiquer</button>';
        html += '<button onclick="window.location.href=\'/app/insightevent/suivis\'" style="flex:1;max-width:320px;padding:12px;border:0.5px solid rgba(0,0,0,0.12);border-radius:12px;background:#fff;font-size:14px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;font-family:inherit;color:#111;"><i class="ti ti-settings" style="font-size:16px"></i> G\u00e9rer</button>';
        html += '</div>';

        document.getElementById("cp-content").innerHTML = html;

        // Tab switching
        document.querySelectorAll(".cp-tab").forEach(function(btn) {
          btn.addEventListener("click", function() {
            document.querySelectorAll(".cp-tab").forEach(function(b) {
              b.style.background = "#fff";
              b.style.color = "#111";
              b.style.border = "0.5px solid rgba(0,0,0,0.12)";
            });
            btn.style.background = "#111";
            btn.style.color = "#fff";
            btn.style.border = "none";
            var tab = btn.getAttribute("data-tab");
            document.getElementById("cp-tab-profil").style.display = tab === "profil" ? "block" : "none";
            document.getElementById("cp-tab-actus").style.display = tab === "actus" ? "block" : "none";
          });
        });

        // Parity toggle
        var parityToggle = document.getElementById("cp-parity-toggle");
        var parityContent = document.getElementById("cp-parity-content");
        if (parityToggle && parityContent) {
          parityToggle.addEventListener("click", function() {
            var visible = parityContent.style.display !== "none";
            parityContent.style.display = visible ? "none" : "block";
            var arrow = parityToggle.querySelector(".cp-parity-arrow");
            if (arrow) arrow.className = visible ? "ti ti-chevron-right cp-parity-arrow" : "ti ti-chevron-down cp-parity-arrow";
          });
        }
      }

      function renderProfilTab(dir, enriched, usr, userEnriched, analysis) {
        var html = "";
        var compName = dir.competitor_name || "Concurrent";
        var userName = (usr && usr.site_name) ? usr.site_name : "Votre site";

        // ── Positionnement & offre ──
        html += '<div style="font-size:11px;font-weight:500;color:#888;letter-spacing:1px;margin-bottom:12px;">POSITIONNEMENT & OFFRE</div>';

        html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">';

        // Competitor column
        html += '<div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-top:3px solid #A32D2D;border-radius:12px;padding:16px;">';
        html += '<div style="font-size:11px;font-weight:500;color:#A32D2D;letter-spacing:0.5px;margin-bottom:10px;">' + esc(compName).toUpperCase() + '</div>';
        if (analysis && analysis.positioning_theirs) {
          html += '<div style="font-size:12px;color:#888;margin-bottom:8px;">' + esc(analysis.positioning_theirs) + '</div>';
        }
        if (enriched && enriched.business_description) {
          html += '<div style="font-size:12px;color:#333;line-height:1.6;margin-bottom:12px;">' + esc(enriched.business_description) + '</div>';
        } else if (dir.description) {
          html += '<div style="font-size:12px;color:#333;line-height:1.6;margin-bottom:12px;">' + esc(dir.description) + '</div>';
        }
        var compAud = [];
        if (enriched && enriched.target_audience) {
          compAud = enriched.target_audience.split(",").map(function(s) { return s.trim(); }).filter(Boolean).slice(0, 4);
        } else {
          if (dir.primary_audience) compAud.push(dir.primary_audience);
          if (dir.secondary_audience) compAud.push(dir.secondary_audience);
        }
        if (compAud.length) {
          html += '<div style="display:flex;flex-wrap:wrap;gap:4px;">';
          for (var a = 0; a < compAud.length; a++) {
            html += '<span style="font-size:11px;padding:2px 8px;border-radius:20px;background:#F1EFE8;color:#444;font-weight:500;">' + esc(compAud[a]) + '</span>';
          }
          html += '</div>';
        }
        html += '</div>';

        // User column
        html += '<div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-top:3px solid #185FA5;border-radius:12px;padding:16px;">';
        html += '<div style="font-size:11px;font-weight:500;color:#185FA5;letter-spacing:0.5px;margin-bottom:10px;">' + esc(userName).toUpperCase() + '</div>';
        if (analysis && analysis.positioning_yours) {
          html += '<div style="font-size:12px;color:#888;margin-bottom:8px;">' + esc(analysis.positioning_yours) + '</div>';
        }
        if (userEnriched && userEnriched.business_description) {
          html += '<div style="font-size:12px;color:#333;line-height:1.6;margin-bottom:12px;">' + esc(userEnriched.business_description) + '</div>';
        } else if (usr) {
          html += '<div style="font-size:12px;color:#333;line-height:1.6;margin-bottom:12px;">' + esc(usr.company_activity_type || "") + '</div>';
        }
        var usrAud = [];
        if (userEnriched && userEnriched.target_audience) {
          usrAud = userEnriched.target_audience.split(",").map(function(s) { return s.trim(); }).filter(Boolean).slice(0, 4);
        } else if (usr) {
          if (usr.primary_audience_1) usrAud.push(usr.primary_audience_1);
          if (usr.primary_audience_2) usrAud.push(usr.primary_audience_2);
        }
        if (usrAud.length) {
          html += '<div style="display:flex;flex-wrap:wrap;gap:4px;">';
          for (var u = 0; u < usrAud.length; u++) {
            html += '<span style="font-size:11px;padding:2px 8px;border-radius:20px;background:#E6F1FB;color:#185FA5;font-weight:500;">' + esc(usrAud[u]) + '</span>';
          }
          html += '</div>';
        }
        html += '</div>';
        html += '</div>';

        // Badges
        if (analysis) {
          html += '<div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:24px;">';
          if (analysis.segment_overlap) {
            html += '<span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;padding:4px 10px;border-radius:20px;background:#FCEBEB;color:#791F1F;font-weight:500;"><i class="ti ti-alert-triangle" style="font-size:12px"></i> ' + esc(analysis.segment_overlap).substring(0, 80) + '</span>';
          }
          if (analysis.product_complements && analysis.product_complements.length) {
            html += '<span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;padding:4px 10px;border-radius:20px;background:#EAF3DE;color:#27500A;font-weight:500;"><i class="ti ti-check" style="font-size:12px"></i> Produits compl\u00e9mentaires</span>';
          }
          html += '</div>';
        }

        // ── Produits & prix ──
        html += '<div style="font-size:11px;font-weight:500;color:#888;letter-spacing:1px;margin-bottom:12px;">PRODUITS & PRIX</div>';

        // Competitor products
        html += '<div style="font-size:11px;font-weight:500;color:#A32D2D;letter-spacing:0.5px;margin-bottom:8px;">' + esc(compName).toUpperCase() + '</div>';
        html += renderProductList(enriched ? enriched.current_offering : null, enriched ? enriched.pricing_info : null);

        // User products
        if (userEnriched && userEnriched.current_offering) {
          html += '<div style="font-size:11px;font-weight:500;color:#185FA5;letter-spacing:0.5px;margin:16px 0 8px;">' + esc(userName).toUpperCase() + '</div>';
          html += renderProductList(userEnriched.current_offering, userEnriched ? userEnriched.pricing_info : null);
        }

        // Product gaps
        if (analysis && analysis.product_gaps && analysis.product_gaps.length) {
          html += '<div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:12px;margin-bottom:24px;">';
          for (var g = 0; g < analysis.product_gaps.length; g++) {
            html += '<span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;padding:4px 10px;border-radius:20px;background:#FCEBEB;color:#791F1F;font-weight:500;"><i class="ti ti-circle" style="font-size:10px"></i> ' + esc(analysis.product_gaps[g]) + '</span>';
          }
          html += '</div>';
        } else {
          html += '<div style="margin-bottom:24px;"></div>';
        }

        // ── Points de parit\u00e9 ──
        html += '<div id="cp-parity-toggle" style="display:flex;align-items:center;justify-content:space-between;padding:12px 14px;background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;cursor:pointer;user-select:none;margin-bottom:8px;">';
        html += '<span style="font-size:13px;color:#555;"><i class="ti ti-list" style="font-size:14px;margin-right:6px;"></i>Points de parit\u00e9 \u2014 table stakes</span>';
        html += '<i class="ti ti-chevron-right cp-parity-arrow" style="font-size:14px;color:#888;"></i>';
        html += '</div>';
        html += '<div id="cp-parity-content" style="display:none;">';
        if (analysis && analysis.parity_theirs && analysis.parity_theirs.length) {
          html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">';
          for (var p = 0; p < analysis.parity_theirs.length; p++) {
            html += '<div style="font-size:12px;color:#333;padding:8px 10px;background:#F8F8F6;border-radius:8px;"><i class="ti ti-check" style="font-size:12px;color:#1D9E75;margin-right:4px;"></i>' + esc(analysis.parity_theirs[p]) + '</div>';
          }
          html += '</div>';
          if (analysis.parity_gaps && analysis.parity_gaps.length) {
            for (var pg = 0; pg < analysis.parity_gaps.length; pg++) {
              html += '<div style="font-size:12px;color:#791F1F;padding:8px 10px;background:#FCEBEB;border-radius:8px;margin-bottom:4px;"><i class="ti ti-x" style="font-size:12px;margin-right:4px;"></i>' + esc(analysis.parity_gaps[pg]) + '</div>';
            }
          }
        } else {
          html += '<div style="font-size:12px;color:#aaa;font-style:italic;padding:8px;">Donn\u00e9es insuffisantes pour l\u0027analyse de parit\u00e9</div>';
        }
        html += '</div>';

        return html;
      }

      function renderProductList(offeringText, pricingText) {
        if (!offeringText) {
          return '<div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:14px;margin-bottom:12px;font-size:12px;color:#aaa;font-style:italic;">Aucune donn\u00e9e produit disponible</div>';
        }
        // Split on sentence boundaries for cleaner rows
        var items = offeringText
          .replace(/\n/g, ". ")
          .split(/(?<=\))\s*,\s*|(?<=[a-z\u00e9\u00e8\u00ea])\s*,\s+(?=[A-Z])|\.(?:\s|$)/)
          .map(function(s) { return s.trim(); })
          .filter(function(s) { return s.length > 3; });
        if (items.length === 0) items = [offeringText];

        var html = '<div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;overflow:hidden;margin-bottom:12px;">';
        var max = Math.min(items.length, 8);
        for (var i = 0; i < max; i++) {
          var item = items[i];
          var isLast = i === max - 1;
          var borderBottom = isLast ? "" : "border-bottom:0.5px solid rgba(0,0,0,0.06);";

          // Detect tags
          var isNew = /\b(nouveau|lanc|nouvelle|ouvert)/i.test(item);
          var isPromo = /\b(gratuit|promo|offre|r\u00e9duction|\-\d+%|0\s*\u20ac)/i.test(item);

          html += '<div style="display:flex;justify-content:space-between;align-items:baseline;padding:10px 14px;' + borderBottom + '">';
          html += '<div style="flex:1;min-width:0;">';
          html += '<div style="font-size:13px;font-weight:500;color:#111;">';
          if (isNew) html += '<span style="font-size:10px;font-weight:500;padding:2px 6px;border-radius:4px;background:#FCEBEB;color:#791F1F;margin-right:6px;">Nouveau</span>';
          if (isPromo) html += '<span style="font-size:10px;font-weight:500;padding:2px 6px;border-radius:4px;background:#EAF3DE;color:#27500A;margin-right:6px;">Promo</span>';
          html += esc(item);
          html += '</div></div></div>';
        }
        html += '</div>';
        return html;
      }

      function renderActusTab(alerts, events) {
        var html = "";

        // ── Alerts ──
        html += '<div style="font-size:11px;font-weight:500;color:#888;letter-spacing:1px;margin-bottom:12px;">ALERTES</div>';
        if (alerts.length === 0) {
          html += '<div style="font-size:12px;color:#aaa;font-style:italic;margin-bottom:24px;">Aucune alerte pour ce concurrent</div>';
        } else {
          var alertStyles = {
            critical: { bg: "#FCEBEB", border: "#A32D2D", title: "#791F1F", text: "#A32D2D" },
            high:     { bg: "#FCEBEB", border: "#A32D2D", title: "#791F1F", text: "#A32D2D" },
            medium:   { bg: "#FAEEDA", border: "#854F0B", title: "#633806", text: "#854F0B" },
            low:      { bg: "#EAF3DE", border: "#3B6D11", title: "#27500A", text: "#3B6D11" },
            info:     { bg: "#E6F1FB", border: "#185FA5", title: "#0C447C", text: "#185FA5" }
          };
          for (var a = 0; a < alerts.length; a++) {
            var al = alerts[a];
            var st = alertStyles[al.alert_level] || alertStyles.info;
            html += '<div style="background:' + st.bg + ';border-left:3px solid ' + st.border + ';border-radius:0;padding:12px 14px;margin-bottom:8px;">';
            html += '<div style="font-size:13px;font-weight:500;color:' + st.title + ';">' + esc(al.change_subtype || al.change_category || "Alerte") + '</div>';
            if (al.event_label) {
              html += '<div style="font-size:12px;color:' + st.text + ';margin-top:4px;line-height:1.5;">' + esc(al.event_label) + '</div>';
            }
            if (al.old_value || al.new_value) {
              html += '<div style="font-size:11px;color:' + st.text + ';opacity:0.7;margin-top:4px;">' + esc(al.old_value || "") + ' \u2192 ' + esc(al.new_value || "") + '</div>';
            }
            // CTA
            var ctaLabel = "Voir le d\u00e9tail";
            var ctaIcon = "ti-eye";
            if (al.change_category === "promo" || al.change_subtype === "promo_changed") { ctaLabel = "Cr\u00e9er une contre-offre"; ctaIcon = "ti-pencil"; }
            else if (al.change_category === "event" || al.change_subtype === "new_event") { ctaLabel = "Capter le trafic visiteurs"; ctaIcon = "ti-broadcast"; }
            else if (al.change_subtype === "hours_changed") { ctaLabel = "Offre sp\u00e9ciale"; ctaIcon = "ti-calendar-event"; }
            html += '<div style="margin-top:8px;"><span style="display:inline-flex;align-items:center;gap:4px;font-size:12px;padding:6px 12px;border-radius:8px;border:0.5px solid rgba(0,0,0,0.15);background:#fff;color:#111;font-weight:500;cursor:pointer;">';
            html += '<i class="ti ' + ctaIcon + '" style="font-size:13px"></i> ' + ctaLabel + '</span></div>';
            html += '<div style="font-size:10px;color:' + st.text + ';opacity:0.5;margin-top:6px;">' + timeAgo(al.created_at) + '</div>';
            html += '</div>';
          }
          html += '<div style="margin-bottom:24px;"></div>';
        }

        // ── Timeline ──
        html += '<div style="font-size:11px;font-weight:500;color:#888;letter-spacing:1px;margin-bottom:12px;">MOUVEMENTS R\u00c9CENTS</div>';
        if (events.length === 0) {
          html += '<div style="font-size:12px;color:#aaa;font-style:italic;">Aucun \u00e9v\u00e9nement d\u00e9tect\u00e9</div>';
        } else {
          for (var e = 0; e < events.length; e++) {
            var ev = events[e];
            var dotColor = ev.is_launch ? "#A32D2D" : ev.is_active ? "#185FA5" : ev.is_upcoming ? "#1D9E75" : "#B4B2A9";
            var isLast = e === events.length - 1;
            html += '<div style="display:flex;align-items:flex-start;gap:10px;padding:8px 0;' + (isLast ? "" : "border-bottom:0.5px solid rgba(0,0,0,0.06);") + '">';
            html += '<div style="width:8px;height:8px;border-radius:50%;background:' + dotColor + ';margin-top:5px;flex-shrink:0;"></div>';
            html += '<div style="flex:1;min-width:0;">';
            html += '<div style="font-size:13px;color:#111;font-weight:500;">';
            if (ev.is_launch) html += '<span style="font-size:10px;font-weight:500;color:#A32D2D;margin-right:4px;">Nouveau</span>';
            html += esc(ev.event_name);
            html += '</div>';
            var dateParts = [];
            if (ev.event_date) dateParts.push(ev.event_date);
            if (ev.event_date_end && ev.event_date_end !== ev.event_date) dateParts[0] += " \u2013 " + ev.event_date_end;
            if (ev.event_type) dateParts.push(ev.event_type);
            if (ev.venue_name) dateParts.push(ev.venue_name);
            if (dateParts.length) {
              html += '<div style="font-size:11px;color:#888;margin-top:2px;">' + esc(dateParts.join(" \u00b7 ")) + '</div>';
            }
            html += '</div></div>';
          }
        }

        // Surveillance status
        html += '<div style="text-align:center;font-size:11px;color:#aaa;margin-top:16px;">';
        html += '<i class="ti ti-circle-filled" style="font-size:6px;vertical-align:middle;color:#1D9E75;margin-right:4px;"></i>';
        html += 'Surveillance active \u00b7 crawl 15 min \u00b7 enrichissement quotidien';
        html += '</div>';

        return html;
      }
    })();
  </script>
</body>
</html>