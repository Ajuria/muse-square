  // ----------------------------------------------------------------
  // V4 NEW — Change detail (strip 3 expanded)
  // ----------------------------------------------------------------
  function renderChangeDetail(day, topThreats) {
    const count500 = Number(day.events_within_500m_count || 0);
    const count5km = Number(day.events_within_5km_count || 0);
    const pressureRatio = Number(day.competition_pressure_ratio || 0);
    const hasBaseline = Boolean(day.has_valid_baseline_flag);

    let pressureLabel = "";
    let pressureBg = "#f3f4f6";
    let pressureFg = "#374151";
    if (hasBaseline && pressureRatio > 1.2) {
      pressureLabel = "Sup\u00e9rieur \u00e0 la moyenne";
      pressureBg = "#fee2e2"; pressureFg = "#991b1b";
    } else if (hasBaseline && pressureRatio < 0.8) {
      pressureLabel = "Inf\u00e9rieur \u00e0 la moyenne";
      pressureBg = "#dcfce7"; pressureFg = "#166534";
    } else if (hasBaseline) {
      pressureLabel = "Dans la moyenne";
    }

    const AUDIENCE_FR = {
      local: "r\u00e9sidents locaux", professionals: "professionnels",
      tourists: "touristes", students: "\u00e9tudiants",
      families: "familles", seniors: "seniors",
      general_public: "grand public", art_lovers: "amateurs d'art",
      mixed: "public mixte"
    };

    const INDUSTRY_TIER_FR = {
      direct: "M\u00eame secteur",
      partial: "Secteur proche",
      contextual: "Secteur diff\u00e9rent"
    };

    const THREAT_BADGE = {
      high:     { bg: "#fee2e2", fg: "#991b1b", t: "Menace \u00e9lev\u00e9e" },
      moderate: { bg: "#fef3c7", fg: "#92400e", t: "Menace mod\u00e9r\u00e9e" },
      low:      { bg: "#f3f4f6", fg: "#6b7280", t: "Menace faible" },
    };

    function renderThreatCard(tc) {
      const name = tc.competitor_name || "Concurrent";
      const distKm = tc.distance_km != null ? Number(tc.distance_km).toFixed(1) : null;
      const badge = THREAT_BADGE[tc.threat_level] || THREAT_BADGE.low;
      const indLabel = INDUSTRY_TIER_FR[tc.industry_match_tier] || "";

      const locAuds = [tc.location_primary_audience_1, tc.location_primary_audience_2].filter(Boolean);
      const compAuds = [tc.competitor_primary_audience, tc.competitor_secondary_audience].filter(Boolean);
      const sharedAuds = compAuds.filter(a => locAuds.includes(a)).map(a => AUDIENCE_FR[a] || a);

      let audLine = "";
      if (sharedAuds.length > 0) {
        audLine = "Cible les m\u00eames audiences : " + sharedAuds.join(", ");
      } else if (compAuds.length > 0) {
        audLine = "Cible : " + compAuds.map(a => AUDIENCE_FR[a] || a).join(", ");
      }

      const initials = name.split(" ").map(w => (w[0] || "")).join("").slice(0, 2).toUpperCase();

      const detailParts = [];
      if (tc.competitor_industry_code) detailParts.push("Secteur : " + escapeHtml(tc.competitor_industry_code));
      if (tc.competitor_google_rating) detailParts.push("\u2605 " + tc.competitor_google_rating + (tc.competitor_google_rating_count ? " \u00b7 " + Number(tc.competitor_google_rating_count).toLocaleString("fr-FR") + " avis" : ""));

      return '<div class="ms-threat-card" style="background:#fff;border:0.5px solid #E8EDF5;border-radius:10px;overflow:hidden;margin-bottom:6px;">'
        + '<div style="display:flex;align-items:center;gap:10px;padding:12px 14px;">'
          + '<div style="width:36px;height:36px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-weight:500;font-size:13px;color:#0C447C;background:#E6F1FB;flex-shrink:0;">' + escapeHtml(initials) + '</div>'
          + '<div style="flex:1;min-width:0;">'
            + '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">'
              + '<span style="font-size:13px;font-weight:500;color:#111827;">' + escapeHtml(name) + '</span>'
              + (distKm ? '<span style="font-size:11px;color:#6b7280;">' + escapeHtml(distKm + ' km') + '</span>' : '')
            + '</div>'
            + '<div style="display:flex;align-items:center;gap:6px;margin-top:3px;flex-wrap:wrap;">'
              + '<span style="display:inline-block;padding:1px 8px;border-radius:4px;font-size:10px;font-weight:600;background:' + badge.bg + ';color:' + badge.fg + ';">' + escapeHtml(badge.t) + '</span>'
              + (indLabel ? '<span style="font-size:11px;color:#6b7280;">' + escapeHtml(indLabel) + '</span>' : '')
            + '</div>'
            + (audLine ? '<div style="font-size:11px;color:#374151;margin-top:3px;">' + escapeHtml(audLine) + '</div>' : '')
          + '</div>'
          + '<div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;">'
            + '<button type="button" data-follow-threat="' + escapeHtml(tc.competitor_id) + '" data-follow-name="' + escapeHtml(name) + '" style="padding:4px 10px;border-radius:6px;border:1px solid #dbeafe;background:#eff6ff;font-size:11px;font-weight:600;color:#1e40af;cursor:pointer;white-space:nowrap;font-family:inherit;">Suivre \u2192</button>'
            + (detailParts.length ? '<button type="button" data-threat-expand style="font-size:10px;color:#1D3BB3;background:none;border:none;padding:0;cursor:pointer;font-family:inherit;">Voir plus \u2192</button>' : '')
          + '</div>'
        + '</div>'
        + (detailParts.length ? '<div data-threat-detail style="display:none;padding:0 14px 10px;font-size:11px;color:#6b7280;border-top:0.5px solid #F3F4F6;">'
          + '<div style="padding-top:8px;">' + detailParts.map(p => '<div style="padding:2px 0;">' + p + '</div>').join('') + '</div>'
        + '</div>' : '')
      + '</div>';
    }

    const threatsHtml = Array.isArray(topThreats) && topThreats.length > 0
      ? '<div style="margin-top:14px;border-top:0.5px solid #F3F4F6;padding-top:10px;">'
        + '<div style="font-size:10px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#374151;margin-bottom:8px;">Concurrents potentiels</div>'
        + topThreats.map(tc => renderThreatCard(tc)).join('')
      + '</div>'
      : '';

    return '<div style="padding-top:12px;">'
      + '<button type="button" data-radar-carte style="width:100%;display:block;text-align:left;background:none;border:0.5px solid #E6E8EC;border-radius:10px;overflow:hidden;cursor:pointer;font-family:inherit;padding:0;margin-bottom:10px;">'
        + '<div style="position:relative;height:120px;background:#EBEEF2;">'
          + '<svg viewBox="0 0 400 120" preserveAspectRatio="xMidYMid slice" style="position:absolute;inset:0;width:100%;height:100%;">'
            + '<circle cx="200" cy="60" r="50" fill="#1D3BB3" fill-opacity="0.05" stroke="#1D3BB3" stroke-opacity="0.30" stroke-width="1.2"/>'
            + '<circle cx="200" cy="60" r="22" fill="#1D3BB3" fill-opacity="0.08" stroke="#1D3BB3" stroke-opacity="0.45" stroke-width="1.2"/>'
            + '<circle cx="200" cy="60" r="5.5" fill="#1D3BB3" stroke="#fff" stroke-width="2"/>'
          + '</svg>'
          + '<span style="position:absolute;right:10px;bottom:10px;background:#fff;border:0.5px solid #E6E8EC;border-radius:6px;font-size:11px;font-weight:600;color:#1D3BB3;padding:5px 10px;">Ouvrir la carte →</span>'
        + '</div>'
        + '<div style="padding:11px 14px;font-size:12px;color:#565C66;">' + count500 + ' à moins de 500 m · ' + count5km + ' à 5 km</div>'
      + '</button>'
      + '<button type="button" data-radar-concurrents style="width:100%;display:flex;align-items:center;justify-content:center;gap:5px;padding:10px 12px;background:none;border:0.5px solid #E6E8EC;border-radius:8px;font-size:12px;font-weight:600;color:#1D3BB3;cursor:pointer;font-family:inherit;">Concurrents potentiels →</button>'
    + '</div>';
  }

  // ----------------------------------------------------------------
  // V4 NEW — Feed with CTAs
  // ----------------------------------------------------------------
  function renderFeed(allFeed, isMultisite, coveredTypes) {
    coveredTypes = coveredTypes || {};
    allFeed = allFeed.filter(function(f) {
      var sub = String(f.change_subtype||"").toLowerCase();
      if (coveredTypes[sub]) return false;
      return true;
    });
    const totalCount = allFeed.length;
    if (!totalCount) {
      return `
        <div style="margin-top:20px;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
            <span class="eb">Fil d'activité</span>
            <span style="font-size:11px;color:#8A909A;">0 événements</span>
          </div>
          <div style="text-align:center;padding:32px 0;color:#9CA3AF;font-size:14px;">Aucun changement récent.</div>
        </div>`;
    }

    // Group by category (4 buckets)
    const CATEGORY_ORDER = [
      { key: "mobility", label: "Mobilit\u00e9", match: (a) => String(a?.change_subtype||"").startsWith("mobility_") },
      { key: "competition", label: "Concurrence", match: (a) => { const s = String(a?.change_subtype||""); return s === "event_new" || s === "competitor_event_launch" || s === "competitor_event_ending" || s === "competitor_audience_conflict" || s === "competition_pressure_spike" || s === "mega_event_activation" || s === "mega_event_end"; } },
      { key: "weather", label: "M\u00e9t\u00e9o", match: (a) => { const s = String(a?.change_subtype||""); return s === "weather_worsened" || s === "weather_improved" || s === "weather_hazard_onset"; } },
      { key: "context", label: "Contexte", match: (a) => true },
    ];

    const categoryBuckets = new Map();
    for (const cat of CATEGORY_ORDER) categoryBuckets.set(cat.key, []);
    for (const a of allFeed) {
      for (const cat of CATEGORY_ORDER) {
        if (cat.match(a)) { categoryBuckets.get(cat.key).push(a); break; }
      }
    }

    const showAll = window.__plsV4FeedShowAll === true;
    const categoryEntries = CATEGORY_ORDER
      .map(cat => [cat, categoryBuckets.get(cat.key)])
      .filter(([, items]) => items.length > 0);
    const displayed = categoryEntries;

    function feedTypePill(a) {
      const sub = String(a?.change_subtype || "").toLowerCase();
      const dir = String(a?.direction || "").toLowerCase();
      const lvl = Number(a?.alert_level || 0);
      const P = (label, bg, fg) => '<span style="font-size:9px;font-weight:700;padding:2px 7px;border-radius:3px;background:' + bg + ';color:' + fg + ';text-transform:uppercase;letter-spacing:0.03em;">' + escapeHtml(label) + '</span>';
      const RISK = "#f3f4f6"; const RISK_T = "#6b7280";
      const WARN = "#f3f4f6"; const WARN_T = "#6b7280";
      const INFO = "#f3f4f6"; const INFO_T = "#6b7280";
      const LOW = "#f3f4f6"; const LOW_T = "#6b7280";
      const GREEN = "#f3f4f6"; const GREEN_T = "#6b7280";
      if (sub === "competitor_audience_conflict") return P("Conflit audience", RISK, RISK_T);
      if (sub === "competitor_event_launch") return P("Lancement", RISK, RISK_T);
      if (sub === "competition_pressure_spike") { const oldN = Number(a?.old_value||0); const newN = Number(a?.new_value||0); return newN > oldN ? P("Pression \u2191", RISK, RISK_T) : P("Pression \u2193", GREEN, GREEN_T); }
      if (sub === "mega_event_activation") return P("M\u00e9ga-\u00e9v\u00e9nement", RISK, RISK_T);
      if (sub === "mega_event_end") return P("Fin m\u00e9ga-\u00e9v\u00e9n.", GREEN, GREEN_T);
      if (sub === "weather_hazard_onset" || sub === "weather_worsened") return P("M\u00e9t\u00e9o", WARN, WARN_T);
      if (sub === "weather_improved") return P("M\u00e9t\u00e9o \u2713", GREEN, GREEN_T);
      if (sub === "mobility_disruption" || sub === "mobility_disruption_planned") {
        const mode = String(a?.mobility_mode || "").toLowerCase();
        const label = mode === "road" ? "Mobilit\u00e9" : "Mobilit\u00e9";
        return P(label, WARN, WARN_T) + ' ' + feedModeIcon(a?.mobility_mode);
      }
      if (sub === "mobility_disruption_resolved") return P("Mobilit\u00e9 \u2713", GREEN, GREEN_T) + ' ' + feedModeIcon(a?.mobility_mode);
      if (sub === "calendar_audience_shift") return P("Audience", INFO, INFO_T);
      if (sub === "regime_change") return P("Contexte", WARN, WARN_T);
      if (sub === "event_new") return P("Nouvel événement", LOW, LOW_T);
      if (sub === "score_up") return P("Score \u2191", GREEN, GREEN_T);
      if (sub === "score_down") return P("Score \u2193", RISK, RISK_T);
      if (sub === "ranking_up") return P("Classement \u2191", LOW, LOW_T);
      if (sub === "ranking_down") return P("Classement \u2193", LOW, LOW_T);
      if (sub === "competitor_event_ending") return P("Fin prochaine", GREEN, GREEN_T);
      if (sub === "competitor_review_surge") return P("Avis \u2191", WARN, WARN_T);
      if (sub === "competitor_review_drop") return P("Avis \u2193", GREEN, GREEN_T);
      if (sub === "competitor_hours_change") return P("Horaires", WARN, WARN_T);
      if (sub === "competitor_new_offering") return P("Offre", WARN, WARN_T);
      if (sub === "competitor_sold_out") return P("Complet", GREEN, GREEN_T);
      if (sub === "competitor_content_spike") return P("Contenu \u2191", WARN, WARN_T);
      if (sub === "competitor_content_silent") return P("Silence", GREEN, GREEN_T);
      if (sub === "institution_campaign_detected") return P("Campagne", INFO, INFO_T);
      if (sub === "media_mention_detected") return P("M\u00e9dia", INFO, INFO_T);
      return P("Signal", LOW, LOW_T);
    }

    function feedItemCta(a) {
      const sub = String(a?.change_subtype || "").toLowerCase();
      if (sub === "event_new") return { label: "Suivre", action: "follow" };
      return { label: "Consulter", action: "insight" };
    }

    function feedBorderColor(a) {
      const lvl = Number(a?.alert_level || 0);
      const dir = String(a?.direction || "").toLowerCase();
      const sub = String(a?.change_subtype || "").toLowerCase();
      if (lvl >= 4) return "var(--color-dot-audience)";
      if (lvl >= 3) return "var(--color-pill-risk-border)";
      if (dir === "up" || dir === "improved" || sub.endsWith("_resolved") || sub.endsWith("_end") || sub.endsWith("_ending")) return "var(--color-pill-green-text)";
      if (lvl >= 2) return "var(--color-pill-warn-border)";
      return "var(--color-dot-neutral)";
    }

    const groupsHtml = displayed.map(([cat, catItems]) => {
      const groupLabel = cat.label + " (" + catItems.length + ")";

      const locLabels = new Set(catItems.map(a => a?.location_label).filter(Boolean));
      const showLocPill = isMultisite && locLabels.size > 1;

      // Sort by alert_level DESC, then date DESC within category
      const sorted = [...catItems].sort((a, b) => {
        const lvlDiff = (Number(b?.alert_level)||0) - (Number(a?.alert_level)||0);
        if (lvlDiff !== 0) return lvlDiff;
        return String(b?.affected_date||"").localeCompare(String(a?.affected_date||""));
      });
      const maxVisible = showAll ? sorted.length : 5;
      const visible = sorted.slice(0, maxVisible);

      const itemsHtml = visible.map((a, idx) => {
        const line1 = feedLine1(a);
        if (!line1) return "";
        const line2 = feedLine2(a);
        const line4 = feedLine4(a);
        const cta = feedItemCta(a);
        const locPill = showLocPill && a?.location_label ? '<span style="font-size:9px;font-weight:700;padding:2px 7px;border-radius:3px;background:#EFF6FF;color:#1e40af;text-transform:uppercase;letter-spacing:0.03em;">' + escapeHtml(a.location_label) + '</span>' : "";
        var _ad = normalizeYmd(a?.affected_date);
        var _today = todayYmd();
        var _datePillLabel = "";
        if (_ad === _today) _datePillLabel = "Aujourd\u2019hui";
        else { var _dt = parseYmdToDate(_ad); if (_dt) { var _diff = Math.round((_dt - parseYmdToDate(_today)) / 86400000); if (_diff === 1) _datePillLabel = "Demain"; else if (_diff === -1) _datePillLabel = "Hier"; else if (_diff > 1 && _diff <= 7) _datePillLabel = new Intl.DateTimeFormat("fr-FR", {weekday:"short",day:"numeric"}).format(_dt); else _datePillLabel = new Intl.DateTimeFormat("fr-FR", {day:"numeric",month:"short"}).format(_dt); } }
        var datePill = _datePillLabel ? '<span style="font-size:9px;font-weight:600;padding:2px 7px;border-radius:3px;background:#f3f4f6;color:#6b7280;text-transform:uppercase;letter-spacing:0.03em;">' + escapeHtml(_datePillLabel) + '</span>' : "";

        const ctaHtml = (() => {
          if (!cta) return "";
          const sub = String(a?.change_subtype || "").toLowerCase();
          if (sub === "event_new") {
            const uid = escapeHtml(String(a?.entity_id || idx));
            return '<div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;align-self:center;">'
              + '<button type="button" data-feed-follow="' + uid + '" data-follow-label="' + escapeHtml(a?.event_label || '') + '" data-follow-venue="' + escapeHtml(a?.event_venue_name || '') + '" data-follow-city="' + escapeHtml(a?.city_name || '') + '" data-follow-date="' + escapeHtml(normalizeYmd(a?.affected_date) || '') + '" data-follow-industry="' + escapeHtml(a?.industry_code || '') + '" style="padding:5px 10px;border-radius:6px;border:1px solid #dbeafe;background:#eff6ff;font-size:11px;font-weight:600;color:#1e40af;cursor:pointer;white-space:nowrap;font-family:inherit;">Suivre \u2192</button>'
              + '<button type="button" data-feed-enrich="' + uid + '" data-enrich-label="' + escapeHtml(a?.event_label || '') + '" data-enrich-venue="' + escapeHtml(a?.event_venue_name || '') + '" data-enrich-city="' + escapeHtml(a?.city_name || '') + '" data-enrich-distance="' + (a?.distance_m != null ? Math.round(Number(a.distance_m)) : '') + '" data-enrich-industry="' + escapeHtml(a?.industry_code || '') + '" data-enrich-uid="' + escapeHtml(a?.entity_id || '') + '" style="font-size:10px;color:#1D3BB3;background:none;border:none;padding:0;cursor:pointer;font-family:inherit;">Voir plus \u2192</button>'
            + '</div>';
          }
          var feedDate = normalizeYmd(a?.affected_date) || '';
          var feedSub = String(a?.change_subtype || '');
          var feedLocId = a?.location_id || location_id;
          return '<a href="/app/insightevent/insight?type=' + encodeURIComponent(feedSub) + '&date=' + encodeURIComponent(feedDate) + '&location_id=' + encodeURIComponent(feedLocId) + '" style="flex-shrink:0;align-self:center;font-size:11px;font-weight:600;color:#1D3BB3;cursor:pointer;white-space:nowrap;font-family:inherit;text-decoration:none;">Consulter \u2192</a>';
        })();

        return `
          <div class="tlrow">
            <span class="tldot"></span>
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:3px;">${datePill}${locPill}</div>
            <div style="font-size:14px;font-weight:500;color:#1A1D23;margin:0 0 2px;">${escapeHtml(line1)}</div>
            ${line2 ? `<div style="font-size:13px;color:#565C66;">${escapeHtml(line2)}</div>` : ""}
            ${line4 ? `<div style="font-size:11px;color:#8A909A;margin-top:4px;display:flex;align-items:center;gap:6px;">${line4}</div>` : ""}
            <div data-feed-enrich-panel="${idx}" style="display:none;margin-top:8px;"></div>
            <div style="margin-top:6px;">${ctaHtml}</div>
          </div>`;
      }).filter(Boolean).join("");

      if (!itemsHtml) return "";

      return `
        <div style="margin-bottom:18px;">
          <p class="eb" style="margin:0 0 10px;">${escapeHtml(groupLabel)}</p>
          <div class="tl">${itemsHtml}</div>
        </div>`;
    }).filter(Boolean).join("");

    const hasHidden = !showAll && categoryEntries.some(([, items]) => items.length > 5);
    const showAllBtn = hasHidden
      ? `<button type="button" id="pls-v4-feed-show-all" style="display:block;width:100%;margin-top:8px;padding:9px;background:none;border:1px solid #e5e7eb;border-radius:8px;font-size:12px;font-weight:500;color:#3b82f6;cursor:pointer;font-family:inherit;">Voir tout (${totalCount})</button>`
      : "";

    return `
      <div style="margin-top:20px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
          <span class="eb">Fil d'activité</span>
          <span style="font-size:11px;color:#8A909A;">${totalCount} ${totalCount > 1 ? "signaux" : "signal"}</span>
        </div>
        <div>
          ${groupsHtml}
        </div>
        ${showAllBtn}
      </div>`;
  }

  // ----------------------------------------------------------------
  // Main render — V4 REWRITE: pills → alerts → 3 radar strips → feed
  // ----------------------------------------------------------------
  function renderMonitor(data, item, selectedDate, activeView, monitorDates) {
    activeView = activeView || "radar";
    const root = document.getElementById("mon-root");
    if (!root) return;

    // Event's own site — never the active site in pulse.
    const itemLocationId =
      (item && typeof item.location_id === "string" && item.location_id.trim())
        ? item.location_id.trim()
        : location_id;

    const days = Array.isArray(data.days) ? data.days : [];
    window._lastActionCandidates = Array.isArray(data.action_candidates) ? data.action_candidates : [];
    const dayMap = new Map(days.map(d => [normalizeYmd(d.date), d]));
    const currentDay = dayMap.get(selectedDate) || days[0] || null;
    const allFeed = Array.isArray(data.all_feed) ? data.all_feed : [];
    const competitorSignals = data._competitor_signals || [];
    const followedCount = Number(data._competitor_followed_count ?? data.competitor_followed_count ?? 0);
    const isMultisite = false;

    if (!currentDay) {
      root.innerHTML = `<div class="mon-error">Aucune donnée disponible.</div>`;
      return;
    }

    const today = todayYmd();

    // Breadcrumb
    const breadcrumbNav = document.querySelector(".mon-breadcrumb");
    const breadcrumbSub = document.getElementById("mon-breadcrumb-sub");
    const breadcrumbTab = document.getElementById("mon-breadcrumb-tab");
    const breadcrumbRecap = document.getElementById("mon-breadcrumb-recap");
    if (breadcrumbNav) breadcrumbNav.style.display = "flex";
    if (activeView === "radar") { if (breadcrumbSub) breadcrumbSub.style.display = "none"; }
    else { if (breadcrumbTab) breadcrumbTab.textContent = ({ carte:"Environnement", concurrents:"Concurrents potentiels" })[activeView] || activeView; if (breadcrumbSub) breadcrumbSub.style.display = "inline"; }
    if (breadcrumbRecap) { breadcrumbRecap.onclick = (e) => { e.preventDefault(); renderMonitor(data, item, selectedDate, "radar", monitorDates); }; }

    const _score = currentDay?.opportunity_score ?? null;
    const _safeScore = _score !== null ? String(_score).trim() : null;
    const _statusPill = computeStatusPill(currentDay);
    const _cev = countdown(selectedDate);

    // Event metadata tags
    const _evtType = item?.event_type || null;
    const _evtCapacity = item?.expected_audience || item?.capacity || null;
    const _evtStatus = item?.status_label || null;
    const _locationLabel = item?.location_label || item?.company_name || null;

    const EVT_TYPE_LABELS = {
      conference_de_presse: 'Conférence de presse',
      evenement_corporate: 'Événement corporate',
      happening_exterieur: 'Happening extérieur',
      inauguration: 'Inauguration',
      journee_portes_ouvertes: 'Journée portes ouvertes',
      lancement_de_produit: 'Lancement de produit',
      ouverture_point_de_vente: 'Ouverture d\'un point de vente',
      promotion_magasin: 'Promotion en magasin / soldes',
      soiree_de_lancement: 'Soirée de lancement',
      vernissage_exposition: 'Vernissage / Exposition',
      autre: 'Autre',
    };
    const evtTypeLabel = _evtType ? (EVT_TYPE_LABELS[_evtType] || _evtType) : null;

    const STATUS_LABELS = {
      on_track: 'En bonne voie', at_risk: 'À risque', delayed: 'Retardé',
      confirmed: 'Confirmé', cancelled: 'Annulé',
    };
    const evtStatusLabel = _evtStatus ? (STATUS_LABELS[_evtStatus] || _evtStatus) : null;

    const metaTags = [evtTypeLabel, _evtCapacity, evtStatusLabel].filter(Boolean);
    const metaTagsHtml = metaTags.length
      ? `<div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:12px;">${metaTags.map(t =>
          `<span style="display:inline-block;padding:4px 14px;font-size:12px;font-weight:600;color:#565C66;border:1px solid #D6D9DF;background:#fff;">${escapeHtml(t)}</span>`
        ).join("")}</div>`
      : "";

    // Single mode source — clean integer diff, both ends on the same axis
    const _today0 = parseYmdToDate(todayYmd());
    const _target0 = parseYmdToDate(selectedDate);
    const _diffDays = (_today0 && _target0) ? Math.round((_target0 - _today0) / 86400000) : null;
    const _mode = _diffDays === null ? "future" : _diffDays < 0 ? "past" : _diffDays === 0 ? "today" : _diffDays <= 2 ? "soon" : "future";

    let _recencyText = null, _recBg = "rgba(29,59,179,0.08)", _recFg = "#1D3BB3";
    if (_diffDays !== null) {
      if (_diffDays < 0) { _recencyText = "Pass\u00e9 \u00b7 il y a " + Math.abs(_diffDays) + "j"; _recBg = "#F4F5F7"; _recFg = "#8A909A"; }
      else if (_diffDays === 0) { _recencyText = "Aujourd'hui"; }
      else if (_diffDays === 1) { _recencyText = "Demain \u00b7 J\u20111"; _recBg = "#FBE9E1"; _recFg = "#9A3A12"; }
      else if (_diffDays === 2) { _recencyText = "Apr\u00e8s-demain \u00b7 J\u20112"; _recBg = "#FBE9E1"; _recFg = "#9A3A12"; }
      else { _recencyText = "Dans " + _diffDays + " jours"; }
    }
    const _scoreLabel = (_diffDays !== null && _diffDays > 0) ? "Score pr\u00e9vu" : "Score du jour";
    const _heroRight = (_recencyText || _safeScore)
      ? '<div style="display:flex;flex-direction:column;align-items:flex-end;gap:12px;flex-shrink:0;text-align:right;">'
          + (_recencyText ? '<span style="font-size:11px;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;padding:4px 10px;white-space:nowrap;background:' + _recBg + ';color:' + _recFg + ';">' + escapeHtml(_recencyText) + '</span>' : '')
          + (_safeScore ? '<span style="display:flex;flex-direction:column;align-items:flex-end;line-height:1.1;"><span style="font-size:21px;font-weight:600;color:#111827;">' + escapeHtml(_safeScore) + '<span style="font-size:13px;color:#9ca3af;font-weight:400;">/10</span></span><span style="font-size:10px;letter-spacing:0.06em;text-transform:uppercase;color:#9ca3af;margin-top:2px;">' + escapeHtml(_scoreLabel) + '</span></span>' : '')
        + '</div>'
      : '';

    const headerHtml = `
      <div style="background:rgba(29,59,179,0.04);border-left:3px solid #1D3BB3;padding:18px 20px;margin-bottom:0;">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:18px;">
          <div style="flex:1;min-width:0;">
            <div style="font-size:23px;font-weight:600;color:#111827;margin:0;line-height:1.2;">${escapeHtml(item?.title || "Événement")}</div>
            <div style="font-size:13px;color:#6b7280;margin:6px 0 0;">${escapeHtml(fmtDateLong(selectedDate))}${_locationLabel ? " \u00b7 " + escapeHtml(_locationLabel) : ""}</div>
            ${metaTagsHtml}
          </div>
          ${_heroRight}
        </div>
      </div>
    `;

    // ---- Pills (from monitorDates) ----
    const pillsHtml = `<div class="pls-pills">
      ${monitorDates.map(ymd => {
        const d = dayMap.get(ymd);
        const allRisks = [...(d?.attendance||[]),...(d?.operations||[]),...(d?.installation||[])];
        const hasCrit = allRisks.some(r => r.severity==="D"||r.severity==="C");
        const hasWarn = !hasCrit && allRisks.some(r => r.severity==="B");
        const isActive = ymd===selectedDate;
        let cls = "pls-pill";
        if (isActive) cls+=" is-active";
        else if (ymd===today) cls+=" is-today";
        else if (hasCrit) cls+=" has-crit";
        else if (hasWarn) cls+=" has-warn";
        const label = fmtDateShort(ymd);
        const dotColor = isActive ? "#fff" : hasCrit ? "#e24b4a" : hasWarn ? "#ef9f27" : null;
        const dot = dotColor ? `<span class="pls-pill-dot" style="background:${dotColor};"></span>` : "";
        return `<button type="button" class="${cls}" data-pill-date="${ymd}">${escapeHtml(label)}${dot}</button>`;
      }).join("")}
    </div>`;

    // ---- Alerts (severity != A, shown as strips before radar) ----
    const dayAlerts = [
      ...(currentDay.attendance || []),
      ...(currentDay.operations || []),
      ...(currentDay.installation || []),
      ...(currentDay.context || []),
    ].filter(r => r.severity !== "A");

    let alertsHtml = "";
    if (dayAlerts.length > 0) {
      const _alRows = dayAlerts.slice().sort((x, y) => {
        const rk = s => (s === "D" || s === "C") ? 0 : 1;
        return rk(x.severity) - rk(y.severity);
      }).slice(0, 5).map(a => {
        const isCrit = a.severity === "D" || a.severity === "C";
        const blockLabel = BLOCK_LABELS[a.block] || a.block.toUpperCase();
        return `<div style="display:flex;flex-direction:column;gap:2px;padding:8px 0;border-top:1px solid #f3f4f6;">
          <div style="display:flex;align-items:center;gap:6px;">
            <span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#6B7280;">${escapeHtml(blockLabel)}</span>
            ${isCrit ? '<span class="chip-bad">Critique</span>' : ''}
          </div>
          <div style="font-size:12.5px;color:#374151;line-height:1.4;">${escapeHtml(a.sentence)}</div>
        </div>`;
      }).join("");
      const _alLabel = dayAlerts.length + " point" + (dayAlerts.length > 1 ? "s" : "") + " de vigilance";
      alertsHtml = `<div style="margin-bottom:12px;">
        <div onclick="(function(b){var l=b.parentElement.querySelector('[data-alert-list]');var c=b.querySelector('[data-alert-chev]');var open=l.style.display!=='none';l.style.display=open?'none':'block';if(c)c.style.transform=open?'none':'rotate(180deg)';})(this)" style="display:flex;align-items:center;gap:8px;padding:10px 14px;background:#f3f4f6;cursor:pointer;">
          <span style="width:8px;height:8px;border-radius:50%;background:#9ca3af;display:inline-block;flex-shrink:0;"></span>
          <span style="flex:1;font-size:12.5px;font-weight:500;color:#374151;">${escapeHtml(_alLabel)}</span>
          <span data-alert-chev style="font-size:11px;color:#9ca3af;transition:transform 0.15s;">\u25be</span>
        </div>
        <div data-alert-list style="display:none;padding:0 14px;">${_alRows}</div>
      </div>`;
    } else {
      alertsHtml = '<div style="display:flex;align-items:center;gap:6px;margin-bottom:12px;padding:8px 12px;background:rgba(16,185,129,0.06);"><span style="color:#059669;font-size:13px;">\u2713</span><span style="font-size:12.5px;color:#059669;font-weight:500;">Aucune alerte</span></div>';
    }

    // ---- Carte view ----
    if (activeView === "carte") {
      const mapLocs = isMultisite ? data._locations : null;
      const primaryLoc = mapLocs ? (mapLocs.find(l => l.is_primary) || mapLocs[0]) : null;
      const defaultLocId = primaryLoc ? primaryLoc.location_id : itemLocationId;

      const mapSwitcher = mapLocs ? `
        <div style="display:flex;align-items:center;gap:0;border:0.5px solid #E5E7EB;border-radius:8px;overflow:hidden;margin-bottom:8px;">
          ${mapLocs.map((l, i) => {
            const isDefault = l.location_id === defaultLocId;
            return `<button type="button" data-map-loc="${escapeHtml(l.location_id)}" style="flex:1;padding:10px 14px;font-size:13px;font-weight:${isDefault?'500':'400'};color:${isDefault?'#111827':'#9CA3AF'};background:${isDefault?'#fff':'#F9FAFB'};border:none;border-right:${i<mapLocs.length-1?'0.5px solid #E5E7EB':'none'};cursor:pointer;font-family:inherit;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
              ${escapeHtml(l.company_name || l.location_id)}
            </button>`;
          }).join('')}
        </div>` : '';

      const backBtn = `<button type="button" id="mon-back-radar" style="display:flex;align-items:center;gap:6px;margin-bottom:12px;padding:6px 0;background:none;border:none;font-size:13px;font-weight:600;color:#1D3BB3;cursor:pointer;font-family:inherit;">← Retour au radar</button>`;

      root.innerHTML = headerHtml + `<div style="height:12px;"></div>` + backBtn + mapSwitcher +
        `<iframe id="pls-map-iframe" src="/app/insightevent/map?location_id=${encodeURIComponent(defaultLocId)}&date=${encodeURIComponent(selectedDate)}&embed=1${data._mapMode ? '&mode=' + encodeURIComponent(data._mapMode) : ''}" style="width:100%;height:600px;border:none;border-radius:14px;display:block;"></iframe>`;

      // Pills removed — single event date

      // Wire back button
      const backEl = root.querySelector("#mon-back-radar");
      if (backEl) backEl.addEventListener("click", () => renderMonitor(data, item, selectedDate, "radar", monitorDates));

      // Wire map site selector
      root.querySelectorAll("[data-map-loc]").forEach(btn => {
        btn.addEventListener("click", () => {
          const locId = btn.getAttribute("data-map-loc");
          const iframe = root.querySelector("#pls-map-iframe");
          if (iframe && locId) {
            iframe.src = "about:blank";
            setTimeout(() => {
              iframe.src = `/app/insightevent/map?location_id=${encodeURIComponent(locId)}&date=${encodeURIComponent(selectedDate)}&embed=1`;
            }, 0);
          }
          root.querySelectorAll("[data-map-loc]").forEach(b => {
            const isAct = b === btn;
            b.style.fontWeight = isAct ? '500' : '400';
            b.style.color = isAct ? '#111827' : '#9CA3AF';
            b.style.background = isAct ? '#fff' : '#F9FAFB';
          });
