      // Wire back
      const backEl = root.querySelector("#mon-back-radar");
      if (backEl) backEl.addEventListener("click", function() { renderMonitor(data, item, selectedDate, "radar", monitorDates); });

      // Wire Voir plus enrich
      root.querySelectorAll("[data-threat-enrich]").forEach(function(btn) {
        btn.addEventListener("click", async function(e) {
          e.stopPropagation();
