      const backBtn = '<button type="button" id="mon-back-radar" style="display:flex;align-items:center;gap:6px;margin-bottom:12px;padding:6px 0;background:none;border:none;font-size:13px;font-weight:600;color:#1D3BB3;cursor:pointer;font-family:inherit;">\u2190 Retour au radar</button>';

      const concHeaderHtml = '<div style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#374151;margin-bottom:12px;">Concurrents potentiels · ' + topThreats.length + '</div>';

