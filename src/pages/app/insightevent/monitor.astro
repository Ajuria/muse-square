      };
    },
    score_up: function(a, prof) {
      var delta = a.score_delta!=null?Math.round(Number(a.score_delta)):null;
      if (delta===null||delta<3) return null;
      return {
        type:"opportunity", barClass:"ab-opportunity",
        urgencyPill:{label:fmtDateShort(normalizeYmd(a.affected_date)),style:"background:var(--color-pill-green-bg);color:var(--color-pill-green-text);"},
        typePill:{label:"Score \u2191",style:"background:var(--color-pill-green-bg);color:var(--color-pill-green-text);"},
        what: "Score en forte hausse : "+(a.old_value||"?")+" \u2192 "+(a.new_value||"?")+" (+"+delta+" pts)",
        sowhat: "Cette date gagne en attractivit\u00e9. Conditions favorables pour maximiser.",
        actions: [
          {text:"Publier un post pour capter le trafic spontan\u00e9",meta:"Communication \u00b7 R\u00e9seaux sociaux",key:"visitor_comm",channel:CH_GBP},
          {text:"Activer une offre premium",meta:"Marketing \u00b7 Pricing",key:"pricing",channel:CH_GBP},
        ],
      };
    },
    calendar_audience_shift: function(a, prof) {
      var nv = String(a.new_value || "");
      var ov = String(a.old_value || "");
      if (!nv || nv === ov) return null;
      var isHoliday = nv.toLowerCase().indexOf("férié") >= 0;
      var isVacation = nv.toLowerCase().indexOf("vacances") >= 0;
      var isTourist = nv.toLowerCase().indexOf("touris") >= 0;
      var isFamily = nv.toLowerCase().indexOf("famille") >= 0 || nv.toLowerCase().indexOf("résidents") >= 0;
      var isPro = nv.toLowerCase().indexOf("professionnel") >= 0;
      var isSoldes = nv.toLowerCase().indexOf("soldes") >= 0 || nv.toLowerCase().indexOf("commercia") >= 0;
      var myAud = String(prof.primary_audience_1 || "").toLowerCase();
      var AUD_FR = {local:"résidents locaux",professionals:"professionnels",tourists:"touristes",students:"étudiants",families:"familles",seniors:"seniors"};
      var myAudLabel = AUD_FR[myAud] || "";
      var isMismatch = false;
      if (myAud === "professionals" && (isHoliday || isVacation || isFamily)) isMismatch = true;
      if (myAud === "tourists" && !isTourist && !isHoliday && !isVacation) isMismatch = true;
      if ((myAud === "local" || myAud === "families") && isPro) isMismatch = true;
      var barClass = isMismatch ? "ab-warning" : "ab-opportunity";
      var urgStyle = isMismatch
        ? "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);"
        : "background:var(--color-pill-green-bg);color:var(--color-pill-green-text);";
      var typeStyle = "background:#EFF6FF;color:#1e40af;";
      var audToday = isTourist ? "touristes" : isFamily ? "familles et r\u00e9sidents" : isPro ? "professionnels" : isSoldes ? "acheteurs" : "public mixte";
      var what = isMismatch
        ? "Changement d\u2019audience : " + audToday + " aujourd\u2019hui \u2014 votre cible (" + myAudLabel + ") est moins disponible"
        : isHoliday ? "Jour f\u00e9ri\u00e9 : affluence " + audToday + " attendue"
        : isVacation ? "Vacances scolaires : affluence " + audToday + " attendue"
        : isSoldes ? "P\u00e9riode commerciale : flux " + audToday + " en hausse"
        : "Public du jour : " + audToday;
      var sowhat = isMismatch
        ? "Le public disponible ne correspond pas \u00e0 votre cible habituelle. Adaptez votre offre du jour ou r\u00e9duisez vos effectifs."
        : isHoliday || isVacation
          ? "Affluence diff\u00e9rente de vos jours habituels. Adaptez votre accueil et votre communication au public pr\u00e9sent."
          : "Le profil de votre audience change aujourd\u2019hui. Opportunit\u00e9 d\u2019adapter votre message.";
      var actions = isMismatch ? [
        {text:"Adaptez votre \u00e9quipe \u00e0 une fr\u00e9quentation diff\u00e9rente de l\u2019habituel",meta:"Exploitation \u00b7 \u00c9quipe",key:"staff_adjust",channel:CH_INTERNAL},
        {text:"Publiez un post adapt\u00e9 au public du jour (" + audToday + ")",meta:"Communication \u00b7 Ciblage",key:"visitor_comm",channel:CH_GBP},
      ] : [
        {text:"Publiez un post adapt\u00e9 au public du jour (" + audToday + ")",meta:"Communication \u00b7 Ciblage",key:"visitor_comm",channel:CH_GBP},
        isHoliday || isVacation
          ? {text:"Adaptez vos horaires au rythme " + (isHoliday ? "jour f\u00e9ri\u00e9" : "vacances"),meta:"Exploitation \u00b7 Horaires",key:"staff_adjust",channel:CH_INTERNAL}
          : {text:"Mettez en avant votre offre adapt\u00e9e " + audToday,meta:"Marketing \u00b7 Ciblage",key:"marketing_push",channel:CH_GBP},
      ];
      return {
        type: isMismatch ? "threat" : "opportunity",
        barClass: barClass,
        urgencyPill: {label: "Aujourd\u2019hui", style: urgStyle},
        typePill: {label: "Audience", style: typeStyle},
        what: what,
        sowhat: sowhat,
        actions: actions,
      };
    },
  };

  // ---- Opportunity from day context (regime A + favorable signals) ----
  function briefOpportunityFromDay(currentDay, prof) {
    var regime = String(currentDay.opportunity_regime||"B").toUpperCase();
    var score = Number(currentDay.opportunity_score||0);
    if (regime!=="A"||score<7) return null;
    var holiday = currentDay.holiday_name||null;
    var vacation = currentDay.vacation_name||null;
    var contextParts = [];
    if (holiday) contextParts.push(holiday);
    if (vacation) contextParts.push(vacation);
    var envCount5km = Number(currentDay.events_within_5km_count||0);
    var lowComp = envCount5km <= 3;
    if (lowComp) contextParts.push("faible concurrence");
    if (!contextParts.length && score < 8) return null;
    return {
      type:"opportunity", barClass:"ab-opportunity",
      urgencyPill:{label:"Aujourd\u2019hui",style:"background:var(--color-pill-green-bg);color:var(--color-pill-green-text);"},
      typePill:{label:"Opportunit\u00e9",style:"background:var(--color-pill-green-bg);color:var(--color-pill-green-text);"},
      what: "Journ\u00e9e exceptionnelle : score "+score+(contextParts.length?", "+contextParts.join(", "):""),
      sowhat: "Conditions id\u00e9ales pour maximiser votre fr\u00e9quentation et votre chiffre d\u2019affaires.",
      actions: [
        {text:"Publier un post \u00ab \u00e9v\u00e9nement du jour \u00bb pour capter le trafic spontan\u00e9",meta:"Communication \u00b7 R\u00e9seaux sociaux",key:"visitor_comm",channel:CH_INSTAGRAM},
        {text:"Activer une offre premium \u2014 marges plus \u00e9lev\u00e9es quand la demande est forte",meta:"Marketing \u00b7 Pricing",key:"pricing",channel:CH_GBP},
        {text:"Prolonger vos horaires pour maximiser le chiffre d\u2019affaires",meta:"Exploitation \u00b7 Horaires",key:"staff_adjust",channel:CH_INTERNAL},
      ],
    };
  }

  // ---- Actionability scoring ----
  function briefScore(a, prof, today) {
    var s = 0;
    var sub = String(a.change_subtype||"").toLowerCase();
    var lvl = Number(a.alert_level||0);
    var affected = normalizeYmd(a.affected_date);
    var distM = Number(a.distance_m||0);
    s += lvl * 10;
    if (affected===today) s += 30;
    else {
      var ad = parseYmdToDate(affected); var td = parseYmdToDate(today);
      if (ad&&td) { var diff = Math.round((ad.getTime()-td.getTime())/86400000); if(diff===1)s+=20;else if(diff<=3)s+=10;else if(diff<=7)s+=5; }
    }
    if (distM>0) { if(distM<500)s+=20;else if(distM<1000)s+=10;else if(distM<3000)s+=5; }
    var REVENUE = ["competitor_audience_conflict","competitor_event_launch","competition_pressure_spike","mega_event_activation","weather_worsened","weather_hazard_onset","mobility_disruption"];
    if (REVENUE.indexOf(sub)>=0) s += 15;
    if (a.has_active_event) s += 10;
    var isOutdoor = String(prof.location_type_client||"").toLowerCase()==="outdoor"||String(prof.location_type_client||"").toLowerCase()==="mixed";
    if ((sub==="weather_worsened"||sub==="weather_hazard_onset")&&isOutdoor) s += 10;
    var OPP = ["weather_improved","competitor_event_ending","mega_event_end","score_up"];
    if (OPP.indexOf(sub)>=0) s += 25;
    return s;
  }

  // ---- localStorage persistence ----
  function briefStorageKey(locationId, date) { return "ab_"+locationId+"_"+date; }
  function briefLoadChecked(locationId, date) {
    try { var raw = localStorage.getItem(briefStorageKey(locationId,date)); return raw ? JSON.parse(raw) : {}; } catch { return {}; }
  }
  function briefSaveChecked(locationId, date, checked) {
    try { localStorage.setItem(briefStorageKey(locationId,date), JSON.stringify(checked)); } catch {}
  }

  // ---- Render ----
  function renderDailyBrief(allFeed, profile, currentDay, selectedDate, locationId, days) {
    var today = todayYmd();
    var prof = profile || {};

    var ACTIONABLE = Object.keys(BRIEF_TEMPLATES);
    var candidates = [];
    for (var i = 0; i < allFeed.length; i++) {
      var a = allFeed[i];
      var sub = String(a.change_subtype||"").toLowerCase();
      if (ACTIONABLE.indexOf(sub) < 0) continue;
      var affected = normalizeYmd(a.affected_date);
      if (affected < today) continue;
      var HORIZON = {mobility_disruption:7,mobility_disruption_planned:14,weather_worsened:7,weather_hazard_onset:7,weather_improved:7,competitor_event_launch:10,competitor_audience_conflict:10,competition_pressure_spike:10,mega_event_activation:14,score_up:7,competitor_event_ending:14,mega_event_end:14};
      var maxDays = HORIZON[sub] != null ? HORIZON[sub] : 7;
      var ad = parseYmdToDate(affected); var td = parseYmdToDate(today);
      if (ad && td && (ad.getTime() - td.getTime()) / 86400000 > maxDays) continue;
      if (Number(a.alert_level||0) < 2 && sub !== "weather_improved" && sub !== "competitor_event_ending" && sub !== "mega_event_end" && sub !== "score_up") continue;
      var tmplFn = BRIEF_TEMPLATES[sub];
      if (!tmplFn) continue;
      var tmpl = tmplFn(a, prof);
      if (!tmpl) continue;
      candidates.push({ item: a, tmpl: tmpl, score: briefScore(a, prof, today) });
    }

    var dayOpp = briefOpportunityFromDay(currentDay, prof);
    if (dayOpp) {
      candidates.push({ item: { change_subtype:"_day_opportunity", affected_date:currentDay.date, alert_level:0 }, tmpl: dayOpp, score: 80 });
    }

    // ---- Computed: Audience mismatch ----
    var audLabel = String(currentDay.audience_availability_label || "").toLowerCase();
    var myAudComp = String(prof.primary_audience_1 || "").toLowerCase();
    var AUD_FR_COMP = {local:"r\u00e9sidents locaux",professionals:"professionnels",tourists:"touristes",students:"\u00e9tudiants",families:"familles",seniors:"seniors"};
    var myAudLabelComp = AUD_FR_COMP[myAudComp] || "";
    var audMismatch = false;
    if (myAudComp === "professionals" && (audLabel.indexOf("vacances") >= 0 || audLabel.indexOf("f\u00e9ri\u00e9") >= 0 || audLabel.indexOf("famille") >= 0)) audMismatch = true;
    if (myAudComp === "tourists" && audLabel.indexOf("touris") < 0 && audLabel.indexOf("f\u00e9ri\u00e9") < 0 && audLabel.indexOf("vacances") < 0) audMismatch = true;
    if ((myAudComp === "local" || myAudComp === "families") && audLabel.indexOf("professionnel") >= 0 && audLabel.indexOf("vacances") < 0) audMismatch = true;
    if (audMismatch && myAudLabelComp) {
      var audAvailable = audLabel.indexOf("touris") >= 0 ? "touristes" : audLabel.indexOf("famille") >= 0 ? "familles" : audLabel.indexOf("f\u00e9ri\u00e9") >= 0 ? "public jour f\u00e9ri\u00e9" : audLabel.indexOf("vacances") >= 0 ? "vacanciers" : audLabel.indexOf("soldes") >= 0 || audLabel.indexOf("commercia") >= 0 ? "acheteurs" : "public diff\u00e9rent";
      candidates.push({ item: { change_subtype:"_audience_mismatch", affected_date:currentDay.date, alert_level:2, location_label: currentDay.location_label || "" }, tmpl: {
        type:"threat", barClass:"ab-warning",
        urgencyPill:{label:"Aujourd\u2019hui",style:"background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);"},
        typePill:{label:"Audience",style:"background:#EFF6FF;color:#1e40af;"},
        what: "Public du jour : " + audAvailable + " \u2014 votre cible (" + myAudLabelComp + ") est moins disponible",
        sowhat: "Le public pr\u00e9sent aujourd\u2019hui ne correspond pas \u00e0 votre audience habituelle. R\u00e9duisez vos effectifs ou adaptez votre offre.",
        actions: [
          {text:"R\u00e9duisez votre \u00e9quipe si la fr\u00e9quentation cible sera faible",meta:"Exploitation \u00b7 \u00c9quipe",key:"staff_adjust",channel:CH_INTERNAL},
          {text:"Publiez un post adapt\u00e9 au public disponible (" + audAvailable + ")",meta:"Communication \u00b7 Adaptation",key:"visitor_comm",channel:CH_GBP},
        ],
      }, score: 65 });
    }

    // ---- Computed: Weather window after bad spell ----
    var sortedByDate = [...days].sort(function(a,b) { return String(a.date||"").localeCompare(String(b.date||"")); });
    var todayIdx = sortedByDate.findIndex(function(d) { return normalizeYmd(d.date) === today; });
    if (todayIdx >= 2 && Number(currentDay.alert_level_max || 0) <= 1) {
      var prevBadDays = 0;
      for (var pi = todayIdx - 1; pi >= Math.max(0, todayIdx - 3); pi--) {
        if (Number(sortedByDate[pi].alert_level_max || 0) >= 2) prevBadDays++;
      }
      if (prevBadDays >= 2) {
        var tMinW = currentDay.temperature_2m_min != null ? Math.round(Number(currentDay.temperature_2m_min)) : null;
        var tMaxW = currentDay.temperature_2m_max != null ? Math.round(Number(currentDay.temperature_2m_max)) : null;
        var tempStrW = tMinW != null && tMaxW != null ? tMinW + "\u00b0\u2013" + tMaxW + "\u00b0" : "";
        candidates.push({ item: { change_subtype:"_weather_window", affected_date:currentDay.date, alert_level:0, location_label: currentDay.location_label || "" }, tmpl: {
          type:"opportunity", barClass:"ab-opportunity",
          urgencyPill:{label:"Aujourd\u2019hui",style:"background:var(--color-pill-green-bg);color:var(--color-pill-green-text);"},
          typePill:{label:"M\u00e9t\u00e9o \u2713",style:"background:var(--color-pill-green-bg);color:var(--color-pill-green-text);"},
          what: "Premi\u00e8re belle journ\u00e9e apr\u00e8s " + prevBadDays + " jours de mauvais temps" + (tempStrW ? " \u2014 " + tempStrW : ""),
          sowhat: "Afflux de visiteurs probable \u2014 demande accumul\u00e9e apr\u00e8s " + prevBadDays + " jours d\u00e9favorables. Renforcez votre pr\u00e9sence.",
          actions: [
            {text:"Renforcez votre \u00e9quipe pour absorber l\u2019affluence",meta:"Exploitation \u00b7 \u00c9quipe",key:"staff_adjust",channel:CH_INTERNAL},
            {text:"Publiez un post \u00ab le soleil revient \u00bb avec votre programmation du jour",meta:"Communication \u00b7 Opportunit\u00e9",key:"visitor_comm",channel:CH_GBP},
            {text:"R\u00e9installez votre mobilier et signal\u00e9tique ext\u00e9rieurs",meta:"Exploitation \u00b7 Installations",key:"onsite_ops",channel:CH_INTERNAL},
          ],
        }, score: 85 });
      }
    }

    // ---- B1: Perfect storm — 3+ favorable factors align ----
    var b1Factors = [];
    if (currentDay.vacation_name) b1Factors.push(currentDay.vacation_name);
    if (currentDay.holiday_name) b1Factors.push(currentDay.holiday_name);
    if (Number(currentDay.alert_level_max || 0) === 0) b1Factors.push("beau temps");
    if (hasBaselineComp && compRatio > 0 && compRatio < 0.8) b1Factors.push("faible concurrence");
    var b1CommEvt = null;
    try { var b1ce = JSON.parse(String(currentDay.commercial_events || "{}")); if (b1ce.commercial_events && b1ce.commercial_events.length) b1CommEvt = b1ce.commercial_events[0].event_name; } catch(e) {}
    if (b1CommEvt) b1Factors.push(b1CommEvt);
    var b1DayOfWeek = parseYmdToDate(normalizeYmd(currentDay.date));
    var b1IsWeekend = b1DayOfWeek && (b1DayOfWeek.getUTCDay() === 0 || b1DayOfWeek.getUTCDay() === 6);
    if (b1IsWeekend) b1Factors.push("week-end");
    if (b1Factors.length >= 3) {
      candidates.push({ item: { change_subtype:"_perfect_storm", affected_date:currentDay.date, alert_level:0, location_label: currentDay.location_label || "" }, tmpl: {
        type:"opportunity", barClass:"ab-opportunity",
        urgencyPill:{label:"Aujourd\u2019hui",style:"background:var(--color-pill-green-bg);color:var(--color-pill-green-text);"},
        typePill:{label:"Fen\u00eatre rare",style:"background:var(--color-pill-green-bg);color:var(--color-pill-green-text);"},
        what: "Journ\u00e9e exceptionnelle : " + b1Factors.join(" + "),
        sowhat: "Alignement rare de " + b1Factors.length + " facteurs favorables. Ce type de journ\u00e9e ne se pr\u00e9sente que quelques fois par saison.",
        actions: [
          {text:"Lancez votre op\u00e9ration prioritaire \u2014 les conditions ne seront pas meilleures cette semaine",meta:"Strat\u00e9gie \u00b7 Timing",key:"marketing_push",channel:CH_INTERNAL},
          {text:"Prolongez vos horaires pour maximiser la journ\u00e9e",meta:"Exploitation \u00b7 Horaires",key:"staff_adjust",channel:CH_INTERNAL},
        ],
      }, score: 95 });
    }

    // ---- B5: Commercial event + audience/activity match ----
    if (b1CommEvt) {
      var b5Activity = String(prof.company_activity_type || "").toLowerCase();
      var b5Aud = String(prof.primary_audience_1 || "").toLowerCase();
      var b5EvtLower = b1CommEvt.toLowerCase();
      var b5Match = false;
      if (b5Activity === "culture" && (b5EvtLower.indexOf("mus\u00e9e") >= 0 || b5EvtLower.indexOf("patrimoine") >= 0 || b5EvtLower.indexOf("nuit") >= 0)) b5Match = true;
      if (b5Activity === "food_nightlife" && (b5EvtLower.indexOf("f\u00eate") >= 0 || b5EvtLower.indexOf("musique") >= 0 || b5EvtLower.indexOf("plage") >= 0)) b5Match = true;
      if (b5Activity === "commercial" && (b5EvtLower.indexOf("solde") >= 0 || b5EvtLower.indexOf("sales") >= 0 || b5EvtLower.indexOf("black friday") >= 0 || b5EvtLower.indexOf("no\u00ebl") >= 0 || b5EvtLower.indexOf("foire") >= 0)) b5Match = true;
      if (b5Activity === "sport" && (b5EvtLower.indexOf("sport") >= 0 || b5EvtLower.indexOf("natation") >= 0 || b5EvtLower.indexOf("tour de france") >= 0 || b5EvtLower.indexOf("championnat") >= 0)) b5Match = true;
      if (b5EvtLower.indexOf("fashion") >= 0 || b5EvtLower.indexOf("sial") >= 0) b5Match = b5Activity === "commercial" || b5Activity === "pro_event";
      if (!b5Match && (b5EvtLower.indexOf("f\u00eate de la musique") >= 0 || b5EvtLower.indexOf("paris plages") >= 0 || b5EvtLower.indexOf("14 juillet") >= 0)) b5Match = true;
      if (b5Match) {
        candidates.push({ item: { change_subtype:"_commercial_event", affected_date:currentDay.date, alert_level:0, location_label: currentDay.location_label || "" }, tmpl: {
          type:"opportunity", barClass:"ab-opportunity",
          urgencyPill:{label:"Cette semaine",style:"background:var(--color-pill-green-bg);color:var(--color-pill-green-text);"},
          typePill:{label:"\u00c9v\u00e9nement",style:"background:#EFF6FF;color:#1e40af;"},
          what: escapeHtml(b1CommEvt) + " \u2014 votre activit\u00e9 est directement concern\u00e9e",
          sowhat: "Cet \u00e9v\u00e9nement g\u00e9n\u00e8re du trafic qualifi\u00e9 pour votre secteur. Les visiteurs chercheront des lieux comme le v\u00f4tre.",
          actions: [
            {text:"Publiez votre programme li\u00e9 \u00e0 " + escapeHtml(b1CommEvt),meta:"Communication \u00b7 Actualit\u00e9",key:"visitor_comm",channel:CH_GBP},
            {text:"Adaptez vos horaires \u00e0 l\u2019affluence attendue",meta:"Exploitation \u00b7 Horaires",key:"staff_adjust",channel:CH_INTERNAL},
          ],
        }, score: 80 });
      }
    }

    // ---- C2: Same-bucket saturation ----
    var c2PctSameBucket = Number(currentDay.pct_same_bucket_5km || 0);
    var c2SameBucketCount = Number(currentDay.events_within_5km_same_bucket_count || 0);
    if (c2PctSameBucket > 25 && c2SameBucketCount > 5) {
      candidates.push({ item: { change_subtype:"_same_bucket_saturation", affected_date:currentDay.date, alert_level:2, location_label: currentDay.location_label || "" }, tmpl: {
        type:"threat", barClass:"ab-warning",
        urgencyPill:{label:"Aujourd\u2019hui",style:"background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);"},
        typePill:{label:"Saturation",style:"background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);"},
        what: c2SameBucketCount + " \u00e9v\u00e9nements dans votre secteur \u00e0 5 km (" + Math.round(c2PctSameBucket) + "% de l\u2019offre locale)",
        sowhat: "Densit\u00e9 \u00e9lev\u00e9e dans votre cat\u00e9gorie. Votre visibilit\u00e9 est dilu\u00e9e parmi des offres similaires.",
        actions: [
          {text:"Mettez en avant ce qui vous diff\u00e9rencie de l\u2019offre environnante",meta:"Communication \u00b7 Diff\u00e9renciation",key:"visitor_comm",channel:CH_GBP},
          {text:"D\u00e9calez votre cr\u00e9neau horaire pour \u00e9viter la concurrence frontale",meta:"Strat\u00e9gie \u00b7 Timing",key:"programming",channel:CH_INTERNAL},
        ],
      }, score: 60 });
    }

    // ---- D2: Extended bad weather — 3+ consecutive days ----
    if (todayIdx >= 0 && Number(currentDay.alert_level_max || 0) >= 2) {
      var d2ConsecutiveBad = 0;
      for (var d2i = todayIdx; d2i >= Math.max(0, todayIdx - 4); d2i--) {
        if (Number(sortedByDate[d2i].alert_level_max || 0) >= 2) d2ConsecutiveBad++;
        else break;
      }
      if (d2ConsecutiveBad >= 3) {
        var d2NextGood = null;
        for (var d2j = todayIdx + 1; d2j < sortedByDate.length; d2j++) {
          if (Number(sortedByDate[d2j].alert_level_max || 0) <= 1) {
            d2NextGood = fmtDateShort(normalizeYmd(sortedByDate[d2j].date));
            break;
          }
        }
        candidates.push({ item: { change_subtype:"_extended_bad_weather", affected_date:currentDay.date, alert_level:3, location_label: currentDay.location_label || "" }, tmpl: {
          type:"threat", barClass:"ab-threat",
          urgencyPill:{label:"Urgent",style:"background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);"},
          typePill:{label:"M\u00e9t\u00e9o",style:"background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);"},
          what: d2ConsecutiveBad + "e jour cons\u00e9cutif de mauvais temps" + (d2NextGood ? " \u2014 prochaine fen\u00eatre : " + d2NextGood : ""),
          sowhat: "P\u00e9riode prolong\u00e9e de conditions d\u00e9favorables. L\u2019impact cumul\u00e9 sur la fr\u00e9quentation est significatif.",
          actions: [
            {text:"Basculez sur votre plan B int\u00e9rieur pour les prochaines 24h",meta:"Exploitation \u00b7 Plan B",key:"programming",channel:CH_INTERNAL},
            {text:"R\u00e9duisez vos effectifs jusqu\u2019\u00e0 la prochaine fen\u00eatre favorable",meta:"Exploitation \u00b7 \u00c9quipe",key:"staff_adjust",channel:CH_INTERNAL},
            d2NextGood ? {text:"Pr\u00e9parez votre communication de reprise pour " + d2NextGood,meta:"Communication \u00b7 Anticipation",key:"visitor_comm",channel:CH_GBP} : {text:"Surveillez les pr\u00e9visions pour identifier la prochaine fen\u00eatre",meta:"Exploitation \u00b7 Veille",key:"onsite_ops",channel:CH_INTERNAL},
          ],
        }, score: 85 });
      }
    }

    // ---- D5: Weather + mobility double hit ----
    if (Number(currentDay.alert_level_max || 0) >= 2) {
      var d5HasMobility = false;
      var d5MobCount = 0;
      var d5MobLine = "";
      for (var d5i = 0; d5i < allFeed.length; d5i++) {
        var d5f = allFeed[d5i];
        var d5sub = String(d5f.change_subtype || "").toLowerCase();
        var d5affected = normalizeYmd(d5f.affected_date);
        if (d5affected === today && (d5sub === "mobility_disruption" || d5sub === "mobility_disruption_planned")) {
          d5HasMobility = true;
          d5MobCount++;
          if (!d5MobLine && d5f.event_label) d5MobLine = String(d5f.event_label);
        }
      }
      if (d5HasMobility) {
        var d5WeatherTypes = [];
        if (Number(currentDay.lvl_rain || 0) > 0) d5WeatherTypes.push("pluie niv. " + currentDay.lvl_rain);
        if (Number(currentDay.lvl_wind || 0) > 0) d5WeatherTypes.push("vent niv. " + currentDay.lvl_wind);
        if (Number(currentDay.lvl_snow || 0) > 0) d5WeatherTypes.push("neige niv. " + currentDay.lvl_snow);
        var d5WeatherLabel = d5WeatherTypes.length ? d5WeatherTypes.join(" + ") : "m\u00e9t\u00e9o d\u00e9grad\u00e9e";
        candidates.push({ item: { change_subtype:"_weather_mobility_double", affected_date:currentDay.date, alert_level:3, location_label: currentDay.location_label || "" }, tmpl: {
          type:"threat", barClass:"ab-threat",
          urgencyPill:{label:"Urgent",style:"background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);"},
          typePill:{label:"Double impact",style:"background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);"},
          what: "M\u00e9t\u00e9o (" + d5WeatherLabel + ") + " + d5MobCount + " perturbation" + (d5MobCount > 1 ? "s" : "") + " mobilit\u00e9" + (d5MobLine ? " (" + escapeHtml(d5MobLine) + ")" : ""),
          sowhat: "Vos visiteurs sont impact\u00e9s des deux c\u00f4t\u00e9s : conditions ext\u00e9rieures d\u00e9grad\u00e9es ET acc\u00e8s perturb\u00e9. Journ\u00e9e \u00e0 haut risque op\u00e9rationnel.",
          actions: [
            {text:"R\u00e9duisez votre \u00e9quipe \u2014 fr\u00e9quentation tr\u00e8s en dessous de la normale",meta:"Exploitation \u00b7 \u00c9quipe",key:"staff_adjust",channel:CH_INTERNAL},
            {text:"Pr\u00e9venez vos visiteurs et prestataires des conditions d\u2019acc\u00e8s",meta:"Communication \u00b7 Acc\u00e8s",key:"visitor_comm",channel:CH_EMAIL},
            {text:"Reportez livraisons et interventions ext\u00e9rieures si possible",meta:"Coordination \u00b7 Fournisseurs",key:"supplier_coord",channel:CH_PHONE},
          ],
        }, score: 90 });
      }
    }

    // ---- A3: Tourist surge + vacation ----
    var a3VacationName = currentDay.vacation_name || null;
    if (a1HasSignal && a1TourismIdx > 75 && a3VacationName) {
      candidates.push({ item: { change_subtype:"_tourist_surge_vacation", affected_date:currentDay.date, alert_level:0, location_label: currentDay.location_label || "" }, tmpl: {
        type:"opportunity", barClass:"ab-opportunity",
        urgencyPill:{label:"Cette semaine",style:"background:var(--color-pill-green-bg);color:var(--color-pill-green-text);"},
        typePill:{label:"Tourisme + Vacances",style:"background:#EFF6FF;color:#1e40af;"},
        what: "Saison haute touristique (" + Math.round(a1TourismIdx) + "%) + " + escapeHtml(a3VacationName),
        sowhat: "Double effet : touristes ET vacanciers pr\u00e9sents simultan\u00e9ment. P\u00e9riode de pointe confirm\u00e9e.",
        actions: [
          {text:"Lancez votre offre haute saison \u2014 conditions optimales cette semaine",meta:"Marketing \u00b7 Pricing",key:"pricing",channel:CH_GBP},
          {text:"Prolongez vos horaires pour maximiser la p\u00e9riode",meta:"Exploitation \u00b7 Horaires",key:"staff_adjust",channel:CH_INTERNAL},
          {text:"Publiez du contenu ciblant touristes et familles en vacances",meta:"Communication \u00b7 Ciblage",key:"visitor_comm",channel:CH_GBP},
        ],
      }, score: 82 });
    }

    // ---- S3: Saturated + bad weather = write-off day ----
    var c2PctSameBucketM = Number(currentDay.pct_same_bucket_5km || 0);
    var c2SameBucketCountM = Number(currentDay.events_within_5km_same_bucket_count || 0);
    if (Number(currentDay.alert_level_max || 0) >= 2 && c2PctSameBucketM > 25 && c2SameBucketCountM > 5) {
      candidates.push({ item: { change_subtype:"_saturated_bad_weather", affected_date:currentDay.date, alert_level:3, location_label: currentDay.location_label || "" }, tmpl: {
        type:"threat", barClass:"ab-threat",
        urgencyPill:{label:"Urgent",style:"background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);"},
        typePill:{label:"Double n\u00e9gatif",style:"background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);"},
        what: "Mauvais temps + " + c2SameBucketCountM + " concurrents m\u00eame secteur \u00e0 5 km",
        sowhat: "Votre \u00e9v\u00e9nement fait face \u00e0 une m\u00e9t\u00e9o d\u00e9grad\u00e9e ET une saturation de votre cat\u00e9gorie. Pr\u00e9parez un plan B.",
        actions: [
          {text:"Activez votre plan B int\u00e9rieur / format r\u00e9duit",meta:"Exploitation \u00b7 Plan B",key:"programming",channel:CH_INTERNAL},
          {text:"Pr\u00e9venez vos inscrits / visiteurs attendus des conditions",meta:"Communication \u00b7 Visiteurs",key:"visitor_comm",channel:CH_EMAIL},
        ],
      }, score: 88 });
    }

    // ---- S5: Mobility disruption + competition spike ----
    if (hasBaselineComp && compRatio > 1.2) {
      var s5HasMob = false;
      for (var s5i = 0; s5i < allFeed.length; s5i++) {
        var s5sub = String(allFeed[s5i].change_subtype || "").toLowerCase();
        var s5aff = normalizeYmd(allFeed[s5i].affected_date);
        if (s5aff === today && (s5sub === "mobility_disruption" || s5sub === "mobility_disruption_planned")) { s5HasMob = true; break; }
      }
      if (s5HasMob) {
        candidates.push({ item: { change_subtype:"_mobility_comp_squeeze", affected_date:currentDay.date, alert_level:3, location_label: currentDay.location_label || "" }, tmpl: {
          type:"threat", barClass:"ab-threat",
          urgencyPill:{label:"Urgent",style:"background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);"},
          typePill:{label:"Double pression",style:"background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);"},
          what: "Acc\u00e8s perturb\u00e9 + concurrence sup\u00e9rieure \u00e0 la moyenne (\u00d7" + compRatio.toFixed(1) + ")",
          sowhat: "Vos visiteurs ont du mal \u00e0 venir ET d\u2019autres \u00e9v\u00e9nements captent l\u2019attention. Communiquez sur l\u2019acc\u00e8s.",
          actions: [
            {text:"Envoyez l\u2019itin\u00e9raire alternatif \u00e0 vos inscrits / visiteurs attendus",meta:"Communication \u00b7 Acc\u00e8s",key:"visitor_comm",channel:CH_EMAIL},
            {text:"Publiez l\u2019itin\u00e9raire sur vos r\u00e9seaux et Google",meta:"Communication \u00b7 Acc\u00e8s",key:"access_comm",channel:CH_GBP},
            {text:"Pr\u00e9voyez un accueil renforc\u00e9 pour orienter les visiteurs",meta:"Exploitation \u00b7 Accueil",key:"staff_adjust",channel:CH_INTERNAL},
          ],
        }, score: 87 });
      }
    }

    // ---- T5: Tourism peak + mobility disruption ----
    if (a1HasSignal && a1TourismStatus === "high") {
      var t5HasMob = false;
      for (var t5i = 0; t5i < allFeed.length; t5i++) {
        var t5sub = String(allFeed[t5i].change_subtype || "").toLowerCase();
        var t5aff = normalizeYmd(allFeed[t5i].affected_date);
        if (t5aff === today && (t5sub === "mobility_disruption" || t5sub === "mobility_disruption_planned")) { t5HasMob = true; break; }
      }
      if (t5HasMob) {
        candidates.push({ item: { change_subtype:"_tourism_mobility_hit", affected_date:currentDay.date, alert_level:3, location_label: currentDay.location_label || "" }, tmpl: {
          type:"threat", barClass:"ab-threat",
          urgencyPill:{label:"Urgent",style:"background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);"},
          typePill:{label:"Tourisme + Mobilit\u00e9",style:"background:var(--color-pill-risk-bg);color:var(--color-pill-risk-text);"},
          what: "Pic touristique r\u00e9gional + perturbation mobilit\u00e9 active",
          sowhat: "Les touristes d\u00e9pendent davantage des transports. Votre \u00e9v\u00e9nement risque de perdre une partie de son public international.",
          actions: [
            {text:"Publiez l\u2019itin\u00e9raire alternatif en fran\u00e7ais ET en anglais",meta:"Communication \u00b7 Acc\u00e8s",key:"visitor_comm",channel:CH_GBP},
            {text:"Envoyez un email / SMS \u00e0 vos inscrits avec les conditions d\u2019acc\u00e8s",meta:"Communication \u00b7 Inscrits",key:"visitor_comm",channel:CH_EMAIL},
            {text:"Renforcez l\u2019accueil pour orienter les visiteurs perdus",meta:"Exploitation \u00b7 Accueil",key:"staff_adjust",channel:CH_INTERNAL},
          ],
        }, score: 85 });
      }
    }

    // ---- S4: Holiday + high competition = differentiation urgency ----
    if (currentDay.holiday_name && hasBaselineComp && compRatio > 1.3) {
      candidates.push({ item: { change_subtype:"_holiday_high_comp", affected_date:currentDay.date, alert_level:2, location_label: currentDay.location_label || "" }, tmpl: {
        type:"threat", barClass:"ab-warning",
        urgencyPill:{label:"Jour J",style:"background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);"},
        typePill:{label:"Diff\u00e9renciation",style:"background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);"},
        what: escapeHtml(currentDay.holiday_name) + " \u2014 pression concurrentielle \u00e9lev\u00e9e (\u00d7" + compRatio.toFixed(1) + " vs moyenne)",
        sowhat: "Votre \u00e9v\u00e9nement tombe un jour f\u00e9ri\u00e9 avec forte concurrence. Communiquez sur ce qui vous rend unique.",
        actions: [
          {text:"Publiez ce qui diff\u00e9rencie votre \u00e9v\u00e9nement de l\u2019offre environnante",meta:"Communication \u00b7 Diff\u00e9renciation",key:"visitor_comm",channel:CH_GBP},
          {text:"Relancez vos inscrits avec un rappel + argument cl\u00e9",meta:"Communication \u00b7 Relance",key:"visitor_comm",channel:CH_EMAIL},
        ],
      }, score: 72 });
    }

    candidates.sort(function(a,b) { return b.score - a.score; });
    var seen = {};
    var top = [];
    for (var j = 0; j < candidates.length && top.length < 5; j++) {
      var c = candidates[j];
      var sub2 = String(c.item.change_subtype||"").toLowerCase();
      var dedup = sub2 + "|" + normalizeYmd(c.item.affected_date);
      if (seen[dedup]) continue;
      seen[dedup] = true;
      top.push(c);
    }

    if (top.length === 0) {
      return '<div style="margin-bottom:20px;">'
        + '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">'
          + '<span style="font-size:11px;font-weight:700;letter-spacing:0.10em;text-transform:uppercase;color:#1D3BB3;">Vos actions du jour</span>'
        + '</div>'
        + '<div class="ab-zero"><span style="font-size:18px;">\u2713</span><span>Aucune action requise \u2014 votre journ\u00e9e est sous contr\u00f4le</span></div>'
      + '</div>';
    }

    var checked = briefLoadChecked(locationId, selectedDate);

    var totalActions = 0;
    var totalChecked = 0;
    var cardsHtml = top.map(function(entry, cardIdx) {
      var t = entry.tmpl;
      var cardId = "ab-card-" + cardIdx;
      var cardWhat = t.what;
      var cardSowhat = t.sowhat;
      var actionsHtml = t.actions.map(function(act, actIdx) {
        var actKey = cardIdx + "-" + actIdx;
        var isDone = checked[actKey] ? true : false;
        totalActions++;
        if (isDone) totalChecked++;
        var ts = checked[actKey] || "";
        var showCopy = act.channel !== CH_INTERNAL;
        var hasProfile = Boolean(prof.business_short_description);
        var showGen = act.channel !== CH_INTERNAL && act.channel !== CH_PHONE;
        var genData = showGen ? ' data-ab-gen="' + actKey + '" data-ab-gen-sub="' + escapeHtml(String(entry.item.change_subtype||"")) + '" data-ab-gen-actkey="' + escapeHtml(act.key) + '" data-ab-gen-acttext="' + escapeHtml(act.text) + '" data-ab-gen-channel="' + escapeHtml(act.channel||"") + '" data-ab-gen-affected="' + escapeHtml(normalizeYmd(entry.item.affected_date)||"") + '" data-ab-gen-what="' + escapeHtml(String(cardWhat).replace(/<[^>]+>/g,"")) + '" data-ab-gen-sowhat="' + escapeHtml(String(cardSowhat||"")) + '"' : '';
        var itemSignalJson = showGen ? ' data-ab-gen-signal=\'' + escapeHtml(JSON.stringify({change_subtype:String(entry.item.change_subtype||""),event_label:entry.item.event_label||null,distance_m:entry.item.distance_m!=null?Number(entry.item.distance_m):null,mobility_mode:entry.item.mobility_mode||null,affected_date:normalizeYmd(entry.item.affected_date)||null,old_value:entry.item.old_value!=null?String(entry.item.old_value):null,new_value:entry.item.new_value!=null?String(entry.item.new_value):null,city_name:entry.item.city_name||null,event_venue_name:entry.item.event_venue_name||null,lvl_rain:entry.item.lvl_rain||0,lvl_wind:entry.item.lvl_wind||0,lvl_snow:entry.item.lvl_snow||0,lvl_heat:entry.item.lvl_heat||0,lvl_cold:entry.item.lvl_cold||0,score_delta:entry.item.score_delta!=null?Number(entry.item.score_delta):null,mobility_disruption_category:entry.item.mobility_disruption_category||null})) + '\'' : '';
        return '<div class="ab-action-item">'
          + '<div class="ab-check' + (isDone ? " is-checked" : "") + '" data-ab-check="' + actKey + '" data-ab-sub="' + escapeHtml(String(entry.item.change_subtype||"")) + '" data-ab-actkey="' + escapeHtml(act.key) + '" data-ab-acttext="' + escapeHtml(act.text) + '" data-ab-affected="' + escapeHtml(normalizeYmd(entry.item.affected_date)||"") + '" data-ab-channel="' + escapeHtml(act.channel||"") + '">'
            + (isDone ? "\u2713" : "")
          + '</div>'
          + '<div style="flex:1;min-width:0;">'
            + '<div class="ab-action-text' + (isDone ? " is-done" : "") + '">' + escapeHtml(act.text) + '</div>'
            + '<div class="ab-action-meta"' + (isDone ? ' style="color:#059669;"' : '') + '>' + (isDone ? "\u2713 Fait \u00e0 " + ts : escapeHtml(act.meta)) + '</div>'
            + '<div class="ab-draft-panel" id="ab-draft-' + actKey + '"></div>'
          + '</div>'
          + (showCopy || showGen ? '<div class="ab-action-right">'
            + (showGen ? (hasProfile ? '<button type="button" class="ab-gen"' + genData + itemSignalJson + '>G\u00e9n\u00e9rer \u2192</button>' : '<a href="/profile" style="font-size:10px;color:#9CA3AF;text-decoration:none;">Compl\u00e9tez votre profil \u2192</a>') : '')
          + '</div>' : '')
        + '</div>';
      }).join("");
      var doneCount = t.actions.reduce(function(sum, _, ai) { return sum + (checked[cardIdx+"-"+ai] ? 1 : 0); }, 0);
      var pct = Math.round(doneCount / t.actions.length * 100);
      return '<div class="ab-card" id="' + cardId + '">'
        + '<div class="ab-card-row">'
          + '<div class="ab-bar ' + t.barClass + '"></div>'
          + '<div class="ab-inner">'
            + '<div class="ab-summary" data-ab-toggle="' + cardId + '">'
              + '<div class="ab-pills">'
                + '<span class="ab-pill" style="' + t.urgencyPill.style + '">' + escapeHtml(t.urgencyPill.label) + '</span>'
                + '<span class="ab-pill" style="' + t.typePill.style + '">' + escapeHtml(t.typePill.label) + '</span>'
              + '</div>'
              + '<div class="ab-what">' + t.what + '</div>'
              + '<div class="ab-sowhat">' + escapeHtml(t.sowhat) + '</div>'
            + '</div>'
            + '<div class="ab-toggle">'
              + '<button type="button" class="ab-toggle-btn" data-ab-toggle="' + cardId + '">'
                + '<span data-ab-chevron="' + cardId + '">\u25be</span> '
                + 'Agir \u2014 ' + t.actions.length + ' actions recommand\u00e9es'
              + '</button>'
            + '</div>'
            + '<div class="ab-actions" id="' + cardId + '-actions" data-ab-card-idx="' + cardIdx + '">'
              + actionsHtml
              + '<div class="ab-progress">'
                + '<div class="ab-progress-bar"><div class="ab-progress-fill" style="width:' + pct + '%;"></div></div>'
                + '<span class="ab-progress-label">' + doneCount + '/' + t.actions.length + '</span>'
              + '</div>'
              + '<a href="#" class="ab-help-link" data-ab-help="' + cardIdx + '" data-ab-help-what="' + escapeHtml(t.what.replace(/<[^>]+>/g,"")) + '" data-ab-help-sowhat="' + escapeHtml(t.sowhat) + '">Besoin d\u2019aide pour agir ? \u2192</a>'
            + '</div>'
          + '</div>'
        + '</div>'
      + '</div>';
    }).join("");

    var countLabel = totalChecked > 0 ? totalChecked + "/" + totalActions + " trait\u00e9es" : top.length + " action" + (top.length>1?"s":"");

    return '<div style="margin-bottom:20px;" id="daily-brief-section">'
      + '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">'
        + '<span style="font-size:11px;font-weight:700;letter-spacing:0.10em;text-transform:uppercase;color:#1D3BB3;">Vos actions du jour</span>'
        + '<span style="font-size:11px;color:#9ca3af;">' + escapeHtml(countLabel) + '</span>'
      + '</div>'
      + cardsHtml
    + '</div>';
  }

  // ---- Wire handlers ----
  function wireBriefHandlers(root, locationId, selectedDate) {
    // Toggle cards
    root.querySelectorAll("[data-ab-toggle]").forEach(function(el) {
      el.addEventListener("click", function(e) {
        e.stopPropagation();
        var cardId = el.getAttribute("data-ab-toggle");
        var actions = document.getElementById(cardId + "-actions");
        var chevron = root.querySelector('[data-ab-chevron="'+cardId+'"]');
        if (!actions) return;
        var open = actions.classList.toggle("is-open");
        if (chevron) chevron.textContent = open ? "\u25b4" : "\u25be";
      });
    });

    // Checkboxes
    root.querySelectorAll("[data-ab-check]").forEach(function(el) {
      el.addEventListener("click", function() {
        var key = el.getAttribute("data-ab-check");
        var checked = briefLoadChecked(locationId, selectedDate);
        var isDone = el.classList.contains("is-checked");
        var textEl = el.parentElement.querySelector(".ab-action-text");
        var metaEl = el.parentElement.querySelector(".ab-action-meta");

        if (isDone) {
          el.classList.remove("is-checked");
          el.textContent = "";
          if (textEl) textEl.classList.remove("is-done");
          if (metaEl && metaEl.dataset.original) { metaEl.textContent = metaEl.dataset.original; metaEl.style.color = ""; }
          delete checked[key];
        } else {
          var now = new Date();
          var ts = String(now.getHours()).padStart(2,"0")+":"+String(now.getMinutes()).padStart(2,"0");
          el.classList.add("is-checked");
          el.textContent = "\u2713";
          if (textEl) textEl.classList.add("is-done");
          if (metaEl) { metaEl.dataset.original = metaEl.dataset.original || metaEl.textContent; metaEl.textContent = "\u2713 Fait \u00e0 " + ts; metaEl.style.color = "#059669"; }
          checked[key] = ts;
        }

        briefSaveChecked(locationId, selectedDate, checked);

        var card = el.closest(".ab-card");
        if (card) {
          var total = card.querySelectorAll("[data-ab-check]").length;
          var done = card.querySelectorAll("[data-ab-check].is-checked").length;
          var fill = card.querySelector(".ab-progress-fill");
          var label = card.querySelector(".ab-progress-label");
          if (fill) fill.style.width = Math.round(done/total*100) + "%";
          if (label) label.textContent = done + "/" + total;
        }

        // Analytics (fire-and-forget)
        fetch("/api/insight/action-log", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            location_id: locationId,
            affected_date: el.getAttribute("data-ab-affected") || null,
            change_subtype: el.getAttribute("data-ab-sub") || null,
            action_key: el.getAttribute("data-ab-actkey") || null,
            action_text: el.getAttribute("data-ab-acttext") || null,
            action_category: el.getAttribute("data-ab-actkey") || null,
            channel: el.getAttribute("data-ab-channel") || null,
            event: isDone ? "uncheck" : "check",
          }),
        }).catch(function(){});
      });
    });

    // Clipboard copy buttons
    root.querySelectorAll("[data-ab-copy]").forEach(function(el) {
      el.addEventListener("click", function(e) {
        e.stopPropagation();
        var what = el.getAttribute("data-ab-copy-what") || "";
        var text = el.getAttribute("data-ab-copy-text") || "";
        var clipText = briefClipboardText(what, "", text);
        navigator.clipboard.writeText(clipText).then(function() {
          el.textContent = "Copi\u00e9 \u2713";
          el.classList.add("is-copied");
          setTimeout(function() { el.textContent = "Copier"; el.classList.remove("is-copied"); }, 2000);
        }).catch(function() {
          // Fallback for older browsers
          var ta = document.createElement("textarea");
          ta.value = clipText;
          ta.style.position = "fixed";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          document.body.removeChild(ta);
          el.textContent = "Copi\u00e9 \u2713";
          el.classList.add("is-copied");
          setTimeout(function() { el.textContent = "Copier"; el.classList.remove("is-copied"); }, 2000);
        });
      });
    });

    // "Générer →" draft buttons
    root.querySelectorAll("[data-ab-gen]").forEach(function(el) {
      el.addEventListener("click", async function(e) {
        e.stopPropagation();
        var actKey = el.getAttribute("data-ab-gen");
        var panel = document.getElementById("ab-draft-" + actKey);
        if (!panel) return;

        // Toggle off if already open
        if (panel.classList.contains("is-open") && panel.innerHTML.trim()) {
          panel.classList.remove("is-open");
          el.textContent = "G\u00e9n\u00e9rer \u2192";
          return;
        }

        // Loading state
        el.textContent = "\u2026";
        el.classList.add("is-loading");
        panel.classList.add("is-open");
        panel.innerHTML = '<div style="color:#9CA3AF;font-size:11px;display:flex;align-items:center;gap:6px;"><span style="width:10px;height:10px;border:1.5px solid #E5E7EB;border-top-color:#1D3BB3;border-radius:50%;display:inline-block;animation:ms-spin 0.7s linear infinite;flex-shrink:0;"></span>G\u00e9n\u00e9ration en cours\u2026</div>';

        var signalJson = {};
        try { signalJson = JSON.parse(el.getAttribute("data-ab-gen-signal") || "{}"); } catch {}

        var payload = {
          action_key: el.getAttribute("data-ab-gen-actkey") || "",
          channel: el.getAttribute("data-ab-gen-channel") || "",
          change_subtype: el.getAttribute("data-ab-gen-sub") || "",
          signal: signalJson,
          card_what: el.getAttribute("data-ab-gen-what") || "",
          card_sowhat: el.getAttribute("data-ab-gen-sowhat") || "",
        };

        try {
          var res = await fetch("/api/insight/generate-action-draft", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(payload),
          });
          var json = await res.json().catch(function() { return null; });
          if (!json?.ok || !json?.draft?.full_text) throw new Error(json?.error || "Draft vide");

          var draft = json.draft;
          var channelLabel = draft.channel === "gbp" ? "Google Business Profile" : draft.channel === "instagram" ? "Instagram" : draft.channel === "email" ? "Email" : draft.channel === "sms" ? "SMS" : draft.channel;
          var titleLine = draft.title ? '<div style="font-size:11px;font-weight:700;color:#1D3BB3;margin-bottom:4px;">' + escapeHtml(draft.title) + '</div>' : '';
          var subjectLine = draft.subject ? '<div style="font-size:11px;font-weight:600;color:#374151;margin-bottom:4px;">Objet : ' + escapeHtml(draft.subject) + '</div>' : '';

          panel.innerHTML = '<div style="margin-bottom:6px;display:flex;align-items:center;gap:6px;">'
            + '<span style="font-size:9px;font-weight:700;padding:2px 7px;border-radius:3px;background:#EFF6FF;color:#1e40af;text-transform:uppercase;letter-spacing:0.03em;">' + escapeHtml(channelLabel) + '</span>'
            + '<span style="font-size:10px;color:#9CA3AF;">' + (draft.char_count || 0) + ' car.</span>'
          + '</div>'
          + titleLine + subjectLine
          + '<pre>' + escapeHtml(draft.body || draft.full_text) + '</pre>'
          + (draft.hashtags ? '<div style="font-size:11px;color:#6366f1;margin-bottom:6px;">' + escapeHtml(draft.hashtags) + '</div>' : '')
          + '<div class="ab-draft-actions">'
            + '<button type="button" class="ab-draft-copy" data-draft-text="' + escapeHtml(draft.full_text) + '">Copier le texte</button>'
            + '<button type="button" class="ab-draft-regen" data-draft-regen="' + escapeHtml(actKey) + '">R\u00e9g\u00e9n\u00e9rer</button>'
            + '<button type="button" class="ab-draft-dismiss" data-draft-dismiss="' + escapeHtml(actKey) + '">Fermer</button>'
          + '</div>';

          el.textContent = "G\u00e9n\u00e9r\u00e9 \u2713";
          el.classList.remove("is-loading");

          // Wire draft panel buttons
          panel.querySelector(".ab-draft-copy")?.addEventListener("click", function() {
            var text = this.getAttribute("data-draft-text") || "";
            navigator.clipboard.writeText(text).then(function() {
              panel.querySelector(".ab-draft-copy").textContent = "Copi\u00e9 \u2713";
              setTimeout(function() { panel.querySelector(".ab-draft-copy").textContent = "Copier le texte"; }, 2000);
            }).catch(function() {});
          });

          panel.querySelector(".ab-draft-regen")?.addEventListener("click", function() {
            panel.classList.remove("is-open");
            panel.innerHTML = "";
            el.textContent = "G\u00e9n\u00e9rer \u2192";
            el.classList.remove("is-loading");
            el.click();
          });

          panel.querySelector(".ab-draft-dismiss")?.addEventListener("click", function() {
            panel.classList.remove("is-open");
            panel.innerHTML = "";
            el.textContent = "G\u00e9n\u00e9rer \u2192";
            el.classList.remove("is-loading");
          });

        } catch(err) {
          panel.innerHTML = '<div style="font-size:11px;color:#B91C1C;">Erreur : ' + escapeHtml(err?.message || "R\u00e9essayez") + '</div>';
          el.textContent = "G\u00e9n\u00e9rer \u2192";
          el.classList.remove("is-loading");
        }
      });
    });

    // Help links → concierge overlay
    root.querySelectorAll("[data-ab-help]").forEach(function(el) {
      el.addEventListener("click", function(e) {
        e.preventDefault();
        e.stopPropagation();
        var overlay = document.getElementById("ab-help-overlay");
        var ctx = document.getElementById("ab-help-ctx");
        if (!overlay) return;
        var what = el.getAttribute("data-ab-help-what") || "";
        var sowhat = el.getAttribute("data-ab-help-sowhat") || "";
        if (ctx) ctx.innerHTML = "<strong>Signal :</strong> " + escapeHtml(what) + "<br><strong>Impact :</strong> " + escapeHtml(sowhat) + "<br><br>D\u00e9crivez ce dont vous avez besoin. Notre \u00e9quipe vous r\u00e9pond sous 2 heures.";
        overlay.__abWhat = what;
        overlay.__abSowhat = sowhat;
        overlay.__abSub = el.closest("[data-ab-card-idx]")?.getAttribute("data-ab-card-idx") || "";
        overlay.classList.add("is-open");
      });
    });

    // Concierge form cancel / submit
    var cancelBtn = document.getElementById("ab-help-cancel");
    if (cancelBtn) cancelBtn.onclick = function() {
      var ov = document.getElementById("ab-help-overlay");
      if (ov) ov.classList.remove("is-open");
      var n = document.getElementById("ab-help-note"); if (n) n.value = "";
    };
    var submitBtn = document.getElementById("ab-help-submit");
    if (submitBtn) submitBtn.onclick = async function() {
      var ov = document.getElementById("ab-help-overlay");
      var noteEl = document.getElementById("ab-help-note");
      var note = noteEl ? noteEl.value : "";
      submitBtn.disabled = true;
      submitBtn.textContent = "Envoi en cours\u2026";
      try {
        await fetch("/api/insight/action-request", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            action_type: "aide_concierge",
            note: note,
            change_subtype: "_help_request",
            signal_summary: ov?.__abWhat || "",
            impact_summary: ov?.__abSowhat || "",
            recommended_action: null,
            affected_date: selectedDate || null,
            location_id: locationId,
            entity_id: null,
            alert_level: 0,
            urgency_label: null,
          }),
        });
        submitBtn.textContent = "\u2713 Demande envoy\u00e9e";
        setTimeout(function() {
          if (ov) ov.classList.remove("is-open");
          submitBtn.textContent = "Envoyer \u2014 r\u00e9ponse sous 2h";
          submitBtn.disabled = false;
          if (noteEl) noteEl.value = "";
        }, 1500);
      } catch {
        submitBtn.textContent = "Erreur r\u00e9seau";
        submitBtn.disabled = false;
      }
    };
  }

  // ----------------------------------------------------------------
  // V4 NEW — Radar strip (collapsible)
  // ----------------------------------------------------------------
  function renderRadarStrip(id, icon, summary, alertLevel, expandedHtml) {
    const borderColor = alertLevel === "critical" ? "#ef4444" : alertLevel === "warning" ? "#f59e0b" : "#e5e7eb";
    return `
      <div id="radar-strip-${escapeHtml(id)}" style="background:#fff;border-radius:10px;border:1px solid #e5e7eb;border-left:4px solid ${borderColor};overflow:hidden;margin-bottom:6px;transition:border-color 0.15s;">
        <div data-radar-toggle="${escapeHtml(id)}" style="display:flex;align-items:center;gap:10px;padding:12px 14px;cursor:pointer;">
          <span style="font-size:15px;flex-shrink:0;">${icon}</span>
          <div style="flex:1;min-width:0;font-size:13.5px;color:#1f2937;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
            ${summary}
          </div>
          <span data-radar-chevron="${escapeHtml(id)}" style="font-size:11px;color:#9ca3af;transition:transform 0.15s;flex-shrink:0;">▾</span>
        </div>
        <div data-radar-body="${escapeHtml(id)}" style="display:none;padding:0 14px 14px;border-top:1px solid #f3f4f6;">
          ${expandedHtml}
        </div>
      </div>`;
  }

  // ----------------------------------------------------------------
  // V4 NEW — Score detail (strip 1 expanded)
  // ----------------------------------------------------------------
  function renderScoreDetail(day, days) {
    const score = day.opportunity_score;
    const regime = String(day.opportunity_regime || "B").toUpperCase();
    const regimeMap = { A: { t: "Contexte favorable", bg: "#dcfce7", fg: "#166534" }, C: { t: "Contexte défavorable", bg: "#fee2e2", fg: "#991b1b" } };
    const rd = regimeMap[regime] || { t: "Conditions normales", bg: "#f3f4f6", fg: "#374151" };

    // weekRank: position of this day among all days sorted by score DESC
    const sorted = [...days].filter(d => d.opportunity_score != null).sort((a, b) => (b.opportunity_score ?? 0) - (a.opportunity_score ?? 0));
    const rankIdx = sorted.findIndex(d => normalizeYmd(d.date) === normalizeYmd(day.date));
    const rank = rankIdx >= 0 ? rankIdx + 1 : null;
    const total = sorted.length;
    let weekRankLabel = "";
    if (rank === 1) weekRankLabel = "Meilleur jour";
    else if (rank === total) weekRankLabel = "Jour le moins favorable";
    else if (rank != null) weekRankLabel = `${rank}e sur ${total} jours`;

    const scoreColor = score >= 7.5 ? "#059669" : score >= 5.5 ? "#d97706" : "#dc2626";

    // Context tags from daily_signal_summary_fr — filter to user-facing only
    const rawTags = Array.isArray(day.daily_signal_summary_fr) ? day.daily_signal_summary_fr : [];
    const TAG_BLOCKLIST = [
      "concurrence", "concurrence présente", "preuves complètes", "preuves incomplètes",
      "evidence_complete", "evidence_incomplete", "competition_present",
      "weather_alert_present", "weather_impact_present",
      "fenêtre stable", "fenêtre mixte", "fenêtre volatile",
      "stable_window", "mixed_window", "volatile_window",
      "weather_risk_present", "competition_spike_present",
    ];
    const tags = rawTags.filter(t => {
      if (!t) return false;
      const lower = String(t).toLowerCase();
      return !TAG_BLOCKLIST.some(blocked => lower === blocked || lower.includes(blocked));
    });
    const holidayTag = day.holiday_name || null;
    const vacationTag = day.vacation_name || null;

    let tagsHtml = "";
    const tagItems = [];
    if (holidayTag) tagItems.push(`<span style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:11.5px;font-weight:600;background:#fef2f2;color:#991b1b;">${escapeHtml(holidayTag)}</span>`);
    if (vacationTag) tagItems.push(`<span style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:11.5px;font-weight:600;background:#faf5ff;color:#6b21a8;">${escapeHtml(vacationTag)}</span>`);
    for (const t of tags) {
      if (t) tagItems.push(`<span style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:11.5px;font-weight:600;background:#f3f4f6;color:#374151;">${escapeHtml(t)}</span>`);
    }
    if (tagItems.length) {
      tagsHtml = `<div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;">${tagItems.join("")}</div>`;
    }

    // Weather (only if alert_level_max > 0)
    let weatherHtml = "";
    const alertMax = Number(day.alert_level_max || 0);
    if (alertMax > 0) {
      const wLabel = day.weather_label_fr || "Alerte météo";
      const tMin = day.temperature_2m_min != null ? Math.round(Number(day.temperature_2m_min)) : null;
      const tMax = day.temperature_2m_max != null ? Math.round(Number(day.temperature_2m_max)) : null;
      const tempStr = (tMin != null && tMax != null) ? `${tMin}° – ${tMax}°` : "";
      weatherHtml = `
        <div style="display:flex;align-items:center;gap:10px;margin-top:10px;padding:10px 12px;background:#fffbeb;border-radius:8px;">
          <span style="font-size:18px;">⚠️</span>
          <div style="flex:1;">
            <span style="font-size:13px;font-weight:600;color:#1f2937;">${escapeHtml(wLabel)}</span>
            ${tempStr ? `<span style="font-size:12px;color:#6b7280;"> · ${escapeHtml(tempStr)}</span>` : ""}
          </div>
          <span style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:10px;font-weight:600;background:#fef3c7;color:#92400e;">Niv. ${alertMax}</span>
        </div>`;
    }

    return `
      <div style="padding-top:12px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
          <div>
            ${score != null ? `<div style="display:flex;align-items:baseline;gap:6px;">
              <span style="font-size:36px;font-weight:800;color:${scoreColor};">${escapeHtml(String(score))}</span>
              <span style="font-size:14px;color:#9ca3af;">/10</span>
            </div>` : ""}
            ${weekRankLabel ? `<div style="font-size:12px;color:#6b7280;margin-top:2px;">${escapeHtml(weekRankLabel)}</div>` : ""}
          </div>
          <div style="text-align:right;">
            <span style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:11.5px;font-weight:600;background:${rd.bg};color:${rd.fg};">${escapeHtml(rd.t)}</span>
          </div>
        </div>
        ${tagsHtml}
        ${weatherHtml}
      </div>`;
  }

  // ----------------------------------------------------------------
  // V4 NEW — Threat summary (strip 2 expanded)
  // ----------------------------------------------------------------
  function renderThreatSummary(competitorSignals, selectedDate, followedCount) {
    // Delegates entirely to the existing 300-line renderSuivisMonitorSection
    return renderSuivisMonitorSection(competitorSignals, selectedDate, followedCount);
  }

  // ----------------------------------------------------------------
  // V4 NEW — Change detail (strip 3 expanded)
  // ----------------------------------------------------------------
  function renderChangeDetail(day, topThreats) {
    const count500 = Number(day.events_within_500m_count || 0);
    const count5km = Number(day.events_within_5km_count || 0);
    const pressureRatio = Number(day.competition_pressure_ratio || 0);
    const hasBaseline = Boolean(day.has_valid_baseline_flag);

    let pressureLabel = "";
    let pressureBg = "#f3f4f6";
    let pressureFg = "#374151";
    if (hasBaseline && pressureRatio > 1.2) {
      pressureLabel = "Sup\u00e9rieur \u00e0 la moyenne";
      pressureBg = "#fee2e2"; pressureFg = "#991b1b";
    } else if (hasBaseline && pressureRatio < 0.8) {
      pressureLabel = "Inf\u00e9rieur \u00e0 la moyenne";
      pressureBg = "#dcfce7"; pressureFg = "#166534";
    } else if (hasBaseline) {
      pressureLabel = "Dans la moyenne";
    }

    const AUDIENCE_FR = {
      local: "r\u00e9sidents locaux", professionals: "professionnels",
      tourists: "touristes", students: "\u00e9tudiants",
      families: "familles", seniors: "seniors",
      general_public: "grand public", art_lovers: "amateurs d'art",
      mixed: "public mixte"
    };

    const INDUSTRY_TIER_FR = {
      direct: "M\u00eame secteur",
      partial: "Secteur proche",
      contextual: "Secteur diff\u00e9rent"
    };

    const THREAT_BADGE = {
      high:     { bg: "#fee2e2", fg: "#991b1b", t: "Menace \u00e9lev\u00e9e" },
      moderate: { bg: "#fef3c7", fg: "#92400e", t: "Menace mod\u00e9r\u00e9e" },
      low:      { bg: "#f3f4f6", fg: "#6b7280", t: "Menace faible" },
    };

    function renderThreatCard(tc) {
      const name = tc.competitor_name || "Concurrent";
      const distKm = tc.distance_km != null ? Number(tc.distance_km).toFixed(1) : null;
      const badge = THREAT_BADGE[tc.threat_level] || THREAT_BADGE.low;
      const indLabel = INDUSTRY_TIER_FR[tc.industry_match_tier] || "";

      const locAuds = [tc.location_primary_audience_1, tc.location_primary_audience_2].filter(Boolean);
      const compAuds = [tc.competitor_primary_audience, tc.competitor_secondary_audience].filter(Boolean);
      const sharedAuds = compAuds.filter(a => locAuds.includes(a)).map(a => AUDIENCE_FR[a] || a);

      let audLine = "";
      if (sharedAuds.length > 0) {
        audLine = "Cible les m\u00eames audiences : " + sharedAuds.join(", ");
      } else if (compAuds.length > 0) {
        audLine = "Cible : " + compAuds.map(a => AUDIENCE_FR[a] || a).join(", ");
      }

      const initials = name.split(" ").map(w => (w[0] || "")).join("").slice(0, 2).toUpperCase();

      const detailParts = [];
      if (tc.competitor_industry_code) detailParts.push("Secteur : " + escapeHtml(tc.competitor_industry_code));
      if (tc.competitor_google_rating) detailParts.push("\u2605 " + tc.competitor_google_rating + (tc.competitor_google_rating_count ? " \u00b7 " + Number(tc.competitor_google_rating_count).toLocaleString("fr-FR") + " avis" : ""));

      return '<div class="ms-threat-card" style="background:#fff;border:0.5px solid #E8EDF5;border-radius:10px;overflow:hidden;margin-bottom:6px;">'
        + '<div style="display:flex;align-items:center;gap:10px;padding:12px 14px;">'
          + '<div style="width:36px;height:36px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-weight:500;font-size:13px;color:#0C447C;background:#E6F1FB;flex-shrink:0;">' + escapeHtml(initials) + '</div>'
          + '<div style="flex:1;min-width:0;">'
            + '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">'
              + '<span style="font-size:13px;font-weight:500;color:#111827;">' + escapeHtml(name) + '</span>'
              + (distKm ? '<span style="font-size:11px;color:#6b7280;">' + escapeHtml(distKm + ' km') + '</span>' : '')
            + '</div>'
            + '<div style="display:flex;align-items:center;gap:6px;margin-top:3px;flex-wrap:wrap;">'
              + '<span style="display:inline-block;padding:1px 8px;border-radius:4px;font-size:10px;font-weight:600;background:' + badge.bg + ';color:' + badge.fg + ';">' + escapeHtml(badge.t) + '</span>'
              + (indLabel ? '<span style="font-size:11px;color:#6b7280;">' + escapeHtml(indLabel) + '</span>' : '')
            + '</div>'
            + (audLine ? '<div style="font-size:11px;color:#374151;margin-top:3px;">' + escapeHtml(audLine) + '</div>' : '')
          + '</div>'
          + '<div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;">'
            + '<button type="button" data-follow-threat="' + escapeHtml(tc.competitor_id) + '" data-follow-name="' + escapeHtml(name) + '" style="padding:4px 10px;border-radius:6px;border:1px solid #dbeafe;background:#eff6ff;font-size:11px;font-weight:600;color:#1e40af;cursor:pointer;white-space:nowrap;font-family:inherit;">Suivre \u2192</button>'
            + (detailParts.length ? '<button type="button" data-threat-expand style="font-size:10px;color:#1D3BB3;background:none;border:none;padding:0;cursor:pointer;font-family:inherit;">Voir plus \u2192</button>' : '')
          + '</div>'
        + '</div>'
        + (detailParts.length ? '<div data-threat-detail style="display:none;padding:0 14px 10px;font-size:11px;color:#6b7280;border-top:0.5px solid #F3F4F6;">'
          + '<div style="padding-top:8px;">' + detailParts.map(p => '<div style="padding:2px 0;">' + p + '</div>').join('') + '</div>'
        + '</div>' : '')
      + '</div>';
    }

    const threatsHtml = Array.isArray(topThreats) && topThreats.length > 0
      ? '<div style="margin-top:14px;border-top:0.5px solid #F3F4F6;padding-top:10px;">'
        + '<div style="font-size:10px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#374151;margin-bottom:8px;">Concurrents potentiels</div>'
        + topThreats.map(tc => renderThreatCard(tc)).join('')
      + '</div>'
      : '';

    return '<div style="padding-top:12px;">'
      + (pressureLabel
        ? '<div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;">'
          + '<span style="font-size:12px;color:#6b7280;">Pression concurrentielle :</span>'
          + '<span style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:11px;font-weight:600;background:' + pressureBg + ';color:' + pressureFg + ';">' + escapeHtml(pressureLabel) + '</span>'
        + '</div>'
        : '')
      + '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;">'
        + '<div style="background:#f8fafc;border-radius:8px;padding:10px 12px;">'
          + '<div style="font-size:10px;color:#6b7280;margin-bottom:3px;">< 500 m</div>'
          + '<div style="font-size:22px;font-weight:700;color:#1f2937;">' + count500 + '</div>'
        + '</div>'
        + '<div style="background:#f8fafc;border-radius:8px;padding:10px 12px;">'
          + '<div style="font-size:10px;color:#6b7280;margin-bottom:3px;">< 5 km</div>'
          + '<div style="font-size:22px;font-weight:700;color:#1f2937;">' + count5km + '</div>'
        + '</div>'
      + '</div>'
      + '<div style="display:flex;gap:8px;margin-bottom:4px;">'
        + '<button type="button" data-radar-carte style="flex:1;display:flex;align-items:center;justify-content:center;gap:5px;padding:8px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;font-size:12px;font-weight:600;color:#1e40af;cursor:pointer;font-family:inherit;">Carte</button>'
        + '<button type="button" data-radar-concurrents style="flex:1;display:flex;align-items:center;justify-content:center;gap:5px;padding:8px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;font-size:12px;font-weight:600;color:#1e40af;cursor:pointer;font-family:inherit;">Concurrents potentiels</button>'
      + '</div>'
    + '</div>';
  }

  // ----------------------------------------------------------------
  // V4 NEW — Feed with CTAs
  // ----------------------------------------------------------------
  function renderFeed(allFeed, isMultisite) {
    const totalCount = allFeed.length;
    if (!totalCount) {
      return `
        <div style="margin-top:20px;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
            <span style="font-size:11px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#374151;">Fil d'activité</span>
            <span style="font-size:11px;color:#9ca3af;">0 événements</span>
          </div>
          <div style="text-align:center;padding:32px 0;color:#9CA3AF;font-size:14px;">Aucun changement récent.</div>
        </div>`;
    }

    // Group by category (4 buckets)
    const CATEGORY_ORDER = [
      { key: "mobility", label: "Mobilit\u00e9", match: (a) => String(a?.change_subtype||"").startsWith("mobility_") },
      { key: "competition", label: "Concurrence", match: (a) => { const s = String(a?.change_subtype||""); return s === "event_new" || s === "competitor_event_launch" || s === "competitor_event_ending" || s === "competitor_audience_conflict" || s === "competition_pressure_spike" || s === "mega_event_activation" || s === "mega_event_end"; } },
      { key: "weather", label: "M\u00e9t\u00e9o", match: (a) => { const s = String(a?.change_subtype||""); return s === "weather_worsened" || s === "weather_improved" || s === "weather_hazard_onset"; } },
      { key: "context", label: "Contexte", match: (a) => true },
    ];

    const categoryBuckets = new Map();
    for (const cat of CATEGORY_ORDER) categoryBuckets.set(cat.key, []);
    for (const a of allFeed) {
      for (const cat of CATEGORY_ORDER) {
        if (cat.match(a)) { categoryBuckets.get(cat.key).push(a); break; }
      }
    }

    const showAll = window.__plsV4FeedShowAll === true;
    const categoryEntries = CATEGORY_ORDER
      .map(cat => [cat, categoryBuckets.get(cat.key)])
      .filter(([, items]) => items.length > 0);
    const displayed = categoryEntries;

    function feedTypePill(a) {
      const sub = String(a?.change_subtype || "").toLowerCase();
      const dir = String(a?.direction || "").toLowerCase();
      const lvl = Number(a?.alert_level || 0);
      const P = (label, bg, fg) => '<span style="font-size:9px;font-weight:700;padding:2px 7px;border-radius:3px;background:' + bg + ';color:' + fg + ';text-transform:uppercase;letter-spacing:0.03em;">' + escapeHtml(label) + '</span>';
      const RISK = "var(--color-pill-risk-bg)"; const RISK_T = "var(--color-pill-risk-text)";
      const WARN = "var(--color-pill-warn-bg)"; const WARN_T = "var(--color-pill-warn-text)";
      const INFO = "var(--color-pill-info-bg)"; const INFO_T = "var(--color-pill-info-text)";
      const LOW = "var(--color-pill-source-low-bg)"; const LOW_T = "var(--color-pill-source-low-text)";
      const GREEN = "var(--color-pill-green-bg)"; const GREEN_T = "var(--color-pill-green-text)";
      if (sub === "competitor_audience_conflict") return P("Conflit audience", RISK, RISK_T);
      if (sub === "competitor_event_launch") return P("Lancement", RISK, RISK_T);
      if (sub === "competition_pressure_spike") { const oldN = Number(a?.old_value||0); const newN = Number(a?.new_value||0); return newN > oldN ? P("Pression \u2191", RISK, RISK_T) : P("Pression \u2193", GREEN, GREEN_T); }
      if (sub === "mega_event_activation") return P("M\u00e9ga-\u00e9v\u00e9nement", RISK, RISK_T);
      if (sub === "mega_event_end") return P("Fin m\u00e9ga-\u00e9v\u00e9n.", GREEN, GREEN_T);
      if (sub === "weather_hazard_onset" || sub === "weather_worsened") return P("M\u00e9t\u00e9o", WARN, WARN_T);
      if (sub === "weather_improved") return P("M\u00e9t\u00e9o \u2713", GREEN, GREEN_T);
      if (sub === "mobility_disruption" || sub === "mobility_disruption_planned") {
        const mode = String(a?.mobility_mode || "").toLowerCase();
        const label = mode === "road" ? "Mobilit\u00e9" : "Mobilit\u00e9";
        return P(label, WARN, WARN_T) + ' ' + feedModeIcon(a?.mobility_mode);
      }
      if (sub === "mobility_disruption_resolved") return P("Mobilit\u00e9 \u2713", GREEN, GREEN_T) + ' ' + feedModeIcon(a?.mobility_mode);
      if (sub === "calendar_audience_shift") return P("Audience", INFO, INFO_T);
      if (sub === "regime_change") return P("Contexte", WARN, WARN_T);
      if (sub === "event_new") return P("Nouvel événement", LOW, LOW_T);
      if (sub === "score_up") return P("Score \u2191", GREEN, GREEN_T);
      if (sub === "score_down") return P("Score \u2193", RISK, RISK_T);
      if (sub === "ranking_up") return P("Classement \u2191", LOW, LOW_T);
      if (sub === "ranking_down") return P("Classement \u2193", LOW, LOW_T);
      if (sub === "competitor_event_ending") return P("Fin prochaine", GREEN, GREEN_T);
      return P("Signal", LOW, LOW_T);
    }

    function feedItemCta(a) {
      const sub = String(a?.change_subtype || "").toLowerCase();
      const cat = String(a?.change_category || "").toLowerCase();
      const lvl = Number(a?.alert_level || 0);

      if (sub === "competitor_event_launch" || sub === "competitor_audience_conflict") return { label: "Voir", action: "threats" };
      if (sub === "competition_pressure_spike" || sub === "mega_event_activation") return { label: "Voir la carte", action: "map" };
      if (sub === "event_new") return { label: "Suivre", action: "follow" };
      if (sub === "weather_worsened" || sub === "weather_hazard_onset") return { label: "Voir conditions", action: "weather" };
      if (sub === "mobility_disruption" || sub === "mobility_disruption_planned") return { label: "Voir acc\u00e8s", action: "mobility" };
      return null;
    }

    function feedBorderColor(a) {
      const lvl = Number(a?.alert_level || 0);
      const dir = String(a?.direction || "").toLowerCase();
      const sub = String(a?.change_subtype || "").toLowerCase();
      if (lvl >= 4) return "var(--color-dot-audience)";
      if (lvl >= 3) return "var(--color-pill-risk-border)";
      if (dir === "up" || dir === "improved" || sub.endsWith("_resolved") || sub.endsWith("_end") || sub.endsWith("_ending")) return "var(--color-pill-green-text)";
      if (lvl >= 2) return "var(--color-pill-warn-border)";
      return "var(--color-dot-neutral)";
    }

    const groupsHtml = displayed.map(([cat, catItems]) => {
      const groupLabel = cat.label + " (" + catItems.length + ")";

      const locLabels = new Set(catItems.map(a => a?.location_label).filter(Boolean));
      const showLocPill = isMultisite && locLabels.size > 1;

      // Sort by alert_level DESC, then date DESC within category
      const sorted = [...catItems].sort((a, b) => {
        const lvlDiff = (Number(b?.alert_level)||0) - (Number(a?.alert_level)||0);
        if (lvlDiff !== 0) return lvlDiff;
        return String(b?.affected_date||"").localeCompare(String(a?.affected_date||""));
      });
      const maxVisible = showAll ? sorted.length : 5;
      const visible = sorted.slice(0, maxVisible);

      const itemsHtml = visible.map((a, idx) => {
        const line1 = feedLine1(a);
        if (!line1) return "";
        const line2 = feedLine2(a);
        const line4 = feedLine4(a);
        const borderCol = feedBorderColor(a);
        const cta = feedItemCta(a);
        const typePill = feedTypePill(a);
        const locPill = showLocPill && a?.location_label ? '<span style="font-size:9px;font-weight:700;padding:2px 7px;border-radius:3px;background:#EFF6FF;color:#1e40af;text-transform:uppercase;letter-spacing:0.03em;">' + escapeHtml(a.location_label) + '</span>' : "";

        const ctaHtml = (() => {
          if (!cta) return "";
          const sub = String(a?.change_subtype || "").toLowerCase();
          if (sub === "event_new") {
            const uid = escapeHtml(String(a?.entity_id || idx));
            return '<div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;align-self:center;">'
              + '<button type="button" data-feed-follow="' + uid + '" data-follow-label="' + escapeHtml(a?.event_label || '') + '" data-follow-venue="' + escapeHtml(a?.event_venue_name || '') + '" data-follow-city="' + escapeHtml(a?.city_name || '') + '" data-follow-date="' + escapeHtml(normalizeYmd(a?.affected_date) || '') + '" data-follow-industry="' + escapeHtml(a?.industry_code || '') + '" style="padding:5px 10px;border-radius:6px;border:1px solid #dbeafe;background:#eff6ff;font-size:11px;font-weight:600;color:#1e40af;cursor:pointer;white-space:nowrap;font-family:inherit;">Suivre \u2192</button>'
              + '<button type="button" data-feed-enrich="' + uid + '" data-enrich-label="' + escapeHtml(a?.event_label || '') + '" data-enrich-venue="' + escapeHtml(a?.event_venue_name || '') + '" data-enrich-city="' + escapeHtml(a?.city_name || '') + '" data-enrich-distance="' + (a?.distance_m != null ? Math.round(Number(a.distance_m)) : '') + '" data-enrich-industry="' + escapeHtml(a?.industry_code || '') + '" data-enrich-uid="' + escapeHtml(a?.entity_id || '') + '" style="font-size:10px;color:#1D3BB3;background:none;border:none;padding:0;cursor:pointer;font-family:inherit;">Voir plus \u2192</button>'
            + '</div>';
          }
          return '<button type="button" data-feed-cta="' + escapeHtml(cta.action) + '" data-feed-idx="' + idx + '" style="flex-shrink:0;align-self:center;padding:5px 10px;border-radius:6px;border:1px solid #dbeafe;background:#eff6ff;font-size:11px;font-weight:600;color:#1e40af;cursor:pointer;white-space:nowrap;font-family:inherit;">' + escapeHtml(cta.label) + ' \u2192</button>';
        })();

        return `
          <div style="padding:10px 14px;${idx > 0 ? "border-top:1px solid #f3f4f6;" : ""}border-left:3px solid ${borderCol};margin-left:-1px;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
              <div style="flex:1;min-width:0;">
                <div style="display:flex;gap:5px;flex-wrap:wrap;margin-bottom:4px;">${locPill}${typePill}</div>
                <div style="font-size:13px;font-weight:600;color:var(--color-text-primary);margin-bottom:2px;">${escapeHtml(line1)}</div>
                ${line2 ? `<div style="font-size:11.5px;color:var(--color-text-secondary);">${escapeHtml(line2)}</div>` : ""}
                ${line4 ? `<div style="font-size:11px;color:var(--color-dot-neutral);margin-top:4px;display:flex;align-items:center;gap:6px;">${line4}</div>` : ""}
                <div data-feed-enrich-panel="${idx}" style="display:none;margin-top:8px;"></div>
              </div>
              ${ctaHtml}
            </div>
          </div>`;
      }).filter(Boolean).join("");

      if (!itemsHtml) return "";

      return `
        <div style="background:#fff;border-radius:10px;border:1px solid #e5e7eb;overflow:hidden;margin-bottom:6px;">
          <div style="padding:5px 14px;background:#f9fafb;font-size:10px;font-weight:600;color:#9ca3af;text-transform:uppercase;letter-spacing:0.04em;">${escapeHtml(groupLabel)}</div>
          ${itemsHtml}
        </div>`;
    }).filter(Boolean).join("");

    const hasHidden = !showAll && categoryEntries.some(([, items]) => items.length > 5);
    const showAllBtn = hasHidden
      ? `<button type="button" id="pls-v4-feed-show-all" style="display:block;width:100%;margin-top:8px;padding:9px;background:none;border:1px solid #e5e7eb;border-radius:8px;font-size:12px;font-weight:500;color:#3b82f6;cursor:pointer;font-family:inherit;">Voir tout (${totalCount})</button>`
      : "";

    return `
      <div style="margin-top:20px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
          <span style="font-size:11px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#374151;">Fil d'activité</span>
          <span style="font-size:11px;color:#9ca3af;">${totalCount} ${totalCount > 1 ? "signaux" : "signal"}</span>
        </div>
        <div style="display:flex;flex-direction:column;gap:6px;">
          ${groupsHtml}
        </div>
        ${showAllBtn}
      </div>`;
  }

  // ----------------------------------------------------------------
  // Main render — V4 REWRITE: pills → alerts → 3 radar strips → feed
  // ----------------------------------------------------------------
  function renderMonitor(data, item, selectedDate, activeView, monitorDates) {
    activeView = activeView || "radar";
    const root = document.getElementById("mon-root");
    if (!root) return;

    const days = Array.isArray(data.days) ? data.days : [];
    const dayMap = new Map(days.map(d => [normalizeYmd(d.date), d]));
    const currentDay = dayMap.get(selectedDate) || days[0] || null;
    const allFeed = Array.isArray(data.all_feed) ? data.all_feed : [];
    const competitorSignals = data._competitor_signals || [];
    const followedCount = Number(data._competitor_followed_count ?? data.competitor_followed_count ?? 0);
    const isMultisite = false;

    if (!currentDay) {
      root.innerHTML = `<div class="mon-error">Aucune donnée disponible.</div>`;
      return;
    }

    const today = todayYmd();

    // Breadcrumb
    const breadcrumbNav = document.querySelector(".mon-breadcrumb");
    const breadcrumbSub = document.getElementById("mon-breadcrumb-sub");
    const breadcrumbTab = document.getElementById("mon-breadcrumb-tab");
    const breadcrumbRecap = document.getElementById("mon-breadcrumb-recap");
    if (breadcrumbNav) breadcrumbNav.style.display = "flex";
    if (activeView === "radar") { if (breadcrumbSub) breadcrumbSub.style.display = "none"; }
    else { if (breadcrumbTab) breadcrumbTab.textContent = ({ carte:"Environnement", concurrents:"Concurrents potentiels" })[activeView] || activeView; if (breadcrumbSub) breadcrumbSub.style.display = "inline"; }
    if (breadcrumbRecap) { breadcrumbRecap.onclick = (e) => { e.preventDefault(); renderMonitor(data, item, selectedDate, "radar", monitorDates); }; }

    const _score = currentDay?.opportunity_score ?? null;
    const _safeScore = _score !== null ? String(_score).trim() : null;
    const _statusPill = computeStatusPill(currentDay);
    const _cev = countdown(selectedDate);

    // Event metadata tags
    const _evtType = item?.event_type || null;
    const _evtCapacity = item?.expected_audience || item?.capacity || null;
    const _evtStatus = item?.status_label || null;
    const _locationLabel = item?.location_label || item?.company_name || null;

    const EVT_TYPE_LABELS = {
      conference_de_presse: 'Conférence de presse',
      evenement_corporate: 'Événement corporate',
      happening_exterieur: 'Happening extérieur',
      inauguration: 'Inauguration',
      journee_portes_ouvertes: 'Journée portes ouvertes',
      lancement_de_produit: 'Lancement de produit',
      ouverture_point_de_vente: 'Ouverture d\'un point de vente',
      promotion_magasin: 'Promotion en magasin / soldes',
      soiree_de_lancement: 'Soirée de lancement',
      vernissage_exposition: 'Vernissage / Exposition',
      autre: 'Autre',
    };
    const evtTypeLabel = _evtType ? (EVT_TYPE_LABELS[_evtType] || _evtType) : null;

    const STATUS_LABELS = {
      on_track: 'En bonne voie', at_risk: 'À risque', delayed: 'Retardé',
      confirmed: 'Confirmé', cancelled: 'Annulé',
    };
    const evtStatusLabel = _evtStatus ? (STATUS_LABELS[_evtStatus] || _evtStatus) : null;

    const metaTags = [evtTypeLabel, _evtCapacity, evtStatusLabel].filter(Boolean);
    const metaTagsHtml = metaTags.length
      ? `<div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;">${metaTags.map(t =>
          `<span style="display:inline-block;padding:4px 14px;border-radius:6px;font-size:12px;font-weight:600;color:#166534;border:1px solid #bbf7d0;background:#f0fdf4;">${escapeHtml(t)}</span>`
        ).join("")}</div>`
      : "";

    const headerHtml = `
      <div style="background:rgba(29,59,179,0.04);border-left:6px solid #0b37e5;padding:24px;margin-bottom:0;">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;">
          <div style="flex:1;min-width:0;">
            <div style="font-size:22px;font-weight:500;color:#111827;margin:0 0 4px 0;line-height:1.2;">${escapeHtml(item?.title || "Événement")}</div>
            <div style="font-size:13px;color:#6b7280;margin:0;">${escapeHtml(fmtDateLong(selectedDate))}</div>
            ${_locationLabel ? `<div style="font-size:13px;color:#9ca3af;margin-top:2px;">${escapeHtml(_locationLabel)}</div>` : ""}
            ${metaTagsHtml}
          </div>
          ${_cev ? `<div style="flex-shrink:0;text-align:right;">
            <div style="font-size:42px;font-weight:700;color:#111827;line-height:1;letter-spacing:-0.02em;">${escapeHtml(_cev)}</div>
          </div>` : ""}
        </div>
      </div>
    `;

    // ---- Pills (from monitorDates) ----
    const pillsHtml = `<div class="pls-pills">
      ${monitorDates.map(ymd => {
        const d = dayMap.get(ymd);
        const allRisks = [...(d?.attendance||[]),...(d?.operations||[]),...(d?.installation||[])];
        const hasCrit = allRisks.some(r => r.severity==="D"||r.severity==="C");
        const hasWarn = !hasCrit && allRisks.some(r => r.severity==="B");
        const isActive = ymd===selectedDate;
        let cls = "pls-pill";
        if (isActive) cls+=" is-active";
        else if (ymd===today) cls+=" is-today";
        else if (hasCrit) cls+=" has-crit";
        else if (hasWarn) cls+=" has-warn";
        const label = fmtDateShort(ymd);
        const dotColor = isActive ? "#fff" : hasCrit ? "#e24b4a" : hasWarn ? "#ef9f27" : null;
        const dot = dotColor ? `<span class="pls-pill-dot" style="background:${dotColor};"></span>` : "";
        return `<button type="button" class="${cls}" data-pill-date="${ymd}">${escapeHtml(label)}${dot}</button>`;
      }).join("")}
    </div>`;

    // ---- Alerts (severity != A, shown as strips before radar) ----
    const dayAlerts = [
      ...(currentDay.attendance || []),
      ...(currentDay.operations || []),
      ...(currentDay.installation || []),
      ...(currentDay.context || []),
    ].filter(r => r.severity !== "A");

    let alertsHtml = "";
    if (dayAlerts.length > 0) {
      alertsHtml = `<div style="display:flex;flex-direction:column;gap:6px;margin-bottom:12px;">
        ${dayAlerts.slice(0, 5).map(a => {
          const isCrit = a.severity === "D" || a.severity === "C";
          const bg = isCrit ? "#fef2f2" : "#fffbeb";
          const border = isCrit ? "#dc2626" : "#f59e0b";
          const labelColor = isCrit ? "#991b1b" : "#92400e";
          const icon = isCrit ? '<span style="width:8px;height:8px;border-radius:50%;background:#dc2626;display:inline-block;"></span>' : '<span style="width:8px;height:8px;border-radius:50%;background:#f59e0b;display:inline-block;"></span>';
          const blockLabel = BLOCK_LABELS[a.block] || a.block.toUpperCase();
          return `<div style="display:flex;align-items:flex-start;gap:10px;padding:10px 14px;border-radius:8px;background:${bg};border-left:3px solid ${border};">
            <span style="display:flex;align-items:center;margin-top:2px;">${icon}</span>
            <div style="flex:1;">
              <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:${labelColor};margin-bottom:1px;">${escapeHtml(blockLabel)}</div>
              <div style="font-size:12.5px;color:#1f2937;line-height:1.4;">${escapeHtml(a.sentence)}</div>
            </div>
          </div>`;
        }).join("")}
      </div>`;
    } else {
      alertsHtml = '<div style="display:flex;align-items:center;gap:6px;margin-bottom:12px;padding:8px 12px;background:rgba(16,185,129,0.06);border-radius:8px;"><span style="color:#059669;font-size:13px;">\u2713</span><span style="font-size:12.5px;color:#059669;font-weight:500;">Aucune alerte</span></div>';
    }

    // ---- Carte view ----
    if (activeView === "carte") {
      const mapLocs = isMultisite ? data._locations : null;
      const primaryLoc = mapLocs ? (mapLocs.find(l => l.is_primary) || mapLocs[0]) : null;
      const defaultLocId = primaryLoc ? primaryLoc.location_id : location_id;

      const mapSwitcher = mapLocs ? `
        <div style="display:flex;align-items:center;gap:0;border:0.5px solid #E5E7EB;border-radius:8px;overflow:hidden;margin-bottom:8px;">
          ${mapLocs.map((l, i) => {
            const isDefault = l.location_id === defaultLocId;
            return `<button type="button" data-map-loc="${escapeHtml(l.location_id)}" style="flex:1;padding:10px 14px;font-size:13px;font-weight:${isDefault?'500':'400'};color:${isDefault?'#111827':'#9CA3AF'};background:${isDefault?'#fff':'#F9FAFB'};border:none;border-right:${i<mapLocs.length-1?'0.5px solid #E5E7EB':'none'};cursor:pointer;font-family:inherit;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
              ${escapeHtml(l.company_name || l.location_id)}
            </button>`;
          }).join('')}
        </div>` : '';

      const backBtn = `<button type="button" id="mon-back-radar" style="display:flex;align-items:center;gap:6px;margin-bottom:12px;padding:6px 0;background:none;border:none;font-size:13px;font-weight:600;color:#1D3BB3;cursor:pointer;font-family:inherit;">← Retour au radar</button>`;

      root.innerHTML = headerHtml + `<div style="height:12px;"></div>` + backBtn + mapSwitcher +
        `<iframe id="pls-map-iframe" src="/app/insightevent/map?location_id=${encodeURIComponent(defaultLocId)}&date=${encodeURIComponent(selectedDate)}&embed=1${data._mapMode ? '&mode=' + encodeURIComponent(data._mapMode) : ''}" style="width:100%;height:600px;border:none;border-radius:14px;display:block;"></iframe>`;

      // Pills removed — single event date

      // Wire back button
      const backEl = root.querySelector("#mon-back-radar");
      if (backEl) backEl.addEventListener("click", () => renderMonitor(data, item, selectedDate, "radar", monitorDates));

      // Wire map site selector
      root.querySelectorAll("[data-map-loc]").forEach(btn => {
        btn.addEventListener("click", () => {
          const locId = btn.getAttribute("data-map-loc");
          const iframe = root.querySelector("#pls-map-iframe");
          if (iframe && locId) {
            iframe.src = "about:blank";
            setTimeout(() => {
              iframe.src = `/app/insightevent/map?location_id=${encodeURIComponent(locId)}&date=${encodeURIComponent(selectedDate)}&embed=1`;
            }, 0);
          }
          root.querySelectorAll("[data-map-loc]").forEach(b => {
            const isAct = b === btn;
            b.style.fontWeight = isAct ? '500' : '400';
            b.style.color = isAct ? '#111827' : '#9CA3AF';
            b.style.background = isAct ? '#fff' : '#F9FAFB';
          });
        });
      });

      // Map height listener
      window.__plsMapHeightListener && window.removeEventListener("message", window.__plsMapHeightListener);
      window.__plsMapHeightListener = function(e) {
        if (e.data?.type === "map-height" && typeof e.data.height === "number" && e.data.height > 100) {
          const iframe = root.querySelector("#pls-map-iframe");
          if (iframe) iframe.style.height = e.data.height + "px";
        }
      };
      window.addEventListener("message", window.__plsMapHeightListener);

      return;
    }

    // ---- Concurrents potentiels view ----
    if (activeView === "concurrents") {
      const topThreats = data._top_threats || [];

      const AUDIENCE_FR = {
        local: "résidents locaux", professionals: "professionnels",
        tourists: "touristes", students: "étudiants",
        families: "familles", seniors: "seniors",
        general_public: "grand public", art_lovers: "amateurs d'art",
        mixed: "public mixte"
      };
      const INDUSTRY_TIER_FR = { direct: "Même secteur", partial: "Secteur proche", contextual: "Secteur différent" };
      const THREAT_BADGE = {
        high:     { bg: "#fee2e2", fg: "#991b1b", t: "Menace élevée" },
        moderate: { bg: "#fef3c7", fg: "#92400e", t: "Menace modérée" },
        low:      { bg: "#f3f4f6", fg: "#6b7280", t: "Menace faible" },
      };

      function renderThreatCard(tc) {
        const name = tc.competitor_name || "Concurrent";
        const distKm = tc.distance_km != null ? Number(tc.distance_km).toFixed(1) : null;
        const badge = THREAT_BADGE[tc.threat_level] || THREAT_BADGE.low;
        const indLabel = INDUSTRY_TIER_FR[tc.industry_match_tier] || "";
        const locAuds = [tc.location_primary_audience_1, tc.location_primary_audience_2].filter(Boolean);
        const compAuds = [tc.competitor_primary_audience, tc.competitor_secondary_audience].filter(Boolean);
        const sharedAuds = compAuds.filter(function(a) { return locAuds.includes(a); }).map(function(a) { return AUDIENCE_FR[a] || a; });
        var audLine = "";
        if (sharedAuds.length > 0) {
          audLine = "Cible les mêmes audiences : " + sharedAuds.join(", ");
        } else if (compAuds.length > 0) {
          audLine = "Cible : " + compAuds.map(function(a) { return AUDIENCE_FR[a] || a; }).join(", ");
        }
        const initials = name.split(" ").map(function(w) { return (w[0] || ""); }).join("").slice(0, 2).toUpperCase();
        const detailParts = [];
        if (tc.competitor_industry_code) detailParts.push("Secteur : " + escapeHtml(tc.competitor_industry_code));
        if (tc.competitor_google_rating) detailParts.push("\u2605 " + tc.competitor_google_rating + (tc.competitor_google_rating_count ? " \u00b7 " + Number(tc.competitor_google_rating_count).toLocaleString("fr-FR") + " avis" : ""));

        return '<div class="ms-threat-card" style="background:#fff;border:0.5px solid #E8EDF5;border-radius:10px;overflow:hidden;margin-bottom:6px;">'
          + '<div style="display:flex;align-items:center;gap:10px;padding:12px 14px;">'
            + '<div style="width:36px;height:36px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-weight:500;font-size:13px;color:#0C447C;background:#E6F1FB;flex-shrink:0;">' + escapeHtml(initials) + '</div>'
            + '<div style="flex:1;min-width:0;">'
              + '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">'
                + '<span style="font-size:13px;font-weight:500;color:#111827;">' + escapeHtml(name) + '</span>'
                + (distKm ? '<span style="font-size:11px;color:#6b7280;">' + escapeHtml(distKm + ' km') + '</span>' : '')
              + '</div>'
              + '<div style="display:flex;align-items:center;gap:6px;margin-top:3px;flex-wrap:wrap;">'
                + '<span style="display:inline-block;padding:1px 8px;border-radius:4px;font-size:10px;font-weight:600;background:' + badge.bg + ';color:' + badge.fg + ';">' + escapeHtml(badge.t) + '</span>'
                + (indLabel ? '<span style="font-size:11px;color:#6b7280;">' + escapeHtml(indLabel) + '</span>' : '')
              + '</div>'
              + (audLine ? '<div style="font-size:11px;color:#374151;margin-top:3px;">' + escapeHtml(audLine) + '</div>' : '')
            + '</div>'
            + '<div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;">'
              + '<button type="button" data-follow-threat="' + escapeHtml(tc.competitor_id) + '" data-follow-name="' + escapeHtml(name) + '" style="padding:4px 10px;border-radius:6px;border:1px solid #dbeafe;background:#eff6ff;font-size:11px;font-weight:600;color:#1e40af;cursor:pointer;white-space:nowrap;font-family:inherit;">Suivre \u2192</button>'
              + '<button type="button" data-threat-enrich="' + escapeHtml(tc.competitor_id) + '" data-enrich-name="' + escapeHtml(name) + '" data-enrich-city="" data-enrich-distance="' + (distKm || '') + '" data-enrich-industry="' + escapeHtml(tc.competitor_industry_code || '') + '" style="font-size:10px;color:#1D3BB3;background:none;border:none;padding:0;cursor:pointer;font-family:inherit;">Voir plus \u2192</button>'
            + '</div>'
          + '</div>'
          + '<div data-threat-detail="' + escapeHtml(tc.competitor_id) + '" style="display:none;padding:0 14px 10px;border-top:0.5px solid #F3F4F6;"></div>'
        + '</div>';
      }

      const backBtn = '<button type="button" id="mon-back-radar" style="display:flex;align-items:center;gap:6px;margin-bottom:12px;padding:6px 0;background:none;border:none;font-size:13px;font-weight:600;color:#1D3BB3;cursor:pointer;font-family:inherit;">\u2190 Retour au radar</button>';

      const concHeaderHtml = '<div style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#374151;margin-bottom:12px;">Concurrents potentiels · ' + topThreats.length + '</div>';

      const cardsHtml = topThreats.length > 0
        ? topThreats.map(function(tc) { return renderThreatCard(tc); }).join('')
        : '<div style="text-align:center;padding:32px 0;color:#9CA3AF;font-size:14px;">Aucun concurrent potentiel détecté.</div>';

      root.innerHTML = headerHtml + '<div style="height:12px;"></div>' + backBtn + concHeaderHtml + cardsHtml;

      // Wire pills
      root.querySelectorAll("[data-pill-date]").forEach(function(btn) {
        btn.addEventListener("click", async function() {
          const d = btn.getAttribute("data-pill-date");
          if (!d) return;
          const csResult = await fetchCompetitorSignals(d).catch(function() { return { signals: [], followed_count: 0, top_threats: [] }; });
          data._competitor_signals = csResult.signals;
          data._competitor_followed_count = csResult.followed_count;
          data._top_threats = csResult.top_threats;
          renderMonitor(data, item, d, "radar", monitorDates);
        });
      });

      // Wire back
      const backEl = root.querySelector("#mon-back-radar");
      if (backEl) backEl.addEventListener("click", function() { renderMonitor(data, item, selectedDate, "radar", monitorDates); });

      // Wire Voir plus enrich
      root.querySelectorAll("[data-threat-enrich]").forEach(function(btn) {
        btn.addEventListener("click", async function(e) {
          e.stopPropagation();
          const compId = btn.getAttribute("data-threat-enrich");
          const card = btn.closest(".ms-threat-card");
          if (!card) return;
          const detail = card.querySelector("[data-threat-detail]");
          if (!detail) return;

          if (detail.style.display !== "none" && detail.innerHTML.trim()) {
            detail.style.display = "none";
            btn.textContent = "Voir plus \u2192";
            return;
          }

          detail.style.display = "block";
          detail.innerHTML = '<div style="font-size:12px;color:#9CA3AF;padding:8px 0;display:flex;align-items:center;gap:8px;"><span style="width:10px;height:10px;border:1.5px solid #E5E7EB;border-top-color:#1D3BB3;border-radius:50%;display:inline-block;animation:ms-spin 0.7s linear infinite;flex-shrink:0;"></span>Recherche en cours\u2026</div>';
          btn.textContent = "R\u00e9duire \u2191";

          try {
            var res = await fetch("/api/insight/enrich-event", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({
                event_label: btn.getAttribute("data-enrich-name") || "",
                description: "",
                city_name: btn.getAttribute("data-enrich-city") || "",
                event_venue_name: "",
                event_uid: null,
                city_id: null,
                distance_m: btn.getAttribute("data-enrich-distance") ? Number(btn.getAttribute("data-enrich-distance")) * 1000 : null,
                radius_bucket: null,
                industry_code: btn.getAttribute("data-enrich-industry") || null,
              }),
            });
            var json = await res.json().catch(function() { return null; });
            if (!json?.ok || !json?.data) throw new Error("Réponse invalide");
            var d = json.data;
            var rows = [
              d.confirmed_dates      ? ["Dates",        d.confirmed_dates]      : null,
              d.venue_name           ? ["Lieu",          d.venue_name]           : null,
              d.venue_capacity       ? ["Capacit\u00e9", d.venue_capacity]       : null,
              d.organizer            ? ["Organisateur",  d.organizer]            : null,
              d.estimated_attendance ? ["Fr\u00e9quentation", d.estimated_attendance] : null,
            ].filter(Boolean);
            var tags = d.audience_profile ? d.audience_profile.split(/[,;]/).map(function(t) { return t.trim(); }).filter(Boolean) : [];
            detail.innerHTML = '<div style="background:#F9FAFB;border:0.5px solid #E5E7EB;border-radius:10px;overflow:hidden;margin-top:8px;">'
              + (rows.length ? '<div style="display:grid;grid-template-columns:1fr 1fr;">' + rows.map(function(r, i) {
                return '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;' + (i % 2 === 0 && i < rows.length - 1 ? 'border-right:0.5px solid #F3F4F6;' : '') + '">'
                  + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:3px;">' + escapeHtml(r[0]) + '</div>'
                  + '<div style="font-size:13px;color:#111827;line-height:1.4;">' + escapeHtml(String(r[1])) + '</div>'
                + '</div>';
              }).join('') + '</div>' : '')
              + (tags.length ? '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
                + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:6px;">Audience</div>'
                + '<div style="display:flex;flex-wrap:wrap;gap:5px;">' + tags.map(function(t) { return '<span style="font-size:11px;font-weight:500;padding:2px 9px;border-radius:20px;background:#EFF6FF;color:#1D4ED8;">' + escapeHtml(t) + '</span>'; }).join('') + '</div>'
              + '</div>' : '')
              + (d.business_takeaway ? '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
                + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:5px;">Impact pour votre activit\u00e9</div>'
                + '<div style="font-size:12px;color:#111827;line-height:1.55;">' + escapeHtml(d.business_takeaway) + '</div>'
              + '</div>' : '')
              + '<div style="padding:9px 14px;display:flex;justify-content:space-between;align-items:center;">'
                + '<div style="font-size:10px;letter-spacing:0.07em;text-transform:uppercase;color:#9CA3AF;display:flex;align-items:center;gap:5px;">'
                  + '<span style="width:6px;height:6px;border-radius:50%;background:#059669;display:inline-block;flex-shrink:0;"></span>'
                  + 'Agent IA \u00b7 web'
                + '</div>'
                + (d.source_url ? '<a href="' + escapeHtml(d.source_url) + '" target="_blank" rel="noopener" style="font-size:12px;color:#1D3BB3;text-decoration:none;">Source officielle \u2192</a>' : '')
              + '</div>'
            + '</div>';
          } catch(err) {
            detail.innerHTML = '<div style="font-size:12px;color:#B91C1C;padding:8px 0;">Donn\u00e9es non disponibles.</div>';
            btn.textContent = "Voir plus \u2192";
          }
        });
      });

      // Wire Suivre CTA
      root.querySelectorAll("[data-follow-threat]").forEach(function(btn) {
        btn.addEventListener("click", async function(e) {
          e.stopPropagation();
          const compId = btn.getAttribute("data-follow-threat");
          const compName = btn.getAttribute("data-follow-name") || "";
          if (!compId) return;
          btn.disabled = true;
          btn.textContent = "...";
          try {
            const res = await fetch("/api/competitive/add-competitor", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ competitor_id: compId, competitor_name: compName }),
            });
            const json = await res.json().catch(function() { return null; });
            if (res.ok && json?.ok) {
              btn.textContent = "Suivi";
              btn.style.background = "#dcfce7";
              btn.style.borderColor = "#bbf7d0";
              btn.style.color = "#166534";
            } else {
              btn.textContent = "Erreur";
              btn.style.background = "#fef2f2";
              btn.style.borderColor = "#fecaca";
              btn.style.color = "#991b1b";
            }
          } catch(err) {
            btn.textContent = "Erreur";
            btn.disabled = false;
          }
        });
      });

      return;
    }

    // ---- RADAR VIEW (default) ----

    var compSigs = Array.isArray(data._competitor_signals) ? data._competitor_signals : [];
    for (var fi = 0; fi < allFeed.length; fi++) {
      var feedItem = allFeed[fi];
      var fSub = String(feedItem.change_subtype || "").toLowerCase();
      if (fSub !== "competitor_event_launch" && fSub !== "competitor_audience_conflict" && fSub !== "competitor_event_ending" && fSub !== "competition_pressure_spike") continue;
      var fEntityId = feedItem.entity_id || null;
      var fNewValue = String(feedItem.new_value || "");
      var fCompName = fNewValue.split(" \u2014 ")[0] || "";
      var matched = null;
      for (var ci = 0; ci < compSigs.length; ci++) {
        if (fEntityId && compSigs[ci].competitor_event_id === fEntityId) { matched = compSigs[ci]; break; }
      }
      if (!matched && fCompName) {
        for (var ci2 = 0; ci2 < compSigs.length; ci2++) {
          if (String(compSigs[ci2].competitor_name || "").toLowerCase() === fCompName.toLowerCase()) { matched = compSigs[ci2]; break; }
        }
      }
      if (matched) {
        feedItem._threat_level = matched.entity_threat_level || null;
        feedItem._threat_score = Number(matched.entity_threat_score || 0);
        feedItem._audience_overlap = Boolean(matched.audience_overlap);
        feedItem._audience_overlap_score = Number(matched.audience_overlap_score || 0);
        feedItem._industry_overlap = Boolean(matched.industry_overlap);
        feedItem._distance_flag = Boolean(matched.distance_flag);
        feedItem._conflict_score = Number(matched.conflict_score || 0);
        feedItem._industry_tier = matched.entity_threat_industry_tier || null;
        feedItem._comp_name = matched.competitor_name || fCompName;
        feedItem._comp_event_name = matched.event_name || "";
        feedItem._comp_audience = matched.event_primary_audience || matched.competitor_primary_audience || null;
        feedItem._comp_distance_m = Number(matched.distance_from_location_m || feedItem.distance_m || 0);
      }
    }

    // Selected day's Action Brief
    var briefHtml = renderDailyBrief(allFeed, data.profile || {}, currentDay, selectedDate, location_id, days);

    // Strip 1: Score
    const score = currentDay.opportunity_score;
    const regime = String(currentDay.opportunity_regime || "B").toUpperCase();
    const regimeLabel = regime === "A" ? "Contexte favorable" : regime === "C" ? "Contexte défavorable" : "Conditions normales";

    // weekRank
    const sortedDays = [...days].filter(d => d.opportunity_score != null).sort((a, b) => (b.opportunity_score ?? 0) - (a.opportunity_score ?? 0));
    const rankIdx = sortedDays.findIndex(d => normalizeYmd(d.date) === normalizeYmd(currentDay.date));
    const rank = rankIdx >= 0 ? rankIdx + 1 : null;
    const totalDays = sortedDays.length;
    let weekRankShort = "";
    if (rank === 1) weekRankShort = "Meilleur jour de la semaine";
    else if (rank === totalDays) weekRankShort = "Jour le moins favorable de la semaine";
    else if (rank != null && totalDays > 0) weekRankShort = `${rank}e meilleur jour de la semaine`;

    const scoreSummary = score != null
      ? `Score jour : ${score} /10${weekRankShort ? ` · ${escapeHtml(weekRankShort)}` : ""} · ${escapeHtml(regimeLabel)}`
      : "Score indisponible";

    const scoreAlert = currentDay.is_forced_regime_c_flag ? "critical" : (dayAlerts.length > 0 ? "warning" : null);

    // Strip 2: Threats — recap across ALL followed competitors
    const compByComp = new Map();
    for (const s of competitorSignals) {
      const cid = s.competitor_id || "unknown";
      if (!compByComp.has(cid)) compByComp.set(cid, []);
      compByComp.get(cid).push(s);
    }
    const totalComps = compByComp.size;
    const totalActiveEvents = competitorSignals.filter(s => s.is_active).length;

    // Find worst threat level across all competitors
    const THREAT_ORDER = { high: 3, moderate: 2, low: 1 };
    let worstThreatLevel = null;
    let worstThreatScore = 0;
    let hasAnyAudOverlap = false;
    for (const [, sigs] of compByComp) {
      const lvl = sigs[0]?.entity_threat_level || null;
      const ts = Number(sigs[0]?.entity_threat_score || 0);
      if (ts > worstThreatScore) { worstThreatScore = ts; worstThreatLevel = lvl; }
      if (sigs.some(s => s.audience_overlap)) hasAnyAudOverlap = true;
    }

    const THREAT_LABELS_FR = { high: "Menace \u00e9lev\u00e9e", moderate: "Menace mod\u00e9r\u00e9e", low: "Menace faible" };
    let threatSummary = "";
    if (totalComps > 0) {
      const worstLabel = THREAT_LABELS_FR[worstThreatLevel] || null;
      const parts = [];
      parts.push(`Concurrents suivis : ${totalComps}`);
      parts.push(`${totalActiveEvents} \u00e9v\u00e9n. actif${totalActiveEvents > 1 ? "s" : ""}`);
      if (worstLabel) parts.push(escapeHtml(worstLabel));
      else if (hasAnyAudOverlap) parts.push("Chevauchement audience");
      threatSummary = parts.join(" \u00b7 ");
    } else {
      threatSummary = followedCount > 0 ? "Aucun conflit direct" : "Aucun concurrent suivi";
    }

    const threatAlert = (worstThreatLevel === "high" || hasAnyAudOverlap) ? "warning" : null;

    // Strip 3: Environnement concurrentiel — use competition_pressure_ratio for pressure label
    const envCount500 = Number(currentDay.events_within_500m_count || 0);
    const envCount5km = Number(currentDay.events_within_5km_count || 0);
    const pressureRatio = Number(currentDay.competition_pressure_ratio || 0);
    const hasBaseline = Boolean(currentDay.has_valid_baseline_flag);
    let envSummary = "";
    let envAlert = null;
    if (hasBaseline && pressureRatio > 1.2) {
      envSummary = `Autour de vous : ${envCount5km} \u00e9v\u00e9nements \u00e0 5 km \u00b7 Sup\u00e9rieur \u00e0 la moyenne`;
      envAlert = "warning";
    } else if (hasBaseline && pressureRatio < 0.8) {
      envSummary = `Contexte concurrentiel : ${envCount5km} \u00e9v\u00e9nements \u00e0 5 km \u00b7 Inf\u00e9rieur \u00e0 la moyenne`;
    } else if (hasBaseline) {
      envSummary = `Contexte concurrentiel : ${envCount5km} \u00e9v\u00e9nements \u00e0 5 km \u00b7 Dans la moyenne`;
    } else {
      envSummary = `Contexte concurrentiel : ${envCount5km} \u00e9v\u00e9nements \u00e0 5 km`;
    }

    // Build strips
    const strip1 = renderRadarStrip("score", "📈", scoreSummary, scoreAlert,
      renderScoreDetail(currentDay, days));

    const strip2 = renderRadarStrip("changes", "📡", envSummary, envAlert,
      renderChangeDetail(currentDay, data._top_threats || []));

    const strip3 = renderRadarStrip("threats", "🎯", threatSummary, threatAlert,
      renderThreatSummary(competitorSignals, selectedDate, followedCount));

    // Feed
    const feedHtml = renderFeed(allFeed, isMultisite);

    // Date header
    const dateHeaderHtml = `<div style="font-size:11px;font-weight:700;letter-spacing:0.10em;text-transform:uppercase;color:#1D3BB3;margin-bottom:12px;">${escapeHtml(fmtDateLong(selectedDate))}</div>`;

    // Assemble
    root.innerHTML = headerHtml + `<div style="height:12px;"></div>` + alertsHtml +
      `<div style="margin-bottom:20px;">${strip1}${strip2}${strip3}</div>` + briefHtml + feedHtml;

    // ---- Wire event handlers ----

    // Pills removed — single event date, no switching

    // Radar strip toggles
    root.querySelectorAll("[data-radar-toggle]").forEach(btn => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-radar-toggle");
        const body = root.querySelector(`[data-radar-body="${id}"]`);
        const chevron = root.querySelector(`[data-radar-chevron="${id}"]`);
        if (!body) return;
        const isOpen = body.style.display !== "none";
        body.style.display = isOpen ? "none" : "block";
        if (chevron) chevron.style.transform = isOpen ? "none" : "rotate(180deg)";
      });
    });

    // Carte CTA in strip 3
    root.querySelectorAll("[data-radar-carte]").forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        data._mapMode = null;
        renderMonitor(data, item, selectedDate, "carte", monitorDates);
      });
    });

    // Concurrents potentiels button → dedicated view
    root.querySelectorAll("[data-radar-concurrents]").forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        renderMonitor(data, item, selectedDate, "concurrents", monitorDates);
      });
    });

    // Feed "show all" button
    const feedShowAll = root.querySelector("#pls-v4-feed-show-all");
    if (feedShowAll) {
      feedShowAll.addEventListener("click", () => {
        window.__plsV4FeedShowAll = true;
        renderMonitor(data, item, selectedDate, "radar", monitorDates);
      });
    }

    // Feed "Suivre" handlers (event_new)
    root.querySelectorAll("[data-feed-follow]").forEach(btn => {
      btn.addEventListener("click", async (e) => {
        e.stopPropagation();
        btn.disabled = true;
        btn.textContent = "...";
        const label = btn.getAttribute("data-follow-label") || "";
        const venue = btn.getAttribute("data-follow-venue") || "";
        const city = btn.getAttribute("data-follow-city") || "";
        const date = btn.getAttribute("data-follow-date") || "";
        const industry = btn.getAttribute("data-follow-industry") || "";
        try {
          const [compRes, evRes] = await Promise.all([
            venue && city ? fetch("/api/competitive/add-competitor", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ competitor_name: venue, city: city, industry_code: industry || null }),
            }) : Promise.resolve(null),
            label && city && date ? fetch("/api/competitive/add-event", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ event_name: label, event_city: city, date_start: date }),
            }) : Promise.resolve(null),
          ]);
          const compOk = !compRes || (await compRes.json().catch(() => null))?.ok;
          const evOk = !evRes || (await evRes.json().catch(() => null))?.ok;
          if (compOk || evOk) {
            btn.textContent = "Suivi \u2713";
            btn.style.background = "#dcfce7";
            btn.style.borderColor = "#bbf7d0";
            btn.style.color = "#166534";
          } else {
            btn.textContent = "Erreur";
            btn.style.background = "#fef2f2";
            btn.style.borderColor = "#fecaca";
            btn.style.color = "#991b1b";
            btn.disabled = false;
          }
        } catch {
          btn.textContent = "Erreur";
          btn.disabled = false;
        }
      });
    });

    // Feed "Voir plus" enrich handlers (event_new)
    root.querySelectorAll("[data-feed-enrich]").forEach(btn => {
      btn.addEventListener("click", async (e) => {
        e.stopPropagation();
        const idx = btn.getAttribute("data-feed-enrich");
        const panel = root.querySelector('[data-feed-enrich-panel="' + idx + '"]');
        if (!panel) return;

        if (panel.style.display !== "none" && panel.innerHTML.trim()) {
          panel.style.display = "none";
          btn.textContent = "Voir plus \u2192";
          return;
        }

        panel.style.display = "block";
        panel.innerHTML = '<div style="font-size:12px;color:#9CA3AF;padding:8px 0;display:flex;align-items:center;gap:8px;"><span style="width:10px;height:10px;border:1.5px solid #E5E7EB;border-top-color:#1D3BB3;border-radius:50%;display:inline-block;animation:ms-spin 0.7s linear infinite;flex-shrink:0;"></span>Recherche en cours\u2026</div>';
        btn.textContent = "R\u00e9duire \u2191";

        try {
          const res = await fetch("/api/insight/enrich-event", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              event_label: btn.getAttribute("data-enrich-label") || "",
              description: "",
              city_name: btn.getAttribute("data-enrich-city") || "",
              event_venue_name: btn.getAttribute("data-enrich-venue") || "",
              event_uid: btn.getAttribute("data-enrich-uid") || null,
              city_id: null,
              distance_m: btn.getAttribute("data-enrich-distance") ? Number(btn.getAttribute("data-enrich-distance")) : null,
              radius_bucket: null,
              industry_code: btn.getAttribute("data-enrich-industry") || null,
            }),
          });
          const json = await res.json().catch(() => null);
          if (!json?.ok || !json?.data) throw new Error("R\u00e9ponse invalide");
          const d = json.data;
          const rows = [
            d.confirmed_dates      ? ["Dates",        d.confirmed_dates]      : null,
            d.venue_name           ? ["Lieu",          d.venue_name]           : null,
            d.venue_capacity       ? ["Capacit\u00e9", d.venue_capacity]       : null,
            d.organizer            ? ["Organisateur",  d.organizer]            : null,
            d.estimated_attendance ? ["Fr\u00e9quentation", d.estimated_attendance] : null,
          ].filter(Boolean);
          const tags = d.audience_profile ? d.audience_profile.split(/[,;]/).map(t => t.trim()).filter(Boolean) : [];
          panel.innerHTML = '<div style="background:#F9FAFB;border:0.5px solid #E5E7EB;border-radius:10px;overflow:hidden;margin-top:4px;">'
            + (rows.length ? '<div style="display:grid;grid-template-columns:1fr 1fr;">' + rows.map((r, i) =>
              '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;' + (i % 2 === 0 && i < rows.length - 1 ? 'border-right:0.5px solid #F3F4F6;' : '') + '">'
              + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:3px;">' + escapeHtml(r[0]) + '</div>'
              + '<div style="font-size:13px;color:#111827;line-height:1.4;">' + escapeHtml(String(r[1])) + '</div>'
              + '</div>'
            ).join('') + '</div>' : '')
            + (tags.length ? '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
              + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:6px;">Audience</div>'
              + '<div style="display:flex;flex-wrap:wrap;gap:5px;">' + tags.map(t => '<span style="font-size:11px;font-weight:500;padding:2px 9px;border-radius:20px;background:#EFF6FF;color:#1D4ED8;">' + escapeHtml(t) + '</span>').join('') + '</div>'
              + '</div>' : '')
            + (d.business_takeaway ? '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
              + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:5px;">Impact pour votre activit\u00e9</div>'
              + '<div style="font-size:12px;color:#111827;line-height:1.55;">' + escapeHtml(d.business_takeaway) + '</div>'
              + '</div>' : '')
            + '<div style="padding:9px 14px;display:flex;justify-content:space-between;align-items:center;">'
              + '<div style="font-size:10px;letter-spacing:0.07em;text-transform:uppercase;color:#9CA3AF;display:flex;align-items:center;gap:5px;">'
                + '<span style="width:6px;height:6px;border-radius:50%;background:#059669;display:inline-block;flex-shrink:0;"></span>'
                + 'Agent IA \u00b7 web'
              + '</div>'
              + (d.source_url ? '<a href="' + escapeHtml(d.source_url) + '" target="_blank" rel="noopener" style="font-size:12px;color:#1D3BB3;text-decoration:none;">Source officielle \u2192</a>' : '')
            + '</div>'
          + '</div>';
        } catch {
          panel.innerHTML = '<div style="font-size:12px;color:#B91C1C;padding:4px 0;">Donn\u00e9es non disponibles.</div>';
          btn.textContent = "Voir plus \u2192";
        }
      });
    });

    // Daily Brief handlers
    wireBriefHandlers(root, location_id, selectedDate);

    // Feed CTA handlers
    root.querySelectorAll("[data-feed-cta]").forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const action = btn.getAttribute("data-feed-cta");
        if (action === "map") {
          data._mapMode = null;
          renderMonitor(data, item, selectedDate, "carte", monitorDates);
        } else if (action === "threats") {
          const strip2Body = root.querySelector('[data-radar-body="threats"]');
          const strip2Chevron = root.querySelector('[data-radar-chevron="threats"]');
          if (strip2Body && strip2Body.style.display === "none") {
            strip2Body.style.display = "block";
            if (strip2Chevron) strip2Chevron.style.transform = "rotate(180deg)";
            strip2Body.scrollIntoView({ behavior: "smooth", block: "start" });
          }
        }
        if (action === "mobility") {
          data._mapMode = "mobilite";
          renderMonitor(data, item, selectedDate, "carte", monitorDates);
        }
      });
    });
  }

  // ----------------------------------------------------------------
  // Fetch
  // ----------------------------------------------------------------
  async function fetchMonitor(loc, datesArr) {
    const qs = new URLSearchParams();
    qs.set("location_id", loc);
    qs.set("selected_dates", datesArr.join(","));
    const res = await fetch("/api/insight/monitor?" + qs.toString(), { cache: "no-store" });
    const json = await res.json().catch(() => null);
    if (!res.ok || !json?.ok) throw new Error(json?.error || "Erreur monitor API");
    return json;
  }

  async function fetchSavedItem(id) {
    const res = await fetch("/api/saved-items/get", {
      method: "POST",
      headers: { "content-type": "application/json", accept: "application/json" },
      body: JSON.stringify({ saved_item_id: id }),
      cache: "no-store",
    });
    const json = await res.json().catch(() => null);
    if (!res.ok || !json?.ok) throw new Error(json?.error || "Erreur get");
    return json.item;
  }

  function extractDates(item) {
    if (Array.isArray(item?.dates)) return item.dates.map(normalizeYmd).filter(Boolean);
    const s = typeof item?.dates === "string" ? item.dates.trim() : "";
    if (s.startsWith("[")) { try { return JSON.parse(s).map(normalizeYmd).filter(Boolean); } catch (_) {} }
    if (s.includes("-")) return s.split(",").map(normalizeYmd).filter(Boolean);
    return [];
  }

  async function fetchCompetitorSignals(date) {
    if (!date) return { signals: [], followed_count: 0 };
    try {
      const res = await fetch(
        `/api/competitive/competitor-signals?selected_date=${encodeURIComponent(date)}`
      );
      const json = await res.json().catch(() => null);
      return {
        signals: (json?.ok && Array.isArray(json.signals)) ? json.signals : [],
        followed_count: json?.followed_count ?? 0,
        top_threats: (json?.ok && Array.isArray(json.top_threats)) ? json.top_threats : [],
      };
    } catch { return { signals: [], followed_count: 0 }; }
  }

