            + '<button type="button" data-bilan-fb="non" data-bilan-i="' + i + '" data-bilan-loc="' + escapeHtml(location_id) + '" data-bilan-date="' + escapeHtml(selectedDate) + '" style="font-size:11px;font-weight:600;padding:3px 11px;border:1px solid #E6E8EC;background:#fff;color:#565C66;cursor:pointer;font-family:inherit;border-radius:6px;">Non</button>'
          + '</div>';
        }
        return '<div style="display:flex;align-items:flex-start;gap:11px;padding:13px 0;' + (i > 0 ? "border-top:1px solid #E6E8EC;" : "") + '">'
          + '<span style="width:5px;height:5px;border-radius:50%;background:#C4C9D1;flex-shrink:0;margin-top:7px;"></span>'
          + '<div style="flex:1;min-width:0;font-size:13.5px;color:#565C66;line-height:1.45;">' + escapeHtml(a.sentence) + '</div>'
          + _ctrl
        + '</div>';
      }).join("");
      bilanHtml = '<div style="margin-bottom:20px;">'
        + '<p style="font-size:11px;letter-spacing:0.07em;text-transform:uppercase;color:#8A909A;font-weight:500;margin:0 0 10px;">Bilan de la journ\u00e9e</p>'
        + '<p style="font-size:13.5px;color:#565C66;line-height:1.5;margin:0 0 12px;">' + escapeHtml(_bSummary) + '</p>'
        + (_n > 0 ? ('<div>' + _bRows + '</div>') : '')
      + '</div>';
    }

    // Assemble
    const stripsPanel = `<div style="margin-bottom:20px;"><p style="font-size:11px;letter-spacing:0.07em;text-transform:uppercase;color:#8A909A;font-weight:500;margin:0 0 10px;">Mon environnement</p><div style="background:#F4F5F7;border:0.5px solid #E6E8EC;border-radius:10px;overflow:hidden;">${strip1}${strip2}${strip3}</div></div>`;
    root.innerHTML = headerHtml + `<div style="height:12px;"></div>`
      + (_mode === "past"
          ? bilanHtml + stripsPanel + feedHtml
          : alertsHtml + stripsPanel + briefHtml + feedHtml);

    // ---- Bilan per-factor feedback wiring (document-delegated, attached once) ----
    if (!window.__bilanFbWired) {
      window.__bilanFbWired = true;
      document.addEventListener("click", function (ev) {
        var btn = ev.target && ev.target.closest ? ev.target.closest("[data-bilan-fb]") : null;
        if (!btn) return;
        var ans = btn.getAttribute("data-bilan-fb");
        var i = parseInt(btn.getAttribute("data-bilan-i"), 10);
        var loc = btn.getAttribute("data-bilan-loc");
        var dt = btn.getAttribute("data-bilan-date");
        var conf = ans === "oui" ? "confirmed" : "negative";
        var ctrl = btn.parentNode;
        if (ctrl) {
          ctrl.innerHTML = ans === "oui"
            ? '<span style="font-size:11px;font-weight:600;color:#166534;white-space:nowrap;">\u2713 Confirm\u00e9</span>'
            : '<span style="font-size:11px;font-weight:600;color:#8A909A;white-space:nowrap;">Pas arriv\u00e9 \u00b7 not\u00e9</span>';
        }
        try {
          var k = "ms_bilan_fb_" + loc + "_" + dt;
          var st = JSON.parse(localStorage.getItem(k) || "{}");
          st[i] = conf;
          localStorage.setItem(k, JSON.stringify(st));
        } catch (e) {}
        var reg = (window.__bilanData || {})[loc + "|" + dt] || [];
        var fct = reg[i] || {};
        fetch("/api/analytics/confirm", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            signal_type: "outcome",
            confirmation: conf,
            signal_ref_id: "bilan:" + dt + ":" + i,
            signal_date: dt,
            location_id: loc,
            feedback_text: fct.sentence || null
          })
        }).catch(function () {});
      });
    }

    // ---- Wire event handlers ----

    // Pills removed — single event date, no switching

    // Radar strip toggles
    root.querySelectorAll("[data-radar-toggle]").forEach(btn => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-radar-toggle");
        const body = root.querySelector(`[data-radar-body="${id}"]`);
        const chevron = root.querySelector(`[data-radar-chevron="${id}"]`);
        if (!body) return;
        const isOpen = body.style.display !== "none";
        body.style.display = isOpen ? "none" : "block";
        if (chevron) chevron.style.transform = isOpen ? "none" : "rotate(180deg)";
      });
    });

    // Carte CTA in strip 3
    root.querySelectorAll("[data-radar-carte]").forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        data._mapMode = null;
        renderMonitor(data, item, selectedDate, "carte", monitorDates);
      });
    });

    // Concurrents potentiels button → dedicated view
    root.querySelectorAll("[data-radar-concurrents]").forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        renderMonitor(data, item, selectedDate, "concurrents", monitorDates);
      });
    });

    // Feed "show all" button
    const feedShowAll = root.querySelector("#pls-v4-feed-show-all");
    if (feedShowAll) {
      feedShowAll.addEventListener("click", () => {
        window.__plsV4FeedShowAll = true;
        renderMonitor(data, item, selectedDate, "radar", monitorDates);
      });
    }

    // Feed "Suivre" handlers (event_new)
    root.querySelectorAll("[data-feed-follow]").forEach(btn => {
      btn.addEventListener("click", async (e) => {
        e.stopPropagation();
        btn.disabled = true;
        btn.textContent = "...";
        const label = btn.getAttribute("data-follow-label") || "";
        const venue = btn.getAttribute("data-follow-venue") || "";
        const city = btn.getAttribute("data-follow-city") || "";
        const date = btn.getAttribute("data-follow-date") || "";
        const industry = btn.getAttribute("data-follow-industry") || "";
        try {
          const [compRes, evRes] = await Promise.all([
            venue && city ? fetch("/api/competitive/add-competitor", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ competitor_name: venue, city: city, industry_code: industry || null }),
            }) : Promise.resolve(null),
            label && city && date ? fetch("/api/competitive/add-event", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ event_name: label, event_city: city, date_start: date }),
            }) : Promise.resolve(null),
          ]);
          const compOk = !compRes || (await compRes.json().catch(() => null))?.ok;
          const evOk = !evRes || (await evRes.json().catch(() => null))?.ok;
          if (compOk || evOk) {
            btn.textContent = "Suivi \u2713";
            btn.style.background = "#dcfce7";
            btn.style.borderColor = "#bbf7d0";
            btn.style.color = "#166534";
          } else {
            btn.textContent = "Erreur";
            btn.style.background = "#fef2f2";
            btn.style.borderColor = "#fecaca";
            btn.style.color = "#991b1b";
            btn.disabled = false;
          }
        } catch {
          btn.textContent = "Erreur";
          btn.disabled = false;
        }
      });
    });

    // Feed "Voir plus" enrich handlers (event_new)
    root.querySelectorAll("[data-feed-enrich]").forEach(btn => {
      btn.addEventListener("click", async (e) => {
        e.stopPropagation();
        const idx = btn.getAttribute("data-feed-enrich");
        const panel = root.querySelector('[data-feed-enrich-panel="' + idx + '"]');
        if (!panel) return;

        if (panel.style.display !== "none" && panel.innerHTML.trim()) {
          panel.style.display = "none";
          btn.textContent = "Voir plus \u2192";
          return;
        }

        panel.style.display = "block";
        panel.innerHTML = '<div style="font-size:12px;color:#9CA3AF;padding:8px 0;display:flex;align-items:center;gap:8px;"><span style="width:10px;height:10px;border:1.5px solid #E5E7EB;border-top-color:#1D3BB3;border-radius:50%;display:inline-block;animation:ms-spin 0.7s linear infinite;flex-shrink:0;"></span>Recherche en cours\u2026</div>';
        btn.textContent = "R\u00e9duire \u2191";

        try {
          const res = await fetch("/api/insight/enrich-event", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              event_label: btn.getAttribute("data-enrich-label") || "",
              description: "",
              city_name: btn.getAttribute("data-enrich-city") || "",
              event_venue_name: btn.getAttribute("data-enrich-venue") || "",
              event_uid: btn.getAttribute("data-enrich-uid") || null,
              city_id: null,
              distance_m: btn.getAttribute("data-enrich-distance") ? Number(btn.getAttribute("data-enrich-distance")) : null,
              radius_bucket: null,
              industry_code: btn.getAttribute("data-enrich-industry") || null,
            }),
          });
          const json = await res.json().catch(() => null);
          if (!json?.ok || !json?.data) throw new Error("R\u00e9ponse invalide");
          const d = json.data;
          const rows = [
            d.confirmed_dates      ? ["Dates",        d.confirmed_dates]      : null,
            d.venue_name           ? ["Lieu",          d.venue_name]           : null,
            d.venue_capacity       ? ["Capacit\u00e9", d.venue_capacity]       : null,
            d.organizer            ? ["Organisateur",  d.organizer]            : null,
            d.estimated_attendance ? ["Fr\u00e9quentation", d.estimated_attendance] : null,
          ].filter(Boolean);
          const tags = d.audience_profile ? d.audience_profile.split(/[,;]/).map(t => t.trim()).filter(Boolean) : [];
          panel.innerHTML = '<div style="background:#F9FAFB;border:0.5px solid #E5E7EB;border-radius:10px;overflow:hidden;margin-top:4px;">'
            + (rows.length ? '<div style="display:grid;grid-template-columns:1fr 1fr;">' + rows.map((r, i) =>
              '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;' + (i % 2 === 0 && i < rows.length - 1 ? 'border-right:0.5px solid #F3F4F6;' : '') + '">'
              + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:3px;">' + escapeHtml(r[0]) + '</div>'
              + '<div style="font-size:13px;color:#111827;line-height:1.4;">' + escapeHtml(String(r[1])) + '</div>'
              + '</div>'
            ).join('') + '</div>' : '')
            + (tags.length ? '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
              + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:6px;">Audience</div>'
              + '<div style="display:flex;flex-wrap:wrap;gap:5px;">' + tags.map(t => '<span style="font-size:11px;font-weight:500;padding:2px 9px;border-radius:20px;background:#EFF6FF;color:#1D4ED8;">' + escapeHtml(t) + '</span>').join('') + '</div>'
              + '</div>' : '')
            + (d.business_takeaway ? '<div style="padding:10px 14px;border-bottom:0.5px solid #F3F4F6;">'
              + '<div style="font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:#9CA3AF;margin-bottom:5px;">Impact pour votre activit\u00e9</div>'
              + '<div style="font-size:12px;color:#111827;line-height:1.55;">' + escapeHtml(d.business_takeaway) + '</div>'
              + '</div>' : '')
            + '<div style="padding:9px 14px;display:flex;justify-content:space-between;align-items:center;">'
              + '<div style="font-size:10px;letter-spacing:0.07em;text-transform:uppercase;color:#9CA3AF;display:flex;align-items:center;gap:5px;">'
                + '<span style="width:6px;height:6px;border-radius:50%;background:#059669;display:inline-block;flex-shrink:0;"></span>'
                + 'Agent IA \u00b7 web'
              + '</div>'
              + (d.source_url ? '<a href="' + escapeHtml(d.source_url) + '" target="_blank" rel="noopener" style="font-size:12px;color:#1D3BB3;text-decoration:none;">Source officielle \u2192</a>' : '')
            + '</div>'
          + '</div>';
        } catch {
          panel.innerHTML = '<div style="font-size:12px;color:#B91C1C;padding:4px 0;">Donn\u00e9es non disponibles.</div>';
          btn.textContent = "Voir plus \u2192";
        }
      });
    });

    // Daily Brief handlers
    wireBriefHandlers(root, itemLocationId, selectedDate);

    // Feed CTA handlers — links navigate directly, no JS needed
  }

  // ----------------------------------------------------------------
  // Fetch
  // ----------------------------------------------------------------
  async function fetchMonitor(loc, datesArr) {
    const qs = new URLSearchParams();
    qs.set("location_id", loc);
    qs.set("selected_dates", datesArr.join(","));
    const res = await fetch("/api/insight/monitor?" + qs.toString(), { cache: "no-store" });
    const json = await res.json().catch(() => null);
    if (!res.ok || !json?.ok) throw new Error(json?.error || "Erreur monitor API");
    return json;
  }

  async function fetchSavedItem(id) {
    const res = await fetch("/api/saved-items/get", {
      method: "POST",
      headers: { "content-type": "application/json", accept: "application/json" },
      body: JSON.stringify({ saved_item_id: id }),
      cache: "no-store",
    });
    const json = await res.json().catch(() => null);
    if (!res.ok || !json?.ok) throw new Error(json?.error || "Erreur get");
    return json.item;
  }

  function extractDates(item) {
    if (Array.isArray(item?.dates)) return item.dates.map(normalizeYmd).filter(Boolean);
    const s = typeof item?.dates === "string" ? item.dates.trim() : "";
    if (s.startsWith("[")) { try { return JSON.parse(s).map(normalizeYmd).filter(Boolean); } catch (_) {} }
    if (s.includes("-")) return s.split(",").map(normalizeYmd).filter(Boolean);
    return [];
  }

  async function fetchCompetitorSignals(date) {
    if (!date) return { signals: [], followed_count: 0 };
    try {
      const res = await fetch(
        `/api/competitive/competitor-signals?selected_date=${encodeURIComponent(date)}`
      );
      const json = await res.json().catch(() => null);
      return {
        signals: (json?.ok && Array.isArray(json.signals)) ? json.signals : [],
        followed_count: json?.followed_count ?? 0,
        top_threats: (json?.ok && Array.isArray(json.top_threats)) ? json.top_threats : [],
      };
    } catch { return { signals: [], followed_count: 0 }; }
  }

    // ----------------------------------------------------------------
  // Main render
  // ----------------------------------------------------------------
  function renderBilan(item, snapshot, savedItemId) {
    const root = document.getElementById("mon-root");
    if (!root) return;

    const selDate = normalizeYmd(item?.selected_date?.value ?? item?.selected_date ?? "");

    function radioGroup(id, options) {
      return `<div id="rg-${id}" style="display:flex;flex-direction:column;gap:7px;margin-bottom:20px;">
        ${options.map((opt, i) => `
          <div class="bilan-opt" data-group="${id}" data-value="${escapeHtml(opt.value)}"
            style="display:flex;align-items:center;gap:10px;padding:10px 14px;border:.5px solid #E5E7EB;border-radius:10px;cursor:pointer;">
            <span class="bilan-dot" style="width:16px;height:16px;border-radius:50%;border:1.5px solid #D1D5DB;flex-shrink:0;display:inline-block;"></span>
            <span style="font-size:13px;color:#111827;">${escapeHtml(opt.label)}</span>
          </div>`).join('')}
      </div>`;
    }

    function predictionBadge(label) {
      return `<span style="display:inline-block;font-size:11px;font-weight:500;padding:2px 9px;border-radius:6px;background:#EEF2FF;color:#1D3BB3;margin-bottom:8px;">${escapeHtml(label)}</span>`;
    }

    const weatherPred = snapshot
      ? (snapshot.lvl_rain > 1 || snapshot.lvl_wind > 1 || snapshot.lvl_snow > 1
          ? `Risque météo prévu (niv. ${Math.max(snapshot.lvl_rain||0, snapshot.lvl_wind||0, snapshot.lvl_snow||0)})`
          : "Conditions météo favorables prévues")
      : null;

    const concPred = snapshot
      ? (snapshot.delta_att_events_pct > 3 ? "Pression concurrentielle élevée prévue" : "Faible pression concurrentielle prévue")
      : null;

    const mobPred = snapshot
      ? (snapshot.delta_att_mobility_car_pct < -4 ? "Perturbations mobilité prévues" : "Accessibilité fluide prévue")
      : null;

    root.innerHTML = `
      <div class="mon-card-decision" style="margin-bottom:0;">
        <div style="display:flex;align-items:center;gap:6px;margin-bottom:8px;">
          <span style="width:8px;height:8px;border-radius:50%;background:#6B7280;flex-shrink:0;"></span>
          <span style="font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#6B7280;">Événement terminé · ${escapeHtml(fmtDateLong(selDate))}</span>
        </div>
        <div style="font-size:20px;font-weight:500;color:#111827;margin-bottom:4px;">${escapeHtml(item?.title || "Événement")}</div>
        <div style="font-size:13px;color:#6b7280;">Bilan conditions externes — aide à calibrer vos prochaines recommandations.</div>
      </div>

      <div class="mon-panels" style="padding-top:16px;">
        <div class="mon-card">
          <div style="font-size:11px;font-weight:700;letter-spacing:0.10em;text-transform:uppercase;color:#1D3BB3;margin-bottom:16px;">Conditions externes</div>

          <div style="font-size:13px;font-weight:500;color:#111827;margin-bottom:4px;">Météo</div>
          ${weatherPred ? predictionBadge('Nous avions prévu : ' + weatherPred) : ''}
          <div style="font-size:12px;color:#6b7280;margin-bottom:10px;">Les conditions météo correspondaient-elles à nos prévisions ?</div>
          ${radioGroup('meteo', [
            {value:'conforme',  label:'Oui, conforme'},
            {value:'mieux',     label:'Meilleures que prévu'},
            {value:'pire',      label:'Pires que prévu'},
          ])}

          <div style="height:1px;background:#F3F4F6;margin:4px 0 18px;"></div>

          <div style="font-size:13px;font-weight:500;color:#111827;margin-bottom:4px;">Concurrence</div>
          ${concPred ? predictionBadge('Nous avions prévu : ' + concPred) : ''}
          <div style="font-size:12px;color:#6b7280;margin-bottom:10px;">Avez-vous observé une pression concurrentielle ce jour-là ?</div>
          ${radioGroup('conc', [
            {value:'faible',   label:'Faible — aucun impact notable'},
            {value:'moderee',  label:'Modérée — impact limité'},
            {value:'forte',    label:'Forte — impact ressenti'},
          ])}

          <div style="height:1px;background:#F3F4F6;margin:4px 0 18px;"></div>

          <div style="font-size:13px;font-weight:500;color:#111827;margin-bottom:4px;">Accessibilité</div>
          ${mobPred ? predictionBadge('Nous avions prévu : ' + mobPred) : ''}
          <div style="font-size:12px;color:#6b7280;margin-bottom:10px;">L'accès à votre site était-il fluide pour vos visiteurs ?</div>
          ${radioGroup('mob', [
            {value:'fluide',    label:'Fluide'},
            {value:'difficile', label:'Quelques difficultés'},
            {value:'perturbe',  label:'Fortement perturbé'},
          ])}
        </div>

        <div class="mon-card">
          <div style="font-size:11px;font-weight:700;letter-spacing:0.10em;text-transform:uppercase;color:#9CA3AF;margin-bottom:16px;">Votre performance</div>

          <div style="font-size:13px;font-weight:500;color:#111827;margin-bottom:10px;">Fréquentation</div>
          ${radioGroup('freq', [
            {value:'beyond',    label:'Bien au-delà des attentes'},
            {value:'conforme',  label:'Conforme aux attentes'},
            {value:'endeca',    label:'En deçà des attentes'},
          ])}

          <div style="font-size:13px;font-weight:500;color:#111827;margin-bottom:6px;">
            Nombre de visiteurs <span style="color:#9CA3AF;font-weight:400;">(optionnel)</span>
          </div>
          <input id="bilan-attendance" type="number" placeholder="ex. 340"
            style="width:140px;padding:8px 12px;border:.5px solid #E5E7EB;border-radius:8px;font-size:13px;font-family:inherit;color:#111827;background:#fff;margin-bottom:20px;" />

          <div style="font-size:13px;font-weight:500;color:#111827;margin-bottom:6px;">
            Commentaire <span style="color:#9CA3AF;font-weight:400;">(optionnel)</span>
          </div>
          <textarea id="bilan-comment" placeholder="Contexte particulier, observation, retour terrain…"
            style="width:100%;padding:10px 12px;border:.5px solid #E5E7EB;border-radius:8px;font-size:13px;font-family:inherit;color:#111827;background:#fff;resize:vertical;min-height:72px;margin-bottom:20px;"></textarea>

          <div style="display:flex;align-items:center;gap:10px;">
            <button id="bilan-submit"
              style="padding:10px 20px;background:#1D3BB3;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;font-family:inherit;">
