      } catch (e) {}
      var _fbKey = "ms_bilan_fb_" + location_id + "_" + selectedDate;
      var _fbState = {};
      try { _fbState = JSON.parse(localStorage.getItem(_fbKey) || "{}"); } catch (e) {}
      const _bRows = _bSorted.map((a, i) => {
        var _ans = _fbState[i];
        var _ctrl;
        if (_ans === "confirmed") {
          _ctrl = '<div style="display:flex;align-items:center;flex-shrink:0;margin-top:1px;"><span style="font-size:11px;font-weight:600;color:#166534;white-space:nowrap;">\u2713 Confirm\u00e9</span></div>';
        } else if (_ans === "negative") {
          _ctrl = '<div style="display:flex;align-items:center;flex-shrink:0;margin-top:1px;"><span style="font-size:11px;font-weight:600;color:#8A909A;white-space:nowrap;">Pas arriv\u00e9 \u00b7 not\u00e9</span></div>';
        } else {
          _ctrl = '<div style="display:flex;align-items:center;gap:7px;flex-shrink:0;margin-top:1px;">'
