---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { SignedIn, SignedOut } from "@clerk/astro/components";
import InsightBottomBar from "../../../components/InsightBottomBar.astro";

const location_id =
  Astro.locals && typeof (Astro.locals as any).location_id === "string" && (Astro.locals as any).location_id.trim()
    ? (Astro.locals as any).location_id.trim()
    : null;

if (!location_id) {
  return Astro.redirect("/profile");
}

const saved_item_id = Astro.url?.searchParams?.get("saved_item_id") ?? "";
const focused_date  = Astro.url?.searchParams?.get("date") ?? "";
---

<SignedOut>
  <script is:inline>window.location.href = "/sign-in";</script>
</SignedOut>

<SignedIn>
  <BaseLayout title="Monitor — Insight Event" hideSurveyCta={true} hideFooter={true}>

    <style is:inline>
      .mon-wrap {
        width: 100%;
        max-width: 720px;
        margin: 0 auto;
        padding: 0 20px 160px 20px;
        box-sizing: border-box;
      }

      /* ---- Cards (match days page) ---- */
      .mon-card {
        background: #FFFFFF;
        border: 1px solid #E8EDF5;
        border-radius: 14px;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(17,24,39,0.06);
      }

      .mon-card-decision {
        background: rgba(29,59,179,0.04);
        border-left: 6px solid #0b37e5;
        padding: 24px;
      }

      .mon-panels {
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding-top: 16px;
      }

      /* ---- Typography (match days page) ---- */
      .mon-kicker {
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.10em;
        text-transform: uppercase;
        color: #1D3BB3;
        line-height: 1.1;
        margin: 0 0 6px 0;
      }

      .mon-head {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
      }

      .mon-ico {
        width: 20px;
        height: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .mon-ico svg { display: block; }

      /* ---- Header ---- */
      .mon-header-suivi {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #059669;
        margin-bottom: 10px;
      }

      .mon-header-suivi-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #059669;
        flex-shrink: 0;
      }

      .mon-header-title {
        font-size: 22px;
        font-weight: 500;
        color: #111827;
        margin: 0 0 4px 0;
        line-height: 1.2;
      }

      .mon-header-date {
        font-size: 13px;
        color: #6b7280;
        margin: 0;
      }

      .mon-header-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 10px;
      }

      .mon-header-score {
        font-size: 42px;
        font-weight: 700;
        color: #111827;
        line-height: 1;
      }

      .mon-header-score-max {
        font-size: 16px;
        color: #9CA3AF;
        font-weight: 400;
      }

      .mon-countdown {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #9CA3AF;
      }

      .mon-statut-safe { background: #1D3BB3; color: #fff; padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
      .mon-statut-risk { background: rgba(220,38,38,0.1); color: #b91c1c; border: 1px solid rgba(220,38,38,0.2); padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }

      /* ---- Tabs (match days page ms-tab style) ---- */
      .mon-tabs-bar {
        display: flex;
        justify-content: flex-start;
        align-items: flex-end;
        gap: 22px;
        padding: 0 0 0 0;
        margin: 16px 0 0 0;
        border-bottom: 1px solid #E5E7EB;
      }

      .mon-tab {
        appearance: none;
        border: none;
        background: transparent;
        font-size: 14px;
        font-weight: 500;
        color: #94A3B8;
        padding: 0 0 16px 0;
        position: relative;
        cursor: pointer;
      }

      .mon-tab.is-active { color: #1D3BB3; }

      .mon-tab.is-active::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -1px;
        height: 3px;
        width: 100%;
        background: #1D3BB3;
        border-radius: 3px;
      }

      /* ---- Feed items (match days page) ---- */
      .mon-feed-item {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 14px 0;
        border-bottom: 1px solid #F3F4F6;
      }
      .mon-feed-item:last-child { border-bottom: none; }

      .mon-feed-line1 { font-size: 14px; font-weight: 700; color: #111827; line-height: 1.3; margin-bottom: 3px; }
      .mon-feed-line2 { font-size: 13px; color: #374151; line-height: 1.4; margin-bottom: 2px; }
      .mon-feed-line3 { font-size: 12px; color: #6B7280; }

      /* ---- Vigilance ---- */
      .mon-vigilance-item {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        font-size: 14px;
        color: #374151;
        line-height: 1.45;
        padding: 8px 0;
        border-bottom: 1px solid #F3F4F6;
      }
      .mon-vigilance-item:last-child { border-bottom: none; }

      /* ---- Context ---- */
      .mon-context-toggle {
        width: 100%;
        background: none;
        border: none;
        padding: 0;
        font: inherit;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .mon-context-body { margin-top: 16px; }

      .mon-context-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-top: 8px;
      }

      .mon-context-cell { display: flex; flex-direction: column; gap: 2px; }
      .mon-context-label { font-size: 11px; color: #9CA3AF; text-transform: uppercase; letter-spacing: .06em; }
      .mon-context-value { font-size: 13px; color: #111827; }

      /* ---- Map iframe ---- */
      .mon-map-iframe {
        width: 100%;
        height: 600px;
        border: none;
        border-radius: 14px;
        margin-top: 16px;
        display: block;
      }

      .mon-map-wrap {
        border-radius: 14px;
        margin-top: 16px;
      }

      /* ---- Breadcrumb ---- */
      .mon-breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 16px 0 20px 0;
        font-size: 13px;
        color: #888;
      }
      .mon-breadcrumb a { color: #0F1F3D; text-decoration: none; font-weight: 500; }
      .mon-breadcrumb a:hover { text-decoration: underline; }

      .mon-loading { padding: 40px 0; text-align: center; color: #9CA3AF; font-size: 14px; }
      .mon-error { padding: 20px; background: rgba(220,38,38,0.06); border-radius: 10px; color: #B91C1C; font-size: 13px; margin-top: 16px; }

      /* Status ok/warn/crit */
      .mon-status-ok   { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 600; color: #059669; }
      .mon-status-warn { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 600; color: #D97706; }
      .mon-status-crit { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 600; color: #b91c1c; }
    </style>

    <div class="mon-wrap">
      <nav class="mon-breadcrumb">
        <a href="#" id="mon-back">Choix</a>
        <span>/</span>
        <span>Piloter</span>
      </nav>

      <div id="mon-root">
        <div class="mon-loading">Chargement…</div>
      </div>
    </div>

    <InsightBottomBar active="days" showActions={false} />
  </BaseLayout>
</SignedIn>

<script is:inline define:vars={{ location_id, saved_item_id, focused_date }}>
(function () {

  // ----------------------------------------------------------------
  // Back button
  // ----------------------------------------------------------------
  document.getElementById('mon-back').addEventListener('click', function (e) {
    e.preventDefault();
    const mp = new URLSearchParams(window.location.search);
    const sid = mp.get("saved_item_id") || "";
    const d   = mp.get("date") || "";
    const params = new URLSearchParams();
    if (sid) params.set("saved_item_id", sid);
    if (d)   params.set("date", d);
    params.set("selected_date", "__comparison__");
    window.location.assign("/app/insightevent/days?" + params.toString());
  });

  // ----------------------------------------------------------------
  // Helpers
  // ----------------------------------------------------------------
  function escapeHtml(v) {
    return String(v ?? "")
      .replace(/&/g, "&amp;").replace(/</g, "&lt;")
      .replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
  }

  function normalizeYmd(v) {
    const s = String(v ?? "").trim();
    const m = s.match(/^(\d{4}-\d{2}-\d{2})/);
    return m ? m[1] : "";
  }

  function parseYmdToDate(ymd) {
    const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(String(ymd || "").trim());
    if (!m) return null;
    return new Date(Date.UTC(Number(m[1]), Number(m[2]) - 1, Number(m[3])));
  }

  function fmtDateLong(ymd) {
    const d = parseYmdToDate(ymd);
    if (!d) return ymd;
    const s = new Intl.DateTimeFormat("fr-FR", {
      weekday: "long", day: "numeric", month: "long", year: "numeric"
    }).format(d);
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  function fmtDateShort(ymd) {
    const d = parseYmdToDate(ymd);
    if (!d) return ymd;
    return new Intl.DateTimeFormat("fr-FR", { day: "numeric", month: "long" }).format(d);
  }

  function countdown(ymd) {
    if (!ymd) return null;
    const today = new Date(); today.setHours(0,0,0,0);
    const target = parseYmdToDate(ymd);
    if (!target) return null;
    const d = Math.round((target - today) / 86400000);
    if (d < 0)  return `Passé il y a ${Math.abs(d)}j`;
    if (d === 0) return `Aujourd'hui`;
    return `J-${d}`;
  }

  function pill(label, style) {
    return `<span style="display:inline-block;font-size:11px;font-weight:600;padding:2px 10px;border-radius:20px;${style}">${escapeHtml(label)}</span>`;
  }

  const GREEN  = "background:rgba(16,185,129,0.1);color:#059669;";
  const YELLOW = "background:#FEF3C7;color:#92400E;";
  const RED    = "background:#FCEBEB;color:#791F1F;";
  const GREY   = "background:#F1EFE8;color:#444441;";

  function severityDots(level) {
    const l = Math.min(4, Math.max(1, Number(level) || 1));
    return [1,2,3,4].map(i =>
      `<span style="width:8px;height:8px;border-radius:50%;display:inline-block;background:${i <= l ? "#1D3BB3" : "#E2E8F0"};"></span>`
    ).join("&nbsp;");
  }

  function iconSVG(kind) {
    if (kind === "sparkle")  return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2l1.2 5.1L18 9l-4.8 1.9L12 16l-1.2-5.1L6 9l4.8-1.9L12 2z" stroke="#1D3BB3" stroke-width="1.6"/></svg>`;
    if (kind === "alert")    return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 9v4" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"/><path d="M12 17h.01" stroke="#1D3BB3" stroke-width="3" stroke-linecap="round"/><path d="M10.3 4.3l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.7-2.7l-8-14a2 2 0 0 0-3.4 0z" stroke="#1D3BB3" stroke-width="1.6"/></svg>`;
    if (kind === "feed")     return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M4 4h16v12H4z" stroke="#1D3BB3" stroke-width="1.6" stroke-linejoin="round"/><path d="M8 20h8M12 16v4" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"/></svg>`;
    if (kind === "context")  return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 2v3M17 2v3" stroke="#1D3BB3" stroke-width="1.6" stroke-linecap="round"/><path d="M3.5 9h17" stroke="#1D3BB3" stroke-width="1.6"/><path d="M6 5h12a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z" stroke="#1D3BB3" stroke-width="1.6"/></svg>`;
    return "";
  }

  function feedCatIcon(cat) {
    const c = String(cat || "").toLowerCase();
    if (c === "competition") return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M8 21v-7M12 21V3M16 21v-11"/></svg>`;
    if (c === "opportunity") return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>`;
    if (c === "context")     return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.3 4.3l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.7-2.7l-8-14a2 2 0 0 0-3.4 0z"/></svg>`;
    if (c === "mobility")    return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><path d="M7 16h10l1-6H6l1 6z"/><path d="M7 16l-1 4M17 16l1 4"/><path d="M9 10V7a3 3 0 0 1 6 0v3"/></svg>`;
    return `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111827" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/></svg>`;
  }

  // ----------------------------------------------------------------
  // Feed rendering (copied from days page renderFeedForDate)
  // ----------------------------------------------------------------
  function feedLine1(a) {
    const sub = String(a?.change_subtype || "").toLowerCase();
    const dir = String(a?.direction || "").toLowerCase();
    const cat = String(a?.change_category || "").toLowerCase();
    const nv  = String(a?.new_value ?? "").toLowerCase();
    const d   = fmtDateShort(normalizeYmd(a?.affected_date));
    const map = {
      context_change:           cat === "competition" ? (nv === "true" ? `Concurrent détecté · ${d}` : `Concurrent retiré · ${d}`) : cat === "context" ? (dir === "worsened" || dir === "down" ? `Alerte météo renforcée · ${d}` : `Alerte météo réduite · ${d}`) : cat === "mobility" ? `Mobilité perturbée · ${d}` : `Signal de contexte · ${d}`,
      score_change:             dir === "up" ? `Score d'opportunité en hausse · ${d}` : `Score d'opportunité en baisse · ${d}`,
      future_score_change:      `Prévision d'opportunité revue · ${d}`,
      regime_change:            `Régime d'opportunité changé · ${d}`,
      medal_change:             `Classement des dates modifié · ${d}`,
      event_new:                `Concurrent détecté · ${d}`,
      event_removed:            `Concurrent retiré · ${d}`,
      weather_change:           (dir === "down" || dir === "worsened") ? `Alerte météo renforcée · ${d}` : `Alerte météo réduite · ${d}`,
      mobility_change:          `Mobilité perturbée · ${d}`,
      mega_event_activation:    `Méga-événement annoncé · ${d}`,
      mega_event_end:           `Méga-événement terminé · ${d}`,
      ranking_change:           `Classement des dates modifié · ${d}`,
      baseline_validity_change: `Référence recalculée · ${d}`,
    };
    return map[sub] || `Signal détecté · ${d}`;
  }

  function feedLine2(a) {
    const cat = String(a?.change_category || "").toLowerCase();
    const lvl = Math.min(4, Math.max(1, Number(a?.alert_level) || 1));
    const vocab = {
      competition: { 1: "Impact de la concurrence locale.", 2: "Impact notable de la concurrence locale.", 3: "Impact important de la concurrence locale.", 4: "Impact majeur de la concurrence locale." },
      opportunity: { 1: "Évolution globale du contexte.", 2: "Évolution notable du contexte global.", 3: "Impact sensible sur l'attractivité de la date.", 4: "Impact important sur l'attractivité de la date." },
      context:     { 1: "Impact météo sur cette date.", 2: "Impact notable de la météo sur cette date.", 3: "Impact possible de la météo sur l'organisation.", 4: "Impact important de la météo sur l'organisation." },
      planning:    { 1: "Impact de l'activité événementielle locale.", 2: "Impact notable de l'activité événementielle locale.", 3: "Impact important de l'activité événementielle locale.", 4: "Impact majeur de l'activité événementielle locale." },
      mobility:    { 1: "Impact des conditions de mobilité.", 2: "Impact notable sur les conditions d'accès.", 3: "Impact possible sur l'accès au lieu.", 4: "Impact important sur l'accès au lieu." },
    };
    return (vocab[cat] && vocab[cat][lvl]) || "Évolution globale du contexte.";
  }

  function feedLine3(a) {
    const sub = String(a?.change_subtype || "").toLowerCase();
    const cat = String(a?.change_category || "").toLowerCase();
    const parts = [];
    if (sub === "score_change" || cat === "opportunity") {
      const from  = a?.old_value != null ? Math.round(Number(a.old_value)) : null;
      const to    = a?.new_value != null ? Math.round(Number(a.new_value)) : null;
      const delta = a?.score_delta != null ? Math.round(Number(a.score_delta)) : (from != null && to != null ? to - from : null);
      if (from != null && to != null) { const sign = delta >= 0 ? "+" : ""; parts.push(`Score : ${from} → ${to} (${sign}${delta})`); }
    } else if (cat === "competition" || sub === "event_new" || sub === "event_removed" || sub === "context_change") {
      const name = a?.event_label || a?.event_name || "";
      const km   = a?.distance_m != null ? `${(Number(a.distance_m)/1000).toFixed(1)} km` : "";
      const ov   = a?.old_value != null ? String(a.old_value) : null;
      const nv   = a?.new_value != null ? String(a.new_value) : null;
      if (name && km) parts.push(`${name} · ${km}`);
      else if (name) parts.push(name);
      else if (km)   parts.push(`À ${km}`);
      else if (ov != null && nv != null && ov !== nv) {
        const ovL = ov === "true" ? "présent" : ov === "false" ? "absent" : ov;
        const nvL = nv === "true" ? "présent" : nv === "false" ? "absent" : nv;
        parts.push(`Présence concurrentielle : ${ovL} → ${nvL}`);
      }
    } else if (cat === "context" || sub === "weather_change") {
      const from = a?.old_value != null ? String(a.old_value) : null;
      const to   = a?.new_value != null ? String(a.new_value) : null;
      if (from && to && from !== to) parts.push(`${from} → ${to}`);
      else if (to) parts.push(to);
    } else if (cat === "mobility" || sub === "mobility_change") {
      const from = a?.old_value != null ? String(a.old_value) : null;
      const to   = a?.new_value != null ? String(a.new_value) : null;
      if (from && to && from !== to) parts.push(`Trafic : ${from} → ${to}`);
    }
    return parts.join(" · ");
  }

  function renderFeedItems(items) {
    if (!items.length) {
      return `<div style="text-align:center;padding:32px 0;color:#9CA3AF;font-size:14px;">Aucun signal détecté.</div>`;
    }

    // Group by affected_date
    const byDate = new Map();
    for (const a of items) {
      const d = normalizeYmd(a?.affected_date);
      if (!byDate.has(d)) byDate.set(d, []);
      byDate.get(d).push(a);
    }

    return [...byDate.entries()].map(([d, dayItems]) => {
      const itemsHtml = dayItems.map((a, idx) => {
        const line1 = feedLine1(a);
        const line2 = feedLine2(a);
        const line3 = feedLine3(a);
        const cat   = String(a?.change_category || "").toLowerCase();
        const lvl   = Number(a?.alert_level) || 1;
        const isLast = idx === dayItems.length - 1;

        return `
          <div style="padding:14px 0;display:flex;align-items:flex-start;gap:12px;${isLast ? "" : "border-bottom:1px solid #F3F4F6;"}">
            <div style="flex:0 0 auto;width:24px;display:flex;align-items:center;justify-content:center;margin-top:2px;">
              ${feedCatIcon(cat)}
            </div>
            <div style="flex:1;min-width:0;">
              <div class="mon-feed-line1">${escapeHtml(line1)}</div>
              ${line2 ? `<div class="mon-feed-line2" style="display:flex;align-items:center;gap:12px;"><span>${escapeHtml(line2)}</span><span style="display:inline-flex;align-items:center;gap:4px;">${severityDots(lvl)}</span></div>` : ""}
              ${line3 ? `<div class="mon-feed-line3">${escapeHtml(line3)}</div>` : ""}
            </div>
          </div>
        `;
      }).join("");

      const dateLabel = (() => {
        const dt = parseYmdToDate(d);
        if (!dt) return d;
        const raw = new Intl.DateTimeFormat("fr-FR", { weekday: "long", day: "numeric", month: "long", year: "numeric" }).format(dt);
        return raw.charAt(0).toUpperCase() + raw.slice(1);
      })();

      return `
        <div style="margin-bottom:16px;">
          <div style="background:#fff;border:1px solid #E8EDF5;border-radius:12px;padding:0 16px;box-shadow:0 1px 4px rgba(17,24,39,0.04);">
            <div style="font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(17,24,39,0.38);padding:14px 0 10px 0;border-bottom:1px solid #F3F4F6;">
              ${escapeHtml(dateLabel)}
            </div>
            ${itemsHtml}
          </div>
        </div>
      `;
    }).join("");
  }

  // ----------------------------------------------------------------
  // Render tabs
  // ----------------------------------------------------------------
  function renderTabBar(activeTab, date, selectedDates) {
    const tabs = [
      { id: "recap",   label: "Récapitulatif" },
      { id: "alertes", label: "Alertes" },
      { id: "carte",   label: "Carte" },
    ];
    return `
      <div class="mon-tabs-bar">
        ${tabs.map(t => `
          <button type="button" class="mon-tab ${activeTab === t.id ? "is-active" : ""}"
            data-tab="${escapeHtml(t.id)}">
            ${escapeHtml(t.label)}
          </button>
        `).join("")}
      </div>
    `;
  }

  // ----------------------------------------------------------------
  // Render recap tab
  // ----------------------------------------------------------------
  function renderRecap(currentDay, allFeed, item) {
    // Statut global
    const alerts = allFeed.filter(a => (Number(a?.alert_level) || 0) >= 2);
    const hasChanges = alerts.length > 0;
    const hasCrit = alerts.some(a => Number(a?.alert_level) >= 3);

    const statusHtml = `
      <div class="mon-card">
        <span class="${hasCrit ? "mon-status-crit" : hasChanges ? "mon-status-warn" : "mon-status-ok"}">
          ${hasCrit ? "⚠ Signaux critiques à surveiller"
            : hasChanges ? `⚠ ${alerts.length} signal${alerts.length > 1 ? "s" : ""} à surveiller`
            : "✓ Rien de nouveau depuis votre dernière consultation"}
        </span>
        ${renderLast3Feed(allFeed)}
      </div>
    `;

    // Points de vigilance
    const attendance   = Array.isArray(currentDay.attendance)   ? currentDay.attendance   : [];
    const operations   = Array.isArray(currentDay.operations)   ? currentDay.operations   : [];
    const installation = Array.isArray(currentDay.installation) ? currentDay.installation : [];
    const context      = Array.isArray(currentDay.context)      ? currentDay.context      : [];

    const vigilanceItems = [...attendance, ...operations, ...installation, ...context]
      .filter(r => r.severity !== "A")
      .sort((a, b) => ({ D: 0, C: 1, B: 2 }[a.severity] ?? 3) - ({ D: 0, C: 1, B: 2 }[b.severity] ?? 3))
      .slice(0, 5);

    const dotColor = s => s === "D" ? "#b91c1c" : s === "C" ? "#D97706" : "#9CA3AF";

    const vigilanceHtml = vigilanceItems.length ? `
      <div class="mon-card">
        <div class="mon-head">
          ${iconSVG("alert")}
          <div class="mon-kicker" style="margin:0;">Points de vigilance</div>
        </div>
        ${vigilanceItems.map(r => `
          <div class="mon-vigilance-item">
            <span style="width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:5px;background:${dotColor(r.severity)};display:inline-block;"></span>
            <span>${escapeHtml(r.sentence)}</span>
          </div>
        `).join("")}
      </div>
    ` : "";

    // Contexte de référence (open by default)
    const contextHtml = renderContext(currentDay);

    return `<div class="mon-panels">${statusHtml}${vigilanceHtml}${contextHtml}</div>`;
  }

  function renderLast3Feed(allFeed) {
    const last3 = [...allFeed]
      .sort((a, b) => String(b?.feed_date || "").localeCompare(String(a?.feed_date || "")))
      .slice(0, 3);

    if (!last3.length) return "";

    return `
      <div style="margin-top:16px;border-top:1px solid #F3F4F6;padding-top:4px;">
        <div style="font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:rgba(17,24,39,0.4);padding:10px 0 6px 0;">
          Derniers signaux
        </div>
        ${last3.map((a, idx) => {
          const line1 = feedLine1(a);
          const line2 = feedLine2(a);
          const lvl = Number(a?.alert_level) || 1;
          const isLast = idx === last3.length - 1;
          const dir = String(a?.direction || "").toLowerCase();
          const pillStyle = (dir === "up" || dir === "improved") ? GREEN
            : (dir === "down" || dir === "worsened" || lvl >= 3) ? RED
            : lvl >= 2 ? YELLOW : GREY;
          const pillLabel = (dir === "up" || dir === "improved") ? "En hausse"
            : (dir === "down" || dir === "worsened") ? "En baisse"
            : "Changement";

          return `
            <div style="padding:12px 0;display:flex;align-items:flex-start;gap:12px;${isLast ? "" : "border-bottom:1px solid #F3F4F6;}"}">
              <div style="flex:0 0 auto;width:20px;display:flex;align-items:center;justify-content:center;margin-top:2px;">
                ${feedCatIcon(String(a?.change_category || ""))}
              </div>
              <div style="flex:1;min-width:0;">
                <div style="font-size:13px;font-weight:700;color:#111827;line-height:1.3;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                  ${escapeHtml(line1)}
                  ${pill(pillLabel, pillStyle)}
                </div>
                ${line2 ? `<div style="font-size:12px;color:#374151;margin-top:2px;">${escapeHtml(line2)}</div>` : ""}
              </div>
            </div>
          `;
        }).join("")}
      </div>
    `;
  }

  function renderContext(day) {
    const score = day?.opportunity_score ?? day?.opportunity_score_final_local ?? null;
    const audience = day?.audience_likelihood;
    const audienceLabel = audience?.label ?? "—";
    const audienceReason = audience?.reason ?? "";
    
    // Concurrence: use raw counts (no delta available in monitor API)
    const count500 = Number(day?.events_within_500m_count) || 0;
    const count5km = Number(day?.events_within_5km_count)  || 0;
    const compTotal = count500 + count5km;
    const concurrenceLabel = compTotal === 0 ? "Aucune" : compTotal <= 5 ? "Modérée" : "Élevée";
    const concurrenceStyle = compTotal === 0 ? GREEN : compTotal <= 5 ? YELLOW : RED;

    // Mobility: use mobility_score from monitor API
    const mobilityScore = Number(day?.mobility_score ?? 100);
    const mobilityLabel = mobilityScore >= 70 ? "Fluide" : mobilityScore >= 55 ? "Perturbé" : "Fortement perturbé";
    const mobilityStyle = mobilityScore >= 70 ? GREEN : mobilityScore >= 55 ? YELLOW : RED;

    // Exploitation: use alert_level_max
    const alertMax = Number(day?.alert_level_max ?? 0);
    const exploitationLabel = alertMax === 0 ? "Aucune alerte" : `Alerte niv. ${alertMax}`;
    const exploitationStyle = alertMax === 0 ? GREEN : alertMax <= 2 ? YELLOW : RED;

    const dt = parseYmdToDate(normalizeYmd(day?.date || ""));
    const isWeekend = dt ? (dt.getUTCDay() === 0 || dt.getUTCDay() === 6) : false;
    const isAvailable = isWeekend || Boolean(day?.vacation_name) || Boolean(day?.holiday_name);
    const audienceAvailLabel = isAvailable ? "Disponible" : "Peu disponible";
    const audienceAvailStyle = isAvailable ? GREEN : RED;

    return `
      <div class="mon-card">
        <div class="mon-head" style="margin-bottom:0;cursor:pointer;" id="mon-context-toggle">
          <div style="display:flex;align-items:center;gap:12px;flex:1;">
            <div class="mon-ico" style="margin-bottom:0;">${iconSVG("context")}</div>
            <div class="mon-kicker" style="margin:0;">Contexte de référence</div>
          </div>
          <svg id="mon-context-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round" style="transition:transform 200ms;flex-shrink:0;transform:rotate(180deg);">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </div>
        <div id="mon-context-body" style="margin-top:16px;">
          <div class="mon-context-grid">
            <div class="mon-context-cell">
              <span class="mon-context-label">Audience</span>
              <span class="mon-context-value">${pill(audienceAvailLabel, audienceAvailStyle)}</span>
            </div>
            <div class="mon-context-cell">
              <span class="mon-context-label">Concurrence</span>
              <span class="mon-context-value">${compTotal} événements ${pill(concurrenceLabel, concurrenceStyle)}</span>
            </div>
            <div class="mon-context-cell">
              <span class="mon-context-label">Accessibilité</span>
              <span class="mon-context-value">${pill(mobilityLabel, mobilityStyle)}</span>
            </div>
            <div class="mon-context-cell">
              <span class="mon-context-label">Exploitation</span>
              <span class="mon-context-value">${pill(exploitationLabel, exploitationStyle)}</span>
            </div>
          </div>
          ${audienceLabel !== "—" ? `
            <div style="margin-top:14px;padding-top:14px;border-top:1px solid #F1F5F9;">
              <div class="mon-context-label">Public le plus probable</div>
              <div style="font-size:14px;font-weight:600;color:#111827;margin-top:2px;">${escapeHtml(audienceLabel)}</div>
              ${audienceReason ? `<div style="font-size:12px;color:#6b7280;margin-top:2px;">${escapeHtml(audienceReason)}</div>` : ""}
            </div>
          ` : ""}
        </div>
      </div>
    `;
  }

  // ----------------------------------------------------------------
  // Main render
  // ----------------------------------------------------------------
  function renderMonitor(data, item, selectedDate, activeTab) {
    activeTab = activeTab || "recap";
    const root = document.getElementById("mon-root");
    if (!root) return;

    const days = Array.isArray(data.days) ? data.days : [];
    const currentDay = days.find(d => normalizeYmd(d.date) === selectedDate) ?? days[0] ?? null;

    if (!currentDay) {
      root.innerHTML = `<div class="mon-error">Aucune donnée disponible pour cette date.</div>`;
      return;
    }

    const decisionDate = item?.decision_date?.value ?? item?.decision_date ?? null;
    const score    = currentDay?.opportunity_score ?? currentDay?.opportunity_score_final_local ?? null;
    const safeScore = score !== null ? String(score).trim() : null;
    const hasRisk  = currentDay?.is_major_realization_risk_flag === true;
    const cev      = countdown(selectedDate);

    // All feed items across all days
    const allFeed = days.flatMap(d => Array.isArray(d.change_feed) ? d.change_feed : []);

    // Selected dates for map URL
    const allDates = days.map(d => normalizeYmd(d.date)).filter(Boolean);

    // ---- Header ----
    const headerHtml = `
      <div class="mon-card-decision" style="margin-bottom:0;">
        <div class="mon-header-suivi">
          <span class="mon-header-suivi-dot"></span>
          Suivi activé
        </div>
        <div class="mon-header-row">
          <div>
            <div class="mon-header-title">${escapeHtml(item?.title || "Événement")}</div>
            <div class="mon-header-date">${escapeHtml(fmtDateLong(selectedDate))}</div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px;">
            <span class="${hasRisk ? "mon-statut-risk" : "mon-statut-safe"}">${hasRisk ? "À RISQUE" : "SANS RISQUE"}</span>
            ${cev ? `<span class="mon-countdown">${escapeHtml(cev)} avant événement</span>` : ""}
          </div>
        </div>
        ${safeScore !== null ? `
          <div style="display:flex;align-items:baseline;gap:6px;margin-top:4px;">
            <span class="mon-header-score">${escapeHtml(safeScore)}<span class="mon-header-score-max">/10</span></span>
          </div>
        ` : ""}
        ${renderTabBar(activeTab, selectedDate, allDates)}
      </div>
    `;

    // ---- Tab content ----
    let tabContent = "";
    if (activeTab === "recap") {
      tabContent = renderRecap(currentDay, allFeed, item);
    } else if (activeTab === "alertes") {
      tabContent = `
        <div class="mon-panels">
          <div style="padding-top:8px;">
            ${renderFeedItems(allFeed)}
          </div>
        </div>
      `;
    } else if (activeTab === "carte") {
      const mapUrl = `/app/insightevent/map?date=${encodeURIComponent(selectedDate)}&selected_dates=${encodeURIComponent(allDates.join(","))}&embed=1`;
      tabContent = `
        <div class="mon-panels">
          <iframe
            src="${mapUrl}"
            id="mon-map-frame"
            style="width:100%;height:200px;border:none;border-radius:14px;margin-top:16px;display:block;"
            onload="(function(f){try{var h=f.contentWindow.document.documentElement.scrollHeight;if(h>400)f.style.height=h+'px';}catch(e){}})(this)"
            title="Carte des événements">
          </iframe>
        </div>
      `;
    }

    root.innerHTML = headerHtml + tabContent;

    // Wire tabs
    root.querySelectorAll(".mon-tab[data-tab]").forEach(btn => {
      btn.addEventListener("click", () => {
        const t = btn.getAttribute("data-tab");
        if (t) renderMonitor(data, item, selectedDate, t);
      });
    });

    // Wire context toggle
    const toggleBtn  = root.querySelector("#mon-context-toggle");
    const ctxBody    = root.querySelector("#mon-context-body");
    const ctxChevron = root.querySelector("#mon-context-chevron");
    if (toggleBtn && ctxBody) {
      toggleBtn.addEventListener("click", () => {
        const isOpen = ctxBody.style.display !== "none";
        ctxBody.style.display = isOpen ? "none" : "block";
        if (ctxChevron) ctxChevron.style.transform = isOpen ? "" : "rotate(180deg)";
      });
    }
  }

  // ----------------------------------------------------------------
  // Fetch helpers
  // ----------------------------------------------------------------
  async function fetchSavedItem(id) {
    const res = await fetch("/api/saved-items/get", {
      method: "POST",
      headers: { "content-type": "application/json", accept: "application/json" },
      body: JSON.stringify({ saved_item_id: id }),
      cache: "no-store",
    });
    const json = await res.json().catch(() => null);
    if (!res.ok || !json?.ok) throw new Error(json?.error || "Erreur get");
    return json.item;
  }

  function extractDates(item) {
    if (Array.isArray(item?.dates)) return item.dates.map(normalizeYmd).filter(Boolean);
    const s = typeof item?.dates === "string" ? item.dates.trim() : "";
    if (s.startsWith("[")) { try { return JSON.parse(s).map(normalizeYmd).filter(Boolean); } catch (_) {} }
    if (s.includes("-")) return s.split(",").map(normalizeYmd).filter(Boolean);
    return [];
  }

  async function fetchMonitor(loc, dates) {
    const qs = new URLSearchParams();
    qs.set("location_id", loc);
    qs.set("selected_dates", dates.join(","));
    const res = await fetch("/api/insight/monitor?" + qs.toString(), { cache: "no-store" });
    const json = await res.json().catch(() => null);
    if (!res.ok || !json?.ok) throw new Error(json?.error || "Erreur monitor API");
    return json;
  }

  // ----------------------------------------------------------------
  // Boot
  // ----------------------------------------------------------------
  (async function boot() {
    const root = document.getElementById("mon-root");
    try {
      if (!saved_item_id) throw new Error("saved_item_id manquant dans l'URL.");

      const item  = await fetchSavedItem(saved_item_id);
      const dates = extractDates(item).map(normalizeYmd).filter(Boolean).slice(0, 7);
      if (!dates.length) throw new Error("Cet enregistrement ne contient aucune date.");

      const monitorDates = focused_date ? [normalizeYmd(focused_date)] : dates;
      const data = await fetchMonitor(location_id, monitorDates);

      const firstDate = focused_date
        ? normalizeYmd(focused_date)
        : normalizeYmd(data.days?.[0]?.date ?? dates[0]);

      if (firstDate && !window.location.search.includes("date=")) {
        const mp = new URLSearchParams(window.location.search);
        mp.set("date", firstDate);
        window.history.replaceState({}, "", "?" + mp.toString());
      }

      renderMonitor(data, item, firstDate, "recap");

    } catch (e) {
      if (root) root.innerHTML = `<div class="mon-error">${escapeHtml(e?.message || "Erreur de chargement.")}</div>`;
      console.error(e);
    }
  })();

})();
</script>
