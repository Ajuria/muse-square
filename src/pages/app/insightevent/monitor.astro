    const strip2 = renderRadarStrip("changes", "swords", envPrimary, envSecondary,
      renderChangeDetail(currentDay, data._top_threats || []), false);

    const strip3 = renderRadarStrip("threats", "target", threatPrimary, threatSecondary,
      renderThreatSummary(competitorSignals, selectedDate, followedCount), false);

    // Feed
    var _feedCoveredTypes = (typeof window.getActionCandidateTypes === 'function' && window._lastActionCandidates) ? window.getActionCandidateTypes(window._lastActionCandidates, selectedDate) : {};
    const feedHtml = renderFeed(allFeed, isMultisite, _feedCoveredTypes);

    // Date header
    const dateHeaderHtml = `<div style="font-size:11px;font-weight:700;letter-spacing:0.10em;text-transform:uppercase;color:#1D3BB3;margin-bottom:12px;">${escapeHtml(fmtDateLong(selectedDate))}</div>`;

    // ---- Past-date Bilan (Variant B grammar + per-factor field feedback) ----
    let bilanHtml = "";
    {
      const _bSorted = dayAlerts.slice().sort((x, y) => {
        const rk = s => (s === "D" || s === "C") ? 0 : 1;
        return rk(x.severity) - rk(y.severity);
      });
      const _n = _bSorted.length;
      const _bSummary = _n > 0
        ? "Journ\u00e9e pass\u00e9e. " + _n + " facteur" + (_n > 1 ? "s ont" : " a") + " marqu\u00e9 cette date. Confirmez ce qui s'est r\u00e9ellement produit \u2014 vos retours affinent les pr\u00e9visions."
        : "Journ\u00e9e pass\u00e9e \u2014 aucun facteur notable. Rien \u00e0 confirmer.";
      try {
        window.__bilanData = window.__bilanData || {};
