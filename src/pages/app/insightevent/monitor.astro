      if (section) {
        var progressBar = section.querySelector("div > div > div[style]");
        // Simpler: find by structure
        var allDivs = section.querySelectorAll("div");
        for (var pi = 0; pi < allDivs.length; pi++) {
          if (allDivs[pi].style.background === "rgb(5, 150, 105)" || allDivs[pi].style.background === "#059669") {
            allDivs[pi].style.width = (totalCards > 0 ? Math.round(completed / totalCards * 100) : 0) + "%";
            break;
          }
        }
        var spans = section.querySelectorAll("span");
        for (var si = spans.length - 1; si >= 0; si--) {
          if (spans[si].textContent.match(/^\d+\/\d+$/)) {
            spans[si].textContent = completed + "/" + totalCards;
            break;
          }
        }
        // Update header count
        var headerSpans = section.querySelectorAll("span");
        for (var hi = 0; hi < headerSpans.length; hi++) {
          if (headerSpans[hi].textContent.match(/trait|en cours|action/)) {
            headerSpans[hi].textContent = completed > 0 ? completed + "/" + totalCards + " en cours" : totalCards + " action" + (totalCards > 1 ? "s" : "");
            break;
          }
        }
      }
    }
 
