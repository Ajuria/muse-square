---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { Show } from "@clerk/astro/components";
import PiloterBottomBar from "../../../components/PiloterBottomBar.astro";

const location_id =
  Astro.locals && typeof (Astro.locals as any).location_id === "string" && (Astro.locals as any).location_id.trim()
    ? (Astro.locals as any).location_id.trim()
    : null;

if (!location_id) {
  return Astro.redirect("/profile");
}

const saved_item_id = Astro.url?.searchParams?.get("saved_item_id") ?? "";
const focused_date  = Astro.url?.searchParams?.get("date") ?? "";
---

<Show when="signed-out" client:load>
  <script is:inline>window.location.href = "/sign-in";</script>
</Show>

<Show when="signed-in" client:load>
  <BaseLayout title="Monitor — Insight Event" hideSurveyCta={true} hideFooter={true}>

    <style is:inline>
      .mon-wrap {
        width: 100%;
        max-width: 720px;
        margin: 0 auto;
        padding: 20px 20px 160px 20px;
        box-sizing: border-box;
        overflow: visible;
      }

      .mon-card {
        background: #FFFFFF;
        border: 1px solid #E8EDF5;
        border-radius: 14px;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(17,24,39,0.06);
      }

      .mon-card-decision {
        background: rgba(29,59,179,0.04);
        border-left: 6px solid #0b37e5;
        padding: 24px;
        border-radius: 0;
      }

      .mon-panels {
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding-top: 16px;
      }

      .mon-kicker {
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.10em;
        text-transform: uppercase;
        color: #1D3BB3;
        line-height: 1.1;
        margin: 0 0 6px 0;
      }

      .mon-head {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
      }

      .mon-ico { width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
      .mon-ico svg { display: block; }

      .mon-tabs-bar {
        display: flex;
        justify-content: flex-start;
        align-items: flex-end;
        gap: 22px;
        padding: 0 24px;
        border-bottom: none;
        margin: 16px -24px -24px -24px;
      }

      .mon-tab {
        appearance: none;
        border: none;
        background: transparent;
        font-size: 14px;
        font-weight: 500;
        color: #94A3B8;
        padding: 0 0 16px 0;
        position: relative;
        cursor: pointer;
      }

      .mon-tab.is-active { color: #1D3BB3; }
      .mon-tab.is-active::after {
        content: "";
        position: absolute;
        left: 0; bottom: 0;
        height: 3px; width: 100%;
        background: #1D3BB3;
        border-radius: 3px;
      }

      .mon-feed-item {
        display: flex; align-items: flex-start; gap: 12px;
        padding: 14px 0; border-bottom: 1px solid #F3F4F6;
      }
      .mon-feed-item:last-child { border-bottom: none; }
      .mon-feed-line1 { font-size: 14px; font-weight: 700; color: #111827; line-height: 1.3; margin-bottom: 3px; }
      .mon-feed-line2 { font-size: 13px; color: #374151; line-height: 1.4; margin-bottom: 2px; }
      .mon-feed-line3 { font-size: 12px; color: #6B7280; }
      .mon-feed-line4 { font-size: 12px; color: #6B7280; }

      .mon-vigilance-item {
        display: flex; align-items: flex-start; gap: 10px;
        font-size: 14px; color: #374151; line-height: 1.45;
        padding: 8px 0; border-bottom: 1px solid #F3F4F6;
      }
      .mon-vigilance-item:last-child { border-bottom: none; }

      .mon-status-ok   { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 600; color: #059669; }
      .mon-loading { padding: 40px 0; text-align: center; color: #9CA3AF; font-size: 14px; }
      .mon-error { padding: 20px; background: rgba(220,38,38,0.06); border-radius: 10px; color: #B91C1C; font-size: 13px; margin-top: 16px; }

      .mon-statut-safe { background: var(--color-pill-safe-bg); color: var(--color-pill-safe-text); padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
      .mon-statut-warn { background: var(--color-pill-warn-bg); color: var(--color-pill-warn-text); border: 1px solid var(--color-pill-warn-border); padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
      .mon-statut-risk { background: var(--color-pill-risk-bg); color: var(--color-pill-risk-text); border: 1px solid var(--color-pill-risk-border); padding: 6px 14px; border-radius: 999px; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }

      /* ---- Date pills ---- */
      .pls-pills {
        display: flex; gap: 6px; flex-wrap: wrap;
        padding: 12px 0 0 0;
      }

      .pls-pill {
        padding: 5px 12px; border-radius: 999px;
        font-size: 12px; font-weight: 600;
        border: 1px solid #e5e7eb;
        background: #fff; color: #6b7280;
        cursor: pointer; white-space: nowrap;
        transition: all 100ms;
        display: inline-flex; align-items: center; gap: 6px;
      }
      .pls-pill.is-today { border-color: #1D3BB3; color: #1D3BB3; }
      .pls-pill.is-active { background: #1D3BB3; border-color: #1D3BB3; color: #fff; }
      .pls-pill.has-crit  { border-color: #e24b4a; }
      .pls-pill.has-warn  { border-color: #ef9f27; }
      .pls-pill-dot {
        width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
      }

      /* ---- Location switcher ---- */
      .pls-loc-row {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 4px;
      }
      .pls-loc-name { font-size: 13px; font-weight: 600; color: #111827; }
      .pls-loc-addr { font-size: 12px; color: #9ca3af; }
      .pls-loc-btn {
        font-size: 12px; font-weight: 600; color: #1D3BB3;
        background: none; border: none; cursor: pointer; padding: 0;
      }

      .mon-context-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 8px; }
      .mon-context-cell { display: flex; flex-direction: column; gap: 2px; }
      .mon-context-label { font-size: 11px; color: #9CA3AF; text-transform: uppercase; letter-spacing: .06em; }
      .mon-context-value { font-size: 13px; color: #111827; }

      .mon-map-btn {
        height: 36px; border: 1px solid #E5E7EB; border-radius: 6px;
        background: #f9fafb; color: #6b7280;
        font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
        text-transform: uppercase; cursor: pointer;
      }
      .mon-map-btn.is-active { border-color: #0b37e5; color: #0b37e5; }

      /* ---- Daily Action Brief ---- */
      .ab-card-row { display:flex; }
      .ab-card { background:var(--color-bg-card); border:1px solid var(--color-border); border-radius:0; overflow:visible; margin-bottom:12px; box-shadow:0 1px 3px rgba(16,24,40,0.06),0 1px 2px rgba(16,24,40,0.04); }
      .ab-bar { width:3px; flex-shrink:0; }
      .ab-bar.ab-threat { background:#e24b4a; }
      .ab-bar.ab-warning { background:#ef9f27; }
      .ab-bar.ab-opportunity { background:#059669; }
      .ab-inner { flex:1; min-width:0; }
      .ab-summary { padding:14px 16px; cursor:pointer; }
      .ab-pills { display:flex; gap:5px; flex-wrap:wrap; margin-bottom:6px; }
      .ab-pill { font-size:9px; font-weight:700; padding:2px 7px; border-radius:0; text-transform:uppercase; letter-spacing:0.03em; }
      .ab-what { font-size:13px; font-weight:600; color:#111827; line-height:1.35; margin-bottom:4px; }
      .ab-sowhat { font-size:12px; color:#6B7280; line-height:1.4; }
      .ab-toggle { display:flex; align-items:center; padding:0 16px 12px; }
      .ab-toggle-btn { font-size:12px; font-weight:700; color:#1D3BB3; background:none; border:none; cursor:pointer; padding:0; font-family:inherit; display:flex; align-items:center; gap:5px; }
      .ab-actions { display:none; padding:0 16px 14px; border-top:1px solid #F3F4F6; }
      .ab-actions.is-open { display:block; }
      .ab-action-item { display:flex; align-items:flex-start; gap:10px; padding:10px 0; border-bottom:1px solid #F9FAFB; }
      .ab-action-item:last-of-type { border-bottom:none; }
      .ab-check { width:18px; height:18px; border:1.5px solid #d1d5db; border-radius:0; flex-shrink:0; margin-top:1px; display:flex; align-items:center; justify-content:center; cursor:pointer; background:#fff; transition:all 0.1s; }
      .ab-check.is-checked { background:#059669; border-color:#059669; }
      .ab-action-text { font-size:12.5px; color:#111827; line-height:1.4; }
      .ab-action-text.is-done { text-decoration:line-through; color:#6B7280; }
      .ab-action-meta { font-size:10px; color:#6B7280; margin-top:2px; }
      .ab-action-right { display:flex; flex-direction:column; align-items:flex-end; gap:4px; flex-shrink:0; margin-left:auto; padding-top:2px; }
      .ab-copy { font-size:10px; font-weight:600; color:#1D3BB3; background:none; border:none; cursor:pointer; padding:0; font-family:inherit; white-space:nowrap; }
      .ab-copy.is-copied { color:#059669; }
      .ab-progress { display:flex; align-items:center; gap:8px; margin-top:8px; }
      .ab-progress-bar { flex:1; height:3px; background:#E5E7EB; overflow:hidden; }
      .ab-progress-fill { height:100%; background:#059669; transition:width 0.3s; }
      .ab-progress-label { font-size:10px; color:#6B7280; white-space:nowrap; }
      .ab-help-link { display:block; margin-top:10px; padding-top:10px; border-top:1px solid #F3F4F6; font-size:11px; color:#1D3BB3; text-decoration:none; font-weight:500; }
      .ab-zero { background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.15); border-radius:0; padding:16px 18px; display:flex; align-items:center; gap:10px; font-size:13px; font-weight:500; color:#059669; }
      .ab-gen { font-size:10px; font-weight:600; color:#1D3BB3; background:none; border:none; cursor:pointer; padding:0; font-family:inherit; white-space:nowrap; }
      .ab-gen.is-loading { color:#9CA3AF; pointer-events:none; }
      .ab-draft-panel { display:none; margin-top:8px; padding:10px 12px; background:#f8fafc; border:1px solid #E8EDF5; border-radius:8px; font-size:12px; color:#111827; line-height:1.5; }
      .ab-draft-panel.is-open { display:block; }
      .ab-draft-panel pre { white-space:pre-wrap; word-break:break-word; margin:0 0 8px; font-family:inherit; font-size:12px; }
      .ab-draft-actions { display:flex; gap:12px; align-items:center; margin-top:6px; }
      .ab-draft-copy { font-size:11px; font-weight:600; color:#059669; background:none; border:none; cursor:pointer; padding:0; font-family:inherit; }
      .ab-draft-regen { font-size:11px; font-weight:600; color:#1D3BB3; background:none; border:none; cursor:pointer; padding:0; font-family:inherit; }
      .ab-draft-dismiss { font-size:11px; color:#9CA3AF; background:none; border:none; cursor:pointer; padding:0; font-family:inherit; }
      .ab-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:9999; align-items:flex-end; justify-content:center; }
      .ab-overlay.is-open { display:flex; }
      .ab-form-panel { background:#fff; width:100%; max-width:720px; border-top:3px solid #1D3BB3; padding:20px 20px 32px; animation:abSlideUp 0.2s ease-out; }
      @keyframes abSlideUp { from{transform:translateY(100%);opacity:0} to{transform:translateY(0);opacity:1} }
      .ab-form-title { font-size:14px; font-weight:700; color:#111827; margin-bottom:14px; }
      .ab-form-ctx { background:#f9fafb; border:1px solid #E8EDF5; padding:10px 12px; margin-bottom:14px; font-size:12px; color:#6B7280; line-height:1.4; }
      .ab-form-label { font-size:11px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#6B7280; margin-bottom:6px; }
      .ab-form-textarea { width:100%; padding:10px 12px; border:1px solid #E5E7EB; font-size:13px; color:#111827; background:#f9fafb; resize:vertical; min-height:80px; font-family:inherit; margin-bottom:14px; }
      .ab-form-submit { width:100%; padding:12px; background:#1D3BB3; color:#fff; border:none; font-size:14px; font-weight:700; cursor:pointer; font-family:inherit; }
      .ab-form-cancel { width:100%; padding:10px; background:none; color:#6B7280; border:none; font-size:13px; font-weight:500; cursor:pointer; font-family:inherit; margin-top:6px; }

      .mon-header-row { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
      .mon-header-score { font-size: 42px; font-weight: 700; color: #111827; line-height: 1; }
      .mon-header-score-max { font-size: 16px; color: #9CA3AF; font-weight: 400; }
      .mon-countdown { font-size: 12px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #9CA3AF; }
      .mon-header-suivi { display: flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #059669; margin-bottom: 10px; }
      .mon-header-suivi-dot { width: 8px; height: 8px; border-radius: 50%; background: #059669; flex-shrink: 0; }
      .mon-header-title { font-size: 22px; font-weight: 500; color: #111827; margin: 0 0 4px 0; line-height: 1.2; }
      .mon-header-date { font-size: 13px; color: #6b7280; margin: 0; }
      .mon-breadcrumb { display: flex; align-items: center; gap: 8px; margin: 16px 0 20px 0; font-size: 13px; color: #888; }
      .mon-breadcrumb a { color: #0F1F3D; text-decoration: none; font-weight: 500; }
      .mon-breadcrumb a:hover { text-decoration: underline; }
      .eb { font-size:11px; letter-spacing:0.07em; text-transform:uppercase; color:#8A909A; font-weight:500; margin:0; }
      .tl { position:relative; padding-left:22px; margin-left:5px; border-left:1.5px solid #E6E8EC; }
      .tlrow { position:relative; padding-bottom:18px; }
      .tldot { position:absolute; left:-28px; top:3px; width:9px; height:9px; border-radius:50%; background:#1D3BB3; border:2px solid #fff; }
      @keyframes ms-spin { to { transform: rotate(360deg); } }
    </style>

    <div class="mon-wrap">
      <nav class="mon-breadcrumb" style="display:none;">
        <a href="#" id="mon-breadcrumb-recap">Situation</a>
        <span id="mon-breadcrumb-sub" style="display:none;">
          <span>/</span>
          <span id="mon-breadcrumb-tab"></span>
        </span>
      </nav>

      <div id="mon-root">
        <div class="mon-loading" style="display:flex;align-items:center;justify-content:center;padding:24px 0;"><img src="/icons/load/ms_load_icon.gif" alt="Chargement" style="height:140px;width:auto;" loading="lazy" /></div>
      </div>
    </div>

    <!-- Action Brief — concierge help overlay -->
    <div class="ab-overlay" id="ab-help-overlay">
      <div class="ab-form-panel">
        <div class="ab-form-title">Besoin d'aide pour agir ?</div>
        <div class="ab-form-ctx" id="ab-help-ctx">Décrivez ce dont vous avez besoin. Notre équipe vous répond sous 2 heures.</div>
        <div class="ab-form-label">Votre demande</div>
        <textarea class="ab-form-textarea" id="ab-help-note" placeholder="Ex : aidez-moi à créer un post Instagram avec l'itinéraire alternatif."></textarea>
        <button class="ab-form-submit" id="ab-help-submit">Envoyer — réponse sous 2h</button>
        <button class="ab-form-cancel" id="ab-help-cancel">Annuler</button>
      </div>
    </div>

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script is:inline src="/map-markers.js"></script>
    <script is:inline src="/action-cards.js?v=18"></script>
  
  <PiloterBottomBar active="evenements" />

  </BaseLayout>
</Show>

<script is:inline define:vars={{ location_id, saved_item_id, focused_date }}>
(function () {

  // ----------------------------------------------------------------
  // Helpers (same as monitor.astro)
  // ----------------------------------------------------------------
  function escapeHtml(v) {
    return String(v ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#039;");
  }

  function normalizeYmd(v) {
    const s = String(v ?? "").trim();
    const m = s.match(/^(\d{4}-\d{2}-\d{2})/);
    return m ? m[1] : "";
  }

  function parseYmdToDate(ymd) {
    const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(String(ymd||"").trim());
    if (!m) return null;
    return new Date(Date.UTC(+m[1], +m[2]-1, +m[3]));
  }

  function fmtDateLong(ymd) {
    const d = parseYmdToDate(ymd);
    if (!d) return ymd;
    const s = new Intl.DateTimeFormat("fr-FR", {
      weekday: "long", day: "numeric", month: "long", year: "numeric"
    }).format(d);
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  function fmtDateShort(ymd) {
    const d = parseYmdToDate(ymd);
    if (!d) return ymd;
    const dow = ["LUN","MAR","MER","JEU","VEN","SAM","DIM"][((d.getUTCDay()+6)%7)];
    return `${dow} ${String(d.getUTCDate()).padStart(2,"0")}`;
  }

  function countdown(ymd) {
    if (!ymd) return null;
    const today = new Date(); today.setHours(0,0,0,0);
    const target = parseYmdToDate(ymd);
    if (!target) return null;
    const d = Math.round((target - today) / 86400000);
    if (d < 0)  return `Passé il y a ${Math.abs(d)}j`;
    if (d === 0) return `Aujourd'hui`;
    return `J-${d}`;
  }

  function todayYmd() {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`;
  }

  function getToday() {
    const d = new Date();
    return new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
  }

  function addDays(dateUTC, n) {
    const d = new Date(dateUTC);
    d.setUTCDate(d.getUTCDate() + n);
    return d;
  }

  function ymdFromUTC(d) {
    return `${d.getUTCFullYear()}-${String(d.getUTCMonth()+1).padStart(2,"0")}-${String(d.getUTCDate()).padStart(2,"0")}`;
  }

  function getLastVisitTimestamp(key) {
    try { return parseInt(localStorage.getItem(key) || "0", 10) || 0; } catch { return 0; }
  }

  function setLastVisitTimestamp(key) {
    try { localStorage.setItem(key, String(Date.now())); } catch {}
  }

  function filterFeedByWindow(allFeed, lastVisitTs, anchorYmd) {
    const anchor = anchorYmd ? parseYmdToDate(anchorYmd) : getToday();
    const windowStart = ymdFromUTC(addDays(anchor, -7));
    const windowEnd   = ymdFromUTC(addDays(anchor, 6));
    const mobilityEnd = ymdFromUTC(addDays(anchor, 14));

    const competitionEnd = ymdFromUTC(addDays(anchor, 14));

    return allFeed.filter(a => {
      const affected = normalizeYmd(a?.affected_date);
      const feedDate = normalizeYmd(a?.feed_date);
      if (!affected) return false;

      const sub = String(a?.change_subtype || "").toLowerCase();
      const isMobility = String(a?.change_category || "").toLowerCase() === "mobility"
        || sub.startsWith("mobility_");
      const isWeather  = String(a?.change_category || "").toLowerCase() === "context" &&
                        sub === "weather_change";
      const isCompetition = sub === "competitor_event_launch" || sub === "competitor_audience_conflict"
        || sub === "competition_pressure_spike" || sub === "mega_event_activation"
        || sub === "competitor_event_ending" || sub === "mega_event_end";

      const maxDate = isMobility ? mobilityEnd : isCompetition ? competitionEnd : windowEnd;

      if (affected < windowStart || affected > maxDate) return false;
      if (isWeather && affected > windowEnd) return false;

      if (lastVisitTs > 0) {
        const fd = feedDate ? new Date(feedDate).getTime() : 0;
        if (fd > 0 && fd <= lastVisitTs) return false;
      }

      // Skip mobility items with no mode (unmatched road incidents)
      if (isMobility && !a?.mobility_mode) return false;

      return true;
    });
  }

  const BLOCK_LABELS = {
    attendance:   'FRÉQUENTATION',
    operations:   'EXPLOITATION',
    installation: 'INSTALLATION',
    context:      'CONTEXTE',
  };

  function computeStatusPill(day) {
    if (day?.is_forced_regime_c_flag === true) {
      return { cls: 'mon-statut-risk', label: 'À RISQUE' };
    }
    const all = [
      ...(day?.attendance   || []),
      ...(day?.operations   || []),
      ...(day?.installation || []),
      ...(day?.context      || []),
    ].filter(r => r.severity !== 'A');
    if (!all.length) {
      return { cls: 'mon-statut-safe', label: 'SANS RISQUE' };
    }
    const maxSev = all.reduce((max, r) => {
      return (['D','C','B'].indexOf(r.severity) < ['D','C','B'].indexOf(max) ? r.severity : max);
    }, 'B');
    const cls = (maxSev === 'D' || maxSev === 'C') ? 'mon-statut-risk' : 'mon-statut-warn';
    if (all.length === 1) {
      const block = all[0].block;
      const label = 'ALERTE ' + (BLOCK_LABELS[block] || block.toUpperCase());
      return { cls, label };
    }
    return { cls, label: `${all.length} RISQUES` };
  }

  function pill(label, style) {
    return `<span style="display:inline-block;font-size:11px;font-weight:600;padding:2px 10px;border-radius:20px;${style}">${escapeHtml(label)}</span>`;
  }

  const GREEN  = "background:var(--color-pill-green-bg);color:var(--color-pill-green-text);";
  const YELLOW = "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);border:1px solid var(--color-pill-warn-border);";
  const AMBER  = "background:var(--color-pill-warn-bg);color:var(--color-pill-warn-text);border:1px solid var(--color-pill-warn-border);";
