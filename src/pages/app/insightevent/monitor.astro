                  this.textContent = "...";
                  try {
                    var res = await fetch("/api/channels/team", {
                      method: "POST",
                      headers: { "content-type": "application/json" },
                      body: JSON.stringify({
                        location_id: locationId,
                        first_name: fn,
                        last_name: lnEl ? lnEl.value.trim() : "",
                        role: roleEl ? roleEl.value.trim() : "",
                        channels_contact: chContact,
                        signal_routing: {},
                      }),
                    });
                    var json2 = await res.json();
                    if (json2 && json2.ok) {
                      _teamMembersCache = null;
                      await fetchTeamMembers(locationId);
                      savePrompt.innerHTML = '<div style="display:flex;align-items:center;gap:8px;"><span style="color:#166534;">\u2713</span><span style="font-size:12px;color:#166534;font-weight:500;">Destinataire enregistr\u00e9</span></div>';
                      setTimeout(function() { savePrompt.remove(); }, 2000);
                    }
                  } catch(e) { this.textContent = "Erreur"; this.disabled = false; }
                });
              }
            }
          } else {
            pubBtn.textContent = "Erreur";
            pubBtn.style.color = "#B91C1C";
            pubBtn.style.opacity = "1";
            pubBtn.disabled = false;
            setTimeout(function() { pubBtn.textContent = "Publier \u2192"; pubBtn.style.color = "#1D3BB3"; pubBtn.style.borderColor = "#1D3BB3"; }, 2500);
          }
        }).catch(function() {
          pubBtn.textContent = "Publier \u2192";
          pubBtn.style.opacity = "1";
          pubBtn.disabled = false;
        });
      });

      // Library drawer
      var libBtn = workspace.querySelector('[data-ws-library="' + cardIdx + '"]');
      if (libBtn) libBtn.addEventListener("click", function() {
        var existing = document.getElementById("ms-draft-library");
        if (existing) { existing.remove(); return; }
        var drafts = _savedDraftsCache || [];
        var overlay = document.createElement("div");
        overlay.id = "ms-draft-library";
        overlay.style.cssText = "position:fixed;top:0;right:0;bottom:0;width:380px;background:#fff;box-shadow:-4px 0 24px rgba(0,0,0,0.12);z-index:9999;display:flex;flex-direction:column;font-family:inherit;";
        var header = '<div style="padding:16px 20px;border-bottom:1px solid #e5e7eb;display:flex;justify-content:space-between;align-items:center;">'
          + '<div><div style="font-weight:700;font-size:15px;color:#111827;">Mes brouillons</div><div style="font-size:11px;color:#9ca3af;margin-top:2px;">' + drafts.length + ' brouillon' + (drafts.length > 1 ? 's' : '') + '</div></div>'
          + '<button type="button" id="ms-lib-close" style="background:none;border:none;font-size:20px;color:#9ca3af;cursor:pointer;padding:4px 8px;line-height:1;">\u00d7</button>'
        + '</div>';
        var SIGNAL_LABELS = {weather_worsened:"M\u00e9t\u00e9o d\u00e9grad\u00e9e",weather_improved:"M\u00e9t\u00e9o am\u00e9lior\u00e9e",weather_hazard_onset:"Alerte m\u00e9t\u00e9o",competitor_event_launch:"Lancement concurrent",competitor_audience_conflict:"Conflit audience",competition_pressure_spike:"Pression concurrentielle",competitor_event_ending:"Fin concurrent",mobility_disruption:"Perturbation mobilit\u00e9",score_up:"Score en hausse",_day_opportunity:"Opportunit\u00e9 jour",_best_day:"Meilleur jour",score_down:"Score en baisse",competitor_review_surge:"Avis en hausse",competitor_review_drop:"Note en baisse",competitor_hours_change:"Horaires modifi\u00e9s",competitor_new_offering:"Nouvelle offre",competitor_sold_out:"Complet",competitor_content_spike:"Contenu en hausse",competitor_content_silent:"Concurrent silencieux",institution_campaign_detected:"Campagne",media_mention_detected:"Mention m\u00e9dia"};
        var cards = '';
        for (var di = 0; di < drafts.length; di++) {
          var d = drafts[di];
          var _dch = d.channel === "note_interne" ? "internal" : d.channel;
          var dCh = CHANNEL_DEFS[_dch] || CHANNEL_DEFS.gbp;
          var sigLbl = SIGNAL_LABELS[d.signal_type] || d.signal_type || "";
          var isMatch = d.signal_type === payload.change_subtype && d.channel === channel;
          var preview = (d.body || "").substring(0, 120) + ((d.body || "").length > 120 ? "\u2026" : "");
          var dateLbl = d.created_at ? d.created_at.substring(0, 10) : "";
          cards += '<div style="padding:12px 14px;border-radius:8px;margin-bottom:8px;border:' + (isMatch ? '1.5px solid #1D3BB3' : '1px solid #e5e7eb') + ';background:' + (isMatch ? '#F5F7FF' : '#fff') + ';cursor:pointer;">'
            + '<div style="display:flex;gap:6px;margin-bottom:6px;align-items:center;flex-wrap:wrap;">'
              + '<span style="font-size:9px;font-weight:700;padding:2px 6px;border-radius:3px;background:#EFF6FF;color:#1D3BB3;">' + escapeHtml(sigLbl) + '</span>'
              + '<span style="font-size:9px;font-weight:600;padding:2px 6px;border-radius:3px;background:' + dCh.color + '18;color:' + dCh.color + ';">' + escapeHtml(dCh.icon + ' ' + dCh.label) + '</span>'
              + (isMatch ? '<span style="font-size:9px;font-weight:700;padding:2px 6px;border-radius:3px;background:#DCFCE7;color:#166534;">Correspondance</span>' : '')
              + '<span style="font-size:10px;color:#9ca3af;margin-left:auto;">' + escapeHtml(dateLbl) + '</span>'
            + '</div>'
            + (d.title ? '<div style="font-weight:600;font-size:12px;color:#111827;margin-bottom:3px;">' + escapeHtml(d.title) + '</div>' : '')
            + '<div style="font-size:11px;color:#6b7280;line-height:1.4;">' + escapeHtml(preview) + '</div>'
            + (d.tone ? '<div style="font-size:10px;color:#9ca3af;margin-top:6px;font-style:italic;">Ton : ' + escapeHtml(d.tone) + '</div>' : '')
            + '<div style="display:flex;gap:6px;margin-top:8px;">'
              + '<button type="button" data-lib-style="' + di + '" style="flex:1;padding:6px 0;border-radius:6px;font-size:11px;font-weight:600;background:#1D3BB3;color:#fff;border:none;cursor:pointer;font-family:inherit;">Adapter au signal</button>'
              + '<button type="button" data-lib-raw="' + di + '" style="flex:1;padding:6px 0;border-radius:6px;font-size:11px;font-weight:600;background:#f9fafb;color:#374151;border:1px solid #e5e7eb;cursor:pointer;font-family:inherit;">Utiliser tel quel</button>'
            + '</div>'
          + '</div>';
        }
        overlay.innerHTML = header + '<div style="flex:1;overflow-y:auto;padding:12px 16px;">' + cards + '</div>';
        document.body.appendChild(overlay);
        document.getElementById("ms-lib-close").addEventListener("click", function() { overlay.remove(); });
        overlay.querySelectorAll("[data-lib-raw]").forEach(function(btn) {
          btn.addEventListener("click", function() {
            var idx = parseInt(btn.getAttribute("data-lib-raw"), 10);
            var picked = drafts[idx];
            if (!picked) return;
            draft = { title: picked.title || null, body: picked.body || "", hashtags: picked.hashtags || null, full_text: picked.body || "" };
            workspace.innerHTML = buildWorkspaceHtml(cardIdx, channel, draft, false, payload.change_subtype);
            wireWorkspaceButtons(cardIdx, channel, draft, payload, triggerBtn);
            overlay.remove();
          });
        });
        overlay.querySelectorAll("[data-lib-style]").forEach(function(btn) {
          btn.addEventListener("click", function() {
            var idx = parseInt(btn.getAttribute("data-lib-style"), 10);
            var picked = drafts[idx];
            if (!picked) return;
            overlay.remove();
            workspace.innerHTML = '<div style="padding:20px 0;display:flex;align-items:center;justify-content:center;gap:8px;color:#9ca3af;font-size:11px;"><span style="width:10px;height:10px;border:1.5px solid #e5e7eb;border-top-color:#1D3BB3;border-radius:50%;display:inline-block;animation:ms-spin 0.7s linear infinite;flex-shrink:0;"></span>Adaptation en cours\u2026</div>';
            var styledPayload = JSON.parse(JSON.stringify(payload));
            styledPayload.style_reference = picked.body;
            fetch("/api/insight/generate-action-draft", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify(styledPayload),
            }).then(function(res) { return res.json(); }).then(function(json) {
              if (!json || !json.ok || !json.draft) throw new Error("Draft vide");
              draft = json.draft;
              workspace.innerHTML = buildWorkspaceHtml(cardIdx, channel, draft, true, payload.change_subtype);
              wireWorkspaceButtons(cardIdx, channel, draft, payload, triggerBtn);
            }).catch(function(err) {
              workspace.innerHTML = '<div style="padding:14px;font-size:11px;color:#B91C1C;">Erreur : ' + escapeHtml(err?.message || "R\u00e9essayez") + '</div>';
            });
          });
        });
      });

      // Automate button
      var autoBtn = workspace.querySelector('[data-ws-automate="' + cardIdx + '"]');
      var autoPromptEl = workspace.querySelector('[data-ws-auto-prompt="' + cardIdx + '"]');
      if (autoBtn && autoPromptEl) autoBtn.addEventListener("click", function() {
        showAutoPrompt(autoPromptEl, cardIdx, channel, payload, triggerBtn);
      });
    }

    function showAutoPrompt(container, cardIdx, channel, payload, triggerBtn) {
      var ROUTING_MAP = window.MS_ROUTING_MAP || {};
      var CAT_LABELS = {weather:"M\u00e9t\u00e9o",competition:"Concurrence",mobility:"Mobilit\u00e9",opportunity:"Opportunit\u00e9",calendar:"Calendrier"};
      var sigCat = ROUTING_MAP[payload.change_subtype] || "competition";
      var catLabel = CAT_LABELS[sigCat] || sigCat;
      var chDef = {gbp:"GBP",instagram:"Instagram",facebook:"Facebook",email:"Email",sms:"SMS",whatsapp:"WhatsApp",slack:"Slack",internal:"Interne",phone:"T\u00e9l\u00e9phone"};
      var chLabel = chDef[channel] || channel;
      var workspace = document.getElementById("ab-card-" + cardIdx + "-workspace");
      var rEl = workspace ? workspace.querySelector('[data-ws-recipient="' + cardIdx + '"]') : null;
      var recipVal = rEl ? rEl.value.trim() : "";
      var hasChannelConfig = _channelConfigsCache && _channelConfigsCache[channel];
      var canPublish = hasChannelConfig && (channel === "gbp" || channel === "facebook" || channel === "instagram" || channel === "internal" || recipVal);

      container.style.display = "block";
      container.innerHTML = '<div style="padding:12px 14px;margin:8px 0 4px;background:#EFF3FF;border-radius:8px;border:1px solid #D6DFFF;">'
        + '<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">'
          + '<span style="width:22px;height:22px;border-radius:5px;background:#1D3BB3;color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;">\u26A1</span>'
          + '<span style="font-size:12px;font-weight:600;color:#1D3BB3;">Publier + automatiser</span>'
        + '</div>'
        + '<div style="font-size:11px;color:#4B5563;margin-bottom:8px;line-height:1.4;">'
          + (canPublish
            ? 'Publie ce brouillon sur <strong style="color:#1F2937;">' + escapeHtml(chLabel) + '</strong>' + (recipVal ? ' pour <strong style="color:#1F2937;">' + escapeHtml(recipVal) + '</strong>' : '') + ' maintenant, et automatise pour les prochains signaux <strong style="color:#1F2937;">' + escapeHtml(catLabel) + '</strong>.'
            : 'Copie ce brouillon et automatise pour les prochains signaux <strong style="color:#1F2937;">' + escapeHtml(catLabel) + '</strong> sur <strong style="color:#1F2937;">' + escapeHtml(chLabel) + '</strong>' + (recipVal ? ' pour <strong style="color:#1F2937;">' + escapeHtml(recipVal) + '</strong>' : '') + '.')
        + '</div>'
        + '<div style="display:flex;gap:6px;flex-wrap:wrap;">'
          + '<button type="button" data-auto-confirm="validation" style="font-size:10px;font-weight:600;padding:5px 10px;border-radius:5px;background:#1D3BB3;color:#fff;border:none;cursor:pointer;font-family:inherit;">' + (canPublish ? 'Publier + validation' : 'Copier + validation') + '</button>'
          + '<button type="button" data-auto-confirm="auto" style="font-size:10px;font-weight:600;padding:5px 10px;border-radius:5px;background:#fff;color:#1D3BB3;border:1px solid #C7D2FE;cursor:pointer;font-family:inherit;">' + (canPublish ? 'Publier + auto' : 'Copier + auto') + '</button>'
          + '<button type="button" data-auto-confirm="dismiss" style="font-size:10px;font-weight:500;padding:5px 6px;background:none;border:none;color:#9CA3AF;cursor:pointer;font-family:inherit;">Non merci</button>'
        + '</div>'
      + '</div>';

      container.querySelectorAll("[data-auto-confirm]").forEach(function(btn) {
        btn.addEventListener("click", function() {
          var mode = btn.getAttribute("data-auto-confirm");
          if (mode === "dismiss") { container.style.display = "none"; container.innerHTML = ""; return; }
          btn.disabled = true;
          btn.textContent = "...";
          var locId = typeof locationId !== "undefined" ? locationId : "";

          // Read draft content from workspace
          var bEl = workspace ? workspace.querySelector('[data-ws-body="' + cardIdx + '"]') : null;
          var tEl = workspace ? workspace.querySelector('[data-ws-title="' + cardIdx + '"]') : null;
          var hEl = workspace ? workspace.querySelector('[data-ws-hashtags="' + cardIdx + '"]') : null;
          var bodyText = bEl ? bEl.value : "";
          var titleText = tEl ? tEl.value : "";
          var hashText = hEl ? hEl.value : "";
          var affectedDate = triggerBtn ? (triggerBtn.getAttribute("data-ab-draft-affected") || "") : "";

          // Step 1: Create the automation rule
          fetch("/api/channels/automation", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              location_id: locId,
              signal_category: sigCat,
              channel: channel,
              recipient: recipVal,
              require_approval: mode === "validation",
              frequency: "first_occurrence",
            }),
          }).then(function(ruleRes) { return ruleRes.json(); }).then(function(ruleJson) {
            if (!ruleJson || !ruleJson.ok) throw new Error(ruleJson?.error || "Erreur r\u00e8gle");

            // Step 2: Publish or copy
            if (canPublish) {
              return fetch("/api/channels/publish", {
                method: "POST",
                headers: { "content-type": "application/json" },
                body: JSON.stringify({
                  channel: channel,
                  location_id: locId,
                  title: titleText,
                  body: bodyText,
                  hashtags: hashText,
                  recipient: recipVal,
                  signal_type: payload.change_subtype || "",
                  affected_date: affectedDate,
                }),
              }).then(function(pubRes) { return pubRes.json(); }).then(function(pubJson) {
                if (pubJson && pubJson.ok) {
                  // Track publish
                  fetch("/api/analytics/track", {
                    method: "POST",
                    headers: { "content-type": "application/json" },
                    body: JSON.stringify({ event: "auto_publish", location_id: locId, change_subtype: payload.change_subtype, action_key: "auto_publish", channel: channel, affected_date: affectedDate }),
                  }).catch(function(){});
                  // Update card status
                  if (triggerBtn) { triggerBtn.style.color = "#059669"; triggerBtn.textContent = "Trait\u00e9 \u2713"; }
                  updateBriefStatus(cardIdx, "published");
                  // Show confirmation
                  container.innerHTML = '<div style="padding:10px 14px;margin:8px 0 4px;background:#ECFDF5;border-radius:8px;border:1px solid #D1FAE5;">'
                    + '<div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">'
                      + '<span style="width:18px;height:18px;border-radius:50%;background:#059669;color:#fff;display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0;">\u2713</span>'
                      + '<span style="font-size:11px;color:#065F46;font-weight:600;">Publi\u00e9 sur ' + escapeHtml(chLabel) + '</span>'
                    + '</div>'
                    + '<div style="display:flex;align-items:center;gap:8px;">'
                      + '<span style="width:18px;height:18px;border-radius:50%;background:#1D3BB3;color:#fff;display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0;">\u26A1</span>'
                      + '<span style="font-size:11px;color:#1D3BB3;font-weight:500;">R\u00e8gle cr\u00e9\u00e9e : ' + escapeHtml(catLabel) + ' \u2192 ' + escapeHtml(chLabel) + ' (' + (mode === "auto" ? "auto" : "validation") + ')</span>'
                    + '</div>'
                  + '</div>';
                  // Check for unknown recipient → save prompt
                  showRecipientSavePrompt(workspace, cardIdx, channel, locId, recipVal);
                } else {
                  throw new Error(pubJson?.error || "Erreur publication");
                }
              });
            } else {
              // No channel config → copy to clipboard
              var fullText = [titleText, bodyText, hashText].filter(Boolean).join("\n\n");
              if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(fullText).catch(function(){});
              }
              // Track copy
              fetch("/api/analytics/track", {
                method: "POST",
                headers: { "content-type": "application/json" },
                body: JSON.stringify({ event: "draft_copied", location_id: locId, change_subtype: payload.change_subtype, action_key: "draft", channel: channel, affected_date: affectedDate }),
              }).catch(function(){});
              if (triggerBtn) { triggerBtn.style.color = "#1D3BB3"; triggerBtn.textContent = "Copi\u00e9 \u270e"; }
              updateBriefStatus(cardIdx, "copied");
              container.innerHTML = '<div style="padding:10px 14px;margin:8px 0 4px;background:#EFF3FF;border-radius:8px;border:1px solid #D6DFFF;">'
                + '<div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">'
                  + '<span style="width:18px;height:18px;border-radius:50%;background:#1D3BB3;color:#fff;display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0;">\u2713</span>'
                  + '<span style="font-size:11px;color:#1D3BB3;font-weight:500;">Texte copi\u00e9 + R\u00e8gle cr\u00e9\u00e9e : ' + escapeHtml(catLabel) + ' \u2192 ' + escapeHtml(chLabel) + ' (' + (mode === "auto" ? "auto" : "validation") + ')</span>'
                + '</div>'
              + '</div>';
            }
          }).catch(function(err) {
            container.innerHTML = '<div style="padding:10px 14px;font-size:11px;color:#B91C1C;">Erreur : ' + escapeHtml(err?.message || "R\u00e9essayez") + '</div>';
          });
        });
      });
    }

    function showRecipientSavePrompt(workspace, cardIdx, channel, locId, recipVal) {
      if (!recipVal || channel === "internal" || channel === "gbp" || channel === "facebook" || channel === "instagram") return;
      var isKnown = (_teamMembersCache || []).some(function(m) { return (m.channels_contact || {})[channel] === recipVal; });
      if (isKnown) return;
      var savePrompt = document.createElement("div");
      savePrompt.style.cssText = "margin:10px 0 0;padding:14px 16px;border-radius:8px;background:#F5F7FF;border:1px solid #DBEAFE;";
      savePrompt.innerHTML = '<div style="font-size:13px;font-weight:600;color:#111827;margin-bottom:4px;">Enregistrer ce destinataire ?</div>'
        + '<div style="font-size:11px;color:#6b7280;margin-bottom:12px;">' + escapeHtml(recipVal) + ' sera disponible pour vos prochaines publications.</div>'
        + '<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">'
          + '<input data-save-recip-fn placeholder="Pr\u00e9nom" style="border:1px solid #e5e7eb;border-radius:6px;padding:7px 10px;font-size:12px;color:#111827;outline:none;font-family:inherit;" />'
          + '<input data-save-recip-ln placeholder="Nom" style="border:1px solid #e5e7eb;border-radius:6px;padding:7px 10px;font-size:12px;color:#111827;outline:none;font-family:inherit;" />'
        + '</div>'
        + '<input data-save-recip-role placeholder="R\u00f4le (optionnel)" style="width:100%;border:1px solid #e5e7eb;border-radius:6px;padding:7px 10px;font-size:12px;color:#111827;outline:none;font-family:inherit;margin-bottom:10px;box-sizing:border-box;" />'
        + '<div style="display:flex;gap:8px;">'
          + '<button type="button" data-save-recip-ok style="padding:7px 16px;border-radius:6px;font-size:12px;font-weight:600;background:#1D3BB3;color:#fff;border:none;cursor:pointer;font-family:inherit;">Enregistrer</button>'
          + '<button type="button" data-save-recip-skip style="padding:7px 16px;border-radius:6px;font-size:12px;font-weight:600;background:#f9fafb;color:#6b7280;border:1px solid #e5e7eb;cursor:pointer;font-family:inherit;">Pas maintenant</button>'
        + '</div>';
      workspace.appendChild(savePrompt);
      savePrompt.querySelector("[data-save-recip-skip]").addEventListener("click", function() { savePrompt.remove(); });
      savePrompt.querySelector("[data-save-recip-ok]").addEventListener("click", async function() {
        var fnEl = savePrompt.querySelector("[data-save-recip-fn]");
        var lnEl = savePrompt.querySelector("[data-save-recip-ln]");
        var roleEl = savePrompt.querySelector("[data-save-recip-role]");
        var fn = fnEl ? fnEl.value.trim() : "";
        if (!fn) { fnEl.style.borderColor = "#ef4444"; return; }
        var chContact = {};
        chContact[channel] = recipVal;
        this.disabled = true;
        this.textContent = "...";
        try {
          var res = await fetch("/api/channels/team", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              location_id: locId,
              first_name: fn,
              last_name: lnEl ? lnEl.value.trim() : "",
              role: roleEl ? roleEl.value.trim() : "",
              channels_contact: chContact,
              signal_routing: {},
            }),
          });
          var json2 = await res.json();
          if (json2 && json2.ok) {
            _teamMembersCache = null;
            await fetchTeamMembers(locId);
            savePrompt.innerHTML = '<div style="display:flex;align-items:center;gap:8px;"><span style="color:#166534;">\u2713</span><span style="font-size:12px;color:#166534;font-weight:500;">Destinataire enregistr\u00e9</span></div>';
            setTimeout(function() { savePrompt.remove(); }, 2000);
          }
        } catch(e) { this.textContent = "Erreur"; this.disabled = false; }
      });
    }

    // ---- Help link → concierge overlay ----
    var helpLink = document.getElementById("ab-help-global");
    if (helpLink) {
      helpLink.addEventListener("click", function(e) {
        e.preventDefault();
        var overlay = document.getElementById("ab-help-overlay");
        if (overlay) overlay.classList.add("is-open");
      });
    }
 
    // Concierge form cancel / submit
    var cancelBtn = document.getElementById("ab-help-cancel");
    if (cancelBtn) cancelBtn.onclick = function() {
      var ov = document.getElementById("ab-help-overlay");
      if (ov) ov.classList.remove("is-open");
      var n = document.getElementById("ab-help-note"); if (n) n.value = "";
    };
    var submitBtn = document.getElementById("ab-help-submit");
    if (submitBtn) submitBtn.onclick = async function() {
      var ov = document.getElementById("ab-help-overlay");
      var noteEl = document.getElementById("ab-help-note");
      var note = noteEl ? noteEl.value : "";
      submitBtn.disabled = true;
      submitBtn.textContent = "Envoi en cours\u2026";
      try {
        await fetch("/api/insight/action-request", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            action_type: "aide_concierge",
            note: note,
            change_subtype: "_help_request",
            signal_summary: "",
            impact_summary: "",
            recommended_action: null,
            affected_date: selectedDate || null,
            location_id: locationId,
            entity_id: null,
            alert_level: 0,
            urgency_label: null,
          }),
        });
        submitBtn.textContent = "\u2713 Demande envoy\u00e9e";
        setTimeout(function() {
          if (ov) ov.classList.remove("is-open");
          submitBtn.textContent = "Envoyer \u2014 r\u00e9ponse sous 2h";
          submitBtn.disabled = false;
          if (noteEl) noteEl.value = "";
        }, 1500);
      } catch {
        submitBtn.textContent = "Erreur r\u00e9seau";
        submitBtn.disabled = false;
      }
    };
 
    // Feedback vote handlers (Layer A)
    root.querySelectorAll("[data-fb-vote]").forEach(function(btn) {
      btn.addEventListener("click", function() {
        var vote = btn.getAttribute("data-fb-vote");
        var logId = btn.getAttribute("data-fb-log-id");
        var signalDate = btn.getAttribute("data-fb-date") || null;
        var card = document.getElementById("fb-card-" + logId);
        function dismissFeedback(feedbackText) {
          fetch("/api/analytics/confirm", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              signal_type: "draft_feedback",
              confirmation: vote,
              signal_ref_id: logId,
              signal_date: signalDate,
              location_id: locationId,
              feedback_text: feedbackText || null,
            }),
          }).catch(function() {});
          var lsKey = "ms_feedback_dismissed_" + locationId;
          var dismissed = {};
          try { dismissed = JSON.parse(localStorage.getItem(lsKey) || "{}"); } catch(e) {}
          dismissed[logId] = vote;
          try { localStorage.setItem(lsKey, JSON.stringify(dismissed)); } catch(e) {}
          if (card) {
            card.innerHTML = '<div style="display:flex;align-items:center;gap:8px;padding:12px 16px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:0;">'
              + '<span style="color:#166534;">\u2713</span>'
              + '<span style="font-size:12px;color:#166534;font-weight:500;">Merci \u2014 votre retour am\u00e9liore vos prochaines recommandations</span>'
            + '</div>';
          }
        }
        if (vote === "positive") {
          dismissFeedback(null);
        } else {
          if (!card) return;
          var inner = card.querySelector(".ab-inner");
          if (!inner) return;
          inner.innerHTML = '<div style="padding:14px 16px;">'
            + '<div style="font-size:13px;font-weight:600;color:#111827;margin-bottom:8px;">Qu\u2019est-ce qui pourrait \u00eatre am\u00e9lior\u00e9 ?</div>'
            + '<textarea id="fb-text-' + escapeHtml(logId) + '" placeholder="Ex : le ton n\u2019\u00e9tait pas adapt\u00e9, trop long, manque de donn\u00e9es\u2026" style="width:100%;min-height:60px;border:1px solid #e5e7eb;border-radius:6px;padding:8px 10px;font-size:12px;color:#111827;font-family:inherit;resize:vertical;outline:none;box-sizing:border-box;"></textarea>'
            + '<div style="display:flex;gap:8px;margin-top:8px;">'
              + '<button type="button" data-fb-send="' + escapeHtml(logId) + '" style="padding:7px 16px;border-radius:6px;background:#1D3BB3;color:#fff;border:none;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;">Envoyer</button>'
              + '<button type="button" data-fb-skip="' + escapeHtml(logId) + '" style="padding:7px 16px;border-radius:6px;background:#f9fafb;color:#6b7280;border:1px solid #e5e7eb;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;">Passer</button>'
            + '</div>'
          + '</div>';
          var sendBtn = inner.querySelector('[data-fb-send="' + logId + '"]');
          var skipBtn = inner.querySelector('[data-fb-skip="' + logId + '"]');
          if (sendBtn) sendBtn.addEventListener("click", function() {
            var ta = document.getElementById("fb-text-" + logId);
            dismissFeedback(ta ? ta.value.trim() : null);
          });
          if (skipBtn) skipBtn.addEventListener("click", function() {
            dismissFeedback(null);
          });
        }
      });
    });
  }

  // V4 NEW — Radar strip (collapsible)
