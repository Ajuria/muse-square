window._cityData = {};

function getCityData(idx) {
  if (!window._cityData[idx]) {
    const ids = ['', '', ''];
    const labels = ['', '', ''];
    for (let i = 1; i <= 3; i++) {
      const idEl = document.getElementById(`city-id-${i}-${idx}`);
      const lblEl = document.getElementById(`city-label-${i}-${idx}`);
      if (idEl && idEl.value) { ids[i-1] = idEl.value; labels[i-1] = lblEl?.value || ''; }
    }
    window._cityData[idx] = ids
      .map((id, i) => id ? { id, label: labels[i] } : null)
      .filter(Boolean);
  }
  return window._cityData[idx];
}

function saveCityData(idx) {
  const data = window._cityData[idx] || [];
  for (let i = 1; i <= 3; i++) {
    const el = document.getElementById(`city-id-${i}-${idx}`);
    const lbl = document.getElementById(`city-label-${i}-${idx}`);
    if (el) el.value = data[i-1]?.id || '';
    if (lbl) lbl.value = data[i-1]?.label || '';
  }
}

function renderCityTags(idx) {
  const data = window._cityData[idx] || [];
  const row = document.getElementById(`city-tags-row-${idx}`);
  const inp = document.getElementById(`city-search-${idx}`);
  if (!row || !inp) return;
  row.innerHTML = data.map(c =>
    `<span class="city-tag" data-city-id="${c.id}">${c.label}<span class="city-tag-x" data-idx="${idx}" data-city-id="${c.id}">×</span></span>`
  ).join('');
  inp.disabled = data.length >= 3;
  inp.placeholder = data.length >= 3 ? 'Maximum atteint' : 'Rechercher une ville…';
  saveCityData(idx);
}

