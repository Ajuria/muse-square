  const idx = inp.dataset.idx;
  if (inp.value.trim()) _addrConfirmed[idx] = true;
});

function debounce(fn, ms) {
  const timers = {};
  return function(key, ...args) {
    clearTimeout(timers[key]);
    timers[key] = setTimeout(() => fn(key, ...args), ms);
  };
}

const fetchBAN = debounce(async function(idx, q) {
  const dd = document.getElementById(`addr-suggestions-${idx}`);
  if (!dd) return;
  if (_addrAborters[idx]) _addrAborters[idx].abort();
  _addrAborters[idx] = new AbortController();
  try {
    const url = new URL('https://api-adresse.data.gouv.fr/search');
    url.searchParams.set('q', q);
    url.searchParams.set('limit', '5');
    url.searchParams.set('autocomplete', '1');
    const res = await fetch(url.toString(), { signal: _addrAborters[idx].signal });
    if (!res.ok) { dd.style.display = 'none'; return; }
    const data = await res.json().catch(() => null);
    const feats = data?.features || [];
    if (!feats.length) { dd.style.display = 'none'; return; }
    dd.innerHTML = feats.map((f, i) =>
      `<div class="city-option" data-idx="${idx}" data-addr="${f.properties.label}">
        <span>${f.properties.label}</span>
      </div>`
    ).join('');
    dd.style.display = 'block';
  } catch (_) { }
}, 250);

document.addEventListener('input', function(e) {
  const inp = e.target;
  if (!inp.classList.contains('addr-autocomplete')) return;
  const idx = inp.dataset.idx;
  _addrConfirmed[idx] = false;
  const q = inp.value.trim();
  if (q.length < 6) {
    const dd = document.getElementById(`addr-suggestions-${idx}`);
    if (dd) dd.style.display = 'none';
    return;
  }
  fetchBAN(idx, q);
});

