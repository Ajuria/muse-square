window.toggleLocCard = function(cardId, bodyId) {
  const card = document.getElementById(cardId);
  const body = document.getElementById(bodyId);
  if (!card || !body) return;
  const isOpen = card.classList.contains('loc-expanded');
  // Close all
  document.querySelectorAll('.loc-card').forEach(c => c.classList.remove('loc-expanded'));
  document.querySelectorAll('.loc-body').forEach(b => { b.style.display = 'none'; });
  if (!isOpen) {
    card.classList.add('loc-expanded');
    body.style.display = 'block';
  }
};

window.toggleUserProfileCard = function() {
  const card = document.getElementById('user-profile-card');
  const body = document.getElementById('user-profile-body');
  if (!card || !body) return;
  const isOpen = card.classList.contains('loc-expanded');
  card.classList.toggle('loc-expanded', !isOpen);
