  data.mode = existingLocationId ? 'update' : 'create';
  if (existingLocationId) {
    data.location_id = existingLocationId;
    const idx = primaryCard.id.replace('loc-card-', '');
    const body = document.getElementById(`loc-body-${idx}`);
    if (body) {
