              </div>
            </div>
          </section>

        </div>

        </form>

      <!-- SECONDARY LOCATIONS -->
      <div class="mt-12">
        <h2 class="text-base font-medium text-black uppercase tracking-wider mb-1">Mes autres sites</h2>
        <p class="text-sm text-gray-500 mb-6">Sites secondaires ajoutés depuis le calendrier.</p>

        <div id="secondary-locations-list">
          {secondary_locations.length === 0 ? (
            <p class="text-sm text-gray-400">Aucun site secondaire. Ajoutez-en un depuis le calendrier.</p>
          ) : (
            secondary_locations.map(loc => (
              <div class="flex items-center justify-between py-4 border-b border-gray-100" data-loc-id={loc.location_id}>
                <div class="flex items-center gap-3">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;">
                    <path d="M8 1.5C5.51 1.5 3.5 3.51 3.5 6c0 3.5 4.5 8.5 4.5 8.5s4.5-5 4.5-8.5c0-2.49-2.01-4.5-4.5-4.5z" stroke="#9ca3af" stroke-width="1.2"/>
                    <circle cx="8" cy="6" r="1.5" stroke="#9ca3af" stroke-width="1.2"/>
                  </svg>
                  <div>
                    <div class="text-sm font-medium text-gray-900">{loc.company_name}</div>
                    <div class="text-xs text-gray-500">{loc.company_address}</div>
                  </div>
                </div>
                <button
                  type="button"
                  class="text-xs text-red-500 hover:text-red-700 cursor-pointer bg-none border-none"
                  style="background:none;border:none;padding:0;"
                  data-delete-loc={loc.location_id}
                >
                  Supprimer
                </button>
              </div>
            ))
          )}
        </div>
      </div>

      <div class="pt-10">
        <button
          type="submit"
          form="profileForm"
          class="ms-btn w-full h-[56px] font-normal"
        >
          Enregistrer les modifications
        </button>
      </div>
    </div>
  </div>

  <script>
    // @ts-nocheck
    window.metroConfirmed = false;
    window.addressConfirmed = false;

    // If fields are pre-filled from saved profile, mark as confirmed
    const _metroInput = document.getElementById('metroStopInput');
    const _addressInput = document.getElementById('companyAddressInput');
    if (_metroInput instanceof HTMLInputElement && _metroInput.value.trim() !== '') window.metroConfirmed = true;
    if (_addressInput instanceof HTMLInputElement && _addressInput.value.trim() !== '') window.addressConfirmed = true;

    const profileForm = document.getElementById('profileForm');

    profileForm?.addEventListener('submit', async function (e) {
        e.preventDefault();

        const form = e.currentTarget;
        if (!(form instanceof HTMLFormElement)) return;

        if (form.dataset.saving === "1") return;
        form.dataset.saving = "1";

        const btn = document.querySelector('button[type="submit"][form="profileForm"]');
        const button = btn instanceof HTMLButtonElement ? btn : null;

        const originalText =
        button && button.textContent ? button.textContent : "Enregistrer les modifications";

        let status = document.querySelector('#profileSaveStatus');
        if (!(status instanceof HTMLElement)) {
        status = document.createElement('div');
        status.id = 'profileSaveStatus';
        status.className = 'mt-4 text-sm';
        status.setAttribute('role', 'status');
        status.setAttribute('aria-live', 'polite');
        const submitBtn = document.querySelector('button[type="submit"][form="profileForm"]');
        if (submitBtn && submitBtn.parentNode) {
          submitBtn.parentNode.insertBefore(status, submitBtn.nextSibling);
        } else {
          document.body.appendChild(status);
        }
        }

        function setStatus(message, kind) {
        status.textContent = message || '';
        status.className =
            'mt-4 text-sm ' +
            (kind === 'error'
            ? 'text-red-700'
            : kind === 'success'
                ? 'text-emerald-700'
                : 'text-gray-600');
        }

        function resetButtonText() {
        if (!button) return;
        button.textContent = originalText;
        }

        // Clear status when user edits any field after a save attempt
        const clearStatusOnce = () => setStatus('', 'info');
        form.addEventListener('input', clearStatusOnce, { once: true });

        setStatus('', 'info');

        if (button) {
        button.disabled = true;
        button.textContent = "Enregistrement...";
        }

        try {
        const formData = new FormData(form);

        const metroInput = form.querySelector('#metroStopInput');
        const metroVal = metroInput instanceof HTMLInputElement ? metroInput.value.trim() : "";
        if (metroVal !== "" && !window.metroConfirmed) {
          if (button) button.textContent = originalText;
          form.dataset.saving = "0";
          if (button) button.disabled = false;
          setStatus("Veuillez sélectionner une station depuis la liste.", 'error');
          return;
        }

        const addressInput = form.querySelector('#companyAddressInput');
        const addressVal = addressInput instanceof HTMLInputElement ? addressInput.value.trim() : "";
        if (addressVal !== "" && !window.addressConfirmed) {
          if (button) button.textContent = originalText;
          form.dataset.saving = "0";
          if (button) button.disabled = false;
          setStatus("Veuillez sélectionner une adresse depuis la liste.", 'error');
          return;
        }

        const data = Object.fromEntries(formData.entries());

        // Fix multi-select arrays (critical)
        data.primary_audience_1 = formData.getAll("primary_audience_1");
        data.origin_city_ids = formData.getAll("origin_city_ids");

        // ---- ADD MODE CONTRACT (REQUIRED BY BACKEND) ----
        const rawLocationId = typeof data.location_id === "string" ? data.location_id.trim() : "";

        data.mode = rawLocationId !== "" ? "update" : "create";

        // In create mode, location_id must NOT be sent
        if (rawLocationId === "") {
          delete data.location_id;
        }

        const res = await fetch('/api/profile/save', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify(data),
        });

        let out = null;
        try {
            out = await res.json();
        } catch (_) {
            out = null;
        }

        if (!res.ok) {
            if (button) button.textContent = "Réessayer";
            setStatus((out && out.error) ? out.error : `Erreur lors de l’enregistrement (HTTP ${res.status}).`, 'error');
            return;
        }

        if (!out || out.ok !== true) {
            if (button) button.textContent = "Réessayer";
            setStatus((out && out.error) ? out.error : 'Erreur lors de l’enregistrement.', 'error');
            return;
        }

        setStatus('Profil enregistré.', 'success');
        if (data.mode === "create" && !localStorage.getItem('ms_map_notice_shown')) {
          localStorage.setItem('ms_map_notice_shown', '1');
          document.getElementById('ms-map-notice-modal').style.display = 'flex';
        }

        // Persist generated UUID after first create (so next saves are updates)
        if (out && typeof out.location_id === "string" && out.location_id.trim() !== "") {
          const locInput = form.querySelector('input[name="location_id"]');
          if (locInput instanceof HTMLInputElement) {
            locInput.value = out.location_id.trim();
          }
        }

        if (button) {
            button.textContent = "✓ Modifications enregistrées";
            setTimeout(() => {
            resetButtonText();
            }, 2000);
        }
        } catch (err) {
        if (button) button.textContent = "Réessayer";
        setStatus('Erreur réseau. Veuillez réessayer.', 'error');
        } finally {
        form.dataset.saving = "0";
        if (button) button.disabled = false;
        // If an error happened, keep "Réessayer" visible; if success timeout already set, it will reset.
        // If neither, ensure we don't leave an empty label.
        if (button && !button.textContent) resetButtonText();
        }
    });

    const origin = document.querySelector('select[name="origin_city_ids"]');
    const originSelect = origin instanceof HTMLSelectElement ? origin : null;

    if (originSelect) {
      function syncOriginCityLabels() {
        const selected = Array.from(originSelect.selectedOptions);

        // Keep your max-3 rule
        if (selected.length > 3) {
          selected[selected.length - 1].selected = false;
        }

        // Recompute after enforcing limit
        const kept = Array.from(originSelect.selectedOptions);

        // Only keep real INSEE codes (5 digits). Skip idf_other, paca_other, etc.
        const labels = kept
          .filter((opt) => /^\d{5}$/.test(opt.value))
          .map((opt) => (opt.textContent || "").trim());

        const l1 = document.getElementById("origin_city_label_1");
        const l2 = document.getElementById("origin_city_label_2");
        const l3 = document.getElementById("origin_city_label_3");

        if (l1) l1.value = labels[0] || "";
        if (l2) l2.value = labels[1] || "";
        if (l3) l3.value = labels[2] || "";
      }

      originSelect.addEventListener("change", syncOriginCityLabels);

      // Ensure labels are set even if the user doesn’t touch the field before saving
      syncOriginCityLabels();
    }

    function enableClickToggleMultiSelect(selectEl, maxSelected) {
        if (!selectEl || !(selectEl instanceof HTMLSelectElement)) return;
        if (!selectEl.multiple) return;

        selectEl.addEventListener(
        'mousedown',
        function (e) {
            const opt = e.target;
            if (!(opt instanceof HTMLOptionElement)) return;

            e.preventDefault();

            opt.selected = !opt.selected;

            const selected = Array.from(selectEl.selectedOptions);
            if (selected.length > maxSelected) {
            opt.selected = false;
            }

            selectEl.dispatchEvent(new Event('change', { bubbles: true }));
        },
        true
        );
    }

    enableClickToggleMultiSelect(
        document.querySelector('select[name="primary_audience_1"]'),
        2
    );

    enableClickToggleMultiSelect(
        document.querySelector('select[name="origin_city_ids"]'),
        3
    );

    // ------------------------------
    // Metro stop autocomplete
    // ------------------------------
    (function () {
      const input = document.getElementById("metroStopInput");
      const box = document.getElementById("metroStopSuggestions");

      if (!(input instanceof HTMLInputElement)) return;
      if (!(box instanceof HTMLDivElement)) return;

      let activeIndex = -1;
      let items = [];

      function hide() {
        box.classList.add("hidden");
        box.innerHTML = "";
        activeIndex = -1;
        items = [];
      }

      function show() {
        box.classList.remove("hidden");
      }

      function esc(s) {
        return String(s)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");
      }

      function debounce(fn, ms) {
        let t = null;
        return function (...args) {
          if (t) clearTimeout(t);
          t = setTimeout(() => fn.apply(this, args), ms);
        };
      }

      async function fetchMetro(q) {
        const res = await fetch(`/api/metro/search?q=${encodeURIComponent(q)}`);
        if (!res.ok) return [];
        return await res.json().catch(() => []);
      }

      function render(stops) {
        items = stops;
        activeIndex = -1;

        if (!items.length) { hide(); return; }

        box.innerHTML = items.map((s, i) => `
          <button
            type="button"
            data-idx="${i}"
            class="w-full text-left px-5 py-3 hover:bg-gray-50 focus:bg-gray-50 outline-none"
          >
            <div class="text-sm text-gray-900">${esc(s.stop_name)}</div>
            ${s.nom_commune ? `<div class="text-xs text-gray-500">${esc(s.nom_commune)}</div>` : ""}
          </button>
        `).join("");

        show();
      }

      function pick(i) {
        const s = items[i];
        if (!s) return;
        input.value = s.stop_name;
        window.metroConfirmed = true;
        const idInput = document.getElementById("nearest_transit_stop_id");
        const linesInput = document.getElementById("nearest_transit_lines");
        if (idInput instanceof HTMLInputElement) idInput.value = s.stop_id || "";
        if (linesInput instanceof HTMLInputElement) linesInput.value = s.lines || "";
        hide();
      }

      const onInput = debounce(async () => {
        window.metroConfirmed = false;
        const idInput = document.getElementById("nearest_transit_stop_id");
        const linesInput = document.getElementById("nearest_transit_lines");
        if (idInput instanceof HTMLInputElement) idInput.value = "";
        if (linesInput instanceof HTMLInputElement) linesInput.value = "";
        const q = input.value.trim();
        if (q.length < 2) { hide(); return; }
        try {
          const stops = await fetchMetro(q);
          render(stops);
        } catch { hide(); }
      }, 220);

      input.addEventListener("input", onInput);

      box.addEventListener("click", (e) => {
        const btn = e.target instanceof Element ? e.target.closest("button[data-idx]") : null;
        if (!btn) return;
        pick(Number(btn.getAttribute("data-idx")));
      });

      input.addEventListener("keydown", (e) => {
        if (box.classList.contains("hidden")) return;
        if (e.key === "ArrowDown") { e.preventDefault(); activeIndex = Math.min(activeIndex + 1, items.length - 1); }
        else if (e.key === "ArrowUp") { e.preventDefault(); activeIndex = Math.max(activeIndex - 1, 0); }
        else if (e.key === "Enter" && activeIndex >= 0) { e.preventDefault(); pick(activeIndex); }
        else if (e.key === "Escape") { hide(); return; }

        const buttons = box.querySelectorAll("button[data-idx]");
        buttons.forEach(b => b.classList.remove("bg-gray-50"));
        if (activeIndex >= 0 && buttons[activeIndex]) {
          buttons[activeIndex].classList.add("bg-gray-50");
          buttons[activeIndex].scrollIntoView({ block: "nearest" });
        }
      });

      document.addEventListener("mousedown", (e) => {
        const t = e.target;
        if (!(t instanceof Node)) return;
        if (t === input || box.contains(t)) return;
        hide();
      });

      input.addEventListener("blur", () => setTimeout(() => hide(), 150));
    })();

    // ------------------------------
    // BAN address autocomplete (company_address)
    // ------------------------------
    (function () {
      const input = document.getElementById("companyAddressInput");
      const box = document.getElementById("companyAddressSuggestions");

      if (!(input instanceof HTMLInputElement)) return;
      if (!(box instanceof HTMLDivElement)) return;

      let aborter = null;
      let activeIndex = -1;
      let items = []; // current feature list

      function hide() {
        box.classList.add("hidden");
        box.innerHTML = "";
        activeIndex = -1;
        items = [];
      }

      function show() {
        box.classList.remove("hidden");
      }

      function esc(s) {
        return String(s)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function debounce(fn, ms) {
        let t = null;
        return function (...args) {
          if (t) clearTimeout(t);
          t = setTimeout(() => fn.apply(this, args), ms);
        };
      }

      async function fetchBAN(q) {
        if (aborter) aborter.abort();
        aborter = new AbortController();

        const url = new URL("https://api-adresse.data.gouv.fr/search");
        url.searchParams.set("q", q);
        url.searchParams.set("limit", "6");
        url.searchParams.set("type", "housenumber");

        const res = await fetch(url.toString(), {
          method: "GET",
          headers: { Accept: "application/json" },
          signal: aborter.signal,
        });

        if (!res.ok) return [];
        const data = await res.json().catch(() => null);
        const feats = Array.isArray(data?.features) ? data.features : [];
        return feats;
      }

      function render(features) {
        items = features;
        activeIndex = -1;

        if (!items.length) {
          hide();
          return;
        }

        const html = items
          .map((f, i) => {
            const label = f?.properties?.label ?? "";
            const score = typeof f?.properties?.score === "number" ? f.properties.score : null;
            return `
              <button
                type="button"
                data-idx="${i}"
                class="w-full text-left px-5 py-3 hover:bg-gray-50 focus:bg-gray-50 outline-none"
              >
                <div class="text-sm text-gray-900">${esc(label)}</div>
              </button>
            `;
          })
          .join("");

        box.innerHTML = html;
        show();
      }

      function pick(i) {
        const f = items[i];
        const label = f?.properties?.label;
        if (typeof label === "string" && label.trim()) {
          input.value = label.trim();
          window.addressConfirmed = true;
        }
        hide();
      }

      const onInput = debounce(async () => {
        window.addressConfirmed = false;
        const q = input.value.trim();
        if (q.length < 6) {
          hide();
          return;
        }

        try {
          const feats = await fetchBAN(q);
          render(feats);
        } catch (e) {
          // Network / abort: silently degrade
          hide();
        }
      }, 220);

      input.addEventListener("input", onInput);

      // Click selection
      box.addEventListener("click", (e) => {
        const btn = e.target instanceof Element ? e.target.closest("button[data-idx]") : null;
        if (!btn) return;
        const idx = Number(btn.getAttribute("data-idx"));
        if (Number.isFinite(idx)) pick(idx);
      });

      // Keyboard navigation
      input.addEventListener("keydown", (e) => {
        if (box.classList.contains("hidden")) return;

        if (e.key === "ArrowDown") {
          e.preventDefault();
          activeIndex = Math.min(activeIndex + 1, items.length - 1);
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          activeIndex = Math.max(activeIndex - 1, 0);
        } else if (e.key === "Enter") {
          if (activeIndex >= 0) {
            e.preventDefault();
            pick(activeIndex);
          }
        } else if (e.key === "Escape") {
          hide();
        }

        // highlight active
        const buttons = box.querySelectorAll("button[data-idx]");
        buttons.forEach((b) => b.classList.remove("bg-gray-50"));
        if (activeIndex >= 0 && buttons[activeIndex]) {
          buttons[activeIndex].classList.add("bg-gray-50");
          (buttons[activeIndex]).scrollIntoView({ block: "nearest" });
        }
      });

      // Hide when clicking outside
      document.addEventListener("mousedown", (e) => {
        const t = e.target;
        if (!(t instanceof Node)) return;
        if (t === input || box.contains(t)) return;
        hide();
      });

      // Hide on blur (with small delay so click can register)
      input.addEventListener("blur", () => {
        setTimeout(() => hide(), 150);
      });
    })();

  // ---- Delete secondary location ----
    document.querySelectorAll('[data-delete-loc]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const locId = btn.getAttribute('data-delete-loc');
        if (!locId) return;
        if (!confirm('Supprimer ce site ?')) return;
        try {
          const res = await fetch('/api/profile/location-delete', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ location_id: locId }),
          });
          if (res.ok) {
            const row = btn.closest('[data-loc-id]');
            if (row) row.remove();
          }
        } catch (_) {}
      });
    });
  </script>

<!-- Password change modal -->
<div id="pwd-modal" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,0.4);align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:0;padding:32px;width:100%;max-width:420px;margin:0 20px;position:relative;"></div>
    <button id="pwd-modal-close" type="button" style="position:absolute;top:16px;right:16px;background:none;border:none;font-size:20px;cursor:pointer;color:#6b7280;">✕</button>
    <h2 style="font-size:18px;font-weight:600;margin:0 0 24px 0;">Modifier mon mot de passe</h2>
    <div style="display:flex;flex-direction:column;gap:16px;">
      <div>
        <label style="display:block;font-size:11px;font-weight:500;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:8px;">Mot de passe actuel</label>
        <input id="pwd-current" type="password" style="width:100%;padding:14px 0;background:transparent;border:0;border-bottom:1.5px solid #d1d5db;font-size:15px;box-sizing:border-box;outline:none;" />
      </div>
      <div>
        <label style="display:block;font-size:11px;font-weight:500;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:8px;">Nouveau mot de passe</label>
        <input id="pwd-new" type="password" style="width:100%;padding:14px 0;background:transparent;border:0;border-bottom:1.5px solid #d1d5db;font-size:15px;box-sizing:border-box;outline:none;" />
      </div>
      <div>
        <label style="display:block;font-size:11px;font-weight:500;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:8px;">Confirmer le nouveau mot de passe</label>
        <input id="pwd-confirm" type="password" style="width:100%;padding:14px 0;background:transparent;border:0;border-bottom:1.5px solid #d1d5db;font-size:15px;box-sizing:border-box;outline:none;" />
      </div>
      <div id="pwd-status" style="font-size:13px;min-height:20px;"></div>
      <button id="pwd-submit" type="button" style="width:100%;height:52px;background:transparent;color:#111827;border:1.5px solid #111827;border-radius:0;font-size:15px;cursor:pointer;font-weight:600;">Enregistrer</button>
    </div>
  </div>
</div>

<script>
  // @ts-nocheck
  const modal = document.getElementById('pwd-modal');
  const openBtn = document.getElementById('pwd-open');
  const closeBtn = document.getElementById('pwd-modal-close');
  const submitBtn = document.getElementById('pwd-submit');
  const status = document.getElementById('pwd-status');

  function openModal() {
    if (!modal) return;
    modal.style.display = 'flex';
    document.getElementById('pwd-current')?.focus();
  }
  function closeModal() {
    if (!modal) return;
    modal.style.display = 'none';
    ['pwd-current','pwd-new','pwd-confirm'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.value = '';
    });
    if (status) status.textContent = '';
  }

  openBtn?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

  submitBtn?.addEventListener('click', async () => {
    const current = document.getElementById('pwd-current')?.value;
    const newPwd = document.getElementById('pwd-new')?.value;
    const confirm = document.getElementById('pwd-confirm')?.value;

    if (!current || !newPwd || !confirm) {
      status.style.color = '#b91c1c';
      status.textContent = 'Tous les champs sont requis.';
      return;
    }
    if (newPwd !== confirm) {
      status.style.color = '#b91c1c';
      status.textContent = 'Les mots de passe ne correspondent pas.';
      return;
    }
    if (newPwd.length < 8) {
      status.style.color = '#b91c1c';
      status.textContent = 'Le mot de passe doit contenir au moins 8 caractères.';
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Enregistrement...';
    status.textContent = '';

    try {
      const res = await fetch('/api/profile/change-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ current_password: current, new_password: newPwd }),
      });
      const out = await res.json().catch(() => null);
      if (!res.ok) {
        status.style.color = '#b91c1c';
        status.textContent = out?.error || 'Erreur lors du changement de mot de passe.';
      } else {
        status.style.color = '#059669';
        status.textContent = 'Mot de passe modifié avec succès.';
        setTimeout(closeModal, 1500);
      }
    } catch {
      status.style.color = '#b91c1c';
      status.textContent = 'Erreur réseau. Veuillez réessayer.';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enregistrer';
    }
  });

</script>

