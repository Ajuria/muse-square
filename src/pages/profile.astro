<script>
// @ts-nocheck
'use strict';

// ============================================================
// ACCORDION
// ============================================================
window.toggleLocCard = function(cardId, bodyId) {
  const card = document.getElementById(cardId);
  const body = document.getElementById(bodyId);
  if (!card || !body) return;
  const isOpen = card.classList.contains('loc-expanded');
  // Close all
  document.querySelectorAll('.loc-card').forEach(c => c.classList.remove('loc-expanded'));
  document.querySelectorAll('.loc-body').forEach(b => { b.style.display = 'none'; });
  if (!isOpen) {
    card.classList.add('loc-expanded');
    body.style.display = 'block';
  }
};

window.toggleTeamCard = function() {
  const card = document.getElementById('team-card');
  const body = document.getElementById('team-body');
  if (!card || !body) return;
  const isOpen = card.classList.contains('loc-expanded');
  card.classList.toggle('loc-expanded', !isOpen);
  body.style.display = isOpen ? 'none' : 'block';
};

window.toggleCommsCard = function() {
  const card = document.getElementById('comms-card');
  const body = document.getElementById('comms-body');
  if (!card || !body) return;
  const isOpen = card.classList.contains('loc-expanded');
  card.classList.toggle('loc-expanded', !isOpen);
  body.style.display = isOpen ? 'none' : 'block';
};

window.toggleUserProfileCard = function() {
  const card = document.getElementById('user-profile-card');
  const body = document.getElementById('user-profile-body');
  if (!card || !body) return;
  const isOpen = card.classList.contains('loc-expanded');
  card.classList.toggle('loc-expanded', !isOpen);
  body.style.display = isOpen ? 'none' : 'block';
};

// ============================================================
// LABEL MAPS (for summary line rebuild after save)
// ============================================================
const _ACTIVITY_LABELS = {
  non_profit:'Associatif & Non lucratif',wellness:'Bien-être & Fitness',
  camping_outdoor:'Camping & Plein air',convention_center:'Centres de congrès & Palais des expos',
  cinema_theatre:'Cinéma & Théâtre',commercial:'Commerce & Retail',
  institutional:'Collectivités & Secteur public',coworking:'Coworking & Tiers-lieux',
  culture:'Culture & Patrimoine',family:'Éducation & Enseignement',
  live_event:'Événementiel',gallery:"Galeries d'art & Ateliers",
  hotel_lodging:'Hôtellerie & Hébergement',market_hall:'Marchés & Halles',
  wine_tourism:'\u0152notourisme & Domaines viticoles',theme_park:"Parcs d'attractions & Loisirs",
  food_nightlife:'Restauration & Bars',science_innovation:'Sciences & Innovation',
  pro_event:'Salons & Événements pro',sport:'Sports & Loisirs actifs',
  transport_mobility:'Transport & Mobilité locale',nightlife:'Vie nocturne',
  unknown:'Autre activité accueillant du public',
};
const _LOCATION_TYPE_LABELS = { outdoor:'Extérieur', indoor:'Intérieur', mixed:'Mixte' };
const _WEATHER_LABELS = { '0':'Météo : aucune','1':'Météo : faible','2':'Météo : modérée','3':'Météo : élevée','4':'Météo : extrême' };
const _EVT_LABELS = {
  concert:'Concert / Spectacle',press_conf:'Conférence de presse',
  tasting:'Dégustation / Soirée gastronomique',charity:'Événement caritatif / Associatif',
  corporate:'Événement corporate',sport_evt:'Événement sportif',
  outdoor:'Happening extérieur',inauguration:'Inauguration',
  open_day:'Journée portes ouvertes',product_launch:'Lancement de produit',
  store_opening:'Ouverture d\'un point de vente',promo:'Promotion en magasin / soldes',
  seminar:'Séminaire / Formation',launch_party:'Soirée de lancement',
  expo:'Vernissage / Exposition',other:'Autre',
};

// Collapse a card and update its summary line from current form values
function collapseCard(idx, cardId, bodyId, data) {
  // Rebuild summary tags from saved data
  const tags = [];
  if (data.company_activity_type) tags.push(_ACTIVITY_LABELS[data.company_activity_type] || data.company_activity_type);
  const evtTypes = [data.event_type_1, data.event_type_2, data.event_type_3].filter(Boolean).map(v => _EVT_LABELS[v] || v);
  if (evtTypes.length) tags.push(evtTypes.join(', '));
  if (data.location_type) tags.push(_LOCATION_TYPE_LABELS[data.location_type] || data.location_type);
  if (data.weather_sensitivity) tags.push(_WEATHER_LABELS[data.weather_sensitivity] || '');
  const summaryText = tags.filter(Boolean).join(' · ');

  // Determine completeness
  const isComplete = !!(data.company_activity_type && data.location_type && data.event_type_1);

  const card = document.getElementById(cardId);
  if (!card) return;

  // Update name
  const nameEl = card.querySelector('.loc-name');
  if (nameEl && data.site_name) nameEl.textContent = data.site_name;

  // Update address
  const addrEl = card.querySelector('.loc-address');
  if (addrEl && data.company_address) addrEl.textContent = data.company_address;

  // Update summary or incomplete indicator
  const summaryEl = card.querySelector('.loc-summary');
  const statusEl = card.querySelector('.loc-status');
  if (statusEl) {
    statusEl.textContent = isComplete ? 'Profil complet · IA optimisée' : 'Profil incomplet · IA limitée';
    statusEl.className = `loc-status ${isComplete ? 'is-complete' : 'is-incomplete'}`;
    statusEl.style.marginLeft = 'auto';
  }
  if (summaryEl) {
    summaryEl.textContent = isComplete ? summaryText : '';
    summaryEl.style.display = isComplete ? '' : 'none';
  }

  // Collapse — close all, mark none expanded
  document.querySelectorAll('.loc-card').forEach(c => c.classList.remove('loc-expanded'));
  document.querySelectorAll('.loc-body').forEach(b => { b.style.display = 'none'; });
}

// ============================================================
// PILL MULTI-SELECT
// ============================================================
const PILL_MAX = {};
document.querySelectorAll('[data-pill-group]').forEach(pg => {
  const group = pg.dataset.pillGroup;
  const max = parseInt(pg.dataset.pillMax || '3', 10);
  PILL_MAX[group] = max;
});

document.addEventListener('click', function(e) {
  const pill = e.target.closest('.pill[data-group]');
  if (!pill) return;
  const group = pill.dataset.group;
  const val = pill.dataset.value;
  const max = PILL_MAX[group] || 3;
  const allPills = document.querySelectorAll(`.pill[data-group="${group}"]`);
  const activePills = document.querySelectorAll(`.pill[data-group="${group}"].pill-active`);

  if (pill.classList.contains('pill-active')) {
    pill.classList.remove('pill-active');
  } else {
    if (activePills.length >= max) return;
    pill.classList.add('pill-active');
  }

  // Sync hidden inputs based on group prefix
  const now = Array.from(document.querySelectorAll(`.pill[data-group="${group}"].pill-active`)).map(p => p.dataset.value);
  const nowCount = now.length;

  // Disable/enable remaining pills
  allPills.forEach(p => {
    if (!p.classList.contains('pill-active')) {
      p.classList.toggle('pill-disabled', nowCount >= max);
    } else {
      p.classList.remove('pill-disabled');
    }
  });

  // Determine idx and type from group name: "evt-0", "aud-1" etc
  const parts = group.split('-');
  const type = parts[0];
  const idx = parts[1];

  if (type === 'aud') {
    const h1 = document.getElementById(`aud-1-${idx}`);
    const h2 = document.getElementById(`aud-2-${idx}`);
    if (h1) h1.value = now[0] || '';
    if (h2) h2.value = now[1] || '';
  } else if (type === 'evt') {
    const h1 = document.getElementById(`et-1-${idx}`);
    const h2 = document.getElementById(`et-2-${idx}`);
    const h3 = document.getElementById(`et-3-${idx}`);
    if (h1) h1.value = now[0] || '';
    if (h2) h2.value = now[1] || '';
    if (h3) h3.value = now[2] || '';
  }
});

// ============================================================
// CITY SEARCH-TAG
// ============================================================
window._cityData = {};

function getCityData(idx) {
  if (!window._cityData[idx]) {
    const ids = ['', '', ''];
    const labels = ['', '', ''];
    for (let i = 1; i <= 3; i++) {
      const idEl = document.getElementById(`city-id-${i}-${idx}`);
      const lblEl = document.getElementById(`city-label-${i}-${idx}`);
      if (idEl && idEl.value) { ids[i-1] = idEl.value; labels[i-1] = lblEl?.value || ''; }
    }
    window._cityData[idx] = ids
      .map((id, i) => id ? { id, label: labels[i] } : null)
      .filter(Boolean);
  }
  return window._cityData[idx];
}

function saveCityData(idx) {
  const data = window._cityData[idx] || [];
  for (let i = 1; i <= 3; i++) {
    const el = document.getElementById(`city-id-${i}-${idx}`);
    const lbl = document.getElementById(`city-label-${i}-${idx}`);
    if (el) el.value = data[i-1]?.id || '';
    if (lbl) lbl.value = data[i-1]?.label || '';
  }
}

function renderCityTags(idx) {
  const data = window._cityData[idx] || [];
  const row = document.getElementById(`city-tags-row-${idx}`);
  const inp = document.getElementById(`city-search-${idx}`);
  if (!row || !inp) return;
  row.innerHTML = data.map(c =>
    `<span class="city-tag" data-city-id="${c.id}">${c.label}<span class="city-tag-x" data-idx="${idx}" data-city-id="${c.id}">×</span></span>`
  ).join('');
  inp.disabled = data.length >= 3;
  inp.placeholder = data.length >= 3 ? 'Maximum atteint' : 'Rechercher une ville…';
  saveCityData(idx);
}

