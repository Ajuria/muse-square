            + '</div>'
          + '</div>'
          + '<div style="display:flex;align-items:center;gap:6px;margin-bottom:8px;">'
            + '<span style="font-size:9px;font-weight:600;color:#9ca3af;text-transform:uppercase;width:42px;">\u00c0</span>'
            + '<input data-edit-recip="' + r.rule_id + '" value="' + (recip || '') + '" placeholder="email, #canal..." style="flex:1;font-size:10px;padding:3px 6px;border:1px solid #e5e7eb;border-radius:4px;font-family:inherit;color:#374151;outline:none;" />'
          + '</div>'
          + '<div style="display:flex;gap:6px;">'
            + '<button type="button" data-edit-save="' + r.rule_id + '" style="font-size:9px;font-weight:600;padding:4px 10px;border-radius:4px;background:#1D3BB3;color:#fff;border:none;cursor:pointer;font-family:inherit;">Enregistrer</button>'
            + '<button type="button" data-edit-cancel="' + r.rule_id + '" style="font-size:9px;font-weight:600;padding:4px 10px;border-radius:4px;background:#f3f4f6;color:#6b7280;border:none;cursor:pointer;font-family:inherit;">Annuler</button>'
          + '</div>'
        + '</div>'
      + '</div>';
    }).join('');

    // Wire tri-toggle
    list.querySelectorAll('[data-tri]').forEach(function(opt) {
      opt.addEventListener('click', async function() {
        var ruleId = opt.getAttribute('data-rule-id');
        var mode = opt.getAttribute('data-tri');
        var rule = _autoRules.find(function(r) { return r.rule_id === ruleId; });
        if (!rule) return;
        if (mode === 'off') {
          await fetch('/api/channels/automation', { method: 'DELETE', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ rule_id: ruleId, location_id: locId }) });
        } else {
          await fetch('/api/channels/automation', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ rule_id: ruleId, location_id: locId, signal_category: rule.signal_category, channel: rule.channel, recipient: rule.recipient, require_approval: mode === 'validation', enabled: true, frequency: rule.frequency || 'first_occurrence' }) });
        }
        await loadAutoRules();
      });
    });

    // Wire edit toggle
    list.querySelectorAll('[data-auto-edit]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var ruleId = btn.getAttribute('data-auto-edit');
        var panel = list.querySelector('[data-auto-edit-panel="' + ruleId + '"]');
        if (panel) panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
      });
    });

    // Wire edit channel pills
    list.querySelectorAll('[data-edit-ch]').forEach(function(pill) {
      pill.addEventListener('click', function() {
        var ruleId = pill.getAttribute('data-rule-id');
        list.querySelectorAll('[data-edit-ch][data-rule-id="' + ruleId + '"]').forEach(function(p) {
          p.style.borderColor = '#e5e7eb'; p.style.color = '#6b7280'; p.style.background = '#fff';
        });
        pill.style.borderColor = '#1D3BB3'; pill.style.color = '#1D3BB3'; pill.style.background = '#EFF3FF';
      });
    });

    // Wire edit cancel
    list.querySelectorAll('[data-edit-cancel]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var ruleId = btn.getAttribute('data-edit-cancel');
        var panel = list.querySelector('[data-auto-edit-panel="' + ruleId + '"]');
        if (panel) panel.style.display = 'none';
      });
    });

    // Wire edit save
    list.querySelectorAll('[data-edit-save]').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        var ruleId = btn.getAttribute('data-edit-save');
        var rule = _autoRules.find(function(r) { return r.rule_id === ruleId; });
        if (!rule) return;
        var activePill = list.querySelector('[data-edit-ch][data-rule-id="' + ruleId + '"][style*="1D3BB3"]');
        var newCh = activePill ? activePill.getAttribute('data-edit-ch') : rule.channel;
        var recipInput = list.querySelector('[data-edit-recip="' + ruleId + '"]');
        var newRecip = recipInput ? recipInput.value.trim() : rule.recipient;
        btn.textContent = '...';
        btn.disabled = true;
        await fetch('/api/channels/automation', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ rule_id: ruleId, location_id: locId, signal_category: rule.signal_category, channel: newCh, recipient: newRecip, require_approval: rule.require_approval, enabled: true, frequency: rule.frequency || 'first_occurrence' }) });
        await loadAutoRules();
      });
    });

    // Wire delete
    list.querySelectorAll('[data-auto-delete]').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        var ruleId = btn.getAttribute('data-auto-delete');
        if (!confirm('Supprimer cette r\u00e8gle ?')) return;
        await fetch('/api/channels/automation', { method: 'DELETE', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ rule_id: ruleId, location_id: locId }) });
        await loadAutoRules();
      });
    });
  }

  async function loadAutoRules() {
    try {
      var res = await fetch('/api/channels/automation?location_id=' + encodeURIComponent(locId));
      var json = await res.json();
      if (json && json.ok && Array.isArray(json.items)) {
        renderAutoRules(json.items);
      } else {
        renderAutoRules([]);
      }
    } catch(e) { renderAutoRules([]); }
  }

  await loadAutoRules();
})();

