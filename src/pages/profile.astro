  .reco-root .chev{transition:transform .25s ease;color:var(--ink-faint);flex:none;}
  .reco-root .bucket.open .chev{transform:rotate(180deg);}
  .reco-root .reco-sw{--w:46px;--h:26px;appearance:none;-webkit-appearance:none;cursor:pointer;flex:none;width:var(--w);height:var(--h);border-radius:999px;position:relative;background:#D9D0BD;border:1px solid rgba(38,34,27,.08);transition:background .2s ease;margin:0;}
  .reco-root .reco-sw::after{content:"";position:absolute;top:2px;left:2px;width:20px;height:20px;border-radius:50%;background:#fff;box-shadow:0 1px 2px rgba(0,0,0,.18);transition:transform .2s ease;}
  .reco-root .reco-sw:checked{background:var(--on-bg);}
  .reco-root .reco-sw:checked::after{transform:translateX(20px);}
  .reco-root .reco-sw.sm{--w:40px;--h:23px;}
  .reco-root .reco-sw.sm::after{width:17px;height:17px;}
  .reco-root .reco-sw.sm:checked::after{transform:translateX(17px);}
  .reco-root .b-body{display:grid;grid-template-rows:0fr;transition:grid-template-rows .3s ease;}
  .reco-root .bucket.open .b-body{grid-template-rows:1fr;}
