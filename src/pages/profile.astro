document.getElementById('userProfileForm')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const form = e.currentTarget;
  const btn = document.getElementById('userSaveBtn');
  const statusEl = document.getElementById('userSaveStatus');
  if (btn) { btn.disabled = true; btn.textContent = 'Enregistrement\u2026'; }
  if (statusEl) { statusEl.textContent = ''; statusEl.className = 'save-status'; }

  const fd = new FormData(form);
  const data = {
    first_name: fd.get('first_name') || '',
    last_name: fd.get('last_name') || '',
    position: fd.get('position') || '',
    main_event_objective: fd.get('main_event_objective') || '',
  };

  try {
    const res = await fetch('/api/profile/save-user', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify(data),
    });
    const out = await res.json().catch(() => null);
    if (res.ok && out?.ok) {
      if (statusEl) { statusEl.textContent = 'Profil enregistr\u00e9.'; statusEl.className = 'save-status status-ok'; }
      if (btn) btn.textContent = '\u2713 Enregistr\u00e9';
      setTimeout(() => {
        if (btn) btn.textContent = 'Enregistrer';
        const nameEl = document.getElementById('user-profile-name');
        if (nameEl) {
          const fn = data.first_name || '';
          const ln = data.last_name || '';
          const pos = data.position || '';
          nameEl.textContent = [fn, ln].filter(Boolean).join(' ') + (pos ? ' \u00b7 ' + pos : '');
        }
        const objEl = document.getElementById('user-profile-objective');
        const OBJ_LABELS = {
          maximize_attendance: "Maximiser l'affluence",
          avoid_competition: "\u00c9viter la concurrence",
          optimize_weather: "Optimiser le rapport co\u00fbt / m\u00e9t\u00e9o",
          test_market: "Tester un nouveau march\u00e9",
        };
        if (objEl) {
          const val = data.main_event_objective || '';
          objEl.textContent = val ? 'Objectif : ' + (OBJ_LABELS[val] || val) : '';
          objEl.style.display = val ? '' : 'none';
        }
        }, 900);
    } else {
      if (statusEl) { statusEl.textContent = out?.error || 'Erreur lors de l\u2019enregistrement.'; statusEl.className = 'save-status status-err'; }
      if (btn) btn.textContent = 'R\u00e9essayer';
    }
  } catch (_) {
    if (statusEl) { statusEl.textContent = 'Erreur r\u00e9seau.'; statusEl.className = 'save-status status-err'; }
    if (btn) btn.textContent = 'R\u00e9essayer';
  } finally {
    if (btn) btn.disabled = false;
  }
});

