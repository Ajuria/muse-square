  .reco-root .t-desc{color:var(--ink-soft);font-size:13px;margin-top:3px;max-width:50ch;}
  .reco-root .t-gate{margin-top:7px;display:inline-flex;align-items:center;gap:6px;font-size:12px;color:#8A4A1E;background:#FBEEE2;border:1px solid #E9D2BC;border-radius:8px;padding:5px 9px;}
  .reco-root .t-gate svg{flex:none;}
  .reco-root .theme.gated .t-name,.reco-root .theme.gated .t-desc{opacity:.6;}
  .reco-root .theme.off .t-main{opacity:.5;}
  .reco-root .theme.off .intensity{display:none;}
  .reco-root .intensity{margin-top:10px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
  .reco-root .intensity .lbl{font-size:12px;color:var(--ink-faint);}
  .reco-root .seg{display:inline-flex;border:1px solid var(--line);border-radius:9px;overflow:hidden;background:#fff;}
  .reco-root .seg button{appearance:none;border:none;background:transparent;cursor:pointer;font:inherit;font-size:12.5px;padding:5px 12px;color:var(--ink-soft);}
  .reco-root .seg button.active{background:var(--on-bg);color:#fff;font-weight:600;}
  .reco-root .reco-foot{margin-top:26px;padding:16px 18px;border:1px dashed var(--line);border-radius:var(--radius);color:var(--ink-soft);font-size:13px;display:flex;gap:12px;align-items:flex-start;}
  .reco-root .reco-foot svg{flex:none;color:var(--ink-faint);margin-top:1px;}
  .reco-root .reco-foot b{color:var(--ink);font-weight:600;}
</style>

<div class="profile-wrap">

  <!-- PAGE HEADER -->
  <div style="margin-bottom: 2rem;">
    <h1 style="font-size: 28px; font-weight: 600; margin-bottom: 4px;">Mon compte</h1>
    <p style="font-size: 14px; color: #6b7280;">Profil, sites, communications et préférences.</p>
  </div>

  <div class="ms-tabs" id="ms-tabs">
    <button type="button" class={`ms-tab-btn${activeTab === "profil" ? " active" : ""}`} data-tab-btn="profil">Profil</button>
    <button type="button" class={`ms-tab-btn${activeTab === "sites" ? " active" : ""}`} data-tab-btn="sites">Sites</button>
    {recoLocationId && (<button type="button" class={`ms-tab-btn${activeTab === "reco" ? " active" : ""}`} data-tab-btn="reco">Recommandations</button>)}
    <button type="button" class={`ms-tab-btn${activeTab === "comm" ? " active" : ""}`} data-tab-btn="comm">Communication</button>
  </div>

  <div class="ms-tab" data-tab="profil" hidden={activeTab !== "profil"}>
  <div class="section-title">Profil</div>
  <p class="section-desc">Informations personnelles et accès.</p>

  <form id="userProfileForm">
    <div class="field-row">
      <div class="field-group" style="margin-top:0">
        <label class="field-label">Prénom <span class="field-req">*</span></label>
        <input type="text" name="first_name" required value={saved_safe?.first_name ?? ""} class="field-input" />
      </div>
      <div class="field-group" style="margin-top:0">
        <label class="field-label">Nom <span class="field-req">*</span></label>
        <input type="text" name="last_name" required value={saved_safe?.last_name ?? ""} class="field-input" />
      </div>
    </div>

    <div class="field-group">
      <label class="field-label">Fonction</label>
      <input type="text" name="position" value={saved_safe?.position ?? ""} class="field-input" />
    </div>

    <div class="field-group">
      <label class="field-label">Email</label>
      <input type="email" name="email" value={saved_safe?.email || clerkEmail} readonly class="field-input" />
    </div>

    <div class="field-group">
      <label class="field-label">Objectif principal</label>
      <div class="field-select-wrap">
        <select name="main_event_objective" class="field-select">
          <option value="">Sélectionner…</option>
          <option value="maximize_attendance" selected={(saved_safe?.main_event_objective ?? "") === "maximize_attendance"}>Maximiser l'affluence</option>
          <option value="avoid_competition" selected={(saved_safe?.main_event_objective ?? "") === "avoid_competition"}>Éviter la concurrence</option>
          <option value="optimize_weather" selected={(saved_safe?.main_event_objective ?? "") === "optimize_weather"}>Optimiser le rapport coût / météo</option>
          <option value="test_market" selected={(saved_safe?.main_event_objective ?? "") === "test_market"}>Tester un nouveau marché</option>
