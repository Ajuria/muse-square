window.saveLocation = async function(idx) {
  const btn = document.querySelector(`.loc-btn-save[data-idx="${idx}"]`);
  const statusEl = document.getElementById(`loc-save-status-${idx}`);
  const card = document.querySelector(`.loc-card:nth-child(${idx + 1})`);

  if (btn) { btn.disabled = true; btn.textContent = 'Enregistrement…'; }
  if (statusEl) { statusEl.textContent = ''; statusEl.className = 'save-status'; }

  // Validate address confirmed
  if (!_addrConfirmed[idx]) {
    const addrInp = document.querySelector(`.addr-autocomplete[data-idx="${idx}"]`);
    if (addrInp && addrInp.value.trim()) {
      if (statusEl) { statusEl.textContent = 'Sélectionnez une adresse depuis la liste.'; statusEl.className = 'save-status status-err'; }
      if (btn) { btn.disabled = false; btn.textContent = 'Enregistrer ce site'; }
      return;
    }
  }
  if (!_metroConfirmed[idx]) {
    const metroInp = document.querySelector(`.metro-autocomplete[data-idx="${idx}"]`);
    if (metroInp && metroInp.value.trim()) {
      if (statusEl) { statusEl.textContent = 'Sélectionnez une station depuis la liste.'; statusEl.className = 'save-status status-err'; }
      if (btn) { btn.disabled = false; btn.textContent = 'Enregistrer ce site'; }
      return;
    }
  }

  // Collect all fields from this card's body
  const body = document.getElementById(`loc-body-${idx}`);
  if (!body) return;

  // Validate required fields before submit
  const requiredSelects = ['company_activity_type', 'location_type', 'weather_sensitivity', 'location_access_pattern'];
  const addrInpCheck = body.querySelector('[name="company_address"]');
  if (!addrInpCheck || !addrInpCheck.value.trim()) {
    if (statusEl) { statusEl.textContent = 'L\'adresse professionnelle est obligatoire.'; statusEl.className = 'save-status status-err'; }
    if (btn) { btn.disabled = false; btn.textContent = 'Enregistrer ce site'; }
    if (addrInpCheck) addrInpCheck.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }
  const missingFields = [];
  requiredSelects.forEach(name => {
    const el = body.querySelector(`[name="${name}"]`);
    if (!el || !el.value) missingFields.push(el);
  });
  const siteNameEl = body.querySelector('[name="site_name"]');
  if (!siteNameEl || !siteNameEl.value.trim()) missingFields.push(siteNameEl);
  const websiteEl = body.querySelector('[name="website_url"]');
  if (!websiteEl || !websiteEl.value.trim()) missingFields.push(websiteEl);
  const aud1El = document.getElementById(`aud-1-${idx}`);
  if (!aud1El || !aud1El.value) {
    const audGroup = body.querySelector('[data-pill-group]');
    if (audGroup) missingFields.push(audGroup);
  }
  const et1El = document.getElementById(`et-1-${idx}`);
  if (!et1El || !et1El.value) {
    const etGroup = body.querySelectorAll('[data-pill-group]')[1];
    if (etGroup) missingFields.push(etGroup);
  }

  if (missingFields.length > 0) {
    missingFields.forEach(el => {
      if (!el) return;
      el.style.outline = '2px solid #ef4444';
      el.style.borderColor = '#ef4444';
      setTimeout(() => { el.style.outline = ''; el.style.borderColor = ''; }, 3000);
    });
    if (statusEl) { statusEl.textContent = 'Merci de compléter les champs obligatoires.'; statusEl.className = 'save-status status-err'; }
    if (btn) { btn.disabled = false; btn.textContent = 'Enregistrer ce site'; }
    missingFields[0].scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }

  const modeEl = body.querySelector('[name="mode"]');
  const data = { mode: modeEl?.value || 'update' };

  // Hidden fields
  ['location_id','origin_city_id_1','origin_city_id_2','origin_city_id_3',
   'origin_city_label_1','origin_city_label_2','origin_city_label_3',
   'operating_hours','primary_audience_1','primary_audience_2',
   'event_type_1','event_type_2','event_type_3',
   'nearest_transit_stop_id','nearest_transit_lines'].forEach(name => {
    const el = body.querySelector(`[name="${name}"]`);
    if (el) data[name] = el.value;
  });

  // Named inputs/selects/textareas
  ['site_name','venue_capacity','location_description','website_url','company_address',
   'company_activity_type','location_type','weather_sensitivity','seasonality',
   'location_access_pattern','nearest_transit_stop'].forEach(name => {
    const el = body.querySelector(`[name="${name}"]`);
    if (el) data[name] = el.value;
  });

  // company_name = site_name for compatibility
  data.company_name = data.site_name || data.company_name;

  // Multi-select arrays expected by save.ts
  data.primary_audience_1 = [data.primary_audience_1, data.primary_audience_2].filter(Boolean);
  data.origin_city_ids = [data.origin_city_id_1, data.origin_city_id_2, data.origin_city_id_3].filter(Boolean);

  try {
    const res = await fetch('/api/profile/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify(data),
    });
    const out = await res.json().catch(() => null);
    if (res.ok && out?.ok) {
      if (btn) btn.textContent = '✓ Enregistré';
      // Collapse after brief confirmation delay so user sees the tick
      setTimeout(() => {
        if (btn) { btn.textContent = 'Enregistrer ce site'; btn.disabled = false; }
        if (statusEl) { statusEl.textContent = ''; statusEl.className = 'save-status'; }
        const cardId = `loc-card-${idx}`;
        const bodyId = `loc-body-${idx}`;
        collapseCard(idx, cardId, bodyId, data);
      }, 900);
    } else {
      if (statusEl) { statusEl.textContent = out?.error || 'Erreur.'; statusEl.className = 'save-status status-err'; }
      if (btn) { btn.textContent = 'Réessayer'; btn.disabled = false; }
    }
  } catch (_) {
    if (statusEl) { statusEl.textContent = 'Erreur réseau.'; statusEl.className = 'save-status status-err'; }
    if (btn) { btn.textContent = 'Réessayer'; btn.disabled = false; }
  }
};

