// ============================================================
// OPERATING HOURS
// ============================================================
window.schedToggle = function(idx, day) {
  const row = document.getElementById(`sched-${idx}-${day}`);
  if (!row) return;
  const tog = row.querySelector('.sched-toggle');
  const isOn = tog.classList.contains('tog-on');
  tog.classList.toggle('tog-on', !isOn);
  row.classList.toggle('sched-closed', isOn);
  schedUpdate(idx);
};

window.schedUpdate = function(idx) {
  const days = ['lun','mar','mer','jeu','ven','sam','dim'];
  const result = {};
  days.forEach(day => {
    const row = document.getElementById(`sched-${idx}-${day}`);
    if (!row) return;
    const isClosed = row.classList.contains('sched-closed');
    if (isClosed) {
      result[day] = null;
    } else {
      const openEl = row.querySelector('[data-type="open"]');
      const closeEl = row.querySelector('[data-type="close"]');
      result[day] = {
        open: openEl?.value || '09:00',
        close: closeEl?.value || '22:00',
      };
    }
  });
  const hiddenEl = document.getElementById(`oh-json-${idx}`);
  if (hiddenEl) hiddenEl.value = JSON.stringify(result);
};

window.schedApplyAll = function(idx) {
  const refRow = document.getElementById(`sched-${idx}-lun`);
  if (!refRow || refRow.classList.contains('sched-closed')) return;
  const refOpen = refRow.querySelector('[data-type="open"]')?.value || '09:00';
  const refClose = refRow.querySelector('[data-type="close"]')?.value || '22:00';
  ['mar','mer','jeu','ven','sam','dim'].forEach(day => {
    const row = document.getElementById(`sched-${idx}-${day}`);
    if (!row) return;
    // Force open if closed
    if (row.classList.contains('sched-closed')) {
      row.classList.remove('sched-closed');
      const tog = row.querySelector('.sched-toggle');
      if (tog) tog.classList.add('tog-on');
    }
    const openEl = row.querySelector('[data-type="open"]');
    const closeEl = row.querySelector('[data-type="close"]');
    if (openEl) openEl.value = refOpen;
    if (closeEl) closeEl.value = refClose;
  });
  schedUpdate(idx);
};

