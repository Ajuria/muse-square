      return '<div data-auto-rule="' + r.rule_id + '" style="padding:12px 0;border-bottom:1px solid #f3f4f6;' + (!enabled ? 'opacity:0.45;' : '') + '">'
        + '<div style="display:flex;align-items:center;gap:10px;">'
          + '<span style="width:30px;height:30px;border-radius:7px;background:' + catBg + ';display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;">' + catIcon + '</span>'
          + '<div style="flex:1;min-width:0;">'
            + '<div style="font-weight:600;font-size:12px;color:#111827;">' + catLabel + '</div>'
          + '</div>'
          + '<div style="display:flex;align-items:center;gap:0;user-select:none;background:#f3f4f6;border-radius:6px;padding:2px;flex-shrink:0;">'
            + '<span data-tri="off" data-rule-id="' + r.rule_id + '" style="font-size:9px;font-weight:600;padding:4px 9px;border-radius:4px;cursor:pointer;color:#9ca3af;' + (!enabled ? 'background:#e5e7eb;color:#4b5563;font-weight:700;' : '') + '">Off</span>'
