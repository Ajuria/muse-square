            + '<div style="display:flex;gap:8px;margin-top:10px;">'
              + '<button type="button" data-save-member="' + m.member_id + '" style="padding:7px 16px;border-radius:6px;font-size:12px;font-weight:600;background:#1D3BB3;color:#fff;border:none;cursor:pointer;font-family:inherit;">Enregistrer</button>'
              + '<button type="button" data-cancel-edit="' + m.member_id + '" style="padding:7px 16px;border-radius:6px;font-size:12px;font-weight:600;background:#f9fafb;color:#6b7280;border:1px solid #e5e7eb;cursor:pointer;font-family:inherit;">Annuler</button>'
            + '</div>'
          + '</div>'
        + '</div>';
      }).join('');
      // Wire edit toggle
      list.querySelectorAll('[data-edit-member]').forEach(function(el) {
        el.addEventListener('click', function() {
          var mid = el.getAttribute('data-edit-member');
          var viewEl = list.querySelector('[data-member-view="' + mid + '"]');
          var editEl = list.querySelector('[data-member-edit="' + mid + '"]');
          if (viewEl) viewEl.style.display = 'none';
          if (editEl) editEl.style.display = 'block';
        });
      });
      // Wire cancel
      list.querySelectorAll('[data-cancel-edit]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var mid = btn.getAttribute('data-cancel-edit');
          var viewEl = list.querySelector('[data-member-view="' + mid + '"]');
          var editEl = list.querySelector('[data-member-edit="' + mid + '"]');
          if (viewEl) viewEl.style.display = 'flex';
          if (editEl) editEl.style.display = 'none';
        });
      });
      // Wire save edit
      list.querySelectorAll('[data-save-member]').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var mid = btn.getAttribute('data-save-member');
          var fnEl = list.querySelector('[data-ed-fn="' + mid + '"]');
          var lnEl = list.querySelector('[data-ed-ln="' + mid + '"]');
          var roleEl = list.querySelector('[data-ed-role="' + mid + '"]');
          var slEl = list.querySelector('[data-ed-ch-slack="' + mid + '"]');
          var emEl = list.querySelector('[data-ed-ch-email="' + mid + '"]');
          var smEl = list.querySelector('[data-ed-ch-sms="' + mid + '"]');
          var waEl = list.querySelector('[data-ed-ch-whatsapp="' + mid + '"]');
          var oldMember = _teamCache.find(function(m) { return m.member_id === mid; });
          var ch = {};
          if (slEl && slEl.value.trim()) ch.slack = slEl.value.trim();
          if (emEl && emEl.value.trim()) ch.email = emEl.value.trim();
          if (smEl && smEl.value.trim()) ch.sms = smEl.value.trim();
          if (waEl && waEl.value.trim()) ch.whatsapp = waEl.value.trim();
          btn.textContent = '...';
          btn.disabled = true;
          try {
            var res = await fetch('/api/channels/team', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({
                member_id: mid,
                location_id: locId,
                first_name: fnEl ? fnEl.value.trim() : '',
                last_name: lnEl ? lnEl.value.trim() : '',
                role: roleEl ? roleEl.value.trim() : '',
                channels_contact: ch,
                signal_routing: oldMember ? oldMember.signal_routing : {},
              }),
            });
            var json = await res.json();
            if (json && json.ok) {
              var res2 = await fetch('/api/channels/team?location_id=' + encodeURIComponent(locId));
              var json2 = await res2.json();
              if (json2 && json2.ok) { _teamCache = json2.items; renderTeamList(_teamCache); }
            }
          } catch(e) {}
        });
      });
      // Wire delete
      list.querySelectorAll('[data-delete-member]').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var mid = btn.getAttribute('data-delete-member');
          if (!confirm('Supprimer ce membre ?')) return;
          btn.textContent = '...';
          try {
            var res = await fetch('/api/channels/team', { method: 'DELETE', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ member_id: mid, location_id: locId }) });
            var json = await res.json();
            if (json && json.ok) {
              _teamCache = _teamCache.filter(function(m) { return m.member_id !== mid; });
              renderTeamList(_teamCache);
            }
          } catch(e) {}
        });
      });
    }

    var _teamCache = [];
    try {
      var res = await fetch('/api/channels/team?location_id=' + encodeURIComponent(locId));
      var json = await res.json();
      if (json && json.ok && Array.isArray(json.items)) {
        _teamCache = json.items;
        renderTeamList(_teamCache);
      }
    } catch(e) {}

    document.getElementById('team-add-btn')?.addEventListener('click', async function() {
      var fnEl = document.getElementById('team-new-firstname');
      var lnEl = document.getElementById('team-new-lastname');
      var roleEl = document.getElementById('team-new-role');
      var msgEl = document.getElementById('team-add-msg');
      var btn = this;
      var firstName = fnEl ? fnEl.value.trim() : '';
      if (!firstName) { if (msgEl) { msgEl.textContent = 'Pr\u00e9nom requis.'; msgEl.style.color = '#B91C1C'; } return; }
      var channels_contact = {};
      var slackEl = document.getElementById('team-new-ch-slack');
      var emailEl = document.getElementById('team-new-ch-email');
      var smsEl = document.getElementById('team-new-ch-sms');
      var waEl = document.getElementById('team-new-ch-whatsapp');
      if (slackEl && slackEl.value.trim()) channels_contact.slack = slackEl.value.trim();
      if (emailEl && emailEl.value.trim()) channels_contact.email = emailEl.value.trim();
      if (smsEl && smsEl.value.trim()) channels_contact.sms = smsEl.value.trim();
      if (waEl && waEl.value.trim()) channels_contact.whatsapp = waEl.value.trim();
      var routing = {};
      document.querySelectorAll('[data-group="team-routing"].pill-active').forEach(function(p) { routing[p.dataset.value] = true; });
      document.querySelectorAll('[data-group="team-routing"]:not(.pill-active)').forEach(function(p) { routing[p.dataset.value] = false; });
      btn.disabled = true;
      btn.textContent = 'Ajout...';
      try {
        var res = await fetch('/api/channels/team', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            location_id: locId,
            first_name: firstName,
            last_name: lnEl ? lnEl.value.trim() : '',
            role: roleEl ? roleEl.value.trim() : '',
            channels_contact: channels_contact,
            signal_routing: routing,
          }),
        });
        var json = await res.json();
        if (json && json.ok) {
          if (msgEl) { msgEl.textContent = 'Membre ajout\u00e9.'; msgEl.style.color = '#059669'; }
          if (fnEl) fnEl.value = '';
          if (lnEl) lnEl.value = '';
          if (roleEl) roleEl.value = '';
          if (slackEl) slackEl.value = '';
          if (emailEl) emailEl.value = '';
          if (smsEl) smsEl.value = '';
          if (waEl) waEl.value = '';
          var res2 = await fetch('/api/channels/team?location_id=' + encodeURIComponent(locId));
          var json2 = await res2.json();
          if (json2 && json2.ok) { _teamCache = json2.items; renderTeamList(_teamCache); }
          setTimeout(function() { if (msgEl) msgEl.textContent = ''; }, 2000);
        } else {
          if (msgEl) { msgEl.textContent = json.error || 'Erreur.'; msgEl.style.color = '#B91C1C'; }
        }
      } catch(e) {
        if (msgEl) { msgEl.textContent = 'Erreur r\u00e9seau.'; msgEl.style.color = '#B91C1C'; }
      }
      btn.disabled = false;
      btn.textContent = 'Ajouter';
    });
  })();

</script>

<script>
// @ts-nocheck
'use strict';
(function () {
  var root = document.getElementById('reco-buckets');
  if (!root) return;
  var locId = root.getAttribute('data-reco-location') || '';
  var statusEl = document.getElementById('reco-save-status');
  var countEl = document.getElementById('reco-count');
  var detailEl = document.getElementById('reco-count-detail');

  var meta = { total: 0, themes: [] };
  try { meta = JSON.parse(root.getAttribute('data-reco-meta') || '{}'); } catch (e) {}
  var countById = {};
  (meta.themes || []).forEach(function (t) { countById[t.id] = t.count; });

  var initialDisabled = [];
  try { initialDisabled = JSON.parse(root.getAttribute('data-reco-init-disabled') || '[]'); } catch (e) {}
  var availableIds = Array.prototype.slice.call(root.querySelectorAll('[data-theme]')).map(function (s) { return s.getAttribute('data-theme'); });

  root.querySelectorAll('[data-toggle]').forEach(function (h) {
    h.addEventListener('click', function (e) {
      if (e.target.closest && e.target.closest('.reco-sw')) return;
      h.closest('.bucket').classList.toggle('open');
    });
  });

  function currentDisabled() {
    var offAvail = Array.prototype.slice.call(root.querySelectorAll('[data-theme]'))
      .filter(function (s) { return !s.checked; })
      .map(function (s) { return s.getAttribute('data-theme'); });
    var carried = initialDisabled.filter(function (id) { return availableIds.indexOf(id) === -1; });
    var seen = {};
    return offAvail.concat(carried).filter(function (id) { if (seen[id]) return false; seen[id] = true; return true; });
  }

  function weatherIntensity() {
    var act = root.querySelector('[data-seg="meteo"] button.active');
    return act ? act.getAttribute('data-val') : '';
  }

  function updateSummary() {
    var active = 0, dormant = 0;
    (meta.themes || []).forEach(function (t) {
      if (t.gated) { dormant += t.count; return; }
      var sw = root.querySelector('[data-theme="' + t.id + '"]');
      if (sw && sw.checked) active += t.count;
    });
    var pause = (meta.total || 0) - active - dormant;
    if (countEl) countEl.textContent = active;
    if (detailEl) detailEl.textContent = '· ' + pause + ' en pause · ' + dormant + ' en attente de raccordement · ' + (meta.total || 0) + ' au total';
    root.querySelectorAll('.bucket').forEach(function (bk) {
      var bid = bk.getAttribute('data-bucket');
      var sum = 0;
      bk.querySelectorAll('[data-theme]').forEach(function (sw) { if (sw.checked) sum += (countById[sw.getAttribute('data-theme')] || 0); });
      var cEl = bk.querySelector('[data-bucket-count="' + bid + '"]');
      if (cEl) cEl.textContent = sum;
      var master = bk.querySelector('[data-master]');
      if (master) {
        var kids = (master.getAttribute('data-children') || '').split(',').filter(Boolean);
        master.checked = kids.length > 0 && kids.every(function (cid) { var s = bk.querySelector('[data-theme="' + cid + '"]'); return s && s.checked; });
      }
      bk.querySelectorAll('[data-theme]').forEach(function (sw) {
        var th = sw.closest('.theme');
        if (th) th.classList.toggle('off', !sw.checked);
      });
    });
  }

  var _t = null;
  function save() {
    clearTimeout(_t);
    _t = setTimeout(function () {
      if (statusEl) { statusEl.textContent = 'Enregistrement…'; statusEl.className = 'save-status'; }
      fetch('/api/channels/config', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ location_id: locId, channel: 'recommendations', config: { disabled_themes: currentDisabled(), weather_intensity: weatherIntensity() } }),
      }).then(function (r) { return r.json().catch(function () { return null; }); })
        .then(function (out) {
          if (out && out.ok) { if (statusEl) { statusEl.textContent = 'Préférences enregistrées.'; statusEl.className = 'save-status status-ok'; } }
          else { if (statusEl) { statusEl.textContent = (out && out.error) || 'Erreur.'; statusEl.className = 'save-status status-err'; } }
        })
        .catch(function () { if (statusEl) { statusEl.textContent = 'Erreur réseau.'; statusEl.className = 'save-status status-err'; } });
    }, 500);
  }

  root.addEventListener('change', function (e) {
    var s = e.target;
    if (s.matches && s.matches('[data-theme]')) { updateSummary(); save(); return; }
    if (s.matches && s.matches('[data-master]')) {
      var kids = (s.getAttribute('data-children') || '').split(',').filter(Boolean);
      kids.forEach(function (cid) { var t = root.querySelector('[data-theme="' + cid + '"]'); if (t) t.checked = s.checked; });
      updateSummary(); save(); return;
    }
  });

  root.querySelectorAll('[data-seg] button').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var seg = btn.closest('[data-seg]');
      seg.querySelectorAll('button').forEach(function (x) { x.classList.toggle('active', x === btn); });
      save();
    });
  });

  var sel = document.getElementById('reco-site-select');
  if (sel && sel.tagName === 'SELECT') {
    sel.addEventListener('change', function () {
      var u = new URL(window.location.href);
      u.searchParams.set('site', sel.value);
      window.location.href = u.toString();
    });
  }

  updateSummary();
})();
</script>

<script>
// @ts-nocheck
'use strict';
(function () {
  var tabs = document.getElementById('ms-tabs');
  if (!tabs) return;
  function show(tab) {
    document.querySelectorAll('.ms-tab-btn').forEach(function (b) { b.classList.toggle('active', b.getAttribute('data-tab-btn') === tab); });
    document.querySelectorAll('.ms-tab[data-tab]').forEach(function (p) { p.hidden = p.getAttribute('data-tab') !== tab; });
    var u = new URL(window.location.href);
    u.searchParams.set('tab', tab);
    window.history.replaceState({}, '', u.toString());
  }
  tabs.addEventListener('click', function (e) {
    var b = e.target.closest ? e.target.closest('[data-tab-btn]') : null;
    if (!b) return;
    show(b.getAttribute('data-tab-btn'));
    window.scrollTo({ top: 0 });
  });
})();
</script>

