    });
    const out = await res.json().catch(() => null);
    if (res.ok && out?.ok) {
      window.location.reload();
    } else {
      alert(out?.error || 'Erreur lors de la définition du site principal.');
    }
  } catch (_) {
    alert('Erreur réseau.');
  }
};

