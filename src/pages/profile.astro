       'origin_city_label_1','origin_city_label_2','origin_city_label_3',
       'company_address','company_activity_type','location_type',
       'weather_sensitivity','seasonality','location_access_pattern',
       'nearest_transit_stop','nearest_transit_stop_id','nearest_transit_lines',
       'site_name','venue_capacity','location_description',
       'event_type_1','event_type_2','event_type_3','operating_hours'].forEach(name => {
        const el = body.querySelector(`[name="${name}"]`);
        if (el && !data[name]) data[name] = el.value;
      });
      // Rebuild arrays
      data.primary_audience_1 = [data.primary_audience_1, data.primary_audience_2].filter(Boolean);
      data.origin_city_ids = [data.origin_city_id_1, data.origin_city_id_2, data.origin_city_id_3].filter(Boolean);
    }
  }

  try {
    const res = await fetch('/api/profile/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify(data),
    });
    const out = await res.json().catch(() => null);
    if (res.ok && out?.ok) {
      if (statusEl) { statusEl.textContent = 'Profil enregistré.'; statusEl.className = 'save-status status-ok'; }
      if (btn) btn.textContent = '✓ Enregistré';
      setTimeout(() => {
        if (btn) btn.textContent = 'Enregistrer';
        // Refresh collapsed header
        const nameEl = document.getElementById('user-profile-name');
        if (nameEl) {
          const fn = data.first_name || '';
          const ln = data.last_name || '';
          const pos = data.position || '';
          nameEl.textContent = [fn, ln].filter(Boolean).join(' ') + (pos ? ` · ${pos}` : '');
        }
        const objEl = document.getElementById('user-profile-objective');
        const OBJ_LABELS = {
          maximize_attendance: "Maximiser l'affluence",
          avoid_competition: "Éviter la concurrence",
          optimize_weather: "Optimiser le rapport coût / météo",
          test_market: "Tester un nouveau marché",
        };
        if (objEl) {
          const val = data.main_event_objective || '';
          objEl.textContent = val ? `Objectif : ${OBJ_LABELS[val] || val}` : '';
          objEl.style.display = val ? '' : 'none';
        }
        // Collapse
        const card = document.getElementById('user-profile-card');
        const body = document.getElementById('user-profile-body');
        if (card) card.classList.remove('loc-expanded');
        if (body) body.style.display = 'none';
      }, 900);
    } else {
      if (statusEl) { statusEl.textContent = out?.error || 'Erreur lors de l\'enregistrement.'; statusEl.className = 'save-status status-err'; }
      if (btn) btn.textContent = 'Réessayer';
    }
  } catch (_) {
    if (statusEl) { statusEl.textContent = 'Erreur réseau.'; statusEl.className = 'save-status status-err'; }
    if (btn) btn.textContent = 'Réessayer';
  } finally {
    if (btn) btn.disabled = false;
  }
});

