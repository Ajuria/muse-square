const pwdModal = document.getElementById('pwd-modal');
document.getElementById('pwd-open')?.addEventListener('click', () => { if (pwdModal) pwdModal.style.display = 'flex'; });
document.getElementById('pwd-modal-close')?.addEventListener('click', closeModal);
pwdModal?.addEventListener('click', e => { if (e.target === pwdModal) closeModal(); });

function closeModal() {
  if (pwdModal) pwdModal.style.display = 'none';
  ['pwd-current','pwd-new','pwd-confirm'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  const s = document.getElementById('pwd-status');
  if (s) s.textContent = '';
}

document.getElementById('pwd-submit')?.addEventListener('click', async () => {
  const current = document.getElementById('pwd-current')?.value;
  const newPwd = document.getElementById('pwd-new')?.value;
  const confirm = document.getElementById('pwd-confirm')?.value;
  const status = document.getElementById('pwd-status');
  const btn = document.getElementById('pwd-submit');

  if (!current || !newPwd || !confirm) { if(status){status.style.color='#dc2626';status.textContent='Tous les champs sont requis.';} return; }
  if (newPwd !== confirm) { if(status){status.style.color='#dc2626';status.textContent='Les mots de passe ne correspondent pas.';} return; }
  if (newPwd.length < 8) { if(status){status.style.color='#dc2626';status.textContent='Minimum 8 caractères.';} return; }

  if(btn){btn.disabled=true;btn.textContent='Enregistrement…';}
  if(status) status.textContent='';

  try {
    const res = await fetch('/api/profile/change-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ current_password: current, new_password: newPwd }),
    });
    const out = await res.json().catch(() => null);
    if (res.ok) {
      if(status){status.style.color='#059669';status.textContent='Mot de passe modifié.';}
      setTimeout(closeModal, 1500);
    } else {
      if(status){status.style.color='#dc2626';status.textContent=out?.error||'Erreur.';}
    }
  } catch (_) {
    if(status){status.style.color='#dc2626';status.textContent='Erreur réseau.';}
  } finally {
    if(btn){btn.disabled=false;btn.textContent='Enregistrer';}
  }
});

