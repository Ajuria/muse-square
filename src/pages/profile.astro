};

(async function() {
  var locCard = document.querySelector('.loc-card[data-location-id]');
  var locId = locCard ? locCard.getAttribute('data-location-id') : null;
  if (!locId) return;

  var CAT_LABELS = {weather:"M\u00e9t\u00e9o",competition:"Concurrence",mobility:"Mobilit\u00e9",opportunity:"Opportunit\u00e9",calendar:"Calendrier"};
  var CAT_ICONS = {weather:"\u26C8",competition:"\uD83C\uDFAF",mobility:"\uD83D\uDE87",opportunity:"\u2B06",calendar:"\uD83D\uDCC5"};
  var CAT_BG = {weather:"#FEF3C7",competition:"#FEE2E2",mobility:"#E0E7FF",opportunity:"#D1FAE5",calendar:"#EDE9FE"};
  var CH_LABELS = {gbp:"GBP",instagram:"Instagram",email:"Email",sms:"SMS",whatsapp:"WhatsApp",slack:"Slack",internal:"Interne",phone:"T\u00e9l\u00e9phone"};

  var _autoRules = [];

  function renderAutoRules(rules) {
    _autoRules = rules;
    var list = document.getElementById('automation-rules-list');
    var summary = document.getElementById('auto-header-summary');
    var activeCount = rules.filter(function(r) { return r.enabled !== false; }).length;
    if (summary) {
      summary.textContent = activeCount > 0 ? activeCount + ' active' + (activeCount > 1 ? 's' : '') : 'Aucune r\u00e8gle';
      summary.style.color = activeCount > 0 ? '#059669' : '#9ca3af';
    }
    if (!list) return;
    if (rules.length === 0) {
      list.innerHTML = '<div style="text-align:center;padding:20px 0;"><div style="font-size:12px;color:#9ca3af;margin-bottom:4px;">Aucune r\u00e8gle automatique</div><div style="font-size:10px;color:#d1d5db;">Cr\u00e9ez-en depuis les cartes d\u2019action (bouton \u26A1 Automatiser)</div></div>';
      return;
    }
    list.innerHTML = rules.map(function(r, ri) {
      var cat = r.signal_category || '';
      var catLabel = CAT_LABELS[cat] || cat;
      var catIcon = CAT_ICONS[cat] || '\u26A1';
      var catBg = CAT_BG[cat] || '#F3F4F6';
      var chLabel = CH_LABELS[r.channel] || r.channel || '';
      var recip = r.recipient || '';
      var isApproval = r.require_approval !== false;
