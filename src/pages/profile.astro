// Collapse a card and update its summary line from current form values
function collapseCard(idx, cardId, bodyId, data) {
  // Rebuild summary tags from saved data
  const tags = [];
  if (data.company_activity_type) tags.push(_ACTIVITY_LABELS[data.company_activity_type] || data.company_activity_type);
  const evtTypes = [data.event_type_1, data.event_type_2, data.event_type_3].filter(Boolean).map(v => _EVT_LABELS[v] || v);
  if (evtTypes.length) tags.push(evtTypes.join(', '));
  if (data.location_type) tags.push(_LOCATION_TYPE_LABELS[data.location_type] || data.location_type);
  if (data.weather_sensitivity) tags.push(_WEATHER_LABELS[data.weather_sensitivity] || '');
  const summaryText = tags.filter(Boolean).join(' · ');

  // Determine completeness
  const isComplete = !!(data.company_activity_type && data.location_type && data.event_type_1);

  const card = document.getElementById(cardId);
  if (!card) return;

  // Update name
  const nameEl = card.querySelector('.loc-name');
  if (nameEl && data.site_name) nameEl.textContent = data.site_name;

  // Update address
  const addrEl = card.querySelector('.loc-address');
  if (addrEl && data.company_address) addrEl.textContent = data.company_address;

  // Update summary or incomplete indicator
  const summaryEl = card.querySelector('.loc-summary');
  const statusEl = card.querySelector('.loc-status');
  if (statusEl) {
    statusEl.textContent = isComplete ? 'Profil complet · IA optimisée' : 'Profil incomplet · IA limitée';
    statusEl.className = `loc-status ${isComplete ? 'is-complete' : 'is-incomplete'}`;
    statusEl.style.marginLeft = 'auto';
  }
  if (summaryEl) {
    summaryEl.textContent = isComplete ? summaryText : '';
    summaryEl.style.display = isComplete ? '' : 'none';
  }

  // Collapse — close all, mark none expanded
  document.querySelectorAll('.loc-card').forEach(c => c.classList.remove('loc-expanded'));
  document.querySelectorAll('.loc-body').forEach(b => { b.style.display = 'none'; });
}

// ============================================================
// PILL MULTI-SELECT
// ============================================================
const PILL_MAX = {};
document.querySelectorAll('[data-pill-group]').forEach(pg => {
  const group = pg.dataset.pillGroup;
  const max = parseInt(pg.dataset.pillMax || '3', 10);
  PILL_MAX[group] = max;
});

document.addEventListener('click', function(e) {
  const pill = e.target.closest('.pill[data-group]');
  if (!pill) return;
  const group = pill.dataset.group;
  const val = pill.dataset.value;
  const max = PILL_MAX[group] || 3;
  const allPills = document.querySelectorAll(`.pill[data-group="${group}"]`);
  const activePills = document.querySelectorAll(`.pill[data-group="${group}"].pill-active`);

  if (pill.classList.contains('pill-active')) {
    pill.classList.remove('pill-active');
  } else {
    if (activePills.length >= max) return;
    pill.classList.add('pill-active');
  }

  // Sync hidden inputs based on group prefix
  const now = Array.from(document.querySelectorAll(`.pill[data-group="${group}"].pill-active`)).map(p => p.dataset.value);
  const nowCount = now.length;

  // Disable/enable remaining pills
  allPills.forEach(p => {
    if (!p.classList.contains('pill-active')) {
      p.classList.toggle('pill-disabled', nowCount >= max);
    } else {
      p.classList.remove('pill-disabled');
    }
  });

  // Determine idx and type from group name: "evt-0", "aud-1" etc
  const parts = group.split('-');
  const type = parts[0];
  const idx = parts[1];

  if (type === 'aud') {
    const h1 = document.getElementById(`aud-1-${idx}`);
    const h2 = document.getElementById(`aud-2-${idx}`);
    if (h1) h1.value = now[0] || '';
    if (h2) h2.value = now[1] || '';
  } else if (type === 'evt') {
    const h1 = document.getElementById(`et-1-${idx}`);
    const h2 = document.getElementById(`et-2-${idx}`);
    const h3 = document.getElementById(`et-3-${idx}`);
    if (h1) h1.value = now[0] || '';
    if (h2) h2.value = now[1] || '';
    if (h3) h3.value = now[2] || '';
  }
});

